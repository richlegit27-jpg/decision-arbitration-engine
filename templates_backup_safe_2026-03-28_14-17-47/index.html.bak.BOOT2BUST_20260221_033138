<script>
/* === NOVA_DEDUP_BTN_V1 ===
   Goal: Stop double-send by nuking all existing click handlers on #sendBtn.
   Method: clone+replace the button once, then attach a single handler that calls window.novaSend().
*/
(function(){
  const TAG = "[NOVA DEDUP BTN]";
  function getMsg(){
    try{
      const a = document.getElementById("text");
      if(a && typeof a.value==="string" && a.value.trim()) return a.value.trim();
    }catch(_){}
    try{
      const b = document.getElementById("novaIn");
      if(b && typeof b.value==="string" && b.value.trim()) return b.value.trim();
    }catch(_){}
    return "";
  }
  function clearMsg(){
    try{ const a=document.getElementById("text"); if(a && typeof a.value==="string") a.value=""; }catch(_){}
    try{ const b=document.getElementById("novaIn"); if(b && typeof b.value==="string") b.value=""; }catch(_){}
  }
  function arm(){
    try{
      const btn = document.getElementById("sendBtn");
      if(!btn) return false;

      // If we've already replaced it, don't do it again.
      if(btn.__novaDedupBtnArmed) return true;

      // Clone+replace nukes ALL prior listeners (including the app's)
      const clone = btn.cloneNode(true);
      clone.__novaDedupBtnArmed = true;
      btn.parentNode.replaceChild(clone, btn);

      clone.addEventListener("click", async (e) => {
        try{ e.preventDefault(); e.stopPropagation(); }catch(_){}
        try{
          const fn = (typeof window.novaSend === "function") ? window.novaSend :
                     (typeof window.__NOVA_SEND === "function") ? window.__NOVA_SEND : null;
          if(!fn){
            try{ console.warn(TAG, "no send fn"); }catch(_){}
            return;
          }

          const msg = getMsg();
          if(!msg){
            try{ console.warn(TAG, "no msg"); }catch(_){}
            return;
          }

          // extra guard (in case something still triggers twice)
          if(window.__NOVA_BTN_INFLIGHT__){
            try{ console.warn(TAG, "blocked: inflight"); }catch(_){}
            return;
          }
          window.__NOVA_BTN_INFLIGHT__ = true;

          const r = await fn(msg);
          try{ console.log(TAG, "sent", r); }catch(_){}
          clearMsg();
        }catch(err){
          try{ console.warn(TAG, "send err:", err); }catch(_){}
        }finally{
          setTimeout(()=>{ try{ window.__NOVA_BTN_INFLIGHT__ = false; }catch(_){} }, 80);
        }
      }, true);

      try{ console.log(TAG, "armed: replaced #sendBtn and bound single handler"); }catch(_){}
      return true;
    }catch(e){
      try{ console.warn(TAG, "arm failed:", e); }catch(_){}
      return false;
    }
  }
  arm();
  window.addEventListener("load", arm, { once:false });
})();
</script>
