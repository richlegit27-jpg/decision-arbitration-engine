<!doctype html>
<html lang="en" translate="no">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Nova</title>

  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
  <meta http-equiv="Pragma" content="no-cache" />
  <meta http-equiv="Expires" content="0" />

  <style>
    :root { color-scheme: dark; }
    html, body { height: 100%; margin: 0; background:#0b0f14; color:#e9eef7; font-family: ui-sans-serif, system-ui, Segoe UI, Roboto, Arial; }
    .wrap { height: 100%; display:flex; flex-direction:column; max-width: 1100px; margin: 0 auto; padding: 14px; box-sizing:border-box; }
    .top { display:flex; align-items:center; justify-content:space-between; gap:12px; padding: 10px 12px; border:1px solid #1c2633; border-radius:12px; background:#0e141c; }
    .brand { display:flex; align-items:center; gap:10px; }
    .dot { width:10px; height:10px; border-radius:50%; background:#666; }
    .title { font-weight:700; letter-spacing:.2px; }
    .sub { color:#98a6bb; font-size:12px; }
    .status { display:flex; align-items:center; gap:10px; font-size:12px; color:#9fb0c9; }
    .pill { padding:4px 10px; border:1px solid #223043; border-radius:999px; background:#0b1119; }
    .main { flex: 1; margin-top: 12px; border:1px solid #1c2633; border-radius:12px; background:#0e141c; overflow:hidden; display:flex; flex-direction:column; }
    .out { flex:1; overflow:auto; padding: 12px; }
    .composer { display:flex; gap:10px; padding: 12px; border-top:1px solid #1c2633; background:#0b1119; }
    textarea { flex:1; min-height: 46px; max-height: 240px; resize: vertical; padding: 10px 12px; border-radius:10px; border:1px solid #223043; outline:none; background:#0e141c; color:#e9eef7; }
    button { padding: 10px 14px; border-radius:10px; border:1px solid #223043; background:#122031; color:#e9eef7; cursor:pointer; }
    button:hover { filter: brightness(1.08); }
    .tiny { font-size:12px; color:#93a3bb; margin-top:6px; }
    .msg { padding:10px 12px; border:1px solid #1c2633; border-radius:12px; margin: 10px 0; background:#0b1119; }
    .msg .role { font-size:12px; color:#9fb0c9; margin-bottom:6px; }
    .msg .text { white-space: pre-wrap; line-height: 1.35; }
    .ok { background:#35d07f; }
    .bad { background:#ff5a6b; }
  </style>

  <script>
    // Make API base explicit + same-origin.
    window.NOVA_API_BASE = "/api";

    // Visible proof JS is running (top-right indicator)
    window.__NOVA_BOOTSTAMP = "APPHTML_V3_" + new Date().toISOString();

    // Provide lots of alias ids in case app.js expects specific ones.
    function _aliasId(fromId, toId){
      try{
        var a = document.getElementById(fromId);
        var b = document.getElementById(toId);
        if(a && !b){ a.id = toId; }
      }catch(e){}
    }
  </script>
</head>

<body>
  <div class="wrap">
    <div class="top">
      <div class="brand">
        <div class="dot" id="jsDot"></div>
        <div>
          <div class="title">Nova</div>
          <div class="sub" id="bootstamp">loading…</div>
        </div>
      </div>
      <div class="status">
        <div class="pill" id="modePill">mode: ask</div>
        <div class="pill" id="netPill">api: /api</div>
      </div>
    </div>

    <div class="main">
      <!-- OUTPUT AREA (many alias IDs) -->
      <div class="out" id="output"></div>

      <!-- COMPOSER -->
      <div class="composer">
        <textarea id="input" placeholder="Type here… (Enter = send, Shift+Enter = newline)"></textarea>
        <button id="send">Send</button>
      </div>
    </div>

    <div class="tiny">
      If this UI loads but nothing happens, it means <code>static/app.js</code> didn’t bind to the DOM (wrong IDs) or threw a console error.
    </div>
  </div>

  <script>
    // Fill bootstamp
    try{
      document.getElementById("bootstamp").textContent = window.__NOVA_BOOTSTAMP || "boot";
      document.getElementById("jsDot").classList.add("ok");
    }catch(e){}

    // Aliases: common IDs different builds use
    _aliasId("send","sendBtn");
    _aliasId("send","btnSend");
    _aliasId("input","prompt");
    _aliasId("input","composer");
    _aliasId("output","chat");
    _aliasId("output","messages");
    _aliasId("output","log");
  </script>

  <!-- Load your real client -->
  <script src="/static/app.js?v=APPJS_20260225"></script>

  <script>
    // If app.js runs, it can set this
    setTimeout(function(){
      try{
        // If app.js attached listeners, Enter should send.
        // We also do a fallback binding so you're never stuck.
        var ta = document.getElementById("input");
        var btn = document.getElementById("send");
        var out = document.getElementById("output");
        if(!ta || !btn || !out) return;

        function add(role, text){
          var m = document.createElement("div");
          m.className = "msg";
          m.innerHTML = '<div class="role"></div><div class="text"></div>';
          m.querySelector(".role").textContent = role;
          m.querySelector(".text").textContent = text;
          out.appendChild(m);
          out.scrollTop = out.scrollHeight;
        }

        async function fallbackSend(){
          var text = (ta.value || "").trim();
          if(!text) return;
          ta.value = "";
          add("you", text);
          try{
            var r = await fetch("/api/chat", {
              method:"POST",
              headers:{ "Content-Type":"application/json" },
              body: JSON.stringify({ text, timeout_ms: 8000 })
            });
            var j = await r.json();
            add("nova", (j && j.reply) ? j.reply : JSON.stringify(j));
          }catch(e){
            add("error", String(e));
          }
        }

        // If app.js already bound, this won't hurt — but guarantees it's usable.
        btn.addEventListener("click", fallbackSend);
        ta.addEventListener("keydown", function(ev){
          if(ev.key === "Enter" && !ev.shiftKey){
            ev.preventDefault();
            fallbackSend();
          }
        });
      }catch(e){}
    }, 50);
  </script>
</body>
</html>
