<script>
/* === NOVA_AUTH_HOOK_V1 ===
   Force x-api-key onto fetch + XHR for /api/* calls.
   Source of truth: localStorage.NOVA_API_KEY (already used by NOVA_KEY_BOOT).
*/
(function(){
  function getKey(){
    try { return (localStorage.getItem("NOVA_API_KEY") || "").trim(); } catch(_){ return ""; }
  }
  function shouldAttach(url){
    try{
      if(!url) return false;
      // Normalize to a string URL
      const u = String(url);
      // Same-origin proxy path
      if(u.startsWith("/api/")) return true;

      // Also cover absolute calls to the backend base, if any code uses it directly
      const base = (window.NOVA_API_BASE || "").replace(/\/+$/,"");
      if(base && u.startsWith(base + "/api/")) return true;

      return false;
    }catch(_){ return false; }
  }

  // fetch hook
  try{
    const _fetch = window.fetch;
    if(typeof _fetch === "function"){
      window.fetch = function(input, init){
        try{
          const url = (typeof input === "string") ? input : (input && input.url) || "";
          if(shouldAttach(url)){
            init = init || {};
            init.headers = init.headers || {};
            // If headers is a Headers object, convert to plain
            if(init.headers instanceof Headers){
              const h = {};
              init.headers.forEach((v,k)=>h[k]=v);
              init.headers = h;
            }
            const k = getKey();
            if(k && !init.headers["x-api-key"] && !init.headers["X-API-KEY"]){
              init.headers["x-api-key"] = k;
            }
          }
        }catch(_){}
        return _fetch.call(this, input, init);
      };
    }
  }catch(_){}

  // XHR hook
  try{
    const _open = XMLHttpRequest.prototype.open;
    const _send = XMLHttpRequest.prototype.send;
    XMLHttpRequest.prototype.open = function(method, url){
      this.__nova_url__ = url;
      return _open.apply(this, arguments);
    };
    XMLHttpRequest.prototype.send = function(body){
      try{
        if(shouldAttach(this.__nova_url__)){
          const k = getKey();
          if(k){
            // only set if not already set by caller
            try{ this.setRequestHeader("x-api-key", k); }catch(_){}
          }
        }
      }catch(_){}
      return _send.apply(this, arguments);
    };
  }catch(_){}
})();
 /* === /NOVA_AUTH_HOOK_V1 === */
</script>
