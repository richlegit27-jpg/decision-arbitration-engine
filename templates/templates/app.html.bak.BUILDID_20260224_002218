<script>
(() => {
  // Create a simple output area if the template doesn't already have one
  let out = document.getElementById("out");
  if (!out) {
    out = document.createElement("pre");
    out.id = "out";
    out.style.whiteSpace = "pre-wrap";
    out.style.padding = "12px";
    out.style.borderTop = "1px solid #ddd";
    out.style.marginTop = "12px";
    document.body.appendChild(out);
  }

  // Try to find an existing input/textarea and button; otherwise create them.
  let input = document.querySelector("textarea,input[type='text'],input:not([type])");
  if (!input) {
    input = document.createElement("textarea");
    input.rows = 3;
    input.style.width = "100%";
    input.placeholder = "Type a messageÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¦";
    document.body.insertBefore(input, out);
  }

  let btn = document.querySelector("button");
  if (!btn) {
    btn = document.createElement("button");
    btn.textContent = "Send";
    btn.style.marginTop = "8px";
    document.body.insertBefore(btn, out);
  }

  async function send(text) {
    out.textContent += `\n> ${text}\n`;
    const res = await fetch("/api/chat", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ text, timeout_ms: 60000 })
    });
    const reply = await res.text();
    out.textContent += reply + "\n";
  }

  btn.addEventListener("click", async () => {
    const t = (input.value || "").trim();
    if (!t) return;
    input.value = "";
    await send(t);
  });

  input.addEventListener("keydown", async (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      btn.click();
    }
  });
})();
</script>

