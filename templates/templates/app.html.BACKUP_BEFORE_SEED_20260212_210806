<script>
(function(){
  try{
    const KEY_STORAGE = "NOVA_API_KEY";
    let k = localStorage.getItem(KEY_STORAGE);
    if(!k){
      k = prompt("Enter NOVA_API_KEY for this browser (stored locally):");
      if(k){ localStorage.setItem(KEY_STORAGE, k); }
    }

    const applyAuth = (init) => {
      init = init || {};
      init.headers = init.headers || {};
      const kk = localStorage.getItem(KEY_STORAGE);
      if(kk){
        if(init.headers instanceof Headers){
          init.headers.set("Authorization","Bearer " + kk);
          init.headers.set("X-API-Key", kk);
        } else {
          init.headers["Authorization"] = "Bearer " + kk;
          init.headers["X-API-Key"] = kk;
        }
      }
      return init;
    };

    const origFetch = window.fetch;
    window.fetch = function(input, init){
      try{
        const url = (typeof input === "string") ? input : (input && input.url) || "";
        if(String(url).includes("/api/")){
          init = applyAuth(init);
        }
      }catch(e){}
      return origFetch(input, init);
    };

    const OrigXHR = window.XMLHttpRequest;
    function PatchedXHR(){
      const xhr = new OrigXHR();
      const origOpen = xhr.open;
      xhr.open = function(method, url){
        this._nova_url = url;
        return origOpen.apply(this, arguments);
      };
      const origSend = xhr.send;
      xhr.send = function(){
        try{
          const url = this._nova_url || "";
          if(String(url).includes("/api/")){
            const kk = localStorage.getItem(KEY_STORAGE);
            if(kk){
              try{ xhr.setRequestHeader("Authorization","Bearer " + kk); }catch(e){}
              try{ xhr.setRequestHeader("X-API-Key", kk); }catch(e){}
            }
          }
        }catch(e){}
        return origSend.apply(this, arguments);
      };
      return xhr;
    }
    window.XMLHttpRequest = PatchedXHR;

  }catch(e){}
})();
</script>
<!-- NOVA_UI_AUTH_BOOTSTRAP_V2 -->
<script>
(function(){
  try{
    const KEY_STORAGE = "NOVA_API_KEY";

    function getKey(){
      let k = localStorage.getItem(KEY_STORAGE);
      if(!k){
        k = prompt("Enter NOVA_API_KEY for this browser (stored locally):");
        if(k){ localStorage.setItem(KEY_STORAGE, k); }
      }
      return (k || "").trim();
    }

    function applyHeaders(h){
      const k = getKey();
      if(!k) return h;

      // Always set both.
      try{
        if(h instanceof Headers){
          h.set("X-API-Key", k);
          h.set("Authorization", "Bearer " + k);
          return h;
        }
      }catch(e){}

      // array-of-tuples form
      if(Array.isArray(h)){
        h = h.filter(x => !(x && x[0] && String(x[0]).toLowerCase() === "x-api-key"));
        h = h.filter(x => !(x && x[0] && String(x[0]).toLowerCase() === "authorization"));
        h.push(["X-API-Key", k]);
        h.push(["Authorization", "Bearer " + k]);
        return h;
      }

      // plain object
      h = h || {};
      try{
        h["X-API-Key"] = k;
        h["Authorization"] = "Bearer " + k;
      }catch(e){}
      return h;
    }

    // Also drop a cookie (only helps if server reads cookies)
    try{
      const k = getKey();
      if(k){
        document.cookie = "NOVA_API_KEY=" + encodeURIComponent(k) + "; path=/; SameSite=Lax";
      }
    }catch(e){}

    // Patch fetch robustly (handles Request objects)
    const origFetch = window.fetch;
    window.fetch = function(input, init){
      try{
        const url = (typeof input === "string") ? input : (input && input.url) || "";
        if(String(url).includes("/api/")){
          // If input is a Request, clone it with merged headers
          if(input instanceof Request){
            const h = new Headers(input.headers);
            applyHeaders(h);
            input = new Request(input, { headers: h });
            init = init || {};
            // keep any init.headers too (if present)
            if(init.headers){
              const hh = new Headers(h);
              const add = new Headers(init.headers);
              add.forEach((v,k)=>hh.set(k,v));
              applyHeaders(hh);
              input = new Request(input, { headers: hh });
              delete init.headers;
            }
          } else {
            init = init || {};
            init.headers = applyHeaders(init.headers);
          }
        }
      }catch(e){}
      return origFetch(input, init);
    };

    // Patch XHR
    const OrigXHR = window.XMLHttpRequest;
    function PatchedXHR(){
      const xhr = new OrigXHR();
      const origOpen = xhr.open;
      xhr.open = function(method, url){
        this._nova_url = url;
        return origOpen.apply(this, arguments);
      };
      const origSend = xhr.send;
      xhr.send = function(){
        try{
          const url = this._nova_url || "";
          if(String(url).includes("/api/")){
            const k = getKey();
            if(k){
              try{ xhr.setRequestHeader("X-API-Key", k); }catch(e){}
              try{ xhr.setRequestHeader("Authorization", "Bearer " + k); }catch(e){}
            }
          }
        }catch(e){}
        return origSend.apply(this, arguments);
      };
      return xhr;
    }
    window.XMLHttpRequest = PatchedXHR;

    // Patch EventSource (NOTE: headers not possible; this only works if server accepts ?api_key=)
    const OrigES = window.EventSource;
    window.EventSource = function(url, cfg){
      try{
        if(String(url).includes("/api/")){
          const k = getKey();
          if(k){
            const u = new URL(url, window.location.origin);
            if(!u.searchParams.get("api_key")){
              u.searchParams.set("api_key", k);
            }
            url = u.toString();
          }
        }
      }catch(e){}
      return new OrigES(url, cfg);
    };

  }catch(e){}
})();
</script>
