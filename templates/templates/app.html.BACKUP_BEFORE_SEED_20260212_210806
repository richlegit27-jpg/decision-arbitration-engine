<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Nova</title>
  <style>
    :root{
      --bg:#0b0f14;
      --panel:#0f1722;
      --panel2:#0c131d;
      --border:#223247;
      --border2:#1b2634;
      --text:#e8eef6;
      --muted:rgba(232,238,246,.72);
      --muted2:rgba(232,238,246,.55);
      --accent:#6ea8ff;
      --accent2:#365bff;
      --ok:#2ecc71;
      --warn:#f1c40f;
      --bad:#ff4d6d;
      --shadow:0 14px 40px rgba(0,0,0,.35);
      --r12:12px;
      --r16:16px;
      --r20:20px;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
    }
    * { box-sizing:border-box; }
    body { margin:0; height:100vh; display:flex; background:var(--bg); color:var(--text); }

    /* Layout */
    .sidebar {
      width:380px; min-width:320px; max-width:420px;
      border-right:1px solid var(--border2);
      display:flex; flex-direction:column;
      background:linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,0));
    }
    .main { flex:1; display:flex; flex-direction:column; min-width:0; }

    /* Topbars */
    .topbar {
      padding:12px 12px;
      border-bottom:1px solid var(--border2);
      display:flex; gap:10px; align-items:center;
      background:rgba(15,23,34,.72);
      backdrop-filter: blur(10px);
    }
    .brand { font-weight:800; letter-spacing:.25px; }
    .pill {
      font-size:12px; padding:3px 10px;
      border:1px solid var(--border);
      border-radius:999px;
      color:var(--muted);
      background:rgba(255,255,255,.02);
      display:inline-flex; align-items:center; gap:6px;
    }
    .pillDot { width:8px; height:8px; border-radius:50%; background:var(--muted2); }
    .pillDot.ok { background:var(--ok); }
    .pillDot.bad { background:var(--bad); }
    .pillDot.warn { background:var(--warn); }

    /* Inputs / buttons */
    input, textarea, select {
      background:var(--panel);
      color:var(--text);
      border:1px solid var(--border);
      border-radius:12px;
      padding:10px 12px;
      outline:none;
    }
    input:focus, textarea:focus, select:focus { border-color:rgba(110,168,255,.65); box-shadow:0 0 0 3px rgba(110,168,255,.15); }
    textarea { resize:vertical; min-height:68px; max-height:220px; width:100%; line-height:1.35; }

    .btn {
      cursor:pointer;
      border:1px solid var(--border);
      background:var(--panel);
      color:var(--text);
      padding:9px 12px;
      border-radius:12px;
      transition: transform .04s ease, background .12s ease, border-color .12s ease;
      user-select:none;
    }
    .btn:hover { background:#122033; border-color:#2a3f58; }
    .btn:active { transform: translateY(1px); }
    .btn.small { padding:7px 10px; font-size:12px; border-radius:11px; }
    .btn.green { border-color:rgba(46,204,113,.35); background:rgba(46,204,113,.08); }
    .btn.green:hover { background:rgba(46,204,113,.12); border-color:rgba(46,204,113,.55); }
    .btn.red { border-color:rgba(255,77,109,.35); background:rgba(255,77,109,.08); }
    .btn.red:hover { background:rgba(255,77,109,.12); border-color:rgba(255,77,109,.55); }

    .row { display:flex; gap:8px; align-items:center; }
    .muted { opacity:.78; font-size:12px; color:var(--muted); }
    .muted2 { opacity:.62; font-size:12px; color:var(--muted2); }
    .kbd { font-size:12px; opacity:.75; border:1px solid var(--border); padding:2px 7px; border-radius:10px; }

    /* Sidebar blocks */
    .searchWrap {
      padding:12px;
      border-bottom:1px solid var(--border2);
      display:flex; flex-direction:column; gap:10px;
    }
    .list { overflow:auto; padding:12px; display:flex; flex-direction:column; gap:10px; }

    .sess {
      border:1px solid var(--border);
      border-radius:16px;
      padding:10px 10px;
      display:flex; flex-direction:column; gap:7px;
      background:rgba(15,23,34,.84);
      box-shadow: 0 0 0 rgba(0,0,0,0);
      transition: border-color .12s ease, transform .06s ease, background .12s ease;
      cursor:pointer;
    }
    .sess:hover { background:rgba(18,32,51,.9); border-color:#2a3f58; }
    .sess:active { transform: translateY(1px); }
    .sess.active { outline:2px solid rgba(54,91,255,.25); border-color:rgba(54,91,255,.45); }

    .name { font-weight:700; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:260px; }

    /* Search results */
    .results { border:1px solid var(--border); border-radius:16px; overflow:hidden; }
    .resItem { padding:10px; border-bottom:1px solid var(--border2); cursor:pointer; background:rgba(15,23,34,.82); }
    .resItem:hover { background:rgba(18,32,51,.9); }
    .resItem:last-child { border-bottom:none; }
    .resSnip { font-size:12px; opacity:.95; line-height:1.35; }
    .resSnip .hit { background:rgba(54,91,255,.25); padding:0 3px; border-radius:6px; }

    /* Chat */
    .chat {
      flex:1;
      overflow:auto;
      padding:16px 18px 22px;
      display:flex;
      flex-direction:column;
      gap:12px;
      min-width:0;
      position:relative;
    }

    .msg {
      max-width:980px;
      padding:12px 14px;
      border:1px solid var(--border);
      border-radius:18px;
      background:rgba(15,23,34,.84);
      box-shadow: 0 6px 18px rgba(0,0,0,.18);
      position:relative;
    }
    .msg.user { align-self:flex-end; border-color:rgba(54,91,255,.45); }
    .msg.assistant { align-self:flex-start; }
    .msg.hl { animation: flash 1.2s ease-in-out 0s 2; outline:2px solid rgba(54,91,255,.6); }
    @keyframes flash {
      0%{box-shadow:0 0 0 rgba(54,91,255,0)}
      50%{box-shadow:0 0 20px rgba(54,91,255,.35)}
      100%{box-shadow:0 0 0 rgba(54,91,255,0)}
    }

    .msgHdr { display:flex; justify-content:space-between; gap:12px; align-items:center; margin-bottom:6px; }
    .role { font-size:12px; color:var(--muted); display:flex; gap:8px; align-items:center; }
    .actions { display:flex; gap:10px; align-items:center; }
    .action {
      font-size:12px; color:var(--muted); cursor:pointer;
      padding:3px 8px; border:1px solid transparent; border-radius:999px;
    }
    .action:hover { color:var(--text); border-color:var(--border); background:rgba(255,255,255,.02); }
    .msgBody { white-space:pre-wrap; line-height:1.38; }

    img.inline, video.inline {
      max-width:100%;
      border-radius:14px;
      border:1px solid var(--border);
      margin-top:10px;
      background:#000;
    }
    audio.inline { margin-top:10px; width:100%; }

    /* Composer */
    .composer {
      border-top:1px solid var(--border2);
      padding:12px;
      display:flex; flex-direction:column; gap:10px;
      background:rgba(15,23,34,.72);
      backdrop-filter: blur(10px);
    }
    .composerRow { display:flex; gap:10px; align-items:center; justify-content:space-between; }
    .chips { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
    .fileChip {
      font-size:12px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.02);
      border-radius:999px;
      padding:5px 9px;
      display:inline-flex; gap:8px; align-items:center;
    }
    .fileChip button {
      border:none; background:transparent; color:var(--text);
      cursor:pointer; opacity:.75; padding:0; font-size:14px;
    }
    .fileChip button:hover { opacity:1; }

    .progress {
      width:100%; height:10px; border-radius:999px;
      background:rgba(255,255,255,.06);
      border:1px solid var(--border);
      overflow:hidden;
    }
    .progress > div { height:100%; width:0%; background:rgba(110,168,255,.75); transition: width .12s ease; }

    /* Drop overlay */
    .dropOverlay {
      position:fixed; inset:0;
      background:rgba(54,91,255,.12);
      border:2px dashed rgba(110,168,255,.55);
      display:none;
      place-items:center;
      z-index:999;
    }
    .dropOverlay .box{
      background:rgba(15,23,34,.9);
      border:1px solid var(--border);
      padding:18px 20px;
      border-radius:18px;
      box-shadow:var(--shadow);
      text-align:center;
    }

    /* Toast */
    .toasts { position:fixed; right:14px; bottom:14px; display:flex; flex-direction:column; gap:10px; z-index:1000; }
    .toast {
      min-width:260px; max-width:380px;
      padding:10px 12px;
      border-radius:14px;
      border:1px solid var(--border);
      background:rgba(15,23,34,.92);
      box-shadow:var(--shadow);
      display:flex; gap:10px; align-items:flex-start;
    }
    .toast .dot{ width:10px; height:10px; border-radius:50%; margin-top:4px; background:var(--muted2); }
    .toast.ok .dot{ background:var(--ok); }
    .toast.bad .dot{ background:var(--bad); }
    .toast.warn .dot{ background:var(--warn); }
    .toast .t{ flex:1; }
    .toast .t .h{ font-weight:700; font-size:13px; }
    .toast .t .b{ font-size:12px; color:var(--muted); margin-top:2px; line-height:1.35; }
    .toast .x{ cursor:pointer; opacity:.75; }
    .toast .x:hover{ opacity:1; }

    /* Modal */
    .modalWrap {
      position:fixed; inset:0; display:none;
      background:rgba(0,0,0,.55);
      z-index:1200;
      place-items:center;
    }
    .modal {
      width:min(520px, 92vw);
      background:rgba(15,23,34,.95);
      border:1px solid var(--border);
      border-radius:18px;
      box-shadow:var(--shadow);
      padding:14px;
    }
    .modalTop{ display:flex; justify-content:space-between; align-items:center; gap:10px; margin-bottom:10px; }
    .modalTitle{ font-weight:800; }
    .modalClose{ cursor:pointer; opacity:.75; padding:4px 8px; border-radius:10px; }
    .modalClose:hover{ opacity:1; background:rgba(255,255,255,.04); }
    .modalBody{ display:flex; flex-direction:column; gap:10px; }
    .modalActions{ display:flex; justify-content:flex-end; gap:10px; margin-top:6px; }

    /* Drawer (gallery) */
    .drawerWrap {
      position:fixed; inset:0; display:none;
      background:rgba(0,0,0,.55);
      z-index:1100;
    }
    .drawer {
      position:absolute; right:0; top:0; height:100%;
      width:min(520px, 92vw);
      background:rgba(15,23,34,.95);
      border-left:1px solid var(--border);
      box-shadow:var(--shadow);
      display:flex; flex-direction:column;
    }
    .drawerHead{ padding:12px; border-bottom:1px solid var(--border2); display:flex; align-items:center; justify-content:space-between; gap:10px; }
    .drawerBody{ padding:12px; overflow:auto; display:flex; flex-direction:column; gap:10px; }
    .card {
      border:1px solid var(--border);
      background:rgba(255,255,255,.02);
      border-radius:16px;
      padding:10px;
      display:flex; flex-direction:column; gap:8px;
    }
    .cardTop{ display:flex; justify-content:space-between; gap:10px; align-items:center; }
    .tag { font-size:12px; padding:2px 8px; border-radius:999px; border:1px solid var(--border); color:var(--muted); }
    .aLink { color: #9db0ff; text-decoration:none; }
    .aLink:hover { text-decoration:underline; }

    @media (max-width: 920px){
      .sidebar { display:none; }
    }
  </style>
