  // ---------- Upload with progress ----------
  function showUploadProgress(on, label="Uploading…", pct=0){
    $("uploadBox").style.display = on ? "block" : "none";
    $("uploadLabel").textContent = label;
    $("uploadBar").style.width = Math.max(0, Math.min(100, pct)) + "%";
