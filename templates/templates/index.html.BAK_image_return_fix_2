<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Nova</title>

  <link rel="stylesheet" href="{{ url_for('static', path='css/base.css') }}">
  <link rel="stylesheet" href="{{ url_for('static', path='css/layout.css') }}">
</head>

<body class="sidebar-open">
  <!-- Landing/Chat content -->
  <div id="appShell" class="app-shell">
    <!-- Sidebar -->
    <aside id="sidebar" class="sidebar" aria-label="Chat sidebar">
      <div class="sidebar-header">
        <div class="sidebar-title">Nova</div>
        <button id="btnCloseSidebar" class="sidebar-close">✕</button>
      </div>
      <div class="sidebar-actions">
        <button id="btnNewChat">+ New chat</button>
        <button id="btnOpenMemory">Memory</button>
      </div>
      <div id="chatList" class="chat-list">No chats yet</div>
    </aside>

    <!-- Main -->
    <main class="main">
      <header class="topbar">
        <button id="btnSidebarToggle">☰</button>
        <div class="topbar-center">
          <div class="topbar-eyebrow">Nova Workspace</div>
          <div id="topbarTitle">New chat</div>
        </div>
        <div class="topbar-actions">
          <button id="btnTopbarMemory">Memory</button>
          <button id="btnWorkspaceFiles">Files</button>
        </div>
      </header>

      <section class="chat-stage">
        <div id="messagesScroll" class="messages-scroll">
          <div id="emptyState" class="empty-state">
            <div class="empty-state-badge">Built for focus</div>
            <h1 class="empty-state-title">What are we building today?</h1>
            <p class="empty-state-subtitle">Code, debug, organize files, and keep momentum without breaking flow.</p>
          </div>
          <div id="messages" class="messages"></div>
        </div>

        <div class="composer-wrap">
          <div id="composer" class="composer">
            <button id="attachBtn">+</button>
            <textarea id="input" placeholder="Message Nova..."></textarea>
            <button id="stopBtn" hidden>■</button>
            <button id="sendBtn">↑</button>
          </div>
        </div>
      </section>
    </main>
  </div>
</body>
</html>