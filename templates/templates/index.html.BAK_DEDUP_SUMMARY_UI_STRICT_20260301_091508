<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova Chat</title>

    <style>
        /* Global Styles */
        :root {
            --bg: #f0f0f0;
            --panel: rgba(0,0,0,.05);
            --panel2: rgba(0,0,0,.07);
            --text: rgba(0,0,0,.88);
            --muted: rgba(0,0,0,.62);
            --shadow: 0 10px 20px rgba(0,0,0,.1);
            --brand: #4e73df;
            --danger: #ff4d4f;
            --ok: #22c55e;
            --radius: 8px;
            --font-family: 'Arial', sans-serif;
        }

        body {
            margin: 0;
            font-family: var(--font-family);
            background-color: var(--bg);
            color: var(--text);
        }

        /* Layout */
        .app-container {
            display: flex;
            min-height: 100vh;
            flex-direction: column;
        }

        .chat-container {
            flex-grow: 1;
            background: white;
            padding: 20px;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow);
            border-radius: var(--radius);
            margin: 20px;
        }

        .chat-area {
            flex-grow: 1;
            overflow-y: auto;
            padding: 10px;
            border-bottom: 1px solid #ccc;
        }

        /* Chat Bubble */
        .chat-bubble {
            padding: 12px;
            border-radius: 10px;
            max-width: 75%;
            margin: 5px 0;
            font-size: 14px;
            background-color: #e1e1e1;
        }

        .user-message {
            background-color: #007bff;
            color: white;
            align-self: flex-end;
        }

        .bot-message {
            background-color: #f1f1f1;
            color: black;
            align-self: flex-start;
        }

        /* Textarea & Send Button */
        textarea {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
            border-radius: var(--radius);
            border: 1px solid #ccc;
            font-size: 16px;
            color: var(--text);
            background: #f9f9f9;
            resize: none;
        }

        .send-btn {
            padding: 12px;
            margin-top: 10px;
            background-color: var(--brand);
            color: white;
            border: none;
            font-size: 16px;
            cursor: pointer;
            border-radius: var(--radius);
        }

        .send-btn:hover {
            background-color: #3e6bb5;
        }

        /* Responsive Adjustments */
        @media (max-width: 768px) {
            .app-container {
                padding: 10px;
            }

            .chat-container {
                margin: 10px 0;
            }
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Chat Area -->
        <main class="chat-container">
            <div class="chat-area" id="chat-area"></div>
            <textarea id="input-area" placeholder="Type your message..." rows="3"></textarea>
            <button id="send-btn" class="send-btn">Send</button>
        </main>
    </div>

    <script>
        // Auto-resize input area
        document.getElementById('input-area').addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        });

        // Send message on button click
        document.getElementById('send-btn').addEventListener('click', async function() {
            const inputArea = document.getElementById('input-area');
            const message = inputArea.value.trim();

            if (message) {
                const chatArea = document.getElementById('chat-area');

                // User message
                const userMessage = document.createElement('div');
                userMessage.classList.add('chat-bubble', 'user-message');
                userMessage.textContent = message;
                chatArea.appendChild(userMessage);

                // Typing indicator for bot
                const typingIndicator = document.createElement('div');
                typingIndicator.classList.add('chat-bubble', 'bot-message');
                typingIndicator.textContent = "Bot is typing...";
                chatArea.appendChild(typingIndicator);

                // Auto scroll to the latest message
                chatArea.scrollTop = chatArea.scrollHeight;

                // Clear input
                inputArea.value = '';

                // Send the message to the backend
                const response = await fetch('http://127.0.0.1:8000/chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ message: message })
                });

                const data = await response.json();

                // Remove typing indicator
                chatArea.removeChild(typingIndicator);

                // Bot response
                const botMessage = document.createElement('div');
                botMessage.classList.add('chat-bubble', 'bot-message');
                botMessage.textContent = data.response;
                chatArea.appendChild(botMessage);

                // Auto scroll to the latest message
                chatArea.scrollTop = chatArea.scrollHeight;
            }
        });

        // Handle sending messages with Enter key
        document.getElementById('input-area').addEventListener('keydown', function(event) {
            if (event.key === 'Enter' && !event.shiftKey) {
                document.getElementById('send-btn').click();
                event.preventDefault(); // Prevent default newline behavior
            }
        });
    </script>

    <!-- Link to the JavaScript file -->
    <script src="/static/js/chat.js"></script>
<!-- NOVA_SESSION_SUMMARY_PANEL_V1 -->
<style>
  .nova-sum-card{
    margin: 12px 0;
    padding: 12px;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 12px;
    background: rgba(255,255,255,.6);
  }
  .nova-sum-row{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
  .nova-sum-row label{ font-size:12px; opacity:.75; display:block; margin-bottom:4px; }
  .nova-sum-row input{
    padding: 8px 10px;
    border: 1px solid rgba(0,0,0,.18);
    border-radius: 10px;
    min-width: 280px;
  }
  .nova-sum-btn{
    padding: 9px 12px;
    border-radius: 10px;
    border: 1px solid rgba(0,0,0,.18);
    cursor: pointer;
    background: rgba(0,0,0,.06);
  }
  .nova-sum-btn:active{ transform: translateY(1px); }
  .nova-sum-out{
    margin-top: 10px;
    white-space: pre-wrap;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 12px;
    line-height: 1.35;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 12px;
    padding: 10px;
    max-height: 260px;
    overflow: auto;
    background: rgba(0,0,0,.03);
  }
  .nova-sum-hint{ font-size: 12px; opacity:.75; margin-top:6px; }
</style>

<div class="nova-sum-card" id="novaSummaryCard">
  <div style="font-weight:600; margin-bottom:8px;">Session Summary</div>

  <div class="nova-sum-row">
    <div>
      <label for="novaSessionId">Session ID</label>
      <input id="novaSessionId" type="text" spellcheck="false" />
    </div>

    <div>
      <label for="novaApiKey">x-api-key (optional)</label>
      <input id="novaApiKey" type="password" spellcheck="false" placeholder="stored locally in this browser" />
    </div>

    <div style="margin-top:18px;">
      <button class="nova-sum-btn" id="novaFetchSummaryBtn" type="button">Fetch Summary</button>
    </div>
  </div>

  <div class="nova-sum-hint">
    Tip: if your server requires x-api-key, paste it once here — it will be saved in LocalStorage as <code>nova_api_key</code>.
  </div>

  <div class="nova-sum-out" id="novaSummaryOut">Ready.</div>
</div>

<script>
(function(){
  function $(id){ return document.getElementById(id); }

  function getOrCreateSessionId(){
    try{
      var u = new URL(window.location.href);
      var q = (u.searchParams.get("session_id") || "").trim();
      if(q){ return q; }
    }catch(e){}

    try{
      var s = (localStorage.getItem("nova_session_id") || "").trim();
      if(s){ return s; }
    }catch(e){}

    var sid = "";
    try{
      sid = (crypto && crypto.randomUUID) ? crypto.randomUUID().replace(/-/g,"") : "";
    }catch(e){}
    if(!sid){
      sid = (Date.now().toString(16) + Math.random().toString(16).slice(2)).replace(/\./g,"");
    }
    try{ localStorage.setItem("nova_session_id", sid); }catch(e){}
    return sid;
  }

  function loadApiKey(){
    try{ return (localStorage.getItem("nova_api_key") || "").trim(); }catch(e){ return ""; }
  }
  function saveApiKey(v){
    try{
      if(v && v.trim()) localStorage.setItem("nova_api_key", v.trim());
      else localStorage.removeItem("nova_api_key");
    }catch(e){}
  }

  async function fetchSummary(){
    var out = $("novaSummaryOut");
    var sidEl = $("novaSessionId");
    var keyEl = $("novaApiKey");

    var sid = (sidEl.value || "").trim();
    if(!sid){
      sid = getOrCreateSessionId();
      sidEl.value = sid;
    }

    var key = (keyEl.value || "").trim();
    if(key){ saveApiKey(key); }

    out.textContent = "Fetching summary for session_id=" + sid + " ...";

    var headers = { "Content-Type": "application/json" };
    if(key){ headers["x-api-key"] = key; }
    else{
      var stored = loadApiKey();
      if(stored){
        headers["x-api-key"] = stored;
        keyEl.value = stored;
      }
    }

    try{
      var r = await fetch("/api/session/summary", {
        method: "POST",
        headers: headers,
        body: JSON.stringify({ session_id: sid })
      });

      var text = await r.text();
      var data = null;
      try{ data = JSON.parse(text); }catch(e){}

      if(!r.ok){
        var msg = (data && (data.error || data.detail)) ? (data.error || data.detail) : text;
        out.textContent = "ERROR " + r.status + ": " + msg;
        return;
      }

      var summary = (data && data.summary) ? data.summary : text;
      out.textContent = summary || "(empty summary)";
    }catch(err){
      out.textContent = "ERROR: " + (err && err.message ? err.message : String(err));
    }
  }

  function init(){
    try{
      $("novaSessionId").value = getOrCreateSessionId();
      var k = loadApiKey();
      if(k) $("novaApiKey").value = k;
      $("novaFetchSummaryBtn").addEventListener("click", fetchSummary);
    }catch(e){}
  }

  if(document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
  else init();
})();
</script>
<!-- /NOVA_SESSION_SUMMARY_PANEL_V1 -->
</body>
</html>



