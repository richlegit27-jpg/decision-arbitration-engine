<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Nova</title>

<meta name="theme-color" content="#0b1020">
<meta name="color-scheme" content="dark">

<link rel="stylesheet" href="{{ url_for('static', filename='css/base.css') }}">
<link rel="stylesheet" href="{{ url_for('static', filename='css/layout.css') }}">
</head>
<body>
<div class="app-shell">
  <aside class="sidebar" id="sidebar" aria-label="Sidebar">
    <div class="sidebar-top">
      <div class="sidebar-brand">
        <div class="sidebar-brand-mark" aria-hidden="true">N</div>

        <div class="sidebar-brand-copy">
          <div class="sidebar-logo">Nova</div>
          <div class="sidebar-subtitle">Private local chat</div>
        </div>
      </div>

      <button
        type="button"
        class="sidebar-toggle"
        id="btnSidebarClose"
        aria-label="Close sidebar"
        title="Close sidebar"
      >
        ✕
      </button>
    </div>

    <div class="sidebar-actions">
      <button
        type="button"
        class="new-chat-btn"
        id="btnNewChat"
      >
        + New chat
      </button>
    </div>

    <div class="chat-list-wrap">
      <div class="chat-list-header">
        <div class="chat-list-heading">Chats</div>
        <div class="chat-list-count" id="chatListCount">0</div>
      </div>

      <div class="chat-list" id="chatList" aria-live="polite"></div>
    </div>
  </aside>

  <div class="mobile-overlay" id="mobileOverlay"></div>

  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <button
          type="button"
          class="mobile-sidebar-btn"
          id="btnSidebarToggle"
          aria-label="Open sidebar"
          title="Open sidebar"
        >
          ☰
        </button>

        <div class="topbar-title-wrap">
          <div class="topbar-title" id="topbarTitle">Nova</div>
          <div class="topbar-subtitle" id="topbarSubtitle">Ready</div>
        </div>
      </div>

      <div class="topbar-right">
        <div class="topbar-actions">
          <button
            type="button"
            class="topbar-action"
            id="btnRenameChat"
            title="Rename chat"
          >
            Rename
          </button>

          <button
            type="button"
            class="topbar-action"
            id="btnDeleteChat"
            title="Delete chat"
          >
            Delete
          </button>
        </div>
      </div>
    </header>

    <section class="chat-stage">
      <div class="messages-panel">
        <div class="messages-scroll" id="messagesScroll">
          <div class="empty-state-shell">
            <div class="empty-state" id="emptyState">
              <div class="empty-state-card">
                <div class="empty-badge">Nova</div>
                <div class="empty-title">Start a clean conversation</div>
                <div class="empty-text">
                  Ask Nova anything, attach files, and keep your chats organized in one place.
                </div>
              </div>
            </div>
          </div>

          <div class="messages-empty" id="messagesEmpty" hidden>
            <div class="empty-state-card">
              <div class="messages-empty-title">No messages yet</div>
              <div class="messages-empty-text">
                Send the first message to get this chat moving.
              </div>
            </div>
          </div>

          <div class="messages" id="messages" aria-live="polite" aria-atomic="false"></div>
        </div>
      </div>
    </section>

    <div class="composer-shell">
      <div class="composer-wrap">
        <form class="composer-form" id="composerForm" autocomplete="off">
          <div class="pending-attachments" id="pendingAttachments" hidden>
            <div class="pending-attachments-list" id="pendingAttachmentsList"></div>
          </div>

          <div class="composer">
            <div class="composer-main">
              <button
                type="button"
                class="composer-attach"
                id="attachBtn"
                aria-label="Attach files"
                title="Attach files"
              >
                Attach
              </button>

              <div class="composer-input-wrap">
                <textarea
                  class="composer-input"
                  id="messageInput"
                  name="message"
                  rows="1"
                  placeholder="Message Nova..."
                  aria-label="Message Nova"
                ></textarea>
              </div>

              <button
                type="submit"
                class="composer-send"
                id="sendBtn"
                aria-label="Send message"
                title="Send"
              >
                Send
              </button>

              <button
                type="button"
                class="composer-stop"
                id="stopBtn"
                aria-label="Stop generating"
                title="Stop"
                hidden
              >
                Stop
              </button>
            </div>

            <div class="composer-footer">
              <div class="composer-meta" id="composerMeta" hidden></div>
              <div class="composer-hint" id="composerHint">Enter to send • Shift+Enter for a new line</div>
            </div>
          </div>

          <input
            type="file"
            id="fileInput"
            name="files"
            multiple
            hidden
          >
        </form>
      </div>
    </div>
  </main>
</div>

<script src="{{ url_for('static', filename='js/utils.js') }}"></script>
<script src="{{ url_for('static', filename='js/state.js') }}"></script>
<script src="{{ url_for('static', filename='js/api.js') }}"></script>
<script src="{{ url_for('static', filename='js/render-service.js') }}"></script>
<script src="{{ url_for('static', filename='js/attachments.js') }}"></script>
<script src="{{ url_for('static', filename='js/stream-service.js') }}"></script>
<script src="{{ url_for('static', filename='js/dialog-service.js') }}"></script>
<script src="{{ url_for('static', filename='js/chat-service.js') }}"></script>
<script src="{{ url_for('static', filename='js/chat.js') }}"></script>
</body>
</html>