    function addMsgDom(role, text, save=true){
      const wrap = document.createElement("div");
      wrap.className = "msg " + (role === "user" ? "user" : "ai");

      const who = document.createElement("div");
      who.className = "who";
      who.textContent = role === "user" ? "U" : "N";

      const bubbleWrap = document.createElement("div");
      bubbleWrap.className = "bubbleWrap";

      const bubble = document.createElement("div");
      bubble.className = "bubble";
      bubble.textContent = text;

      bubbleWrap.appendChild(bubble);

      if(role === "ai"){
        const actions = document.createElement("div");
        actions.className = "actions";

        const copyBtn = document.createElement("button");
        copyBtn.className = "aBtn";
        copyBtn.type = "button";
        copyBtn.textContent = "Copy";
        copyBtn.addEventListener("click", async () => {
          try{
            await navigator.clipboard.writeText(bubble.textContent || "");
            toast("Copied");
          }catch(e){
            try{
              const ta = document.createElement("textarea");
              ta.value = bubble.textContent || "";
              document.body.appendChild(ta);
              ta.select();
              document.execCommand("copy");
              ta.remove();
              toast("Copied");
            }catch(e2){
              toast("Copy failed");
            }
          }
        });

        actions.appendChild(copyBtn);
        bubbleWrap.appendChild(actions);
      }

      wrap.appendChild(who);
      wrap.appendChild(bubbleWrap);
      chatEl.appendChild(wrap);
      scrollDown();

      if(save){
        const act = getActive();
        if(act){
          act.messages.push({ role, text, ts: now() });
          act.updated = now();
          saveSessions();
          rebuildSessionSelect();
        }
      }
      return bubble;
    }

    // ---- Export / Import (WORKING)
    function safeFileName(s){
      return String(s||"session").replace(/[^\w\-]+/g, "_").slice(0,60) || "session";
    }

    function downloadText(filename, text){
      const blob = new Blob([text], { type: "application/json;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 2500);
    }

    function exportActiveSession(){
      const act = getActive();
      if(!act){ toast("No session"); return; }
      const payload = {
        format: "nova_session_v1",
        exported_at: now(),
        session: act
      };
      const fn = "Nova_" + safeFileName(act.name) + "_" + act.id + ".json";
      downloadText(fn, JSON.stringify(payload, null, 2));
      toast("Exported");
    }

    function importSessionObject(obj){
      let s = obj && obj.session ? obj.session : obj;
      if(!s || typeof s !== "object"){ throw new Error("Invalid file"); }

      const t = now();
      const imported = {
        id: (typeof s.id === "string" && s.id.length ? s.id : uuid()) + "_imp_" + Math.random().toString(16).slice(2,6),
        name: (typeof s.name === "string" && s.name.trim()) ? (s.name.trim() + " (import)") : "Imported (import)",
        created: +s.created || t,
        updated: t,
        messages: Array.isArray(s.messages)
          ? s.messages
            .filter(m => m && (m.role==="user"||m.role==="ai") && typeof m.text==="string")
            .map(m => ({ role: m.role, text: m.text, ts: +m.ts || t }))
          : []
      };

      sessions.push(imported);
      activeId = imported.id;
      saveSessions();
      rebuildSessionSelect();
      setActiveSession(imported.id);
      toast("Imported");
    }

    // ---- Backend call
    async function postChat(text){
      const act = getActive();
      const sid = act ? act.id : "ui";
      const url = "/api/chat?session_id=" + encodeURIComponent(sid);

      const r = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ text })
      });

      const raw = await r.text();
      let data = null;
      try{ data = JSON.parse(raw); }catch(e){}

      if(!r.ok){
        const msg = (data && (data.error || data.detail)) ? (data.error || data.detail) : raw;
        throw new Error("HTTP " + r.status + " " + msg);
      }
      if(data && data.reply !== undefined) return data.reply;
      return raw;
    }

    async function send(){
      const text = (inputEl.value || "").trim();
      if(!text || busy) return;

      addMsgDom("user", text, true);
      inputEl.value = "";
      saveDraft();
      autoGrow();

      setBusy(true);
      setStatus("thinking…", "warn");
      setLatency(null);

      const aiBubble = addMsgDom("ai", "…", true);
      const t0 = performance.now();

      try{
        let payload = text;
        if(mode === "command" && !text.startsWith("/")) payload = "/cmd " + text;
        if(mode === "doctor" && !text.startsWith("/")) payload = "/doctor " + text;

        const reply = await postChat(payload);

        aiBubble.textContent = reply;

        const act = getActive();
        if(act && act.messages.length){
          for(let i=act.messages.length-1; i>=0; i--){
            if(act.messages[i].role === "ai"){
              act.messages[i].text = reply;
              act.messages[i].ts = now();
              act.updated = now();
              break;
            }
          }
          saveSessions();
          rebuildSessionSelect();
        }

        setLatency(performance.now() - t0);
        setStatus("ready", "ok");
      }catch(err){
        console.error("SEND ERROR:", err);
        aiBubble.textContent = "Error: " + (err && err.message ? err.message : String(err));

        const act = getActive();
        if(act && act.messages.length){
          for(let i=act.messages.length-1; i>=0; i--){
            if(act.messages[i].role === "ai"){
              act.messages[i].text = aiBubble.textContent;
              act.messages[i].ts = now();
              act.updated = now();
              break;
            }
          }
          saveSessions();
          rebuildSessionSelect();
        }

        setStatus("error", "danger");
      }finally{
        setBusy(false);
        try{ inputEl.focus(); }catch(e){}
        scrollDown();
      }
    }

    function bindNav(){
      const buttons = document.querySelectorAll(".nav button[data-mode]");
      buttons.forEach(btn => {
        btn.addEventListener("click", () => {
          buttons.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          mode = btn.getAttribute("data-mode") || "ask";
          localStorage.setItem(LS_MODE, mode);
          modeText.textContent = mode;
          try{ inputEl.focus(); }catch(e){}
        });
      });
    }

    function applyAutosend(){
      const as = localStorage.getItem(LS_AUTOSEND);
      if(as === null){
        localStorage.setItem(LS_AUTOSEND, "1");
        autoSendEl.checked = true;
      } else {
        autoSendEl.checked = (as === "1");
      }
      autoSendEl.addEventListener("change", () => {
        localStorage.setItem(LS_AUTOSEND, autoSendEl.checked ? "1" : "0");
      });
    }

    function setActiveSession(id){
      if(!id || !sessions.some(s => s.id === id)) return;
      activeId = id;
      saveSessions();
      rebuildSessionSelect();
      const act = getActive();
      sessionText.textContent = act ? act.id : "…";
      renderMessages();
      setStatus("ready", "ok");
      setLatency(null);
    }

function init(){
      buildStamp.textContent = "WORKSPACE+EXPORT V1";
      modeText.textContent = mode;

      loadSessions();
      rebuildSessionSelect();

      const act = getActive();
      sessionText.textContent = act ? act.id : "…";

      applyAutosend();
      loadDraft();
      renderMessages();

      if(act && (!act.messages || !act.messages.length)){
        addMsgDom("ai", "Workspace sessions are live.\nExport downloads the current session as JSON.\nImport adds a session from JSON.\n(Stored locally in this browser.)", true);
      }

      sendBtn.addEventListener("click", send);

      inputEl.addEventListener("input", () => { autoGrow(); saveDraft(); });

      inputEl.addEventListener("keydown", (ev) => {
        if(ev.key === "Enter" && !ev.shiftKey){
          if(autoSendEl.checked){
            ev.preventDefault();
            send();
            return;
          }
        }
        if(ev.key === "Escape"){
          ev.preventDefault();
          inputEl.value = "";
          saveDraft();
          autoGrow();
          return;
        }
      });

      document.addEventListener("keydown", (ev) => {
        if((ev.ctrlKey || ev.metaKey) && (ev.key === "k" || ev.key === "K")){
          ev.preventDefault();
          try{ inputEl.focus(); }catch(e){}
        }
      }, { passive:false });

      clearBtn.addEventListener("click", () => {
        const act = getActive();
        if(act){
          act.messages = [];
          act.updated = now();
          saveSessions();
        }
        chatEl.innerHTML = "";
        setStatus("cleared", "ok");
        setLatency(null);
        toast("Cleared session");
        try{ inputEl.focus(); }catch(e){}
        rebuildSessionSelect();
      });

      pingBtn.addEventListener("click", async () => {
        try{
          setStatus("ping…", "warn");
          const r = await fetch("/api/health");
          const t = await r.text();
          setStatus(r.ok ? "ready" : "error", r.ok ? "ok" : "danger");
          addMsgDom("ai", "Ping /api/health -> HTTP " + r.status + "\n" + t, true);
        }catch(e){
          setStatus("error", "danger");
          addMsgDom("ai", "Ping failed: " + (e && e.message ? e.message : String(e)), true);
        }
      });

      sessionSelect.addEventListener("change", () => setActiveSession(sessionSelect.value));

      newSessBtn.addEventListener("click", () => {
        const name = prompt("New session name:", "New Session");
        const s = newSession(name || "New Session");
        sessions.push(s);
        activeId = s.id;
        saveSessions();
        rebuildSessionSelect();
        setActiveSession(s.id);
        toast("New session");
      });

      renameSessBtn.addEventListener("click", () => {
        const act = getActive();
        if(!act) return;
        const name = prompt("Rename session:", act.name);
        if(name === null) return;
        act.name = (String(name).trim() || act.name);
        act.updated = now();
        saveSessions();
        rebuildSessionSelect();
        toast("Renamed");
      });

      deleteSessBtn.addEventListener("click", () => {
        const act = getActive();
        if(!act) return;
        const ok = confirm("Delete session '" + act.name + "'? This cannot be undone.");
        if(!ok) return;

        sessions = sessions.filter(s => s.id !== act.id);
        if(!sessions.length){
          const s = newSession("Welcome");
          sessions = [s];
          activeId = s.id;
        } else {
          sessions.sort((a,b)=>(b.updated||0)-(a.updated||0));
          activeId = sessions[0].id;
        }
        saveSessions();
        rebuildSessionSelect();
        setActiveSession(activeId);
        toast("Deleted");
      });

      exportSessBtn.addEventListener("click", () => {
        try{ exportActiveSession(); }
        catch(e){ console.error(e); toast("Export failed"); }
      });

      importSessBtn.addEventListener("click", () => {
        try{ importFile.value = ""; importFile.click(); }
        catch(e){ console.error(e); toast("Import failed"); }
      });

      importFile.addEventListener("change", async () => {
        try{
          const ff = importFile.files && importFile.files[0];
          if(!ff) return;
          const txt = await ff.text();
          const obj = JSON.parse(txt);
          importSessionObject(obj);
        }catch(e){
          console.error(e);
          toast("Bad import file");
        }
      });

      bindNav();

      // Session search
      const sessSearchInput = document.getElementById("sessSearchInput");
      const sessSearchPrev  = document.getElementById("sessSearchPrev");
      const sessSearchNext  = document.getElementById("sessSearchNext");

      if(sessSearchInput){
        sessSearchInput.addEventListener("input", () => {
          searchInSession(sessSearchInput.value || "");
        });
        sessSearchInput.addEventListener("keydown", (ev) => {
          if(ev.key === "Enter"){
            ev.preventDefault();
            focusHit(__searchIndex + (ev.shiftKey ? -1 : 1));
          }
          if(ev.key === "Escape"){
            ev.preventDefault();
            sessSearchInput.value = "";
            searchInSession("");
            try{ inputEl.focus(); }catch(e){}
          }
        });
      }
      if(sessSearchPrev){
        sessSearchPrev.addEventListener("click", () => focusHit(__searchIndex - 1));
      }
      if(sessSearchNext){
        sessSearchNext.addEventListener("click", () => focusHit(__searchIndex + 1));
      }

      // Ctrl+F focuses session search instead of browser find
      document.addEventListener("keydown", (ev) => {
        if((ev.ctrlKey || ev.metaKey) && (ev.key === "f" || ev.key === "F")){
          if(sessSearchInput){
            ev.preventDefault();
            sessSearchInput.focus();
            sessSearchInput.select();
          }
        }
      }, { passive:false });
autoGrow();
      try{ inputEl.focus(); }catch(e){}
      setStatus("ready", "ok");
      setLatency(null);
    }

    if(document.readyState === "loading"){
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
