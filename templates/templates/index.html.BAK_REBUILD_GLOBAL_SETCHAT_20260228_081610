    function setLatency(ms){
      if(typeof ms === "number" && isFinite(ms)) latencyPill.textContent = "lat: " + Math.round(ms) + "ms";
      else latencyPill.textContent = "lat: —";
    }

    function scrollDown(){ try{ chatEl.scrollTop = chatEl.scrollHeight; }catch(e){} }

    function setBusy(v){
      busy = !!v;
      sendBtn.disabled = busy;
      inputEl.disabled = busy;
    }

    function autoGrow(){
      try{
        inputEl.style.height = "auto";
        inputEl.style.height = Math.min(240, inputEl.scrollHeight) + "px";
      }catch(e){}
    }

    function saveDraft(){
      try{ localStorage.setItem(LS_DRAFT, inputEl.value || ""); }catch(e){}
    }

    function loadDraft(){
      try{
        const d = localStorage.getItem(LS_DRAFT);
        if(typeof d === "string") inputEl.value = d;
      }catch(e){}
    }

    // ---- Sessions persistence
    function loadSessions(){
      try{
        const raw = localStorage.getItem(LS_SESSIONS);
        const arr = raw ? JSON.parse(raw) : [];
        sessions = Array.isArray(arr) ? arr : [];
      }catch(e){
        sessions = [];
      }

      sessions = sessions
        .filter(s => s && typeof s.id === "string")
        .map(s => ({
          id: String(s.id),
          name: typeof s.name === "string" ? s.name : "Session",
          created: +s.created || now(),
          updated: +s.updated || +s.created || now(),
          messages: Array.isArray(s.messages)
            ? s.messages
              .filter(m => m && (m.role==="user"||m.role==="ai") && typeof m.text==="string")
              .map(m => ({ role: m.role, text: m.text, ts: +m.ts || now() }))
            : []
        }));

      activeId = localStorage.getItem(LS_ACTIVE);
      if(!activeId || !sessions.some(s => s.id === activeId)){
        activeId = sessions.length ? sessions[0].id : null;
      }

      if(!sessions.length){
        const s = newSession("Welcome");
        sessions = [s];
        activeId = s.id;
        saveSessions();
      } else {
        saveSessions();
      }
    }

    function saveSessions(){
      try{ localStorage.setItem(LS_SESSIONS, JSON.stringify(sessions)); }catch(e){}
      try{ localStorage.setItem(LS_ACTIVE, activeId || ""); }catch(e){}
    }

    function getActive(){
      return sessions.find(s => s.id === activeId) || null;
    }

    function newSession(name){
      const t = now();
      return {
        id: uuid(),
        name: (name && String(name).trim()) ? String(name).trim() : ("Session " + new Date(t).toLocaleString()),
        created: t,
        updated: t,
        messages: []
      };
    }

    function rebuildSessionSelect(){
      const act = getActive();
      sessionSelect.innerHTML = "";
      const sorted = [...sessions].sort((a,b)=> (b.updated||0)-(a.updated||0));
      for(const s of sorted){
        const opt = document.createElement("option");
        opt.value = s.id;
        opt.textContent = s.name;
        if(act && s.id === act.id) opt.selected = true;
        sessionSelect.appendChild(opt);
      }
    }

