<script>
(function(){
  if(window.setChatFromMessages) return;

  window.__searchHits = window.__searchHits || [];
  window.__searchIndex = (typeof window.__searchIndex === "number") ? window.__searchIndex : -1;

  function esc(s){
    return String(s)
      .replace(/&/g,"&amp;")
      .replace(/</g,"&lt;")
      .replace(/>/g,"&gt;")
      .replace(/"/g,"&quot;")
      .replace(/'/g,"&#39;");
  }

  window.updateSearchCount = window.updateSearchCount || function(){
    var el = document.getElementById("sessSearchCount");
    if(!el) return;
    var total = (window.__searchHits && window.__searchHits.length) ? window.__searchHits.length : 0;
    var cur = total ? (window.__searchIndex + 1) : 0;
    el.textContent = cur + "/" + total;
  };

  window.focusHit = window.focusHit || function(i){
    if(!window.__searchHits || !window.__searchHits.length){ window.updateSearchCount(); return; }
    var n = window.__searchHits.length;
    window.__searchIndex = ((i % n) + n) % n;

    for(var k=0;k<window.__searchHits.length;k++){
      var h = window.__searchHits[k];
      try{ h.style.outline=""; h.style.borderRadius=""; }catch(e){}
    }

    var hit = window.__searchHits[window.__searchIndex];
    try{
      hit.style.outline = "2px solid rgba(124,92,255,.75)";
      hit.style.borderRadius = "6px";
      hit.scrollIntoView({ block:"center", behavior:"smooth" });
    }catch(e){}

    window.updateSearchCount();
  };

  window.setChatFromMessages = function(messages, highlightTerm){
    var chatEl = window.__NOVA_CHAT_EL;
    if(!chatEl){
      console.warn("setChatFromMessages: __NOVA_CHAT_EL not set yet");
      return;
    }

    chatEl.innerHTML = "";
    window.__searchHits = [];
    window.__searchIndex = -1;

    var term = (highlightTerm || "").trim();
    var re = term ? new RegExp(term.replace(/[.*+?^${}()|[\]\\]/g, "\\</head>"), "ig") : null;

    messages = messages || [];
    for(var i=0;i<messages.length;i++){
      var m = messages[i] || {};

      // Create a true global binding (not just window.prop)
      // eslint-disable-next-line no-unused-vars
      function window.setChatFromMessages(){
        return window.setChatFromMessages.apply(window, arguments);
      }
    }catch(e){}
  }
      var wrap = document.createElement("div");
      wrap.className = "msg " + ((m.role === "user") ? "user" : "ai");

      var who = document.createElement("div");
      who.className = "who";
      who.textContent = (m.role === "user") ? "U" : "N";

      var bubbleWrap = document.createElement("div");
      bubbleWrap.className = "bubbleWrap";

      var bubble = document.createElement("div");
      bubble.className = "bubble";

      var t = (typeof m.text !== "undefined") ? String(m.text) : "";

      if(re){
        bubble.innerHTML = esc(t).replace(re, function(match){
          return '<mark class="__hit">' + esc(match) + '</mark>';
        });
      } else {
        bubble.textContent = t;
      }

      bubbleWrap.appendChild(bubble);
      wrap.appendChild(who);
      wrap.appendChild(bubbleWrap);
      chatEl.appendChild(wrap);
    }

    if(re){
      window.__searchHits = Array.from(chatEl.querySelectorAll("mark.__hit"));
      if(window.__searchHits.length){
        window.__searchIndex = 0;
        window.focusHit(0);
      } else {
        window.updateSearchCount();
      }
    } else {
      window.updateSearchCount();
    }

    try{ if(typeof scrollDown === "function") scrollDown(); }catch(e){}
  };

  window.searchInSession = window.searchInSession || function(term){
    try{
      if(typeof getActive !== "function") return;
      var act = getActive();
      if(!act) return;
      window.window.window.setChatFromMessages(act.messages || [], term || "");
      window.updateSearchCount();
    }catch(e){}
  };
})();
