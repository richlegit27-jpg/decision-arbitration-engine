  <script>
  (function(){
    "use strict";

    const $ = (sel) => document.querySelector(sel);

    const chatEl = $("#chat");
    const inputEl = $("#input");
    const sendBtn = $("#sendBtn");
    const clearBtn = $("#clearBtn");
    const pingBtn = $("#pingBtn");
    const autoSendEl = $("#autoSend");

    const statusText = $("#statusText");
