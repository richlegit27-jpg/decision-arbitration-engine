<!-- SERVICES -->

<script src="{{ url_for('static', path='js/stream-service.js') }}?v=endgame_polish_batch_3"></script>
<script src="{{ url_for('static', path='js/attachments-service.js') }}?v=endgame_polish_batch_3"></script>

<!-- SIDEBAR -->

<script src="{{ url_for('static', path='js/chat-sidebar-render.js') }}?v=endgame_polish_batch_3"></script>
<script src="{{ url_for('static', path='js/chat-sidebar-actions.js') }}?v=endgame_polish_batch_3"></script>
<script src="{{ url_for('static', path='js/chat-sidebar-layout.js') }}?v=endgame_polish_batch_3"></script>
<script src="{{ url_for('static', path='js/chat-sidebar.js') }}?v=endgame_polish_batch_3"></script>

<!-- MESSAGES -->

<script src="{{ url_for('static', path='js/chat-messages.js') }}?v=endgame_polish_batch_3"></script>

<!-- COMPOSER -->

<script src="{{ url_for('static', path='js/composer-input.js') }}?v=endgame_polish_batch_3"></script>
<script src="{{ url_for('static', path='js/composer-actions.js') }}?v=endgame_polish_batch_3"></script>
<script src="{{ url_for('static', path='js/composer-attachments.js') }}?v=endgame_polish_batch_3"></script>
<script src="{{ url_for('static', path='js/composer.js') }}?v=endgame_polish_batch_3"></script>

<!-- MEMORY -->

<script src="{{ url_for('static', path='js/memory-panel.js') }}?v=endgame_polish_batch_3"></script>

