<script src="{{ url_for('static', path='js/chat-bootstrap.js') }}?v=endgame_polish_batch_3"></script>
<script src="{{ url_for('static', path='js/chat-app.js') }}?v=endgame_polish_batch_3"></script>

</body>
</html>