<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova Chat</title>

    <style>
        /* Global Styles */
        :root {
            --bg: #f0f0f0;
            --panel: rgba(0,0,0,.05);
            --panel2: rgba(0,0,0,.07);
            --text: rgba(0,0,0,.88);
            --muted: rgba(0,0,0,.62);
            --shadow: 0 10px 20px rgba(0,0,0,.1);
            --brand: #4e73df;
            --danger: #ff4d4f;
            --ok: #22c55e;
            --radius: 8px;
            --font-family: 'Arial', sans-serif;
        }

        body {
            margin: 0;
            font-family: var(--font-family);
            background-color: var(--bg);
            color: var(--text);
        }

        /* Layout */
        .app-container {
            display: flex;
            min-height: 100vh;
            flex-direction: column;
        }

        .chat-container {
            flex-grow: 1;
            background: white;
            padding: 20px;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow);
            border-radius: var(--radius);
            margin: 20px;
        }

        .chat-area {
            flex-grow: 1;
            overflow-y: auto;
            padding: 10px;
            border-bottom: 1px solid #ccc;
        }

        /* Chat Bubble */
        .chat-bubble {
            padding: 12px;
            border-radius: 10px;
            max-width: 75%;
            margin: 5px 0;
            font-size: 14px;
            background-color: #e1e1e1;
        }

        .user-message {
            background-color: #007bff;
            color: white;
            align-self: flex-end;
        }

        .bot-message {
            background-color: #f1f1f1;
            color: black;
            align-self: flex-start;
        }

        /* Textarea & Send Button */
        textarea {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
            border-radius: var(--radius);
            border: 1px solid #ccc;
            font-size: 16px;
            color: var(--text);
            background: #f9f9f9;
            resize: none;
        }

        .send-btn {
            padding: 12px;
            margin-top: 10px;
            background-color: var(--brand);
            color: white;
            border: none;
            font-size: 16px;
            cursor: pointer;
            border-radius: var(--radius);
        }

        .send-btn:hover {
            background-color: #3e6bb5;
        }

        /* Responsive Adjustments */
        @media (max-width: 768px) {
            .app-container {
                padding: 10px;
            }

            .chat-container {
                margin: 10px 0;
            }
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Chat Area -->
        <main class="chat-container">
            <div class="chat-area" id="chat-area"></div>
            <textarea id="input-area" placeholder="Type your message..." rows="3"></textarea>
            <button id="send-btn" class="send-btn">Send</button>
        </main>
    </div>

    <script>
        // Auto-resize input area
        document.getElementById('input-area').addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        });

        // Send message on button click
        document.getElementById('send-btn').addEventListener('click', async function() {
            const inputArea = document.getElementById('input-area');
            const message = inputArea.value.trim();

            if (message) {
                const chatArea = document.getElementById('chat-area');

                // User message
                const userMessage = document.createElement('div');
                userMessage.classList.add('chat-bubble', 'user-message');
                userMessage.textContent = message;
                chatArea.appendChild(userMessage);

                // Typing indicator for bot
                const typingIndicator = document.createElement('div');
                typingIndicator.classList.add('chat-bubble', 'bot-message');
                typingIndicator.textContent = "Bot is typing...";
                chatArea.appendChild(typingIndicator);

                // Auto scroll to the latest message
                chatArea.scrollTop = chatArea.scrollHeight;

                // Clear input
                inputArea.value = '';

                // Send the message to the backend
                const response = await fetch('http://127.0.0.1:8000/chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ message: message })
                });

                const data = await response.json();

                // Remove typing indicator
                chatArea.removeChild(typingIndicator);

                // Bot response
                const botMessage = document.createElement('div');
                botMessage.classList.add('chat-bubble', 'bot-message');
                botMessage.textContent = data.response;
                chatArea.appendChild(botMessage);

                // Auto scroll to the latest message
                chatArea.scrollTop = chatArea.scrollHeight;
            }
        });

        // Handle sending messages with Enter key
        document.getElementById('input-area').addEventListener('keydown', function(event) {
            if (event.key === 'Enter' && !event.shiftKey) {
                document.getElementById('send-btn').click();
                event.preventDefault(); // Prevent default newline behavior
            }
        });
    </script>

    <!-- Link to the JavaScript file -->
    <script src="/static/js/chat.js"></script>
