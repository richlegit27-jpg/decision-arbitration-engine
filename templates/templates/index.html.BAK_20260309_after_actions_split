<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Nova</title>
  <link rel="stylesheet" href="{{ url_for('static', filename='css/base.css') }}?v=20260309a">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/layout.css') }}?v=20260309a">
</head>
<body>
  <div id="appShell" class="app-shell">
    <aside id="sidebar" class="sidebar" data-open="false">
      <div class="sidebar-header">
        <div class="sidebar-title">Nova</div>
        <button id="btnCloseSidebar" class="sidebar-close" type="button" aria-label="Close sidebar">✕</button>
      </div>

      <div class="sidebar-actions">
        <button id="btnNewChat" type="button">New chat</button>
      </div>

      <div id="chatList" class="chat-list">
        <div class="chat-list-empty">No chats yet</div>
      </div>
    </aside>

    <main class="main-panel">
      <header class="topbar">
        <div class="topbar-left">
          <button id="btnSidebarToggle" class="mobile-sidebar-btn" type="button" aria-label="Open sidebar">☰</button>
          <div id="topbarTitle" class="topbar-title">New chat</div>
        </div>

        <div class="topbar-right"></div>
      </header>

      <section class="content-shell">
        <div id="messagesScroll" class="messages-scroll">
          <div id="emptyState" class="empty-state-shell">
            <div class="empty-state">
              <div class="empty-state-badge">Nova</div>
              <h1>How can I help today?</h1>
              <p>Ask Nova anything or start with one of these prompts.</p>

              <div class="empty-state-suggestions">
                <button
                  class="suggestion-chip"
                  type="button"
                  data-suggestion="Help me plan my day and prioritize what matters most.">
                  Plan my day
                </button>

                <button
                  class="suggestion-chip"
                  type="button"
                  data-suggestion="Summarize this topic in simple terms and make it easy to understand.">
                  Explain simply
                </button>

                <button
                  class="suggestion-chip"
                  type="button"
                  data-suggestion="Help me write something clear, strong, and professional.">
                  Write with me
                </button>

                <button
                  class="suggestion-chip"
                  type="button"
                  data-suggestion="Brainstorm ideas with me and give me the strongest options first.">
                  Brainstorm ideas
                </button>
              </div>
            </div>
          </div>

          <div id="messages" class="messages"></div>

          <button
            id="jumpToLatestBtn"
            class="jump-to-latest-btn"
            type="button"
            hidden
            aria-label="Jump to latest message">
            Jump to latest ↓
          </button>
        </div>

        <div class="composer-wrap">
          <div class="composer-shell">
            <div id="pendingAttachments" class="pending-attachments" hidden>
              <div id="pendingAttachmentsList" class="pending-attachments-list"></div>
            </div>

            <form id="composerForm" class="composer-form">
              <div class="composer-input-wrap">
                <textarea id="input" rows="1" placeholder="Message Nova"></textarea>
              </div>

              <div class="composer-actions">
                <div class="composer-actions-left">
                  <button id="attachBtn" type="button">Attach</button>
                  <input id="fileInput" type="file" multiple hidden>
                </div>

                <div class="composer-actions-right">
                  <button id="stopBtn" type="button" hidden>Stop</button>
                  <button id="sendBtn" type="submit">Send</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </section>
    </main>
  </div>

  <div id="mobileOverlay" class="mobile-overlay"></div>

<script src="{{ url_for('static', filename='js/api.js') }}?v=20260309e"></script>
<script src="{{ url_for('static', filename='js/chat-service.js') }}?v=20260309e"></script>
<script src="{{ url_for('static', filename='js/render-service.js') }}?v=20260309e"></script>
<script src="{{ url_for('static', filename='js/attachments-service.js') }}?v=20260309e"></script>
<script src="{{ url_for('static', filename='js/stream-service.js') }}?v=20260309e"></script>
<script src="{{ url_for('static', filename='js/chat-render.js') }}?v=20260309e"></script>
<script src="{{ url_for('static', filename='js/chat-ui.js') }}?v=20260309e"></script>
<script src="{{ url_for('static', filename='js/chat-actions.js') }}?v=20260309e"></script>
<script src="{{ url_for('static', filename='js/chat-events.js') }}?v=20260309e"></script>
<script src="{{ url_for('static', filename='js/chat.js') }}?v=20260309e"></script>
</body>
</html>