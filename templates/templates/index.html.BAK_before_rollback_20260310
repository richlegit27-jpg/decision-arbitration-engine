<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Nova</title>

  <link rel="stylesheet" href="{{ url_for('static', path='css/base.css') }}?v=20260310_md1">
  <link rel="stylesheet" href="{{ url_for('static', path='css/layout.css') }}?v=20260310_md1">
</head>

<body>

<div id="appShell" class="app-shell">

  <!-- SIDEBAR -->
  <aside id="sidebar" class="sidebar">

    <div class="sidebar-header">
      <div class="sidebar-title">Nova</div>
      <button id="btnCloseSidebar" class="sidebar-close" type="button">✕</button>
    </div>

    <div class="sidebar-actions">
      <button id="btnNewChat" class="sidebar-btn" type="button">
        New chat
      </button>
    </div>

    <div id="chatList" class="chat-list">
      <div class="chat-list-empty">No chats yet</div>
    </div>

  </aside>


  <!-- MAIN -->
  <main class="main">

    <!-- TOP BAR -->
    <div class="topbar">

      <button id="btnSidebarToggle" class="topbar-btn" type="button">
        ☰
      </button>

      <div id="topbarTitle" class="topbar-title">
        Nova
      </div>

    </div>


    <!-- MESSAGES -->
    <div id="messagesScroll" class="messages-scroll">

      <div id="messages" class="messages"></div>

      <div id="emptyState" class="empty-state">

        <div class="empty-title">
          Nova
        </div>

        <div id="emptySuggestions" class="empty-suggestions">
          Start a conversation
        </div>

      </div>

    </div>


    <!-- ATTACHMENTS PREVIEW -->
    <div id="pendingAttachments" class="pending-attachments"></div>


    <!-- COMPOSER -->
    <div class="composer">

      <button id="btnAttach" class="composer-btn" type="button">
        +
      </button>

      <textarea
        id="chatInput"
        class="composer-input"
        placeholder="Send a message..."
        rows="1"
      ></textarea>

      <button id="btnSend" class="composer-send" type="button">
        Send
      </button>

      <button id="btnStop" class="composer-stop" type="button" hidden>
        Stop
      </button>

      <input id="fileInput" type="file" multiple hidden>

    </div>

  </main>

</div>


<button id="jumpToLatestBtn" class="jump-to-latest" type="button" hidden>
  Jump to latest
</button>


<!-- CORE SERVICES -->
<script src="{{ url_for('static', path='js/api.js') }}?v=20260310_md1"></script>
<script src="{{ url_for('static', path='js/stream-service.js') }}?v=20260310_md1"></script>
<script src="{{ url_for('static', path='js/attachments-service.js') }}?v=20260310_md1"></script>

<!-- MARKDOWN -->
<script src="{{ url_for('static', path='js/markdown.js') }}?v=20260310_md1"></script>

<!-- MODULAR CHAT SYSTEM -->
<script src="{{ url_for('static', path='js/chat-state.js') }}?v=20260310_md1"></script>
<script src="{{ url_for('static', path='js/chat-storage.js') }}?v=20260310_md1"></script>
<script src="{{ url_for('static', path='js/chat-sidebar.js') }}?v=20260310_md1"></script>
<script src="{{ url_for('static', path='js/chat-messages.js') }}?v=20260310_md1"></script>
<script src="{{ url_for('static', path='js/composer.js') }}?v=20260310_md1"></script>
<script src="{{ url_for('static', path='js/chat-app.js') }}?v=20260310_md1"></script>

</body>
</html>