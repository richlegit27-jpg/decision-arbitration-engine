<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light dark" />
  <title>Nova</title>

  <!-- NOVA_UI_POLISH_ENDGAME_V1 2026-02-26 -->

  <style>
    :root{
      --bg: #0b1020;
      --panel: rgba(255,255,255,.06);
      --panel2: rgba(255,255,255,.08);
      --stroke: rgba(255,255,255,.12);
      --text: rgba(255,255,255,.92);
      --muted: rgba(255,255,255,.65);
      --muted2: rgba(255,255,255,.45);
      --brand: #7c5cff;
      --brand2:#34d399;
      --danger:#ff4d4f;
      --warn:#fbbf24;
      --ok:#22c55e;
      --shadow: 0 20px 55px rgba(0,0,0,.45);
      --radius: 18px;
      --radius2: 22px;
      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      --sans: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
    }

    /* Light mode support */
    @media (prefers-color-scheme: light){
      :root{
        --bg: #f6f7fb;
        --panel: rgba(0,0,0,.04);
        --panel2: rgba(0,0,0,.06);
        --stroke: rgba(0,0,0,.10);
        --text: rgba(0,0,0,.88);
        --muted: rgba(0,0,0,.58);
        --muted2: rgba(0,0,0,.42);
        --shadow: 0 20px 55px rgba(0,0,0,.12);
      }
    }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      margin:0;
      font-family: var(--sans);
      background:
        radial-gradient(1200px 700px at 15% 10%, rgba(124,92,255,.22), transparent 60%),
        radial-gradient(900px 600px at 90% 25%, rgba(52,211,153,.18), transparent 55%),
        radial-gradient(1000px 700px at 45% 90%, rgba(251,191,36,.12), transparent 55%),
        var(--bg);
      color: var(--text);
      overflow: hidden;
    }

    .wrap{
      height:100%;
      display:flex;
      align-items:stretch;
      justify-content:center;
      padding:18px;
    }

    .shell{
      width:min(1120px, 100%);
      height:100%;
      display:flex;
      flex-direction:column;
      gap:14px;
    }

    .topbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:14px 14px;
      border:1px solid var(--stroke);
      background: linear-gradient(180deg, var(--panel2), var(--panel));
      border-radius: var(--radius2);
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width: 260px;
    }

    .logo{
      width:38px; height:38px;
      border-radius:14px;
      background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.45), rgba(255,255,255,.05) 55%),
                  linear-gradient(135deg, rgba(124,92,255,.95), rgba(52,211,153,.85));
      border:1px solid rgba(255,255,255,.18);
      box-shadow: 0 12px 22px rgba(124,92,255,.20);
      position:relative;
      overflow:hidden;
    }
    .logo:after{
      content:"";
      position:absolute; inset:-40%;
      background: conic-gradient(from 180deg, transparent, rgba(255,255,255,.25), transparent);
      transform: rotate(35deg);
    }

    .titleblock{ display:flex; flex-direction:column; line-height:1.05; }
    .title{
      font-size: 16px;
      font-weight: 750;
      letter-spacing: .2px;
    }
    .subtitle{
      font-size: 12px;
      color: var(--muted);
      margin-top: 3px;
    }

    .statusrow{
      display:flex;
      align-items:center;
      gap:10px;
      justify-content:flex-end;
      flex-wrap: wrap;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding: 8px 10px;
      border:1px solid var(--stroke);
      background: rgba(255,255,255,.04);
      border-radius: 999px;
      font-size: 12px;
      color: var(--muted);
      user-select:none;
    }
    .dot{
      width:8px; height:8px;
      border-radius:999px;
      background: var(--muted2);
      box-shadow: 0 0 0 2px rgba(0,0,0,.12);
    }
    .dot.ok{ background: var(--ok); }
    .dot.bad{ background: var(--danger); }
    .dot.warn{ background: var(--warn); }

    .btn{
      appearance:none;
      border:1px solid var(--stroke);
      background: rgba(255,255,255,.05);
      color: var(--text);
      padding: 9px 12px;
      border-radius: 12px;
      font-weight: 650;
      font-size: 12px;
      cursor:pointer;
      transition: transform .06s ease, background .12s ease, border-color .12s ease;
      user-select:none;
    }
    .btn:hover{ background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.18); }
    .btn:active{ transform: translateY(1px); }

    .btn.primary{
      border-color: rgba(124,92,255,.55);
      background: linear-gradient(180deg, rgba(124,92,255,.35), rgba(124,92,255,.18));
    }
    .btn.ghost{
      background: transparent;
    }
    .btn.danger{
      border-color: rgba(255,77,79,.45);
      background: linear-gradient(180deg, rgba(255,77,79,.18), rgba(255,77,79,.08));
    }

    .main{
      flex:1;
      display:flex;
      gap:14px;
      min-height: 0;
    }

    .left{
      flex:1;
      display:flex;
      flex-direction:column;
      gap:14px;
      min-height: 0;
    }

    .panel{
      border:1px solid var(--stroke);
      background: linear-gradient(180deg, var(--panel2), var(--panel));
      border-radius: var(--radius2);
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
      overflow:hidden;
      min-height:0;
    }

    .panelHead{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding: 12px 14px;
      border-bottom:1px solid var(--stroke);
    }

    .tabs{
      display:flex;
      gap:8px;
      align-items:center;
    }
    .tab{
      border:1px solid var(--stroke);
      background: rgba(255,255,255,.04);
      color: var(--muted);
      padding: 8px 10px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 750;
      cursor:pointer;
      user-select:none;
    }
    .tab.active{
      color: var(--text);
      border-color: rgba(124,92,255,.55);
      background: linear-gradient(180deg, rgba(124,92,255,.33), rgba(124,92,255,.14));
    }

    .panelBody{
      padding: 14px;
      min-height:0;
    }

    .output{
      height: 100%;
      min-height:0;
      display:flex;
      flex-direction:column;
      gap:12px;
    }

    .messages{
      flex:1;
      min-height:0;
      overflow:auto;
      padding-right: 6px;
    }

    .msg{
      border:1px solid var(--stroke);
      background: rgba(255,255,255,.04);
      border-radius: 16px;
      padding: 12px 12px;
      margin-bottom: 10px;
    }
    .msg .meta{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      margin-bottom: 8px;
      font-size: 12px;
      color: var(--muted);
    }
    .msg .role{
      font-weight: 800;
      color: var(--text);
      letter-spacing:.2px;
    }
    .msg pre{
      margin:0;
      white-space: pre-wrap;
      word-wrap: break-word;
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.45;
      color: var(--text);
    }

    .copyMini{
      border:1px solid var(--stroke);
      background: rgba(255,255,255,.05);
      color: var(--muted);
      padding: 6px 8px;
      border-radius: 10px;
      font-size: 11px;
      cursor:pointer;
      user-select:none;
    }
    .copyMini:hover{ color: var(--text); }

    .composerRow{
      display:flex;
      gap:10px;
      align-items:flex-end;
    }

    .composer{
      flex:1;
      border:1px solid var(--stroke);
      background: rgba(255,255,255,.03);
      border-radius: 18px;
      padding: 10px 10px;
    }

    textarea{
      width:100%;
      resize:none;
      border:none;
      outline:none;
      background: transparent;
      color: var(--text);
      font-size: 14px;
      line-height: 1.35;
      font-family: var(--sans);
      min-height: 42px;
      max-height: 180px;
    }

    .hintrow{
      display:flex;
      justify-content:space-between;
      gap:12px;
      padding-top: 8px;
      font-size: 12px;
      color: var(--muted2);
      user-select:none;
    }

    .right{
      width: min(360px, 36%);
      display:flex;
      flex-direction:column;
      gap:14px;
      min-height:0;
    }

    .kv{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding: 10px 0;
      border-bottom:1px dashed rgba(255,255,255,.12);
      font-size: 13px;
      color: var(--muted);
    }
    .kv:last-child{ border-bottom:none; }

    .switch{
      display:flex;
      align-items:center;
      gap:10px;
      user-select:none;
    }
    .toggle{
      width:46px; height:26px;
      border-radius:999px;
      border:1px solid var(--stroke);
      background: rgba(255,255,255,.05);
      position:relative;
      cursor:pointer;
      flex: 0 0 auto;
    }
    .knob{
      width:22px; height:22px;
      border-radius:999px;
      position:absolute;
      top:1px; left:1px;
      background: rgba(255,255,255,.65);
      transition: left .12s ease, background .12s ease;
    }
    .toggle.on{
      border-color: rgba(52,211,153,.55);
      background: rgba(52,211,153,.12);
    }
    .toggle.on .knob{
      left: 22px;
      background: rgba(52,211,153,.9);
    }

    .banner{
      display:none;
      margin: 10px 14px 0 14px;
      border:1px solid rgba(255,77,79,.45);
      background: rgba(255,77,79,.10);
      color: rgba(255,255,255,.92);
      border-radius: 14px;
      padding: 10px 12px;
      font-size: 13px;
    }
    .banner.show{ display:block; }

    .foot{
      padding: 10px 14px;
      border-top:1px solid var(--stroke);
      font-size: 12px;
      color: var(--muted2);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      user-select:none;
    }

    /* “circly mouse” */
    #nova_cursor_dot{
      position: fixed;
      width: 12px;
      height: 12px;
      border-radius: 999px;
      border: 2px solid rgba(255,255,255,.55);
      box-shadow: 0 0 18px rgba(124,92,255,.22);
      pointer-events:none;
      z-index: 999999;
      transform: translate(-50%, -50%);
      display:none;
      mix-blend-mode: screen;
    }

    /* Scrollbars */
    .messages::-webkit-scrollbar{ width: 10px; }
    .messages::-webkit-scrollbar-thumb{
      background: rgba(255,255,255,.14);
      border-radius: 999px;
      border: 2px solid rgba(0,0,0,0);
      background-clip: padding-box;
    }

    @media (max-width: 980px){
      body{ overflow:auto; }
      .wrap{ padding: 12px; height:auto; }
      .shell{ height:auto; }
      .main{ flex-direction:column; }
      .right{ width:100%; }
    }
  </style>
</head>

<body>
  <div id="nova_cursor_dot"></div>

  <div class="wrap">
    <div class="shell">

      <div class="topbar">
        <div class="brand">
          <div class="logo"></div>
          <div class="titleblock">
            <div class="title">Nova</div>
            <div class="subtitle">A structured AI workspace — UI Polish Endgame</div>
          </div>
        </div>

        <div class="statusrow">
          <div class="pill" title="Which HTML is actually being served">
            <span class="dot ok" id="dotBuild"></span>
            <span>build:</span>
            <span id="buildStamp" style="font-family:var(--mono); color:var(--text);">NOVA_UI_POLISH_ENDGAME_V1_2026-02-26</span>
          </div>
          <div class="pill" title="Backend /api/health">
            <span class="dot" id="dotApi"></span>
            <span id="apiStatus">api: unknown</span>
          </div>
          <button class="btn ghost" id="btnPing">Ping</button>
          <button class="btn danger" id="btnClear">Clear</button>
          <button class="btn" id="btnCopyAll">Copy</button>
        </div>
      </div>

      <div class="main">
        <div class="left">
          <div class="panel" style="flex:1;">
            <div class="panelHead">
              <div class="tabs">
                <div class="tab active" data-mode="ask">Ask</div>
                <div class="tab" data-mode="command">Command</div>
                <div class="tab" data-mode="doctor">Doctor</div>
              </div>
              <div style="display:flex; gap:10px; align-items:center;">
                <div class="pill" title="Session id used by /api/chat">
                  <span style="color:var(--muted2);">session:</span>
                  <span id="sessionId" style="font-family:var(--mono); color:var(--text);">default</span>
                </div>
                <button class="btn primary" id="btnSend">Send</button>
              </div>
            </div>

            <div class="banner" id="banner"></div>

            <div class="panelBody" style="height: calc(100% - 54px);">
              <div class="output">
                <div class="messages" id="messages"></div>

                <div class="composerRow">
                  <div class="composer">
                    <textarea id="input" placeholder="Type here…"></textarea>
                    <div class="hintrow">
                      <span>Enter = send • Shift+Enter = newline</span>
                      <span id="charCount">0</span>
                    </div>
                  </div>
                </div>

              </div>
            </div>

            <div class="foot">
              <span>Mode: <span id="modeLabel" style="color:var(--text); font-weight:750;">ask</span></span>
              <span style="font-family:var(--mono);">NOVA_UI_POLISH_ENDGAME_V1 2026-02-26</span>
            </div>
          </div>
        </div>

        <div class="right">
          <div class="panel">
            <div class="panelHead">
              <div style="font-weight:800;">Settings</div>
              <div style="font-size:12px;color:var(--muted);">local</div>
            </div>
            <div class="panelBody">
              <div class="kv">
                <span>Auto-send on Enter</span>
                <div class="switch">
                  <div class="toggle on" id="togEnter"><div class="knob"></div></div>
                </div>
              </div>

              <div class="kv">
                <span>Auto-scroll output</span>
                <div class="switch">
                  <div class="toggle on" id="togScroll"><div class="knob"></div></div>
                </div>
              </div>

              <div class="kv">
                <span>Show “circly mouse”</span>
                <div class="switch">
                  <div class="toggle on" id="togCursor"><div class="knob"></div></div>
                </div>
              </div>

              <div class="kv">
                <span>Session Id</span>
                <input id="sessionBox" style="width:160px; border:1px solid var(--stroke); background:rgba(255,255,255,.03); color:var(--text); padding:8px 10px; border-radius:12px; font-family:var(--mono);" placeholder="default" />
              </div>

              <div class="kv">
                <span>Tip</span>
                <span style="color:var(--muted2);">If UI “doesn’t change”, this build stamp will.</span>
              </div>
            </div>
          </div>

          <div class="panel">
            <div class="panelHead">
              <div style="font-weight:800;">Quick Actions</div>
              <div style="font-size:12px;color:var(--muted);">one tap</div>
            </div>
            <div class="panelBody" style="display:flex; flex-direction:column; gap:10px;">
              <button class="btn" id="btnExplain">Explain last reply</button>
              <button class="btn" id="btnSummarize">Summarize chat</button>
              <button class="btn" id="btnPlan">Make a plan</button>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>

  <script>
    (function(){
      const $ = (id)=>document.getElementById(id);

      const messages = $("messages");
      const input = $("input");
      const banner = $("banner");
      const apiStatus = $("apiStatus");
      const dotApi = $("dotApi");
      const modeLabel = $("modeLabel");
      const charCount = $("charCount");
      const sessionId = $("sessionId");
      const sessionBox = $("sessionBox");

      const togEnter = $("togEnter");
      const togScroll = $("togScroll");
      const togCursor = $("togCursor");

      const btnSend = $("btnSend");
      const btnClear = $("btnClear");
      const btnCopyAll = $("btnCopyAll");
      const btnPing = $("btnPing");

      const btnExplain = $("btnExplain");
      const btnSummarize = $("btnSummarize");
      const btnPlan = $("btnPlan");

      const cursorDot = $("nova_cursor_dot");

      // State
      const state = {
        mode: "ask",
        autoEnter: true,
        autoScroll: true,
        cursor: true,
        session: "default",
        history: []
      };

      // Load persisted settings
      try{
        const saved = JSON.parse(localStorage.getItem("nova_ui_state_v1") || "{}");
        Object.assign(state, saved || {});
      }catch(e){}

      function persist(){
        try{
          localStorage.setItem("nova_ui_state_v1", JSON.stringify({
            mode: state.mode,
            autoEnter: state.autoEnter,
            autoScroll: state.autoScroll,
            cursor: state.cursor,
            session: state.session
          }));
        }catch(e){}
      }

      function setToggle(el, on){
        if(on) el.classList.add("on");
        else el.classList.remove("on");
      }

      function showBanner(msg, kind){
        banner.classList.add("show");
        banner.textContent = msg;
        // kind ignored for now (kept simple)
      }
      function hideBanner(){
        banner.classList.remove("show");
        banner.textContent = "";
      }

      function escapeText(s){
        return (s ?? "").toString()
          .replaceAll("&","&amp;")
          .replaceAll("<","&lt;")
          .replaceAll(">","&gt;")
          .replaceAll('"',"&quot;")
          .replaceAll("'","&#039;");
      }

      function addMsg(role, text){
        const box = document.createElement("div");
        box.className = "msg";
        const meta = document.createElement("div");
        meta.className = "meta";

        const left = document.createElement("div");
        left.innerHTML = '<span class="role">'+escapeText(role)+'</span>';

        const right = document.createElement("div");
        const btn = document.createElement("button");
        btn.className = "copyMini";
        btn.textContent = "Copy";
        btn.onclick = async ()=>{
          try{
            await navigator.clipboard.writeText(text || "");
            btn.textContent = "Copied";
            setTimeout(()=>btn.textContent="Copy", 900);
          }catch(e){
            btn.textContent = "Nope";
            setTimeout(()=>btn.textContent="Copy", 900);
          }
        };
        right.appendChild(btn);

        meta.appendChild(left);
        meta.appendChild(right);

        const pre = document.createElement("pre");
        pre.innerHTML = escapeText(text || "");

        box.appendChild(meta);
        box.appendChild(pre);

        messages.appendChild(box);

        if(state.autoScroll){
          messages.scrollTop = messages.scrollHeight + 99999;
        }
      }

      function setMode(m){
        state.mode = m;
        modeLabel.textContent = m;
        document.querySelectorAll(".tab").forEach(t=>{
          t.classList.toggle("active", t.getAttribute("data-mode") === m);
        });
        persist();
      }

      // Tabs
      document.querySelectorAll(".tab").forEach(t=>{
        t.addEventListener("click", ()=> setMode(t.getAttribute("data-mode")));
      });

      // Toggles
      setToggle(togEnter, !!state.autoEnter);
      setToggle(togScroll, !!state.autoScroll);
      setToggle(togCursor, !!state.cursor);

      togEnter.addEventListener("click", ()=>{ state.autoEnter = !state.autoEnter; setToggle(togEnter,state.autoEnter); persist(); });
      togScroll.addEventListener("click", ()=>{ state.autoScroll = !state.autoScroll; setToggle(togScroll,state.autoScroll); persist(); });
      togCursor.addEventListener("click", ()=>{
        state.cursor = !state.cursor;
        setToggle(togCursor,state.cursor);
        if(!state.cursor){ cursorDot.style.display="none"; }
        persist();
      });

      // Session
      sessionBox.value = state.session || "default";
      sessionId.textContent = state.session || "default";
      sessionBox.addEventListener("change", ()=>{
        state.session = (sessionBox.value || "default").trim() || "default";
        sessionId.textContent = state.session;
        persist();
      });

      // Cursor dot
      function installCursor(){
        document.addEventListener("mousemove", (ev)=>{
          if(!state.cursor) return;
          cursorDot.style.display="block";
          cursorDot.style.left = ev.clientX + "px";
          cursorDot.style.top  = ev.clientY + "px";
        }, {passive:true});
        document.addEventListener("mouseleave", ()=>{
          cursorDot.style.display="none";
        }, {passive:true});
      }
      installCursor();

      // Auto-grow textarea
      function autoGrow(){
        input.style.height = "auto";
        input.style.height = Math.min(input.scrollHeight, 180) + "px";
      }

      input.addEventListener("input", ()=>{
        charCount.textContent = String((input.value||"").length);
        autoGrow();
      });

      // Enter-to-send
      input.addEventListener("keydown", (e)=>{
        if(e.key === "Enter" && !e.shiftKey && state.autoEnter){
          e.preventDefault();
          send();
        }
      });

      // Buttons
      btnClear.addEventListener("click", ()=>{
        messages.innerHTML = "";
        hideBanner();
      });

      btnCopyAll.addEventListener("click", async ()=>{
        try{
          const all = Array.from(messages.querySelectorAll(".msg pre")).map(p=>p.textContent).join("\n\n---\n\n");
          await navigator.clipboard.writeText(all);
          btnCopyAll.textContent = "Copied";
          setTimeout(()=>btnCopyAll.textContent="Copy", 900);
        }catch(e){
          btnCopyAll.textContent = "Nope";
          setTimeout(()=>btnCopyAll.textContent="Copy", 900);
        }
      });

      btnPing.addEventListener("click", ()=> pingApi(true));
      btnSend.addEventListener("click", ()=> send());

      // Quick actions (simple prompt helpers)
      btnExplain.addEventListener("click", ()=>{
        addMsg("system", "Quick Action: explain last reply");
        input.value = "Explain your last reply in simpler terms.";
        autoGrow();
        input.focus();
      });
      btnSummarize.addEventListener("click", ()=>{
        addMsg("system", "Quick Action: summarize chat");
        input.value = "Summarize our conversation so far into bullet points.";
        autoGrow();
        input.focus();
      });
      btnPlan.addEventListener("click", ()=>{
        addMsg("system", "Quick Action: make a plan");
        input.value = "Make a step-by-step plan for what we should do next.";
        autoGrow();
        input.focus();
      });

      async function pingApi(verbose){
        dotApi.className = "dot warn";
        apiStatus.textContent = "api: checking…";
        try{
          const r = await fetch("/api/health", { method:"GET" });
          if(r.ok){
            dotApi.className = "dot ok";
            apiStatus.textContent = "api: OK";
            if(verbose) hideBanner();
          }else{
            dotApi.className = "dot bad";
            apiStatus.textContent = "api: " + r.status;
            if(verbose) showBanner("Backend health failed: HTTP " + r.status, "bad");
          }
        }catch(e){
          dotApi.className = "dot bad";
          apiStatus.textContent = "api: down";
          if(verbose) showBanner("Backend not reachable (fetch failed). Is the backend running?", "bad");
        }
      }

      async function send(){
        const text = (input.value || "").trim();
        if(!text){ return; }

        hideBanner();
        addMsg("you", text);
        input.value = "";
        autoGrow();
        charCount.textContent = "0";

        // optimistic assistant placeholder
        addMsg("nova", "…");

        const payload = { text, mode: state.mode };

        try{
          const url = "/api/chat?session_id=" + encodeURIComponent(state.session || "default");
          const res = await fetch(url, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });

          const raw = await res.text();

          // Replace the last "…" message with parsed reply
          const last = messages.querySelector(".msg:last-child pre");
          if(!last){ return; }

          if(!res.ok){
            last.textContent = "HTTP " + res.status + "\n\n" + raw;
            showBanner("Request failed: HTTP " + res.status, "bad");
            return;
          }

          // Nova returns a wrapper that may contain nested JSON as a string
          let out = raw;
          try{
            const j = JSON.parse(raw);
            if(typeof j.reply === "string" && j.reply.trim().startsWith("{")){
              try{
                const inner = JSON.parse(j.reply);
                out = inner.reply || inner.detail || j.reply || raw;
              }catch(e2){
                out = j.reply || raw;
              }
            }else{
              out = j.reply || raw;
            }
          }catch(e3){
            // leave raw
          }

          last.textContent = out || "(empty)";
          if((out||"").includes("invalid_api_key") || (out||"").includes("Incorrect API key")){
            showBanner("Your OpenAI API key is invalid or missing. Create a real key on platform.openai.com and set it in Nova.", "bad");
          }

        }catch(err){
          const last = messages.querySelector(".msg:last-child pre");
          if(last) last.textContent = "Fetch error: " + (err && err.message ? err.message : String(err));
          showBanner("Network error calling /api/chat", "bad");
        }
      }

      // Boot
      setMode(state.mode || "ask");
      pingApi(false);

      // Focus input
      setTimeout(()=>{ try{ input.focus(); }catch(e){} }, 200);
    })();
  </script>
</body>
