  <style>
    :root{
      --bg: #0b1020;
      --panel: rgba(255,255,255,.06);
      --panel2: rgba(255,255,255,.08);
      --stroke: rgba(255,255,255,.12);
      --text: rgba(255,255,255,.92);
      --muted: rgba(255,255,255,.65);
      --muted2: rgba(255,255,255,.45);
      --brand: #7c5cff;
      --brand2:#34d399;
      --danger:#ff4d4f;
      --warn:#fbbf24;
      --ok:#22c55e;
      --shadow: 0 20px 55px rgba(0,0,0,.45);
      --radius2: 22px;
      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      --sans: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
    }
    @media (prefers-color-scheme: light){
      :root{
        --bg:#f7f7fb;
        --panel: rgba(0,0,0,.05);
        --panel2: rgba(0,0,0,.07);
        --stroke: rgba(0,0,0,.10);
        --text: rgba(0,0,0,.88);
        --muted: rgba(0,0,0,.62);
        --muted2: rgba(0,0,0,.45);
        --shadow: 0 20px 55px rgba(0,0,0,.12);
      }
    }
    *{ box-sizing: border-box; }
    html,body{ height:100%; }
    body{
      margin:0;
      background: radial-gradient(1200px 700px at 20% 0%, rgba(124,92,255,.18), transparent 55%),
                  radial-gradient(1000px 650px at 90% 10%, rgba(52,211,153,.12), transparent 55%),
                  var(--bg);
      color: var(--text);
      font-family: var(--sans);
    }
    .app{
      height:100%;
      display:grid;
      grid-template-columns: 260px 1fr;
      gap: 14px;
      padding: 14px;
    }
    .card{
      background: linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.04));
      border: 1px solid var(--stroke);
      border-radius: var(--radius2);
      box-shadow: var(--shadow);
      overflow:hidden;
    }

    /* Sidebar */
    .side{
      display:flex;
      flex-direction:column;
      min-width: 220px;
    }
    .brand{
      padding: 14px 14px 10px 14px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 10px;
      border-bottom: 1px solid var(--stroke);
    }
    .brand .logo{
      display:flex;
      align-items:center;
      gap:10px;
      font-weight: 800;
      letter-spacing:.2px;
    }
    .dot{
      width: 12px; height: 12px; border-radius: 50%;
      background: var(--brand);
      box-shadow: 0 0 0 6px rgba(124,92,255,.18);
    }
    .badge{
      font-size:12px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid var(--stroke);
      color: var(--muted);
      font-family: var(--mono);
      background: rgba(255,255,255,.03);
      white-space: nowrap;
    }
    .nav{
      padding: 10px;
      display:flex;
      flex-direction:column;
      gap:8px;
    }
    .nav button{
      width:100%;
      text-align:left;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
      color: var(--text);
      cursor:pointer;
      font-weight: 650;
    }
    .nav button:hover{ background: rgba(255,255,255,.06); }
    .nav button.active{
      border-color: rgba(124,92,255,.55);
      background: rgba(124,92,255,.14);
    }
    .side .meta{
      margin-top:auto;
      padding: 12px 14px;
      border-top: 1px solid var(--stroke);
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }

    /* Main */
    .main{
      display:flex;
      flex-direction:column;
      min-width: 0;
    }
    .topbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 10px;
      padding: 12px 14px;
      border-bottom: 1px solid var(--stroke);
    }
    .status{
      display:flex;
      align-items:center;
      gap: 10px;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
      flex-wrap: wrap;
    }
    .pill{
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
    }
    .ok{ color: var(--ok); }
    .warn{ color: var(--warn); }
    .danger{ color: var(--danger); }

    .chat{
      display:flex;
      flex-direction:column;
      gap: 10px;
      padding: 14px;
      overflow:auto;
      flex: 1 1 auto;
    }
    .msg{
      display:flex;
      gap: 10px;
      align-items:flex-start;
      max-width: 980px;
    }
    .msg .who{
      width: 34px; height: 34px;
      border-radius: 12px;
      border: 1px solid var(--stroke);
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight: 800;
      font-family: var(--mono);
      background: rgba(255,255,255,.03);
      flex: 0 0 auto;
    }
    .msg.user .who{ background: rgba(52,211,153,.12); border-color: rgba(52,211,153,.35); }
    .msg.ai .who{ background: rgba(124,92,255,.12); border-color: rgba(124,92,255,.35); }

    .bubble{
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
      border-radius: 16px;
      padding: 10px 12px;
      line-height: 1.5;
      color: var(--text);
      white-space: pre-wrap;
      word-wrap: break-word;
      overflow-wrap: anywhere;
      min-width: 0;
    }

    .composer{
      border-top: 1px solid var(--stroke);
      padding: 12px 14px;
      display:grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items:end;
    }
    .leftControls{
      display:flex;
      flex-direction:column;
      gap: 8px;
      min-width: 0;
    }
    textarea{
      width:100%;
      min-height: 54px;
      max-height: 240px;
      resize: none;
      padding: 12px 12px;
      border-radius: 16px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
      color: var(--text);
      outline: none;
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.35;
    }
    textarea:focus{
      border-color: rgba(124,92,255,.55);
      box-shadow: 0 0 0 4px rgba(124,92,255,.16);
    }
    .hintRow{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 10px;
      color: var(--muted);
      font-size: 12px;
      flex-wrap: wrap;
    }
    .toggle{
      display:flex;
      align-items:center;
      gap: 8px;
      user-select:none;
      cursor:pointer;
      font-family: var(--mono);
    }
    .toggle input{ transform: translateY(1px); }
    .send{
      display:flex;
      flex-direction:column;
      gap: 8px;
      align-items: stretch;
      justify-content: flex-end;
    }
    .btn{
      border: 1px solid rgba(124,92,255,.5);
      background: linear-gradient(180deg, rgba(124,92,255,.28), rgba(124,92,255,.18));
      color: var(--text);
      padding: 10px 14px;
      border-radius: 16px;
      cursor:pointer;
      font-weight: 800;
      letter-spacing:.2px;
      min-width: 120px;
    }
    .btn:hover{ filter: brightness(1.06); }
    .btn:disabled{
      opacity: .55;
      cursor: not-allowed;
      filter:none;
    }
    .smallBtn{
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
      color: var(--muted);
      padding: 8px 10px;
