      font-size: 12px;
    }
    .smallBtn:hover{ background: rgba(255,255,255,.06); }

    .mono{ font-family: var(--mono); }

    @media (max-width: 940px){
      .app{ grid-template-columns: 1fr; }
      .side{ display:none; }
    }
