<body>
  <div class="app">
    <aside class="card side">
      <div class="brand">
        <div class="logo"><span class="dot"></span><span>Nova</span></div>
        <div class="badge" id="buildStamp">UI</div>
      </div>

      <div class="nav">
        <button class="active" data-mode="ask">Ask</button>
        <button data-mode="command">Command</button>
        <button data-mode="doctor">Doctor</button>
      </div>

      <div class="meta">
        <div class="mono">Backend: /api/*</div>
        <div class="mono">UI: this page</div>
        <div style="margin-top:8px;">If the page loads but Send does nothing, it’s a broken handler — this build fixes that.</div>
      </div>
    </aside>

    <main class="card main">
      <div class="topbar">
        <div class="status">
          <span class="pill">status: <span id="statusText" class="ok">ready</span></span>
          <span class="pill">mode: <span id="modeText">ask</span></span>
          <span class="pill">session: <span id="sessionText">…</span></span>
        </div>
        <div style="display:flex; gap:8px; align-items:center;">
          <button class="smallBtn" id="clearBtn">Clear</button>
          <button class="smallBtn" id="pingBtn">Ping</button>
        </div>
      </div>

      <div id="chat" class="chat" aria-live="polite"></div>

      <div class="composer">
        <div class="leftControls">
          <textarea id="input" placeholder="Type here…" spellcheck="false"></textarea>
          <div class="hintRow">
            <div>Enter = send &nbsp; • &nbsp; Shift+Enter = newline</div>
            <label class="toggle" title="If enabled, pressing Enter will send (Shift+Enter makes a newline).">
              <input id="autoSend" type="checkbox" />
              <span>Auto-send on Enter</span>
            </label>
          </div>
        </div>

        <div class="send">
          <button class="btn" id="sendBtn">Send</button>
        </div>
      </div>
    </main>
  </div>

  <script>
  (function(){
    "use strict";

    const $ = (sel) => document.querySelector(sel);

    const chatEl = $("#chat");
    const inputEl = $("#input");
    const sendBtn = $("#sendBtn");
    const clearBtn = $("#clearBtn");
    const pingBtn = $("#pingBtn");
    const autoSendEl = $("#autoSend");

    const statusText = $("#statusText");
    const modeText = $("#modeText");
    const sessionText = $("#sessionText");
    const buildStamp = $("#buildStamp");

    // Stable session id per browser tab (persisted)
    const LS_SESSION = "NOVA_SESSION_ID_V1";
    const LS_AUTOSEND = "NOVA_AUTOSEND_V1";
    const LS_MODE = "NOVA_MODE_V1";

    function uuid8(){
      return Math.random().toString(16).slice(2,10);
    }

    let sessionId = localStorage.getItem(LS_SESSION) || ("ui_" + uuid8() + uuid8());
    localStorage.setItem(LS_SESSION, sessionId);

    let mode = localStorage.getItem(LS_MODE) || "ask";
    let busy = false;

    function setStatus(text, cls){
      statusText.textContent = text;
      statusText.className = cls || "";
    }

    function scrollDown(){
      try{
        chatEl.scrollTop = chatEl.scrollHeight;
      }catch(e){}
    }

    function addMsg(role, text){
      const wrap = document.createElement("div");
      wrap.className = "msg " + (role === "user" ? "user" : "ai");

      const who = document.createElement("div");
      who.className = "who";
      who.textContent = role === "user" ? "U" : "N";

      const bubble = document.createElement("div");
      bubble.className = "bubble";
      bubble.textContent = text;

      wrap.appendChild(who);
      wrap.appendChild(bubble);
      chatEl.appendChild(wrap);
      scrollDown();
      return bubble;
    }

    async function postChat(text){
      // IMPORTANT: This matches the console test that worked for you.
      const url = "/api/chat?session_id=" + encodeURIComponent(sessionId);
      const body = { text: text };

      const r = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body)
      });

      const raw = await r.text();
      let data = null;
      try{ data = JSON.parse(raw); }catch(e){}

      if(!r.ok){
        const msg = (data && (data.error || data.detail)) ? (data.error || data.detail) : raw;
        const err = new Error("HTTP " + r.status + " " + msg);
        err.status = r.status;
        err.body = raw;
        throw err;
      }
      if(data && data.reply !== undefined) return data.reply;
      // fallback if server returns plain text
      return raw;
    }

    function setBusy(v){
      busy = !!v;
      sendBtn.disabled = busy;
      inputEl.disabled = busy;
    }

    async function send(){
      const text = (inputEl.value || "").trim();
      if(!text || busy) return;

      addMsg("user", text);
      inputEl.value = "";
      autoGrow();

      setBusy(true);
      setStatus("thinking…", "warn");

      // show placeholder AI bubble immediately
      const aiBubble = addMsg("ai", "…");

      try{
        // optional: prepend mode commands (if your backend uses /ask /cmd etc later)
        let payload = text;
        if(mode === "command" && !text.startsWith("/")) payload = "/cmd " + text;
        if(mode === "doctor" && !text.startsWith("/")) payload = "/doctor " + text;

        const reply = await postChat(payload);
        aiBubble.textContent = reply;
        setStatus("ready", "ok");
      }catch(err){
        console.error("SEND ERROR:", err);
        aiBubble.textContent = "Error: " + (err && err.message ? err.message : String(err));
        setStatus("error", "danger");
      }finally{
        setBusy(false);
        try{ inputEl.focus(); }catch(e){}
        scrollDown();
      }
    }

    function autoGrow(){
      try{
        inputEl.style.height = "auto";
        inputEl.style.height = Math.min(240, inputEl.scrollHeight) + "px";
      }catch(e){}
    }

    function bindNav(){
      const buttons = document.querySelectorAll(".nav button[data-mode]");
      buttons.forEach(btn => {
        btn.addEventListener("click", () => {
          buttons.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          mode = btn.getAttribute("data-mode") || "ask";
          localStorage.setItem(LS_MODE, mode);
          modeText.textContent = mode;
          try{ inputEl.focus(); }catch(e){}
        });
      });
    }

    function init(){
      buildStamp.textContent = "UI V3";
      sessionText.textContent = sessionId;
      modeText.textContent = mode;

      // autosend setting
      const as = localStorage.getItem(LS_AUTOSEND);
      autoSendEl.checked = (as === "1");
      autoSendEl.addEventListener("change", () => {
        localStorage.setItem(LS_AUTOSEND, autoSendEl.checked ? "1" : "0");
      });

      // core handlers
      sendBtn.addEventListener("click", send);

      inputEl.addEventListener("input", autoGrow);

      inputEl.addEventListener("keydown", (ev) => {
  // Enter sends, Shift+Enter makes a newline
  if(ev.key === "Enter" && !ev.shiftKey){
    ev.preventDefault();
    send();
  }
});clearBtn.addEventListener("click", () => {
        chatEl.innerHTML = "";
        setStatus("cleared", "ok");
        try{ inputEl.focus(); }catch(e){}
      });

      pingBtn.addEventListener("click", async () => {
        try{
          setStatus("ping…", "warn");
          const r = await fetch("/api/health");
          const t = await r.text();
          setStatus(r.ok ? "ready" : "error", r.ok ? "ok" : "danger");
          addMsg("ai", "Ping /api/health -> HTTP " + r.status + "\n" + t);
        }catch(e){
          setStatus("error", "danger");
          addMsg("ai", "Ping failed: " + (e && e.message ? e.message : String(e)));
        }
      });

      bindNav();

      // welcome
      addMsg("ai", "Nova UI is live. Type a message and press Send.\n(Enter-to-send works if Auto-send is enabled.)");
      autoGrow();
      try{ inputEl.focus(); }catch(e){}
      setStatus("ready", "ok");
    }

    // start
    if(document.readyState === "loading"){
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
  </script>
</body>
</html>


