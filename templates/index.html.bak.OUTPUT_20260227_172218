    <script>
      (function(){
        const $ = (id)=>document.getElementById(id);

        // Robust fallbacks (in case ids ever change)
        function q(sel){ return document.querySelector(sel); }
        function elInput(){ return $("input") || q("#input") || q("textarea") || q('input[type="text"]'); }
        function elSend(){ return $("sendBtn") || q("#sendBtn") || q("button.btn") || q("button"); }
        function elLog(){ return $("log") || q("#log") || q(".log") || document.body; }

        const log = elLog();
        const input = elInput();
        const sendBtn = elSend();

        const autoSend = $("autoSend");
        const autoScroll = $("autoScroll");
        const circly = $("circly");
        const sessionId = $("sessionId");
        const statusText = $("statusText");
        const modeText = $("modeText");
        const healthLed = $("healthLed");
        const healthText = $("healthText");
        const copyLastBtn = $("copyLastBtn");

        let aborter = null;
        let lastReply = "";

        function nowTime(){
          const d = new Date();
          return d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
        }

        function append(role, text){
          const m = document.createElement("div");
          m.className = "msg " + (role === "YOU" ? "you" : "nova");

          const meta = document.createElement("div");
          meta.className = "meta";
          meta.innerHTML = `<span>${role}</span><span>${nowTime()}</span>`;

          const body = document.createElement("div");
          body.textContent = text;

          m.appendChild(meta);
          m.appendChild(body);
          log.appendChild(m);

          if(autoScroll && autoScroll.checked){
            m.scrollIntoView({block:"end"});
          }
        }

        async function uiHealth(){
          try{
            const r = await fetch("/api/health", { cache: "no-store" });
            const j = await r.json();
            healthText.textContent = j.ok ? "ok" : "down";
            healthLed.classList.toggle("ok", !!j.ok);
            statusText.textContent = j.ok ? "ready" : "down";
          }catch(e){
            healthText.textContent = "down";
            healthLed.classList.remove("ok");
            statusText.textContent = "down";
          }
        }

        function getSession(){
          const v = (sessionId && sessionId.value || "default").trim();
          return v || "default";
        }

        function getKey(){
          // Browser-side key storage (optional). If empty, server may still allow local use.
          return (localStorage.getItem("NOVA_API_KEY") || "").trim();
        }

        async function send(){
          if(!input) return;
          const raw = (input.value || "").trim();
          if(!raw) return;

          // strip any [MODE:...] if it exists
          const cleaned = raw.replace(/\[MODE:[^\]]*\]\s*/g, "").trim();

          append("YOU", cleaned);
          input.value = "";
          input.focus();

          if(aborter){ try{ aborter.abort(); }catch(e){} }
          aborter = new AbortController();

          sendBtn && (sendBtn.disabled = true);
          statusText.textContent = "thinking…";

          try{
            const sid = encodeURIComponent(getSession());
            const key = getKey();

            const payload = { text: cleaned, mode: "chat" };

            const r = await fetch(`/api/chat?session_id=${sid}`, {
              method:"POST",
              headers: Object.assign(
                { "Content-Type":"application/json" },
                (key ? { "x-api-key": key } : {})
              ),
              body: JSON.stringify(payload),
              signal: aborter.signal
            });

            const j = await r.json();

            // works with either backend format:
            // Flask test: {message:"Bot: hi"}
            // Nova backend: {reply:"..."}
            const reply = String((j && (j.message ?? j.reply ?? "")) || "");

            lastReply = reply;
            append("NOVA", reply || JSON.stringify(j