  <style>
    :root{
      --bg: #0b1020;
      --panel: rgba(255,255,255,.06);
      --panel2: rgba(255,255,255,.08);
      --stroke: rgba(255,255,255,.12);
      --text: rgba(255,255,255,.92);
      --muted: rgba(255,255,255,.65);
      --muted2: rgba(255,255,255,.45);
      --brand: #7c5cff;
      --brand2:#34d399;
      --danger:#ff4d4f;
      --warn:#fbbf24;
      --ok:#22c55e;
      --shadow: 0 20px 55px rgba(0,0,0,.45);
      --radius2: 22px;
      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      --sans: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
    }
    @media (prefers-color-scheme: light){
      :root{
        --bg:#f7f7fb;
        --panel: rgba(0,0,0,.05);
        --panel2: rgba(0,0,0,.07);
        --stroke: rgba(0,0,0,.10);
        --text: rgba(0,0,0,.88);
        --muted: rgba(0,0,0,.62);
        --muted2: rgba(0,0,0,.45);
        --shadow: 0 18px 45px rgba(0,0,0,.12);
      }
    }
    *{ box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      margin:0;
      background: radial-gradient(1200px 800px at 25% 20%, rgba(124,92,255,.22), transparent 55%),
                  radial-gradient(900px 700px at 75% 30%, rgba(52,211,153,.16), transparent 60%),
                  var(--bg);
      color: var(--text);
      font-family: var(--sans);
    }
    .wrap{
      max-width: 1100px;
      margin: 0 auto;
      padding: 18px 14px 22px;
      display:flex;
      flex-direction:column;
      gap: 14px;
      min-height:100%;
    }
    .topbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding: 14px 14px;
      border: 1px solid var(--stroke);
      border-radius: var(--radius2);
      background: linear-gradient(180deg, var(--panel2), var(--panel));
      box-shadow: var(--shadow);
    }
    .brand{
      display:flex; align-items:center; gap:10px;
      font-weight: 800;
      letter-spacing:.2px;
    }
    .dot{
      width:10px; height:10px; border-radius:999px;
      background: var(--brand2);
      box-shadow: 0 0 0 6px rgba(52,211,153,.12);
    }
    .pills{ display:flex; gap:8px; align-items:center; flex-wrap:wrap; justify-content:flex-end; }
    .pill{
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 12px;
      color: var(--muted);
      display:flex; align-items:center; gap:8px;
    }
    .pill strong{ color: var(--text); font-weight:700; }
    .grid{
      display:grid;
      grid-template-columns: 1.35fr .65fr;
      gap: 14px;
      flex: 1 1 auto;
      min-height: 0;
    }
    @media (max-width: 980px){
      .grid{ grid-template-columns: 1fr; }
    }
    .card{
      border: 1px solid var(--stroke);
      border-radius: var(--radius2);
      background: linear-gradient(180deg, var(--panel2), var(--panel));
      box-shadow: var(--shadow);
      min-height: 0;
      overflow:hidden;
    }
    .cardHd{
      padding: 12px 14px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      border-bottom: 1px solid var(--stroke);
    }
    .cardHd .title{
      font-weight: 800;
      letter-spacing:.2px;
    }
    .cardBd{ padding: 12px 14px; min-height:0; }

    /* Chat */
    .chat{
      display:flex;
      flex-direction:column;
      height: 100%;
      min-height: 0;
    }
    .log{
      flex:1 1 auto;
      min-height: 0;
      overflow:auto;
      padding: 12px 14px;
      display:flex;
      flex-direction:column;
      gap: 10px;
    }
    .msg{
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
      border-radius: 16px;
      padding: 10px 12px;
      white-space: pre-wrap;
      word-break: break-word;
      line-height: 1.25rem;
    }
    .msg.you{
      border-color: rgba(124,92,255,.35);
      background: rgba(124,92,255,.10);
    }
    .msg.nova{
      border-color: rgba(52,211,153,.35);
      background: rgba(52,211,153,.08);
    }
    .msg .meta{
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 6px;
      display:flex;
      justify-content:space-between;
      gap:10px;
      font-family: var(--mono);
    }
    .composer{
      border-top: 1px solid var(--stroke);
      padding: 12px 14px;
      display:flex;
      gap: 10px;
      align-items:flex-end;
      background: rgba(0,0,0,.08);
    }
    textarea{
      width: 100%;
      resize: none;
      min-height: 44px;
      max-height: 180px;
      border-radius: 16px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
      color: var(--text);
      padding: 10px 12px;
      outline: none;
      font-family: var(--sans);
      line-height: 1.25rem;
    }
    textarea:focus{ border-color: rgba(124,92,255,.55); }
    .btn{
      border: 1px solid var(--stroke);
      background: linear-gradient(180deg, rgba(124,92,255,.18), rgba(124,92,255,.10));
      color: var(--text);
      padding: 10px 14px;
      border-radius: 16px;
      cursor:pointer;
      font-weight: 800;
      user-select:none;
      min-width: 98px;
    }
    .btn:active{ transform: translateY(1px); }
    .btn[disabled]{ opacity:.55; cursor:not-allowed; }

    /* Sidebar settings */
    .row{ display:flex; align-items:center; justify-content:space-between; gap:12px; padding: 10px 0; border-bottom: 1px solid var(--stroke); }
    .row:last-child{ border-bottom:0; }
    .row .label{ font-weight: 700; }
    .row small{ display:block; color: var(--muted); margin-top:4px; }
    .toggle{
      display:flex; align-items:center; gap:10px;
      font-family: var(--mono);
      color: var(--muted);
      font-size: 12px;
    }
    input[type="checkbox"]{ width: 18px; height: 18px; accent-color: var(--brand); cursor:pointer; }
    input[type="text"]{
      width: 100%;
      border-radius: 14px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
      color: var(--text);
      padding: 10px 12px;
      outline:none;
      font-family: var(--mono);
    }
    .hint{
      color: var(--muted);
      font-size: 12px;
      font-family: var(--mono);
      padding-top: 10px;
    }
    .statusLine{
      font-family: var(--mono);
      color: var(--muted);
      font-size: 12px;
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }
    .statusBadge{
      display:inline-flex; align-items:center; gap:8px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
    }
    .led{
      width:8px; height:8px; border-radius:999px; background: var(--warn);
      box-shadow: 0 0 0 6px rgba(251,191,36,.12);
    }
    .led.ok{ background: var(--ok); box-shadow: 0 0 0 6px rgba(34,197,94,.12); }
    .copyBtn{
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.03);
      color: var(--muted);
      border-radius: 12px;
      padding: 6px 10px;
      cursor:pointer;
      font-family: var(--mono);
      font-size: 12px;
    }
    .copyBtn:hover{ color: var(--text); }
  </style>
