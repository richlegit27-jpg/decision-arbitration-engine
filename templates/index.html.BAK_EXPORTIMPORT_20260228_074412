  <div id="toast" class="toast">OK</div>

  <script>
  (function(){
    "use strict";

    const $ = (sel) => document.querySelector(sel);

    const chatEl = $("#chat");
    const inputEl = $("#input");
    const sendBtn = $("#sendBtn");
    const clearBtn = $("#clearBtn");
    const pingBtn = $("#pingBtn");
    const autoSendEl = $("#autoSend");

    const statusText = $("#statusText");
    const modeText = $("#modeText");
    const sessionText = $("#sessionText");
    const buildStamp = $("#buildStamp");
    const latencyPill = $("#latencyPill");
    const toastEl = $("#toast");

    const sessionSelect = $("#sessionSelect");
    const newSessBtn = $("#newSessBtn");
    const renameSessBtn = $("#renameSessBtn");
    const deleteSessBtn = $("#deleteSessBtn");

    // ---- Storage Keys
    const LS_AUTOSEND = "NOVA_AUTOSEND_V1";
    const LS_MODE = "NOVA_MODE_V1";
    const LS_DRAFT = "NOVA_DRAFT_V1";

    const LS_SESSIONS = "NOVA_WORKSPACE_SESSIONS_V1"; // array of sessions
    const LS_ACTIVE = "NOVA_WORKSPACE_ACTIVE_V1";     // active session id

    // ---- Session shape:
    // { id: string, name: string, created: number, updated: number, messages: [{role:'user'|'ai', text:string, ts:number}] }

    let mode = localStorage.getItem(LS_MODE) || "ask";
    let busy = false;

    let sessions = [];
    let activeId = null;

    function now(){ return Date.now(); }
    function uuid(){
      return "s_" + Math.random().toString(16).slice(2,10) + Math.random().toString(16).slice(2,10);
    }

    function toast(msg){
      try{
        toastEl.textContent = msg || "OK";
        toastEl.classList.add("show");
        clearTimeout(toastEl.__t);
        toastEl.__t = setTimeout(() => toastEl.classList.remove("show"), 900);
      }catch(e){}
    }

    function setStatus(text, cls){
      statusText.textContent = text;
      statusText.className = cls || "";
    }

    function setLatency(ms){
      if(typeof ms === "number" && isFinite(ms)) latencyPill.textContent = "lat: " + Math.round(ms) + "ms";
      else latencyPill.textContent = "lat: —";
    }

    function scrollDown(){ try{ chatEl.scrollTop = chatEl.scrollHeight; }catch(e){} }

    function setBusy(v){
      busy = !!v;
      sendBtn.disabled = busy;
      inputEl.disabled = busy;
    }

    function autoGrow(){
      try{
        inputEl.style.height = "auto";
        inputEl.style.height = Math.min(240, inputEl.scrollHeight) + "px";
      }catch(e){}
    }

    function saveDraft(){
      try{ localStorage.setItem(LS_DRAFT, inputEl.value || ""); }catch(e){}
    }

    function loadDraft(){
      try{
        const d = localStorage.getItem(LS_DRAFT);
        if(typeof d === "string") inputEl.value = d;
      }catch(e){}
    }

    // ---- Session persistence
    function loadSessions(){
      try{
        const raw = localStorage.getItem(LS_SESSIONS);
        const arr = raw ? JSON.parse(raw) : [];
        sessions = Array.isArray(arr) ? arr : [];
      }catch(e){
        sessions = [];
      }

      // sanitize
      sessions = sessions
        .filter(s => s && typeof s.id === "string")
        .map(s => ({
          id: String(s.id),
          name: typeof s.name === "string" ? s.name : "Session",
          created: +s.created || now(),
          updated: +s.updated || +s.created || now(),
          messages: Array.isArray(s.messages) ? s.messages.filter(m => m && (m.role==="user"||m.role==="ai") && typeof m.text==="string").map(m => ({role:m.role, text:m.text, ts:+m.ts||now()})) : []
        }));

      // active
      activeId = localStorage.getItem(LS_ACTIVE);
      if(!activeId || !sessions.some(s => s.id === activeId)){
        activeId = sessions.length ? sessions[0].id : null;
      }

      if(!sessions.length){
        const s = newSession("Welcome");
        sessions = [s];
        activeId = s.id;
        saveSessions();
      } else {
        saveSessions(); // normalize
      }
    }

    function saveSessions(){
      try{ localStorage.setItem(LS_SESSIONS, JSON.stringify(sessions)); }catch(e){}
      try{ localStorage.setItem(LS_ACTIVE, activeId || ""); }catch(e){}
    }

    function getActive(){
      return sessions.find(s => s.id === activeId) || null;
    }

    function newSession(name){
      const t = now();
      return {
        id: uuid(),
        name: (name && String(name).trim()) ? String(name).trim() : ("Session " + new Date(t).toLocaleString()),
        created: t,
        updated: t,
        messages: []
      };
    }

    function rebuildSessionSelect(){
      const act = getActive();
      sessionSelect.innerHTML = "";
      // newest first
      const sorted = [...sessions].sort((a,b)=> (b.updated||0)-(a.updated||0));

      for(const s of sorted){
        const opt = document.createElement("option");
        opt.value = s.id;
        opt.textContent = s.name;
        if(act && s.id === act.id) opt.selected = true;
        sessionSelect.appendChild(opt);
      }
    }

    function renderMessages(){
      chatEl.innerHTML = "";
      const act = getActive();
      if(!act) return;

      for(const m of act.messages){
        addMsgDom(m.role, m.text, false);
      }
      scrollDown();
    }

    function addMsgDom(role, text, save=true){
      const wrap = document.createElement("div");
      wrap.className = "msg " + (role === "user" ? "user" : "ai");

      const who = document.createElement("div");
      who.className = "who";
      who.textContent = role === "user" ? "U" : "N";

      const bubbleWrap = document.createElement("div");
      bubbleWrap.className = "bubbleWrap";

      const bubble = document.createElement("div");
      bubble.className = "bubble";
      bubble.textContent = text;

      bubbleWrap.appendChild(bubble);

      if(role === "ai"){
        const actions = document.createElement("div");
        actions.className = "actions";

        const copyBtn = document.createElement("button");
        copyBtn.className = "aBtn";
        copyBtn.type = "button";
        copyBtn.textContent = "Copy";
        copyBtn.addEventListener("click", async () => {
          try{
            await navigator.clipboard.writeText(bubble.textContent || "");
            toast("Copied");
          }catch(e){
            try{
              const ta = document.createElement("textarea");
              ta.value = bubble.textContent || "";
              document.body.appendChild(ta);
              ta.select();
              document.execCommand("copy");
              ta.remove();
              toast("Copied");
            }catch(e2){
              toast("Copy failed");
            }
          }
        });

        actions.appendChild(copyBtn);
        bubbleWrap.appendChild(actions);
      }

      wrap.appendChild(who);
      wrap.appendChild(bubbleWrap);
      chatEl.appendChild(wrap);
      scrollDown();

      if(save){
        const act = getActive();
        if(act){
          act.messages.push({ role, text, ts: now() });
          act.updated = now();
          saveSessions();
          rebuildSessionSelect();
        }
      }

      return bubble;
    }

    // ---- Backend call (non-stream, stable)
    async function postChat(text){
      const act = getActive();
      const sid = act ? act.id : "ui";
      const url = "/api/chat?session_id=" + encodeURIComponent(sid);

      const r = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ text })
      });

      const raw = await r.text();
      let data = null;
      try{ data = JSON.parse(raw); }catch(e){}

      if(!r.ok){
        const msg = (data && (data.error || data.detail)) ? (data.error || data.detail) : raw;
        const err = new Error("HTTP " + r.status + " " + msg);
        err.status = r.status;
        err.body = raw;
        throw err;
      }
      if(data && data.reply !== undefined) return data.reply;
      return raw;
    }

    async function send(){
      const text0 = (inputEl.value || "");
      const text = text0.trim();
      if(!text || busy) return;

      addMsgDom("user", text, true);
      inputEl.value = "";
      saveDraft();
      autoGrow();

      setBusy(true);
      setStatus("thinking…", "warn");
      setLatency(null);

      const aiBubble = addMsgDom("ai", "…", true);
      const t0 = performance.now();

      try{
        let payload = text;
        if(mode === "command" && !text.startsWith("/")) payload = "/cmd " + text;
        if(mode === "doctor" && !text.startsWith("/")) payload = "/doctor " + text;

        const reply = await postChat(payload);

        // Replace last AI message text in storage AND in DOM
        aiBubble.textContent = reply;

        const act = getActive();
        if(act && act.messages.length){
          // last message should be AI placeholder; update it
          for(let i=act.messages.length-1; i>=0; i--){
            if(act.messages[i].role === "ai"){
              act.messages[i].text = reply;
              act.messages[i].ts = now();
              act.updated = now();
              break;
            }
          }
          saveSessions();
          rebuildSessionSelect();
        }

        setLatency(performance.now() - t0);
        setStatus("ready", "ok");
      }catch(err){
        console.error("SEND ERROR:", err);
        aiBubble.textContent = "Error: " + (err && err.message ? err.message : String(err));

        const act = getActive();
        if(act && act.messages.length){
          for(let i=act.messages.length-1; i>=0; i--){
            if(act.messages[i].role === "ai"){
              act.messages[i].text = aiBubble.textContent;
              act.messages[i].ts = now();
              act.updated = now();
              break;
            }
          }
          saveSessions();
          rebuildSessionSelect();
        }

        setStatus("error", "danger");
      }finally{
        setBusy(false);
        try{ inputEl.focus(); }catch(e){}
        scrollDown();
      }
    }

    function bindNav(){
      const buttons = document.querySelectorAll(".nav button[data-mode]");
      buttons.forEach(btn => {
        btn.addEventListener("click", () => {
          buttons.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          mode = btn.getAttribute("data-mode") || "ask";
          localStorage.setItem(LS_MODE, mode);
          modeText.textContent = mode;
          try{ inputEl.focus(); }catch(e){}
        });
      });
    }

    function applyAutosend(){
      const as = localStorage.getItem(LS_AUTOSEND);
      if(as === null){
        localStorage.setItem(LS_AUTOSEND, "1");
        autoSendEl.checked = true;
      } else {
        autoSendEl.checked = (as === "1");
      }
      autoSendEl.addEventListener("change", () => {
        localStorage.setItem(LS_AUTOSEND, autoSendEl.checked ? "1" : "0");
      });
    }

    function setActiveSession(id){
      if(!id || !sessions.some(s => s.id === id)) return;
      activeId = id;
      saveSessions();
      rebuildSessionSelect();
      const act = getActive();
      sessionText.textContent = act ? act.id : "…";
      renderMessages();
      setStatus("ready", "ok");
      setLatency(null);
    }

    function init(){
      buildStamp.textContent = "WORKSPACE V1";
      modeText.textContent = mode;

      loadSessions();
      rebuildSessionSelect();

      const act = getActive();
      sessionText.textContent = act ? act.id : "…";

      applyAutosend();
      loadDraft();

      // render active session messages
      renderMessages();

      // If empty session, seed with a welcome message once
      if(act && (!act.messages || !act.messages.length)){
        addMsgDom("ai", "Workspace sessions are live.\n- Use the dropdown to switch sessions.\n- New creates a fresh context.\n- Rename/ Delete manage your workspace.\nAll stored locally in this browser.", true);
      }

      // UI handlers
      sendBtn.addEventListener("click", send);

      inputEl.addEventListener("input", () => { autoGrow(); saveDraft(); });

      inputEl.addEventListener("keydown", (ev) => {
        if(ev.key === "Enter" && !ev.shiftKey){
          if(autoSendEl.checked){
            ev.preventDefault();
            send();
            return;
          }
        }
        if(ev.key === "Escape"){
          ev.preventDefault();
          inputEl.value = "";
          saveDraft();
          autoGrow();
          return;
        }
      });

      document.addEventListener("keydown", (ev) => {
        if((ev.ctrlKey || ev.metaKey) && (ev.key === "k" || ev.key === "K")){
          ev.preventDefault();
          try{ inputEl.focus(); }catch(e){}
        }
      }, { passive:false });

      clearBtn.addEventListener("click", () => {
        // Clear only the current session messages
        const act = getActive();
        if(act){
          act.messages = [];
          act.updated = now();
          saveSessions();
        }
        chatEl.innerHTML = "";
        setStatus("cleared", "ok");
        setLatency(null);
        toast("Cleared session");
        try{ inputEl.focus(); }catch(e){}
        rebuildSessionSelect();
      });

      pingBtn.addEventListener("click", async () => {
        try{
          setStatus("ping…", "warn");
          const r = await fetch("/api/health");
          const t = await r.text();
          setStatus(r.ok ? "ready" : "error", r.ok ? "ok" : "danger");
          addMsgDom("ai", "Ping /api/health -> HTTP " + r.status + "\n" + t, true);
        }catch(e){
          setStatus("error", "danger");
          addMsgDom("ai", "Ping failed: " + (e && e.message ? e.message : String(e)), true);
        }
      });

      sessionSelect.addEventListener("change", () => {
        const id = sessionSelect.value;
        setActiveSession(id);
      });

      newSessBtn.addEventListener("click", () => {
        const name = prompt("New session name:", "New Session");
        const s = newSession(name || "New Session");
        sessions.push(s);
        activeId = s.id;
        saveSessions();
        rebuildSessionSelect();
        setActiveSession(s.id);
        toast("New session");
      });

      renameSessBtn.addEventListener("click", () => {
        const act = getActive();
        if(!act) return;
        const name = prompt("Rename session:", act.name);
        if(name === null) return;
        act.name = (String(name).trim() || act.name);
        act.updated = now();
        saveSessions();
        rebuildSessionSelect();
        toast("Renamed");
      });

      deleteSessBtn.addEventListener("click", () => {
        const act = getActive();
        if(!act) return;
        const ok = confirm("Delete session '" + act.name + "'? This cannot be undone.");
        if(!ok) return;

        sessions = sessions.filter(s => s.id !== act.id);
        if(!sessions.length){
          const s = newSession("Welcome");
          sessions = [s];
          activeId = s.id;
        } else {
          // pick newest
          sessions.sort((a,b)=>(b.updated||0)-(a.updated||0));
          activeId = sessions[0].id;
        }
        saveSessions();
        rebuildSessionSelect();
        setActiveSession(activeId);
        toast("Deleted");
      });

      bindNav();
      autoGrow();
      try{ inputEl.focus(); }catch(e){}
      setStatus("ready", "ok");
      setLatency(null);
    }

    if(document.readyState === "loading"){
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
  </script>
</body>
</html>
