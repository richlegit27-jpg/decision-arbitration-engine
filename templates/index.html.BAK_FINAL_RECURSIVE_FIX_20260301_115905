<script>
/* === NOVA_SUMMARY_DELEGATED_BIND_V1 ===
   Scope-free controller that survives DOM cloning by using event delegation.
*/
(function(){
  function $(id){ return document.getElementById(id); }

  function authHeaders(){
    try{
      if(typeof window.NOVA_AUTH_HEADERS === "function"){
        var h = window.NOVA_AUTH_HEADERS();
        if(h && typeof h === "object") return h;
      }
    }catch(e){}
    return {};
  }

  function buildHeaders(){
    var h = { "Content-Type":"application/json" };
    try{
      var a = authHeaders();
      for(var k in a){ try{ h[k]=a[k]; }catch(e){} }
    }catch(e){}
    return h;
  }

  function setOut(msg){
    var out = $("novaSummaryOut");
    if(out) out.textContent = String(msg || "");
  }

  function getOrCreateSessionId(){
    // URL ?session_id=...
    try{
      var u = new URL(location.href);
      var sid = (u.searchParams.get("session_id") || "").trim();
      if(sid) return sid;
    }catch(e){}
    // localStorage
    try{
      var sid2 = (localStorage.getItem("nova_session_id") || "").trim();
      if(sid2) return sid2;
    }catch(e){}
    // new
    var s = "s_" + Math.random().toString(16).slice(2) + "_" + Date.now().toString(16);
    try{ localStorage.setItem("nova_session_id", s); }catch(e){}
    return s;
  }

  function setSessionId(sid){
    sid = String(sid||"").trim();
    if(!sid) return;
    try{
      localStorage.setItem("nova_session_id", sid);
    }catch(e){}
    try{
      var u = new URL(location.href);
      u.searchParams.set("session_id", sid);
      history.replaceState(null, "", u.toString());
    }catch(e){}
  }

  async function fetchJsonTry(url, opts){
    try{
      var r = await fetch(url, opts || {});
      var txt = await r.text();
      var data = null;
      try{ data = JSON.parse(txt); }catch(e){ data = { _raw: txt }; }
      return { ok:r.ok, status:r.status, data:data, url:url };
    }catch(e){
      return { ok:false, status:0, data:{ error:String(e && e.message || e) }, url:url };
    }
  }

  async function loadSessions(){
    var sel = $("novaSessionList");
    if(sel){
      try{ sel.innerHTML = '<option value="">(loading...)</option>'; }catch(e){}
    }
    setOut("Loading sessions list...");

    // Try a few common endpoints until one works
    var candidates = [
      "/api/sessions",
      "/api/session/sessions",
      "/api/session/list",
      "/api/sessions/list"
    ];

    var best = null;
    for(var i=0;i<candidates.length;i++){
      var res = await fetchJsonTry(candidates[i], { method:"GET", headers: authHeaders() });
      if(res.ok){
        best = res; break;
      }
      if(!best) best = res;
    }

    if(!best || !best.ok){
      setOut("ERROR " + (best ? best.status : "?") + " loading sessions: " + JSON.stringify(best ? best.data : {}));
      if(sel) sel.innerHTML = '<option value="">(failed to load)</option>';
      return [];
    }

    var data = best.data || {};
    var sessions = [];
    if(Array.isArray(data.sessions)) sessions = data.sessions;
    else if(data.content && Array.isArray(data.content.sessions)) sessions = data.content.sessions;
    else if(Array.isArray(data)) sessions = data;

    // Normalize to strings
    var ids = [];
    for(var j=0;j<sessions.length;j++){
      var s = sessions[j];
      if(typeof s === "string") ids.push(s);
      else if(s && typeof s === "object"){
        if(s.session_id) ids.push(String(s.session_id));
        else if(s.id) ids.push(String(s.id));
      }
    }

    if(sel){
      var opts = ['<option value="">(select a session)</option>'];
      for(var k=0;k<ids.length;k++){
        var sid = ids[k];
        opts.push('<option value="' + sid.replace(/"/g,"&quot;") + '">' + sid + '</option>');
      }
      sel.innerHTML = opts.join("");
    }

    setOut("Loaded " + ids.length + " sessions.");
    return ids;
  }

  async function fetchSummary(){
    var out = $("novaSummaryOut");
    var sidEl = $("novaSessionId");
    var sid = "";

    try{
      if(sidEl) sid = (sidEl.value || "").trim();
    }catch(e){}

    if(!sid){
      // If dropdown selected, use it
      try{
        var sel = $("novaSessionList");
        if(sel && sel.value) sid = String(sel.value).trim();
      }catch(e){}
    }

    if(!sid){
      sid = getOrCreateSessionId();
      try{ if(sidEl) sidEl.value = sid; }catch(e){}
    }

    setSessionId(sid);
    if(out) out.textContent = "Fetching summary for session_id=" + sid + " ...";

    var res = await fetchJsonTry("/api/session/summary", {
      method: "POST",
      headers: buildHeaders(),
      body: JSON.stringify({ session_id: sid })
    });

    if(!res.ok){
      if(out) out.textContent = "ERROR " + res.status + " fetching summary:\n" + JSON.stringify(res.data, null, 2);
      return;
    }

    // Accept common shapes
    var data = res.data || {};
    var summary =
      (typeof data.summary === "string" && data.summary) ? data.summary :
      (data.content && typeof data.content.summary === "string") ? data.content.summary :
      (typeof data.text === "string") ? data.text :
      JSON.stringify(data, null, 2);

    if(out) out.textContent = summary;
  }

  // Delegated click handling survives cloning/replacing buttons
  document.addEventListener("click", function(ev){
    var t = ev.target;
    if(!t) return;

    // handle clicks on child elements inside buttons too
    var id = t.id || (t.closest ? (t.closest("button") && t.closest("button").id) : "");
    if(!id) return;

    if(id === "novaSummaryRefresh"){
      ev.preventDefault();
      try{ loadSessions(); }catch(e){}
      return;
    }
    if(id === "novaSummaryFetch"){
      ev.preventDefault();
      try{ fetchSummary(); }catch(e){}
      return;
    }
  }, true);

  // Delegated change handler for dropdown
  document.addEventListener("change", function(ev){
    var t = ev.target;
    if(!t) return;
    if(t.id === "novaSessionList"){
      try{
        var sidEl = $("novaSessionId");
        if(sidEl) sidEl.value = (t.value || "").trim();
      }catch(e){}
    }
  }, true);

  // Export a global autorun (guaranteed global)
  window.__novaSummaryAutoRun = function(){
    try{ loadSessions(); }catch(e){}
    try{ setTimeout(fetchSummary, 500); }catch(e){}
  };

  // Run once on load (after DOM settles)
  try{ setTimeout(function(){ try{ window.__novaSummaryAutoRun(); }catch(e){} }, 350); }catch(e){}
})();
</script>
