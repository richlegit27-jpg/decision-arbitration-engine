<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Nova</title>

  <!-- CACHE BUST LOCK -->
  <link rel="stylesheet" href="/static/css/nova-main.css?v=live-fix-2026-04-04-001" />
</head>
<body>
  <div id="novaAppShell" class="nova-app-shell">

    <!-- LEFT SIDEBAR -->
    <aside id="novaSidebar" class="nova-sidebar" data-collapsed="false">
      <div class="nova-sidebar-top">
        <button id="sidebarToggle" class="nova-icon-btn nova-sidebar-toggle" type="button">â˜°</button>

        <div class="nova-brand">
          <div class="nova-brand-mark">N</div>
          <div class="nova-brand-text">
            <div class="nova-brand-title">Nova</div>
            <div class="nova-brand-subtitle">Ultimate 2026</div>
          </div>
        </div>

        <button id="newChatBtn" class="nova-btn nova-btn-primary">+ New Chat</button>
      </div>

      <div class="nova-sidebar-collapsed-tools">
        <button id="collapsedNewChatBtn" class="nova-icon-btn">ï¼‹</button>
      </div>

      <div class="nova-session-rail-header">
        <div class="nova-panel-title">Sessions</div>
        <div id="sessionCount" class="nova-panel-subtitle">0 sessions</div>
      </div>

      <div id="sessionList" class="nova-session-list"></div>
    </aside>

    <!-- MAIN -->
    <main class="nova-main">

      <!-- TOPBAR -->
      <header class="nova-topbar">
        <div class="nova-topbar-left">
          <div class="nova-topbar-title-wrap">
            <div id="sessionTitle" class="nova-topbar-title">Nova</div>
            <div id="sessionSubtitle" class="nova-topbar-subtitle">Fast local AI workspace</div>
          </div>
        </div>

        <div class="nova-topbar-right">
          <div id="modelChip" class="nova-chip nova-chip-accent">gpt-5.4</div>
          <div id="statusChip" class="nova-chip nova-chip-good">Ready</div>
          <button id="routeInspectorBtn" class="nova-icon-btn">ðŸ§­</button>
        </div>
      </header>

      <!-- CHAT -->
      <section id="chatScroll" class="nova-chat-scroll">
        <div id="chatMessages" class="nova-chat-messages"></div>
      </section>

      <!-- COMPOSER -->
      <footer class="nova-composer-shell">

        <div id="pendingUploads" class="nova-pending-uploads"></div>

        <div class="nova-composer">

          <div class="nova-composer-controls">
            <label for="fileInput" class="nova-btn nova-btn-ghost">ðŸ“Ž Attach</label>
            <input id="fileInput" type="file" multiple hidden />
            <button id="voiceBtn" class="nova-btn nova-btn-ghost">ðŸŽ¤</button>
            <button id="clearInputBtn" class="nova-btn nova-btn-ghost">âŒ«</button>
          </div>

          <div class="nova-composer-main">
            <textarea id="chatInput" rows="1" placeholder="Message Nova"></textarea>

            <div class="nova-composer-footer">
              <div id="composerHint" class="nova-composer-hint">
                Enter to send Â· Shift+Enter for newline Â· Upload stages files before send
              </div>
              <button id="sendBtn" class="nova-btn nova-btn-primary nova-send-btn">Send</button>
            </div>
          </div>

        </div>

        <div id="composerStatus" class="nova-composer-status">Ready</div>
      </footer>

    </main>

    <!-- RIGHT RAIL -->
    <aside id="rightRail" class="nova-right-rail" data-open="true">

      <div class="nova-right-rail-top">
        <div class="nova-right-rail-tabs">
          <button class="nova-rail-tab is-active" data-panel="artifacts">Artifacts</button>
          <button class="nova-rail-tab" data-panel="memory">Memory</button>
          <button class="nova-rail-tab" data-panel="web">Web</button>
          <button class="nova-rail-tab" data-panel="route">Route</button>
        </div>

        <button id="rightRailCloseBtn" class="nova-icon-btn">Ã—</button>
      </div>

      <div class="nova-right-rail-heading">
        <div id="rightRailTitle" class="nova-panel-title">Artifacts</div>
        <div id="rightRailSubtitle" class="nova-panel-subtitle">Saved outputs tied to this session</div>
      </div>

      <div class="nova-right-rail-body">

        <section id="panelArtifacts" class="nova-rail-panel is-active">
          <div id="artifactList" class="nova-rail-list"></div>
        </section>

        <section id="panelMemory" class="nova-rail-panel">
          <div class="nova-memory-tools">
            <input id="memoryInput" class="nova-input" type="text" placeholder="Add memory note" />
            <button id="memoryAddBtn" class="nova-btn nova-btn-primary">Add</button>
          </div>
          <div id="memoryList" class="nova-rail-list"></div>
        </section>

        <section id="panelWeb" class="nova-rail-panel">
          <div id="webList" class="nova-rail-list"></div>
        </section>

        <section id="panelRoute" class="nova-rail-panel">
          <div id="routeInspector" class="nova-route-inspector">
            <div class="nova-empty-state">
              <div class="nova-empty-title">Route Inspector</div>
              <div class="nova-empty-text">
                Click a route badge on an assistant message or the compass button.
              </div>
            </div>
          </div>
        </section>

      </div>
    </aside>

  </div>

  <!-- CACHE BUST LOCK -->
  <script src="/static/js/nova-artifacts.js?v=FIX-2026-04-04-001"></script>
  <script src="/static/js/nova-composer-bundle.js?v=scroll-stack-fix-2026-04-04-001"></script>

</body>
</html>


