<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Nova JS Probe</title>
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
  <meta http-equiv="Pragma" content="no-cache" />
  <meta http-equiv="Expires" content="0" />
  <style>
    body{font-family:Segoe UI,Arial;margin:20px}
    button{padding:10px 14px;font-size:16px}
    input{padding:10px;font-size:16px;width:520px;max-width:95%}
    pre{background:#111;color:#eee;padding:10px;white-space:pre-wrap}
  </style>
</head>
<body>
  <h2>Nova JS Probe</h2>
  <p>If JS is running, the button will change this dot to green and log text below.</p>
  <div id="dot" style="width:12px;height:12px;border-radius:50%;background:#a00;display:inline-block"></div>
  <button id="btn">CLICK ME</button>

  <div style="margin-top:16px">
    <input id="text" value="hello probe" />
    <button id="send">Send to /api/chat</button>
  </div>

  <pre id="log">(log)</pre>

  <script>
    const log = (m)=>{ document.getElementById('log').textContent += "\n" + m; };
    log("inline script start");
    document.getElementById('btn').addEventListener('click', ()=>{
      document.getElementById('dot').style.background = '#0a0';
      log("CLICK WORKED " + new Date().toISOString());
      alert("JS CLICK WORKED");
    });

    document.getElementById('send').addEventListener('click', async ()=>{
      const t = document.getElementById('text').value;
      log("sending: " + t);
      try{
        const r = await fetch("/api/chat", {
          method:"POST",
          headers:{ "Content-Type":"application/json" },
          body: JSON.stringify({ text:t, timeout_ms: 8000 })
        });
        const j = await r.json();
        log("reply: " + JSON.stringify(j));
        alert("FETCH OK — check log");
      }catch(e){
        log("ERROR: " + String(e));
        alert("FETCH ERROR — check log");
      }
    });

    window.addEventListener("error", (e)=>log("WINDOW ERROR: " + (e && e.message)));
    window.addEventListener("unhandledrejection", (e)=>log("REJECTION: " + (e && e.reason)));
    log("inline script bound events");
  </script>
</body>
</html>
