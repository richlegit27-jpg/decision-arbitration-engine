  <div id="toast" class="toast">Copied</div>

  <script>
  (function(){
    "use strict";

    const $ = (sel) => document.querySelector(sel);

    const chatEl = $("#chat");
    const inputEl = $("#input");
    const sendBtn = $("#sendBtn");
    const stopBtn = $("#stopBtn");
    const clearBtn = $("#clearBtn");
    const pingBtn = $("#pingBtn");
    const autoSendEl = $("#autoSend");

    const statusText = $("#statusText");
    const modeText = $("#modeText");
    const sessionText = $("#sessionText");
    const buildStamp = $("#buildStamp");
    const latencyPill = $("#latencyPill");
    const toastEl = $("#toast");

    const LS_SESSION = "NOVA_SESSION_ID_V1";
    const LS_AUTOSEND = "NOVA_AUTOSEND_V1";
    const LS_MODE = "NOVA_MODE_V1";
    const LS_DRAFT = "NOVA_DRAFT_V1";

    function uuid8(){ return Math.random().toString(16).slice(2,10); }

    let sessionId = localStorage.getItem(LS_SESSION) || ("ui_" + uuid8() + uuid8());
    localStorage.setItem(LS_SESSION, sessionId);

    let mode = localStorage.getItem(LS_MODE) || "ask";
    let busy = false;
    let aborter = null;

    function setStatus(text, cls){
      statusText.textContent = text;
      statusText.className = cls || "";
    }
    function setLatency(ms){
      if(typeof ms === "number" && isFinite(ms)) latencyPill.textContent = "lat: " + Math.round(ms) + "ms";
      else latencyPill.textContent = "lat: —";
    }
    function scrollDown(){ try{ chatEl.scrollTop = chatEl.scrollHeight; }catch(e){} }

    function toast(msg){
      try{
        toastEl.textContent = msg || "OK";
        toastEl.classList.add("show");
        clearTimeout(toastEl.__t);
        toastEl.__t = setTimeout(() => toastEl.classList.remove("show"), 900);
      }catch(e){}
    }

    function addMsg(role, text){
      const wrap = document.createElement("div");
      wrap.className = "msg " + (role === "user" ? "user" : "ai");

      const who = document.createElement("div");
      who.className = "who";
      who.textContent = role === "user" ? "U" : "N";

      const bubbleWrap = document.createElement("div");
      bubbleWrap.className = "bubbleWrap";

      const bubble = document.createElement("div");
      bubble.className = "bubble";
      bubble.textContent = text;

      bubbleWrap.appendChild(bubble);

      if(role === "ai"){
        const actions = document.createElement("div");
        actions.className = "actions";

        const copyBtn = document.createElement("button");
        copyBtn.className = "aBtn";
        copyBtn.type = "button";
        copyBtn.textContent = "Copy";
        copyBtn.addEventListener("click", async () => {
          try{
            await navigator.clipboard.writeText(bubble.textContent || "");
            toast("Copied");
          }catch(e){
            try{
              const ta = document.createElement("textarea");
              ta.value = bubble.textContent || "";
              document.body.appendChild(ta);
              ta.select();
              document.execCommand("copy");
              ta.remove();
              toast("Copied");
            }catch(e2){
              toast("Copy failed");
            }
          }
        });

        actions.appendChild(copyBtn);
        bubbleWrap.appendChild(actions);
      }

      wrap.appendChild(who);
      wrap.appendChild(bubbleWrap);
      chatEl.appendChild(wrap);
      scrollDown();
      return bubble;
    }

    function setBusy(v){
      busy = !!v;
      sendBtn.disabled = busy;
      inputEl.disabled = busy;
      stopBtn.style.display = busy ? "" : "none";
    }

    function autoGrow(){
      try{
        inputEl.style.height = "auto";
        inputEl.style.height = Math.min(240, inputEl.scrollHeight) + "px";
      }catch(e){}
    }

    function saveDraft(){
      try{ localStorage.setItem(LS_DRAFT, inputEl.value || ""); }catch(e){}
    }

    // --- Streaming: try SSE/text-event-stream OR chunked text; fallback to JSON.
    async function postChatStreaming(text, onToken){
      const url = "/api/chat?session_id=" + encodeURIComponent(sessionId);
      const body = { text: text };

      aborter = new AbortController();
      const r = await fetch(url, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "text/event-stream, application/json, text/plain"
        },
        body: JSON.stringify(body),
        signal: aborter.signal
      });

      // If server returns JSON (non-stream), handle it.
      const ct = (r.headers.get("content-type") || "").toLowerCase();

      if(!r.ok){
        const raw = await r.text().catch(() => "");
        let msg = raw;
        try{
          const j = JSON.parse(raw);
          msg = j.error || j.detail || raw;
        }catch(e){}
        const err = new Error("HTTP " + r.status + " " + msg);
        err.status = r.status;
        throw err;
      }

      // Stream path
      if(r.body && (ct.includes("text/event-stream") || ct.includes("text/plain") || ct.includes("application/octet-stream"))){
        const reader = r.body.getReader();
        const dec = new TextDecoder("utf-8");
        let buf = "";

        // SSE parse: look for \n\n boundaries; handle "data:" lines; support JSON {t:"..."} tokens
        while(true){
          const { value, done } = await reader.read();
          if(done) break;
          buf += dec.decode(value, { stream: true });

          // Process complete SSE events (or chunk blocks) split by blank line
          let idx;
          while((idx = buf.indexOf("\n\n")) >= 0){
            const block = buf.slice(0, idx);
            buf = buf.slice(idx + 2);

            const lines = block.split(/\r?\n/);
            for(const line of lines){
              const s = line.trim();
              if(!s) continue;

              if(s.startsWith("data:")){
                const payload = s.slice(5).trim();
                if(!payload) continue;
                if(payload === "[DONE]") return;

                // Try JSON token format: {"t":"..."} or {"delta":"..."} or {"text":"..."}
                let tok = null;
                try{
                  const j = JSON.parse(payload);
                  tok = (j.t ?? j.delta ?? j.text ?? j.token ?? null);
                }catch(e){}

                if(tok === null){
                  // If server sends raw text as data:
                  tok = payload;
                }
                if(typeof tok === "string" && tok.length){
                  onToken(tok);
                }
              }
            }
          }
        }

        // If anything leftover and it's JSON, parse it.
        const tail = buf.trim();
        if(tail){
          try{
            const j = JSON.parse(tail);
            if(typeof j.reply === "string"){
              onToken(j.reply); // as a final chunk
            }
          }catch(e){
            // ignore
          }
        }
        return;
      }

      // Non-stream JSON fallback
      const raw = await r.text();
      let data = null;
      try{ data = JSON.parse(raw); }catch(e){}
      if(data && typeof data.reply === "string"){
        onToken(data.reply);
        return;
      }
      // plain text fallback
      onToken(raw);
    }

    function stop(){
      try{
        if(aborter) aborter.abort();
      }catch(e){}
    }

    async function send(){
      const text = (inputEl.value || "").trim();
      if(!text || busy) return;

      addMsg("user", text);
      inputEl.value = "";
      saveDraft();
      autoGrow();

      setBusy(true);
      setStatus("typing…", "warn");
      setLatency(null);

      const aiBubble = addMsg("ai", "");
      let acc = "";
      const t0 = performance.now();

      try{
        let payload = text;
        if(mode === "command" && !text.startsWith("/")) payload = "/cmd " + text;
        if(mode === "doctor" && !text.startsWith("/")) payload = "/doctor " + text;

        await postChatStreaming(payload, (tok) => {
          acc += tok;
          aiBubble.textContent = acc;
          scrollDown();
        });

        setLatency(performance.now() - t0);
        setStatus("ready", "ok");
      }catch(err){
        if(err && (err.name === "AbortError" || String(err.message||"").includes("aborted"))){
          aiBubble.textContent = acc.length ? acc + "\n\n[stopped]" : "[stopped]";
          setStatus("stopped", "warn");
        } else {
          console.error("SEND ERROR:", err);
          aiBubble.textContent = "Error: " + (err && err.message ? err.message : String(err));
          setStatus("error", "danger");
        }
      }finally{
        aborter = null;
        setBusy(false);
        try{ inputEl.focus(); }catch(e){}
        scrollDown();
      }
    }

    function bindNav(){
      const buttons = document.querySelectorAll(".nav button[data-mode]");
      buttons.forEach(btn => {
        btn.addEventListener("click", () => {
          buttons.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          mode = btn.getAttribute("data-mode") || "ask";
          localStorage.setItem(LS_MODE, mode);
          modeText.textContent = mode;
          try{ inputEl.focus(); }catch(e){}
        });
      });
    }

    function init(){
      buildStamp.textContent = "STREAM V1";
      sessionText.textContent = sessionId;
      modeText.textContent = mode;

      // autosend setting (default ON)
      const as = localStorage.getItem(LS_AUTOSEND);
      if(as === null){
        localStorage.setItem(LS_AUTOSEND, "1");
        autoSendEl.checked = true;
      } else {
        autoSendEl.checked = (as === "1");
      }
      autoSendEl.addEventListener("change", () => {
        localStorage.setItem(LS_AUTOSEND, autoSendEl.checked ? "1" : "0");
      });

      // restore draft
      try{
        const d = localStorage.getItem(LS_DRAFT);
        if(typeof d === "string" && d.length){
          inputEl.value = d;
        }
      }catch(e){}

      // core handlers
      sendBtn.addEventListener("click", send);
      stopBtn.addEventListener("click", stop);

      inputEl.addEventListener("input", () => { autoGrow(); saveDraft(); });

      inputEl.addEventListener("keydown", (ev) => {
        // Enter sends (when auto-send enabled), Shift+Enter newline
        if(ev.key === "Enter" && !ev.shiftKey){
          if(autoSendEl.checked){
            ev.preventDefault();
            send();
            return;
          }
        }
        // Esc clears input
        if(ev.key === "Escape"){
          ev.preventDefault();
          inputEl.value = "";
          saveDraft();
          autoGrow();
          return;
        }
      });

      // global hotkeys
      document.addEventListener("keydown", (ev) => {
        if((ev.ctrlKey || ev.metaKey) && (ev.key === "k" || ev.key === "K")){
          ev.preventDefault();
          try{ inputEl.focus(); }catch(e){}
        }
      }, { passive:false });

      clearBtn.addEventListener("click", () => {
        chatEl.innerHTML = "";
        setStatus("cleared", "ok");
        setLatency(null);
        try{ inputEl.focus(); }catch(e){}
      });

      pingBtn.addEventListener("click", async () => {
        try{
          setStatus("ping…", "warn");
          const r = await fetch("/api/health");
          const t = await r.text();
          setStatus(r.ok ? "ready" : "error", r.ok ? "ok" : "danger");
          addMsg("ai", "Ping /api/health -> HTTP " + r.status + "\n" + t);
        }catch(e){
          setStatus("error", "danger");
          addMsg("ai", "Ping failed: " + (e && e.message ? e.message : String(e)));
        }
      });

      bindNav();

      addMsg("ai", "Streaming enabled. Replies will type live when available.\nIf a reply comes all at once, the server returned JSON (fallback).");
      autoGrow();
      try{ inputEl.focus(); }catch(e){}
      setStatus("ready", "ok");
      setLatency(null);
    }

    if(document.readyState === "loading"){
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
  </script>
</body>
</html>
