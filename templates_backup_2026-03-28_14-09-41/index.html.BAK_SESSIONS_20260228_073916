<body>
  <div class="app">
    <aside class="card side">
      <div class="brand">
        <div class="logo"><span class="dot"></span><span>Nova</span></div>
        <div class="badge" id="buildStamp">UI</div>
      </div>

      <div class="nav">
        <button class="active" data-mode="ask">Ask</button>
        <button data-mode="command">Command</button>
        <button data-mode="doctor">Doctor</button>
      </div>

      <div class="meta">
        <div class="mono">Hotkeys</div>
        <div style="margin-top:6px; line-height:1.8;">
          <span class="k">Enter</span> send (Auto-send on)<br/>
          <span class="k">Shift</span>+<span class="k">Enter</span> newline<br/>
          <span class="k">Ctrl</span>+<span class="k">K</span> focus<br/>
          <span class="k">Esc</span> clear input
        </div>
        <div style="margin-top:10px;">
          Streaming is enabled: replies type live when server streams.
        </div>
      </div>
    </aside>

    <main class="card main">
      <div class="topbar">
        <div class="status">
          <span class="pill">status: <span id="statusText" class="ok">ready</span></span>
          <span class="pill">mode: <span id="modeText">ask</span></span>
          <span class="pill">session: <span id="sessionText">…</span></span>
          <span class="pill mono" id="latencyPill">lat: —</span>
        </div>
        <div style="display:flex; gap:8px; align-items:center;">
          <span class="pill mono" id="uiStamp">UI: STABLE_UI_20260228_071444</span>
          <button class="smallBtn" id="clearBtn">Clear</button>
          <button class="smallBtn" id="pingBtn">Ping</button>
        </div>
      </div>

      <div id="chat" class="chat" aria-live="polite"></div>

      <div class="composer">
        <div class="leftControls">
          <textarea id="input" placeholder="Type here…" spellcheck="false"></textarea>
          <div class="hintRow">
            <div>Enter = send &nbsp; • &nbsp; Shift+Enter = newline</div>
            <label class="toggle" title="If enabled, Enter sends. If disabled, Enter inserts newline.">
              <input id="autoSend" type="checkbox" checked />
              <span>Auto-send on Enter</span>
            </label>
          </div>
        </div>

        <div class="send">
          <button class="btn" id="sendBtn">Send</button>
          <button class="btn btnStop" id="stopBtn" style="display:none;">Stop</button>
        </div>
      </div>
