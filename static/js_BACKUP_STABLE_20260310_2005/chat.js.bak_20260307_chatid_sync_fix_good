(() => {
"use strict"

const el = {
  sidebar: document.getElementById("sidebar"),
  mobileOverlay: document.getElementById("mobileOverlay"),
  btnSidebarToggle: document.getElementById("btnSidebarToggle"),
  btnSidebarClose: document.getElementById("btnSidebarClose"),
  chatList: document.getElementById("chatList"),
  messages: document.getElementById("messages"),
  messagesEmpty: document.getElementById("messagesEmpty"),
  composerForm: document.getElementById("composerForm"),
  input: document.getElementById("messageInput"),
  sendBtn: document.getElementById("sendBtn"),
  stopBtn: document.getElementById("stopBtn"),
  attachBtn: document.getElementById("attachBtn"),
  fileInput: document.getElementById("fileInput"),
  pendingAttachments: document.getElementById("pendingAttachments"),
  pendingAttachmentsList: document.getElementById("pendingAttachmentsList"),
  newChatBtn: document.getElementById("btnNewChat")
}

const state = window.NovaState?.create ? window.NovaState.create() : {
  chats: [],
  activeChatId: null,
  chatId: null,
  messages: [],
  pendingAttachments: [],
  pendingFiles: [],
  isStreaming: false
}

const api = window.NovaAPI || null

const renderService = window.NovaRenderService?.create
  ? window.NovaRenderService.create({
      state,
      elements: {
        chatList: el.chatList,
        messages: el.messages,
        emptyState: el.messagesEmpty,
        pendingAttachments: el.pendingAttachments
      }
    })
  : null

const attachmentsService = window.NovaAttachmentsService?.create
  ? window.NovaAttachmentsService.create({
      state,
      elements: {
        attachBtn: el.attachBtn,
        fileInput: el.fileInput,
        pendingAttachments: el.pendingAttachments,
        pendingAttachmentsList: el.pendingAttachmentsList
      }
    })
  : null

const chatService = window.NovaChatService?.create
  ? window.NovaChatService.create({
      state,
      api,
      elements: {
        chatList: el.chatList
      },
      renderService
    })
  : null

const streamService = window.NovaStreamService?.create
  ? window.NovaStreamService.create({
      state,
      api,
      elements: {
        messages: el.messages
      },
      renderService,
      chatService,
      attachmentsService,
      onStart(){
        setStreamingUi(true)
      },
      onMeta(meta = {}){
        if(meta.chat_id){
          state.activeChatId = meta.chat_id
          state.chatId = meta.chat_id
        }
      },
      onToken(token, context = {}){
        handleAssistantToken(token, context)
      },
      onDone(context = {}){
        finishAssistantStream(context)
      },
      onError(error, context = {}){
        failAssistantStream(error, context)
      },
      onFinally(){
        setStreamingUi(false)
        renderChatList()
      }
    })
  : null

const composerService = window.NovaComposerService?.create
  ? window.NovaComposerService.create({
      state,
      elements: {
        input: el.input,
        sendBtn: el.sendBtn,
        attachBtn: el.attachBtn,
        fileInput: el.fileInput,
        stopBtn: el.stopBtn,
        composerForm: el.composerForm
      },
      attachmentsService,
      streamService,
      renderService,
      chatService
    })
  : null

let activeAssistantMessageId = null
let lastUserMessageText = ""

function uid(prefix = "id"){
  if(window.crypto?.randomUUID){
    return `${prefix}-${window.crypto.randomUUID()}`
  }

  return `${prefix}-${Date.now()}-${Math.random().toString(16).slice(2)}`
}

function escapeSelector(value){
  if(window.CSS?.escape){
    return window.CSS.escape(String(value))
  }

  return String(value).replace(/"/g, '\\"')
}

function setStreamingUi(isStreaming){
  state.isStreaming = !!isStreaming

  if(el.sendBtn){
    el.sendBtn.hidden = !!isStreaming
    el.sendBtn.disabled = !!isStreaming
  }

  if(el.stopBtn){
    el.stopBtn.hidden = !isStreaming
    el.stopBtn.disabled = !isStreaming
  }

  if(el.input){
    el.input.dataset.streaming = isStreaming ? "true" : "false"
  }
}

function openSidebar(){
  if(!el.sidebar){
    return
  }

  el.sidebar.classList.add("is-open")
  document.body.classList.add("sidebar-open")

  if(el.mobileOverlay){
    el.mobileOverlay.hidden = false
  }
}

function closeSidebar(){
  if(!el.sidebar){
    return
  }

  el.sidebar.classList.remove("is-open")
  document.body.classList.remove("sidebar-open")

  if(el.mobileOverlay){
    el.mobileOverlay.hidden = true
  }
}

function renderChatList(){
  if(!el.chatList){
    return
  }

  const chats = Array.isArray(state.chats) ? [...state.chats] : []

  if(chats.length === 0){
    el.chatList.innerHTML = `<div class="chat-list-empty">No chats yet.</div>`
    return
  }

  el.chatList.innerHTML = chats.map((chat) => {
    const title = escapeHtml(chat.title || "New chat")
    const updated = formatTime(chat.updated_at || chat.updated || chat.created_at || "")
    const isActive = String(chat.chat_id || "") === String(state.activeChatId || state.chatId || "")

    return `
      <article class="chat-list-item${isActive ? " is-active" : ""}" data-chat-id="${escapeHtml(chat.chat_id)}">
        <button type="button" class="chat-list-main" data-chat-action="open" data-chat-id="${escapeHtml(chat.chat_id)}">
          <div class="chat-list-title">${title}</div>
          <div class="chat-list-time">${updated}</div>
        </button>

        <div class="chat-list-actions">
          <button type="button" class="chat-list-action" data-chat-action="rename" data-chat-id="${escapeHtml(chat.chat_id)}">
            Rename
          </button>
          <button type="button" class="chat-list-action danger" data-chat-action="delete" data-chat-id="${escapeHtml(chat.chat_id)}">
            Delete
          </button>
        </div>
      </article>
    `
  }).join("")
}

function escapeHtml(value){
  return String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;")
}

function formatTime(value){
  if(!value){
    return ""
  }

  try{
    const date = new Date(value)

    if(Number.isNaN(date.getTime())){
      return ""
    }

    return date.toLocaleTimeString([], {
      hour: "numeric",
      minute: "2-digit"
    })
  }catch{
    return ""
  }
}

function getMessageById(messageId){
  return (state.messages || []).find((message) => String(message.message_id) === String(messageId)) || null
}

function ensureAssistantStreamingMessage(){
  if(activeAssistantMessageId){
    const existing = getMessageById(activeAssistantMessageId)

    if(existing){
      return existing
    }
  }

  const message = {
    message_id: uid("msg"),
    role: "assistant",
    content: "",
    created_at: new Date().toISOString(),
    streaming: true,
    thinking: false,
    error: "",
    attachments: []
  }

  state.messages.push(message)
  activeAssistantMessageId = message.message_id
  renderService?.appendMessage(message)

  return message
}

function addThinkingPlaceholder(){
  const message = {
    message_id: uid("msg"),
    role: "assistant",
    content: "",
    created_at: new Date().toISOString(),
    streaming: false,
    thinking: true,
    error: "",
    attachments: []
  }

  state.messages.push(message)
  activeAssistantMessageId = message.message_id
  renderService?.appendMessage(message)
  return message
}

function clearThinkingState(message){
  if(!message){
    return
  }

  message.thinking = false
  message.streaming = true
  renderService?.updateMessage(message.message_id, {
    thinking: false,
    streaming: true
  })
}

function handleAssistantToken(token, context = {}){
  let message = null

  if(context.messageId){
    message = getMessageById(context.messageId)
  }

  if(!message && activeAssistantMessageId){
    message = getMessageById(activeAssistantMessageId)
  }

  if(!message){
    message = ensureAssistantStreamingMessage()
  }

  if(message.thinking){
    clearThinkingState(message)
  }

  message.streaming = true
  message.error = ""
  message.content = `${message.content || ""}${token || ""}`

  activeAssistantMessageId = message.message_id

  renderService?.updateMessage(message.message_id, {
    content: message.content,
    streaming: true,
    thinking: false,
    error: ""
  })

  renderService?.scrollToBottom()
}

function finishAssistantStream(context = {}){
  let message = null

  if(context.messageId){
    message = getMessageById(context.messageId)
  }

  if(!message && activeAssistantMessageId){
    message = getMessageById(activeAssistantMessageId)
  }

  if(!message){
    activeAssistantMessageId = null
    return
  }

  message.streaming = false
  message.thinking = false

  if(!message.content || !String(message.content).trim()){
    message.content = "Done."
  }

  renderService?.updateMessage(message.message_id, {
    content: message.content,
    streaming: false,
    thinking: false,
    error: ""
  })

  activeAssistantMessageId = null
  renderService?.scrollToBottom()
}

function failAssistantStream(error, context = {}){
  let message = null

  if(context.messageId){
    message = getMessageById(context.messageId)
  }

  if(!message && activeAssistantMessageId){
    message = getMessageById(activeAssistantMessageId)
  }

  if(!message){
    message = ensureAssistantStreamingMessage()
  }

  const errorText = error?.message || String(error || "Something went wrong.")

  message.streaming = false
  message.thinking = false
  message.error = errorText

  if(!message.content || !String(message.content).trim()){
    message.content = "Something went wrong."
  }

  renderService?.updateMessage(message.message_id, {
    content: message.content,
    streaming: false,
    thinking: false,
    error: errorText
  })

  activeAssistantMessageId = null
  renderService?.scrollToBottom()
}

function setMessages(messages){
  state.messages = Array.isArray(messages) ? messages.map(normalizeMessage) : []
  activeAssistantMessageId = null
  renderService?.renderMessages()
  renderService?.scrollToBottom()
}

function normalizeMessage(message = {}){
  return {
    message_id: message.message_id || uid("msg"),
    role: message.role || "assistant",
    content: message.content || "",
    created_at: message.created_at || message.created || new Date().toISOString(),
    streaming: !!message.streaming,
    thinking: !!message.thinking,
    error: message.error || "",
    attachments: Array.isArray(message.attachments) ? message.attachments : []
  }
}

function syncActiveChat(chatId){
  const normalized = String(chatId || "").trim() || null
  state.activeChatId = normalized
  state.chatId = normalized
}

async function loadChats(){
  if(!chatService || typeof chatService.listChats !== "function"){
    renderChatList()
    return
  }

  try{
    const chats = await chatService.listChats()
    state.chats = Array.isArray(chats) ? chats : []
  }catch(error){
    console.error("Failed to load chats:", error)
    state.chats = []
  }

  const active = String(state.activeChatId || state.chatId || "").trim()

  if(active){
    const exists = state.chats.some((chat) => String(chat?.chat_id || "").trim() === active)
    if(!exists){
      syncActiveChat(null)
    }
  }

  renderChatList()
}

async function loadChat(chatId){
  if(!chatId){
    return
  }

  syncActiveChat(chatId)
  renderChatList()

  if(!chatService || typeof chatService.loadChat !== "function"){
    setMessages([])
    return
  }

  try{
    const messages = await chatService.loadChat(chatId)
    setMessages(messages)
  }catch(error){
    console.error("Failed to load chat:", error)
    setMessages([{
      message_id: uid("msg"),
      role: "system",
      content: "Failed to load chat.",
      created_at: new Date().toISOString(),
      error: error?.message || "Load failed."
    }])
  }

  closeSidebar()
}

async function createNewChat(){
  activeAssistantMessageId = null
  lastUserMessageText = ""
  state.messages = []
  syncActiveChat(null)

  renderService?.renderMessages()
  renderChatList()

  if(el.input){
    el.input.focus()
  }

  closeSidebar()
}

async function renameChat(chatId){
  if(!chatId){
    return
  }

  const current = (state.chats || []).find((chat) => chat.chat_id === chatId)
  const nextTitle = window.prompt("Rename chat", current?.title || "New chat")

  if(nextTitle == null){
    return
  }

  const trimmed = nextTitle.trim()

  if(!trimmed){
    return
  }

  try{
    if(chatService?.renameChat){
      await chatService.renameChat(chatId, trimmed)
    }

    const target = (state.chats || []).find((chat) => chat.chat_id === chatId)

    if(target){
      target.title = trimmed
      target.updated_at = new Date().toISOString()
    }

    renderChatList()
  }catch(error){
    console.error("Rename failed:", error)
    window.alert(error?.message || "Rename failed.")
  }
}

async function deleteChat(chatId){
  if(!chatId){
    return
  }

  const ok = window.confirm("Delete this chat?")

  if(!ok){
    return
  }

  try{
    if(chatService?.deleteChat){
      await chatService.deleteChat(chatId)
    }

    state.chats = (state.chats || []).filter((chat) => chat.chat_id !== chatId)

    if(String(state.activeChatId || state.chatId || "") === String(chatId)){
      syncActiveChat(null)
      state.messages = []
      renderService?.renderMessages()
    }

    renderChatList()
  }catch(error){
    console.error("Delete failed:", error)
    window.alert(error?.message || "Delete failed.")
  }
}

async function copyMessage(messageId){
  const message = getMessageById(messageId)

  if(!message){
    return
  }

  try{
    await navigator.clipboard.writeText(message.content || "")

    const row = el.messages?.querySelector(`[data-message-id="${escapeSelector(messageId)}"]`)
    const btn = row?.querySelector('[data-message-action="copy"]')

    if(btn){
      const old = btn.textContent
      btn.textContent = "Copied"
      window.setTimeout(() => {
        btn.textContent = old
      }, 1200)
    }
  }catch(error){
    console.error("Copy failed:", error)
  }
}

async function regenerateMessage(messageId){
  const message = getMessageById(messageId)

  if(!message || message.role !== "assistant"){
    return
  }

  const userMessages = (state.messages || []).filter((item) => item.role === "user")
  const lastUser = userMessages[userMessages.length - 1]

  const prompt = (lastUser?.content || lastUserMessageText || "").trim()

  if(!prompt){
    window.alert("No user message found to regenerate from.")
    return
  }

  if(state.isStreaming){
    return
  }

  const existing = state.messages.findIndex((item) => item.message_id === messageId)

  if(existing !== -1){
    state.messages.splice(existing, 1)
    renderService?.renderMessages()
  }

  const thinking = addThinkingPlaceholder()

  try{
    const files = Array.isArray(lastUser?.attachments) ? lastUser.attachments : []

    await streamService?.send({
      chatId: state.activeChatId || state.chatId,
      message: prompt,
      files,
      extra: {
        regenerate: true,
        messageId: thinking.message_id
      }
    })
  }catch(error){
    failAssistantStream(error, { messageId: thinking.message_id })
  }
}

function wireMessageActions(){
  if(!el.messages){
    return
  }

  el.messages.addEventListener("click", async (event) => {
    const actionBtn = event.target.closest("[data-message-action]")

    if(!actionBtn){
      return
    }

    const action = actionBtn.dataset.messageAction
    const messageId = actionBtn.dataset.messageId

    if(!action || !messageId){
      return
    }

    if(action === "copy"){
      await copyMessage(messageId)
      return
    }

    if(action === "regenerate"){
      await regenerateMessage(messageId)
    }
  })
}

function wireChatListActions(){
  if(!el.chatList){
    return
  }

  el.chatList.addEventListener("click", async (event) => {
    const actionBtn = event.target.closest("[data-chat-action]")

    if(!actionBtn){
      return
    }

    const action = actionBtn.dataset.chatAction
    const chatId = actionBtn.dataset.chatId

    if(action === "open" && chatId){
      await loadChat(chatId)
      return
    }

    if(action === "rename" && chatId){
      await renameChat(chatId)
      return
    }

    if(action === "delete" && chatId){
      await deleteChat(chatId)
    }
  })
}

function wireSidebar(){
  el.btnSidebarToggle?.addEventListener("click", () => {
    const isOpen = el.sidebar?.classList.contains("is-open")
    if(isOpen){
      closeSidebar()
    }else{
      openSidebar()
    }
  })

  el.btnSidebarClose?.addEventListener("click", closeSidebar)
  el.mobileOverlay?.addEventListener("click", closeSidebar)
}

function wireNewChat(){
  el.newChatBtn?.addEventListener("click", async () => {
    await createNewChat()
  })
}

function wireComposerFallback(){
  if(composerService || !el.composerForm){
    return
  }

  el.composerForm.addEventListener("submit", async (event) => {
    event.preventDefault()

    if(state.isStreaming){
      return
    }

    const text = String(el.input?.value || "").trim()
    const pendingFiles = Array.isArray(state.pendingAttachments) ? [...state.pendingAttachments] : []

    if(!text && pendingFiles.length === 0){
      return
    }

    const userMessage = {
      message_id: uid("msg"),
      role: "user",
      content: text,
      created_at: new Date().toISOString(),
      attachments: pendingFiles
    }

    state.messages.push(userMessage)
    lastUserMessageText = text
    renderService?.appendMessage(userMessage)
    renderService?.scrollToBottom()

    if(el.input){
      el.input.value = ""
    }

    if(attachmentsService?.clearPending){
      attachmentsService.clearPending()
    }else{
      state.pendingAttachments = []
      state.pendingFiles = []
    }

    const thinking = addThinkingPlaceholder()

    try{
      await streamService?.send({
        chatId: state.activeChatId || state.chatId,
        message: text,
        files: pendingFiles,
        extra: {
          messageId: thinking.message_id
        }
      })
    }catch(error){
      failAssistantStream(error, { messageId: thinking.message_id })
    }
  })

  el.stopBtn?.addEventListener("click", () => {
    try{
      streamService?.stop?.()
    }catch(error){
      console.error("Stop failed:", error)
    }
  })
}

function wireResize(){
  window.addEventListener("resize", () => {
    if(window.innerWidth > 959){
      if(el.mobileOverlay){
        el.mobileOverlay.hidden = true
      }
      document.body.classList.remove("sidebar-open")
    }
  })
}

async function init(){
  setStreamingUi(false)
  wireSidebar()
  wireNewChat()
  wireChatListActions()
  wireMessageActions()
  wireComposerFallback()
  wireResize()

  renderService?.renderMessages()
  await loadChats()

  const active = String(state.activeChatId || state.chatId || "").trim()

  if(active){
    await loadChat(active)
  }else{
    renderService?.renderMessages()
  }
}

window.NovaChatApp = {
  init,
  state,
  loadChat,
  createNewChat,
  renderChatList
}

document.addEventListener("DOMContentLoaded", init)

})()