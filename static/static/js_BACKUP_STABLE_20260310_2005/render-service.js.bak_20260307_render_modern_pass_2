(() => {
"use strict"

function createRenderService(options = {}){
  const {
    state,
    elements = {},
    utils = {},
    attachmentsService,
  } = options

  if(!state){
    throw new Error("NovaRenderService: state is required")
  }

  const el = {
    messages: elements.messages || null,
    chatList: elements.chatList || null,
    pendingAttachments: elements.pendingAttachments || null,
    emptyState: elements.emptyState || document.getElementById("emptyState"),
    input: elements.input || document.getElementById("promptInput"),
    chatTitle: elements.chatTitle || document.getElementById("chatTitle"),
  }

  const escapeHtml = utils.escapeHtml || ((value) => String(value ?? ""))
  const formatBytes =
    utils.formatBytes ||
    ((bytes) => {
      const n = Number(bytes || 0)

      if(!Number.isFinite(n) || n <= 0){
        return "0 B"
      }

      const units = ["B", "KB", "MB", "GB", "TB"]
      let size = n
      let i = 0

      while(size >= 1024 && i < units.length - 1){
        size /= 1024
        i += 1
      }

      if(i === 0){
        return `${Math.round(size)} ${units[i]}`
      }

      return `${size < 10 ? size.toFixed(1) : Math.round(size)} ${units[i]}`
    })

  function ensureChatsArray(){
    if(!Array.isArray(state.chats)){
      state.chats = []
    }

    return state.chats
  }

  function ensureMessagesArray(){
    if(!Array.isArray(state.messages)){
      state.messages = []
    }

    return state.messages
  }

  function scrollToBottom(){
    try {
      if(!el.messages){
        return
      }

      el.messages.scrollTop = el.messages.scrollHeight
    } catch(error){
      console.error("Nova scrollToBottom error:", error)
    }
  }

  function configureMarkedOnce(){
    if(!window.marked){
      return
    }

    if(window.__novaMarkedConfigured){
      return
    }

    try{
      window.marked.setOptions({
        gfm: true,
        breaks: true,
      })
    }catch(error){
      console.error("Nova marked config error:", error)
    }

    window.__novaMarkedConfigured = true
  }

  function renderAssistantMarkdown(raw){
    const text = String(raw || "")

    if(!window.marked){
      return escapeHtml(text).replace(/\n/g, "<br>")
    }

    try{
      configureMarkedOnce()
      return window.marked.parse(text)
    }catch(error){
      console.error("Nova markdown render error:", error)
      return escapeHtml(text).replace(/\n/g, "<br>")
    }
  }

  function renderMessageText(msg){
    const role = String(msg?.role || "assistant")
    const text = String(msg?.content || "")

    if(role === "assistant"){
      return renderAssistantMarkdown(text)
    }

    return escapeHtml(text).replace(/\n/g, "<br>")
  }

  function getActiveChat(){
    const chats = ensureChatsArray()
    const activeChatId = String(state.activeChatId || state.chatId || "").trim()

    return chats.find((chat) => String(chat?.chat_id || "").trim() === activeChatId) || null
  }

  function renderTopbarTitle(){
    if(!el.chatTitle){
      return
    }

    const activeChat = getActiveChat()
    el.chatTitle.textContent = String(activeChat?.title || "Nova")
  }

  function renderChats(){
    if(!el.chatList){
      return
    }

    const chats = ensureChatsArray()
    const activeChatId = String(state.activeChatId || state.chatId || "").trim()

    if(chats.length === 0){
      el.chatList.innerHTML = `
        <div class="chat-list-empty">No chats yet.</div>
      `
      renderTopbarTitle()
      return
    }

    el.chatList.innerHTML = chats.map((chat) => {
      const chatId = String(chat?.chat_id || "").trim()
      const title = escapeHtml(chat?.title || "New Chat")
      const updated = escapeHtml(chat?.updated || chat?.updated_at || "")
      const activeClass = chatId === activeChatId ? " is-active" : ""

      return `
        <div class="chat-list-item${activeClass}" data-chat-id="${escapeHtml(chatId)}">
          <button
            type="button"
            class="chat-list-main"
            data-chat-id="${escapeHtml(chatId)}"
            title="${title}"
          >
            <div class="chat-list-title">${title}</div>
            <div class="chat-list-time">${updated}</div>
          </button>

          <div class="chat-list-actions">
            <button
              type="button"
              class="chat-list-action"
              data-chat-action="rename"
              data-chat-id="${escapeHtml(chatId)}"
              aria-label="Rename chat"
              title="Rename"
            >
              Rename
            </button>

            <button
              type="button"
              class="chat-list-action danger"
              data-chat-action="delete"
              data-chat-id="${escapeHtml(chatId)}"
              aria-label="Delete chat"
              title="Delete"
            >
              Delete
            </button>
          </div>
        </div>
      `
    }).join("")

    renderTopbarTitle()
  }

  function renderMessageAttachments(attachments){
    if(!Array.isArray(attachments) || attachments.length === 0){
      return ""
    }

    return `
      <div class="message-attachments">
        ${attachments.map((attachment) => {
          const name = escapeHtml(attachment?.name || "file")
          const size = escapeHtml(formatBytes(attachment?.size || 0))

          return `
            <div class="attachment-chip">
              <div class="attachment-chip-body">
                <div class="attachment-chip-name" title="${name}">${name}</div>
                <div class="attachment-chip-meta">${size}</div>
              </div>
            </div>
          `
        }).join("")}
      </div>
    `
  }

  function renderMessageActions(msg){
    const role = String(msg?.role || "assistant")
    const id = escapeHtml(msg?.id || "")

    if(role === "user"){
      return `
        <div class="message-actions">
          <button
            type="button"
            class="message-action-btn"
            data-message-action="edit"
            data-message-id="${id}"
            title="Edit"
            aria-label="Edit message"
          >
            Edit
          </button>
        </div>
      `
    }

    return `
      <div class="message-actions">
        <button
          type="button"
          class="message-action-btn"
          data-message-action="copy"
          data-message-id="${id}"
          title="Copy"
          aria-label="Copy message"
        >
          Copy
        </button>

        <button
          type="button"
          class="message-action-btn"
          data-message-action="regenerate"
          data-message-id="${id}"
          title="Regenerate response"
          aria-label="Regenerate response"
        >
          Regenerate
        </button>
      </div>
    `
  }

  function renderMessageStatus(msg){
    if(msg?.error){
      return `<span class="message-status is-error">Error</span>`
    }

    if(msg?.pending || msg?.status === "streaming"){
      return `<span class="message-status is-streaming">Streaming</span>`
    }

    return ""
  }

  function renderMessages(){
    if(!el.messages){
      return
    }

    const messages = ensureMessagesArray()

    if(messages.length === 0){
      el.messages.innerHTML = ""
      updateEmptyState()
      return
    }

    el.messages.innerHTML = messages.map((msg) => {
      const id = escapeHtml(msg?.id || "")
      const role = String(msg?.role || "assistant")
      const roleClass = `role-${escapeHtml(role)}`
      const rowErrorClass = msg?.error ? " has-error" : ""
      const content = renderMessageText(msg)
      const attachmentsHtml = renderMessageAttachments(msg?.attachments)
      const actionsHtml = renderMessageActions(msg)
      const statusHtml = renderMessageStatus(msg)
      const author =
        role === "user"
          ? "You"
          : role === "assistant"
            ? "Nova"
            : "System"
      const avatar =
        role === "user"
          ? "Y"
          : role === "assistant"
            ? "N"
            : "S"
      const createdAt = escapeHtml(msg?.created_at || msg?.createdAt || "")

      return `
        <div class="message-row ${roleClass}${rowErrorClass}" data-message-id="${id}">
          <div class="message-avatar" aria-hidden="true">${avatar}</div>

          <div class="message-bubble-wrap">
            <div class="message-meta">
              <span class="message-author">${author}</span>
              <span class="message-time">${createdAt}</span>
              ${statusHtml}
            </div>

            <div class="message-bubble">
              <div class="message-content">${content}</div>
              ${attachmentsHtml}
            </div>

            ${actionsHtml}
          </div>
        </div>
      `
    }).join("")

    scrollToBottom()
    updateEmptyState()
  }

  function renderPendingAttachments(){
    if(!el.pendingAttachments){
      return
    }

    const files = attachmentsService?.getPendingFiles?.() || state.pendingFiles || []

    if(!Array.isArray(files) || files.length === 0){
      el.pendingAttachments.innerHTML = ""
      el.pendingAttachments.hidden = true
      updateEmptyState()
      return
    }

    el.pendingAttachments.hidden = false

    el.pendingAttachments.innerHTML = `
      <div class="pending-attachments-list">
        ${files.map((file, index) => {
          const name = escapeHtml(file?.name || "file")
          const size = escapeHtml(formatBytes(file?.size || 0))

          return `
            <div class="attachment-chip" data-file-index="${index}">
              <div class="attachment-chip-body">
                <div class="attachment-chip-name" title="${name}">${name}</div>
                <div class="attachment-chip-meta">${size}</div>
              </div>

              <button
                type="button"
                class="attachment-chip-remove"
                data-remove-file="${index}"
                aria-label="Remove ${name}"
                title="Remove file"
              >
                X
              </button>
            </div>
          `
        }).join("")}
      </div>
    `

    updateEmptyState()
  }

  function updateEmptyState(){
    const emptyState = el.emptyState || document.getElementById("emptyState")
    if(!emptyState){
      return
    }

    const messages = ensureMessagesArray()
    const files = attachmentsService?.getPendingFiles?.() || state.pendingFiles || []
    const hasMessages = Array.isArray(messages) && messages.length > 0
    const hasPendingFiles = Array.isArray(files) && files.length > 0
    const inputValue = String(el.input?.value || "").trim()
    const hasInput = Boolean(inputValue)
    const show = !hasMessages && !hasPendingFiles && !hasInput && !state.isStreaming

    emptyState.hidden = !show
    emptyState.classList.toggle("is-hidden", !show)
    emptyState.setAttribute("aria-hidden", show ? "false" : "true")
  }

  function renderAll(){
    renderChats()
    renderMessages()
    renderPendingAttachments()
    renderTopbarTitle()
    updateEmptyState()
  }

  return {
    renderChats,
    renderMessages,
    renderPendingAttachments,
    renderTopbarTitle,
    renderAll,
    scrollToBottom,
    updateEmptyState,
  }
}

window.NovaRenderService = {
  createRenderService,
}

})()