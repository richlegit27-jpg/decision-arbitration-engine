(() => {
"use strict"

const JSON_HEADERS = {
  "Accept": "application/json",
}

async function listChats(){
  const response = await fetchJson("/api/chats", {
    method: "GET",
  })

  if(Array.isArray(response?.chats)){
    return response.chats
  }

  if(Array.isArray(response)){
    return response
  }

  return []
}

async function getChat(chatId){
  if(!chatId){
    throw new Error("chatId is required")
  }

  return fetchJson(`/api/chats/${encodeURIComponent(chatId)}`, {
    method: "GET",
  })
}

async function getMessages(chatId){
  if(!chatId){
    throw new Error("chatId is required")
  }

  const response = await fetchJson(`/api/chats/${encodeURIComponent(chatId)}`, {
    method: "GET",
  })

  if(Array.isArray(response?.messages)){
    return response.messages
  }

  if(Array.isArray(response)){
    return response
  }

  return []
}

async function createChat(payload = {}){
  const body = {
    title: String(payload.title || "").trim(),
  }

  return fetchJson("/api/chats", {
    method: "POST",
    headers: {
      ...JSON_HEADERS,
      "Content-Type": "application/json",
    },
    body: JSON.stringify(body),
  })
}

async function renameChat(chatId, title){
  if(!chatId){
    throw new Error("chatId is required")
  }

  const cleanTitle = String(title || "").trim()
  if(!cleanTitle){
    throw new Error("title is required")
  }

  const attempts = [
    {
      url: `/api/chats/${encodeURIComponent(chatId)}/rename`,
      method: "POST",
      body: { title: cleanTitle },
    },
    {
      url: `/api/chats/${encodeURIComponent(chatId)}`,
      method: "PATCH",
      body: { title: cleanTitle },
    },
    {
      url: `/api/chats/${encodeURIComponent(chatId)}`,
      method: "PUT",
      body: { title: cleanTitle },
    },
    {
      url: "/api/chats/rename",
      method: "POST",
      body: { chat_id: chatId, title: cleanTitle },
    },
  ]

  let lastError = null

  for(const attempt of attempts){
    try{
      return await fetchJson(attempt.url, {
        method: attempt.method,
        headers: {
          ...JSON_HEADERS,
          "Content-Type": "application/json",
        },
        body: JSON.stringify(attempt.body),
      })
    }catch(error){
      lastError = error

      if(error?.status === 404 || error?.status === 405){
        continue
      }

      throw error
    }
  }

  throw lastError || new Error("Failed to rename chat.")
}

async function deleteChat(chatId){
  if(!chatId){
    throw new Error("chatId is required")
  }

  return fetchJson(`/api/chats/${encodeURIComponent(chatId)}`, {
    method: "DELETE",
  })
}

async function streamChat(payload = {}){
  const {
    chat_id,
    chatId,
    message,
    files = [],
    signal,
  } = payload

  const resolvedChatId = chat_id || chatId
  const cleanMessage = String(message ?? "")
  const safeFiles = Array.isArray(files) ? files.filter(Boolean) : []

  if(!resolvedChatId){
    throw new Error("chat_id required")
  }

  if(!cleanMessage.trim() && safeFiles.length === 0){
    throw new Error("message is required")
  }

  const formData = new FormData()
  formData.append("chat_id", String(resolvedChatId))
  formData.append("message", cleanMessage)

  safeFiles.forEach((file) => {
    formData.append("files", file)
  })

  const response = await fetch("/api/chat/stream", {
    method: "POST",
    body: formData,
    signal,
    headers: {
      "Accept": "text/event-stream",
    },
  })

  if(!response.ok){
    throw await buildHttpError(response)
  }

  return response
}

async function fetchJson(url, options = {}){
  const response = await fetch(url, {
    ...options,
    headers: {
      ...JSON_HEADERS,
      ...(options.headers || {}),
    },
  })

  if(!response.ok){
    throw await buildHttpError(response)
  }

  const contentType = response.headers.get("content-type") || ""

  if(contentType.includes("application/json")){
    return response.json()
  }

  const text = await response.text()

  try{
    return JSON.parse(text)
  }catch(_error){
    return {
      ok: true,
      raw: text,
    }
  }
}

async function buildHttpError(response){
  const status = response?.status || 500
  const fallback = `HTTP ${status}`
  let text = ""

  try{
    text = await response.text()
  }catch(_error){
    text = ""
  }

  let message = fallback

  if(text){
    try{
      const data = JSON.parse(text)
      message =
        data?.error ||
        data?.message ||
        data?.detail ||
        fallback
    }catch(_error){
      message = text.trim() || fallback
    }
  }

  const error = new Error(message)
  error.status = status
  error.responseText = text
  return error
}

window.NovaAPI = {
  listChats,
  getChat,
  getMessages,
  createChat,
  renameChat,
  deleteChat,
  streamChat,
}

})()