(() => {
"use strict"

function createStreamService(options = {}){
  const {
    state,
    api,
    chatService,
    messageService,
    renderService,
    attachmentsService,
  } = options

  if(!state){
    throw new Error("NovaStreamService: state is required")
  }

  if(!api){
    throw new Error("NovaStreamService: api is required")
  }

  if(!messageService){
    throw new Error("NovaStreamService: messageService is required")
  }

  function setAbortController(controller){
    state.streamAbortController = controller || null
    return state.streamAbortController
  }

  function getAbortController(){
    return state.streamAbortController || null
  }

  function abortActiveStream(){
    const controller = getAbortController()

    if(controller){
      try {
        controller.abort()
      } catch(error){
        console.error("Nova abortActiveStream error:", error)
      }
    }

    state.isStreaming = false
    state.streamingMessageId = ""
    setAbortController(null)
  }

  function rerenderAll(){
    try {
      renderService?.renderAll?.()
    } catch(error){
      console.error("Nova rerenderAll error:", error)
    }
  }

  function rerenderMessages(forceScroll = false){
    try {
      renderService?.renderMessages?.()
      renderService?.renderComposerState?.()
      renderService?.renderChatList?.()
      renderService?.renderHeader?.()
      renderService?.scrollMessagesToBottomIfNeeded?.(forceScroll)
    } catch(error){
      console.error("Nova rerenderMessages error:", error)
    }
  }

  function ensureActiveChatId(chatIdFromEvent){
    const incoming = String(chatIdFromEvent || "").trim()

    if(incoming){
      if(chatService?.setActiveChat){
        chatService.setActiveChat(incoming)
      } else {
        state.activeChatId = incoming
        state.chatId = incoming
      }
      return incoming
    }

    return String(state.activeChatId || state.chatId || "").trim()
  }

  function upsertChatTimestamp(chatId){
    const targetChatId = String(chatId || "").trim()

    if(!targetChatId || !chatService?.upsertChat){
      return
    }

    const existing = Array.isArray(state.chats)
      ? state.chats.find(chat => String(chat.chat_id || "") === targetChatId)
      : null

    chatService.upsertChat({
      ...(existing || {}),
      chat_id: targetChatId,
      title: String(existing?.title || "New chat"),
      updated: new Date().toISOString(),
    })
  }

  function createAssistantPlaceholder(){
    return messageService.createAssistantPlaceholder
      ? messageService.createAssistantPlaceholder()
      : {
          id: `assistant-${Date.now()}-${Math.random().toString(16).slice(2)}`,
          role: "assistant",
          content: "",
          created_at: new Date().toISOString(),
          status: "streaming",
          attachments: [],
          error: "",
        }
  }

  function createSystemMessage(text){
    return messageService.createSystemMessage
      ? messageService.createSystemMessage(text)
      : {
          id: `system-${Date.now()}-${Math.random().toString(16).slice(2)}`,
          role: "system",
          content: String(text || ""),
          created_at: new Date().toISOString(),
          status: "done",
          attachments: [],
          error: "",
        }
  }

  function cloneFilesForUserMessage(files = []){
    return (Array.isArray(files) ? files : []).map(item => {
      if(item?.file instanceof File){
        return {
          id: String(item.id || ""),
          name: String(item.name || item.file.name || "attachment"),
          filename: String(item.name || item.file.name || "attachment"),
          content_type: String(item.type || item.file.type || "application/octet-stream"),
          size: Number(item.size ?? item.file.size ?? 0),
        }
      }

      if(item instanceof File){
        return {
          id: "",
          name: String(item.name || "attachment"),
          filename: String(item.name || "attachment"),
          content_type: String(item.type || "application/octet-stream"),
          size: Number(item.size || 0),
        }
      }

      return {
        id: String(item?.id || ""),
        name: String(item?.name || item?.filename || "attachment"),
        filename: String(item?.filename || item?.name || "attachment"),
        content_type: String(item?.content_type || item?.type || "application/octet-stream"),
        size: Number(item?.size || 0),
      }
    })
  }

  async function sendMessage(options = {}){
    const chatId = String(options.chatId || options.chat_id || state.activeChatId || state.chatId || "").trim()
    const messageText = String(options.message || "")
    const files = Array.isArray(options.files) ? options.files : []

    if(!messageText.trim() && files.length === 0){
      throw new Error("NovaStreamService: message or files required")
    }

    if(state.isStreaming){
      abortActiveStream()
    }

    const controller = new AbortController()
    setAbortController(controller)

    state.isStreaming = true

    const userMessage = messageService.addMessage({
      role: "user",
      content: messageText,
      created_at: new Date().toISOString(),
      status: "sent",
      attachments: cloneFilesForUserMessage(files),
    })

    const assistantMessage = messageService.addMessage(createAssistantPlaceholder())

    state.streamingMessageId = assistantMessage.id

    ensureActiveChatId(chatId)
    upsertChatTimestamp(chatId)
    rerenderMessages(true)

    let receivedAnyStreamEvent = false

    try {
      await api.streamChat({
        chat_id: chatId,
        message: messageText,
        files,
        signal: controller.signal,
        onEvent(event = {}){
          receivedAnyStreamEvent = true

          const eventType = String(event.event || "").toLowerCase()
          const data = event.data && typeof event.data === "object" ? event.data : {}

          if(eventType === "meta"){
            const resolvedChatId = ensureActiveChatId(data.chat_id || chatId)

            if(data.user_message_id){
              messageService.patchMessage(userMessage.id, {
                message_id: String(data.user_message_id),
              })
            }

            if(data.assistant_message_id){
              messageService.patchMessage(assistantMessage.id, {
                message_id: String(data.assistant_message_id),
              })
            }

            if(Array.isArray(data.attachments) && data.attachments.length){
              messageService.patchMessage(userMessage.id, {
                attachments: data.attachments,
              })
            }

            upsertChatTimestamp(resolvedChatId)
            rerenderMessages(true)
            return
          }

          if(eventType === "token"){
            const token = String(data.t || data.token || "")

            if(token){
              messageService.appendToMessageContent(assistantMessage.id, token)
              messageService.setMessageStatus(assistantMessage.id, "streaming")
              rerenderMessages(true)
            }
            return
          }

          if(eventType === "done"){
            if(typeof data.full_text === "string"){
              messageService.setMessageContent(assistantMessage.id, data.full_text)
            }

            messageService.patchMessage(assistantMessage.id, {
              status: "done",
              error: "",
            })

            ensureActiveChatId(data.chat_id || chatId)
            upsertChatTimestamp(data.chat_id || chatId)

            try {
              attachmentsService?.clearPendingFiles?.()
            } catch(error){
              console.error("Nova clearPendingFiles error:", error)
            }

            rerenderMessages(true)
            return
          }

          if(eventType === "error"){
            const errorText = String(data.error || data.message || "Stream error.")

            messageService.patchMessage(assistantMessage.id, {
              content: String(messageService.getMessageById(assistantMessage.id)?.content || "") || `⚠️ ${errorText}`,
              status: "error",
              error: errorText,
            })

            rerenderMessages(true)
          }
        },
      })

      const currentAssistant = messageService.getMessageById(assistantMessage.id)

      if(currentAssistant && !String(currentAssistant.content || "").trim() && !receivedAnyStreamEvent){
        messageService.patchMessage(assistantMessage.id, {
          content: "⚠️ No response was returned from the server.",
          status: "error",
          error: "No response was returned from the server.",
        })
      } else if(currentAssistant && String(currentAssistant.status || "") === "streaming"){
        messageService.patchMessage(assistantMessage.id, {
          status: "done",
        })
      }

      rerenderMessages(true)

      return {
        ok: true,
        userMessageId: userMessage.id,
        assistantMessageId: assistantMessage.id,
      }
    } catch(error){
      const wasAborted =
        error?.name === "AbortError" ||
        /abort/i.test(String(error?.message || ""))

      if(wasAborted){
        const currentAssistant = messageService.getMessageById(assistantMessage.id)

        if(currentAssistant && !String(currentAssistant.content || "").trim()){
          messageService.removeMessage(assistantMessage.id)
        } else {
          messageService.patchMessage(assistantMessage.id, {
            status: "done",
          })
        }

        state.isStreaming = false
        state.streamingMessageId = ""
        setAbortController(null)
        rerenderMessages(true)

        return {
          ok: false,
          aborted: true,
        }
      }

      console.error("Nova stream sendMessage error:", error)

      messageService.patchMessage(assistantMessage.id, {
        content: String(messageService.getMessageById(assistantMessage.id)?.content || "") || `⚠️ ${error?.message || "Network/stream error."}`,
        status: "error",
        error: String(error?.message || "Network/stream error."),
      })

      messageService.addMessage(createSystemMessage(`⚠️ Send failed: ${error?.message || "Unknown error"}`))
      rerenderMessages(true)

      return {
        ok: false,
        error,
      }
    } finally {
      state.isStreaming = false
      state.streamingMessageId = ""
      setAbortController(null)
      rerenderAll()
    }
  }

  return {
    sendMessage,
    abortActiveStream,
    getAbortController,
    setAbortController,
  }
}

window.NovaStreamService = {
  createStreamService,
}

})()