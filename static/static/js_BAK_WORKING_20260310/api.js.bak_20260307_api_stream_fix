(() => {
"use strict"

function createApi(options = {}){
  const baseUrl = String(options.baseUrl || "/api").replace(/\/+$/, "")

  async function request(path, requestOptions = {}){
    const response = await fetch(`${baseUrl}${path}`, {
      credentials: "same-origin",
      ...requestOptions,
    })

    const contentType = String(response.headers.get("content-type") || "").toLowerCase()

    if(!response.ok){
      let message = `HTTP ${response.status}`

      try {
        if(contentType.includes("application/json")){
          const errorData = await response.json()
          message = String(
            errorData?.error ||
            errorData?.message ||
            message
          )
        } else {
          const errorText = await response.text()
          if(errorText.trim()){
            message = `HTTP ${response.status} - ${errorText.trim()}`
          }
        }
      } catch(_error){
      }

      throw new Error(message)
    }

    if(contentType.includes("application/json")){
      return response.json()
    }

    return response.text()
  }

  function parseEventData(raw){
    const text = String(raw || "").trim()

    if(!text){
      return {}
    }

    try {
      return JSON.parse(text)
    } catch(_error){
      return { text }
    }
  }

  async function getChats(){
    return request("/chats", {
      method: "GET",
    })
  }

  async function getChat(chatId){
    const id = encodeURIComponent(String(chatId || "").trim())

    if(!id){
      throw new Error("chatId is required")
    }

    return request(`/chats/${id}`, {
      method: "GET",
    })
  }

  async function createChat(title = ""){
    return request("/chats", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        title: String(title || "New chat"),
      }),
    })
  }

  async function renameChat(chatId, title){
    const id = encodeURIComponent(String(chatId || "").trim())

    if(!id){
      throw new Error("chatId is required")
    }

    return request(`/chats/${id}`, {
      method: "PATCH",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        title: String(title || "").trim(),
      }),
    })
  }

  async function deleteChat(chatId){
    const id = encodeURIComponent(String(chatId || "").trim())

    if(!id){
      throw new Error("chatId is required")
    }

    return request(`/chats/${id}`, {
      method: "DELETE",
    })
  }

  async function streamChat(options = {}){
    const chatId = String(options.chat_id || "").trim()
    const message = String(options.message || "")
    const files = Array.isArray(options.files) ? options.files : []
    const signal = options.signal
    const onEvent = typeof options.onEvent === "function" ? options.onEvent : () => {}

    if(!message.trim() && files.length === 0){
      throw new Error("message is required")
    }

    const form = new FormData()
    form.append("chat_id", chatId)
    form.append("message", message)

    for(const item of files){
      if(item instanceof File){
        form.append("files", item, item.name)
        continue
      }

      if(item?.file instanceof File){
        form.append("files", item.file, item.file.name)
      }
    }

    const response = await fetch(`${baseUrl}/chat/stream`, {
      method: "POST",
      body: form,
      signal,
      credentials: "same-origin",
      headers: {
        "Accept": "text/event-stream",
      },
    })

    if(!response.ok){
      let messageText = `HTTP ${response.status}`

      try {
        const contentType = String(response.headers.get("content-type") || "").toLowerCase()

        if(contentType.includes("application/json")){
          const errorData = await response.json()
          messageText = String(
            errorData?.error ||
            errorData?.message ||
            messageText
          )
        } else {
          const errorText = await response.text()
          if(errorText.trim()){
            messageText = `HTTP ${response.status} - ${errorText.trim()}`
          }
        }
      } catch(_error){
      }

      throw new Error(messageText)
    }

    if(!response.body){
      throw new Error("Streaming response body is missing")
    }

    const reader = response.body.getReader()
    const decoder = new TextDecoder("utf-8")

    let buffer = ""
    let eventName = "message"
    let dataLines = []

    function flushEvent(){
      const payload = dataLines.join("\n")
      const parsed = parseEventData(payload)

      onEvent({
        event: eventName || "message",
        data: parsed,
        raw: payload,
      })

      eventName = "message"
      dataLines = []
    }

    while(true){
      const { value, done } = await reader.read()

      if(done){
        if(dataLines.length){
          flushEvent()
        }
        break
      }

      buffer += decoder.decode(value, { stream: true })

      while(true){
        const newlineIndex = buffer.indexOf("\n")

        if(newlineIndex < 0){
          break
        }

        let line = buffer.slice(0, newlineIndex)
        buffer = buffer.slice(newlineIndex + 1)

        if(line.endsWith("\r")){
          line = line.slice(0, -1)
        }

        if(!line){
          if(dataLines.length){
            flushEvent()
          }
          continue
        }

        if(line.startsWith(":")){
          continue
        }

        if(line.startsWith("event:")){
          eventName = line.slice(6).trim() || "message"
          continue
        }

        if(line.startsWith("data:")){
          dataLines.push(line.slice(5).trimStart())
        }
      }
    }

    return true
  }

  return {
    getChats,
    getChat,
    createChat,
    renameChat,
    deleteChat,
    streamChat,
  }
}

window.NovaApi = {
  createApi,
}

})()