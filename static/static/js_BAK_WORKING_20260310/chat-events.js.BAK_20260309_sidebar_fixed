(() => {
"use strict"

function createChatEventsService(options = {}){
  const {
    elements = {},
    actions = {},
    ui = {},
  } = options

  const el = {
    mobileOverlay: elements.mobileOverlay || null,
    btnSidebarToggle: elements.btnSidebarToggle || null,
    btnCloseSidebar: elements.btnCloseSidebar || null,
    btnNewChat: elements.btnNewChat || null,
    chatList: elements.chatList || null,
    messagesScroll: elements.messagesScroll || null,
    composerForm: elements.composerForm || null,
    input: elements.input || null,
    sendBtn: elements.sendBtn || null,
    stopBtn: elements.stopBtn || null,
    attachBtn: elements.attachBtn || null,
    jumpToLatestBtn: elements.jumpToLatestBtn || null,
    emptySuggestions: elements.emptySuggestions || null,
    pendingAttachments: elements.pendingAttachments || null,
    messages: elements.messages || null,
  }

  function wireDomEvents(){
    window.addEventListener("resize", () => {
      actions.onResize?.()
    })

    el.btnSidebarToggle?.addEventListener("click", (event) => {
      event.preventDefault()
      ui.openSidebar?.()
    })

    el.btnCloseSidebar?.addEventListener("click", (event) => {
      event.preventDefault()
      ui.closeSidebar?.()
    })

    el.mobileOverlay?.addEventListener("click", (event) => {
      event.preventDefault()
      ui.closeSidebar?.()
    })

    el.btnNewChat?.addEventListener("click", async (event) => {
      event.preventDefault()
      await actions.createChat?.()
      ui.closeSidebar?.()
    })

    el.messagesScroll?.addEventListener("scroll", () => {
      ui.handleMessagesScroll?.()
    })

    el.input?.addEventListener("input", () => {
      actions.saveDraftForActiveChat?.()
      actions.updateComposerState?.()
      ui.autoResizeInput?.()
    })

    el.input?.addEventListener("keydown", async (event) => {
      if(event.key === "Enter" && !event.shiftKey){
        event.preventDefault()
        await actions.sendCurrentMessage?.()
      }
    })

    el.composerForm?.addEventListener("submit", async (event) => {
      event.preventDefault()
      await actions.sendCurrentMessage?.()
    })

    el.sendBtn?.addEventListener("click", async (event) => {
      event.preventDefault()
      await actions.sendCurrentMessage?.()
    })

    el.stopBtn?.addEventListener("click", (event) => {
      event.preventDefault()
      actions.stopStreaming?.()
    })

    el.attachBtn?.addEventListener("click", (event) => {
      event.preventDefault()
      actions.openFilePicker?.()
    })

    el.jumpToLatestBtn?.addEventListener("click", (event) => {
      event.preventDefault()
      ui.scrollToBottom?.(true)
    })

    el.emptySuggestions?.addEventListener("click", async (event) => {
      const button = event.target.closest("[data-prompt]")
      if(!button || !el.input){
        return
      }

      el.input.value = String(button.dataset.prompt || "")
      actions.saveDraftForActiveChat?.()
      actions.updateComposerState?.()
      ui.autoResizeInput?.()
      ui.focusInput?.()
    })

    el.chatList?.addEventListener("click", async (event) => {
      const deleteButton = event.target.closest("[data-action='delete-chat']")
      if(deleteButton){
        event.preventDefault()
        event.stopPropagation()
        await actions.deleteChat?.(deleteButton.dataset.chatId)
        return
      }

      const renameButton = event.target.closest("[data-action='rename-chat']")
      if(renameButton){
        event.preventDefault()
        event.stopPropagation()
        actions.startRenameChat?.(renameButton.dataset.chatId)
        return
      }

      const chatButton = event.target.closest("[data-chat-id]")
      if(chatButton){
        event.preventDefault()
        await actions.loadChat?.(chatButton.dataset.chatId)
        ui.closeSidebar?.()
      }
    })

    el.chatList?.addEventListener("keydown", async (event) => {
      const renameInput = event.target.closest(".chat-rename-input")
      if(!renameInput){
        return
      }

      if(event.key === "Enter"){
        event.preventDefault()
        await actions.commitRenameFromInput?.(renameInput)
      }else if(event.key === "Escape"){
        event.preventDefault()
        actions.cancelRenameChat?.()
      }
    })

    el.chatList?.addEventListener("focusout", async (event) => {
      const renameInput = event.target.closest(".chat-rename-input")
      if(!renameInput){
        return
      }

      await actions.commitRenameFromInput?.(renameInput)
    })

    el.pendingAttachments?.addEventListener("click", (event) => {
      const removeButton = event.target.closest("[data-remove-pending-index]")
      if(!removeButton){
        return
      }

      event.preventDefault()
      actions.removePendingFileByIndex?.(removeButton.dataset.removePendingIndex)
    })

    el.messages?.addEventListener("click", async (event) => {
      const copyButton = event.target.closest("[data-action='copy-message']")
      if(copyButton){
        event.preventDefault()
        await actions.copyMessage?.(copyButton.dataset.messageId)
        return
      }

      const retryButton = event.target.closest("[data-action='retry-message']")
      if(retryButton){
        event.preventDefault()
        await actions.retryFromMessage?.(retryButton.dataset.messageId)
        return
      }

      const deleteButton = event.target.closest("[data-action='delete-message']")
      if(deleteButton){
        event.preventDefault()
        actions.deleteMessage?.(deleteButton.dataset.messageId)
      }
    })
  }

  return {
    wireDomEvents,
  }
}

window.NovaChatEvents = {
  create: createChatEventsService,
  createChatEventsService,
}

})()