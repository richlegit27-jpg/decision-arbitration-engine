(() => {
"use strict"

function createChatService(options = {}){
  const {
    state,
    api,
    elements = {},
    renderService,
  } = options

  const apiClient = api || window.NovaAPI

  if(!state){
    throw new Error("NovaChatService: state is required")
  }

  if(!apiClient){
    throw new Error("NovaChatService: api is required")
  }

  function ensureChatsArray(){
    if(!Array.isArray(state.chats)){
      state.chats = []
    }

    return state.chats
  }

  function ensureMessagesArray(){
    if(!Array.isArray(state.messages)){
      state.messages = []
    }

    return state.messages
  }

  function normalizeChat(raw = {}){
    return {
      chat_id: raw.chat_id || raw.id || raw.chat?.chat_id || "",
      title: raw.title || raw.chat?.title || "New chat",
      updated_at:
        raw.updated_at ||
        raw.updated ||
        raw.chat?.updated_at ||
        raw.chat?.updated ||
        new Date().toISOString(),
    }
  }

  function normalizeMessage(raw = {}){
    return {
      message_id: raw.message_id || raw.id || "",
      id: raw.id || raw.message_id || "",
      role: raw.role || "assistant",
      content: raw.content || "",
      created_at: raw.created_at || raw.created || new Date().toISOString(),
      pending: !!raw.pending,
      streaming: !!raw.streaming,
      thinking: !!raw.thinking,
      error: raw.error || "",
      attachments: Array.isArray(raw.attachments) ? raw.attachments : [],
    }
  }

  async function listChats(){
    const rawChats = await apiClient.listChats()
    const chats = Array.isArray(rawChats) ? rawChats.map(normalizeChat) : []
    state.chats = chats
    renderService?.renderChats?.()
    return chats
  }

  async function loadChats(){
    return listChats()
  }

  async function getMessages(chatId){
    if(!chatId){
      return []
    }

    const rawMessages = await apiClient.getMessages(chatId)
    const messages = Array.isArray(rawMessages) ? rawMessages.map(normalizeMessage) : []
    state.messages = messages
    renderService?.renderMessages?.()
    return messages
  }

  async function loadChat(chatId){
    return getMessages(chatId)
  }

  async function createChat(payload = {}){
    const response = await apiClient.createChat(payload)

    const rawChat =
      response?.chat ||
      response?.data?.chat ||
      response

    const chat = normalizeChat(rawChat)

    if(!chat.chat_id){
      throw new Error("NovaChatService.createChat: missing chat_id in response")
    }

    const chats = ensureChatsArray()
    const exists = chats.some((item) => String(item.chat_id) === String(chat.chat_id))

    if(!exists){
      chats.unshift(chat)
    }else{
      const existing = chats.find((item) => String(item.chat_id) === String(chat.chat_id))
      Object.assign(existing, chat)
    }

    state.activeChatId = chat.chat_id
    state.chatId = chat.chat_id
    ensureMessagesArray()
    renderService?.renderChats?.()

    return chat
  }

  async function renameChat(chatId, title){
    const response = await apiClient.renameChat(chatId, title)

    const chats = ensureChatsArray()
    const target = chats.find((chat) => String(chat.chat_id) === String(chatId))

    if(target){
      target.title = String(title || target.title || "New chat").trim() || "New chat"
      target.updated_at = new Date().toISOString()
    }

    renderService?.renderChats?.()
    return response
  }

  async function deleteChat(chatId){
    const response = await apiClient.deleteChat(chatId)

    state.chats = ensureChatsArray().filter((chat) => String(chat.chat_id) !== String(chatId))

    if(String(state.activeChatId || "") === String(chatId)){
      state.activeChatId = null
      state.chatId = null
      state.messages = []
      renderService?.renderMessages?.()
    }

    renderService?.renderChats?.()
    return response
  }

  return {
    listChats,
    loadChats,
    getMessages,
    loadChat,
    createChat,
    renameChat,
    deleteChat,
  }
}

window.NovaChatService = {
  create: createChatService,
  createChatService
}

})()