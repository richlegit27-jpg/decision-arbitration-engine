(() => {
"use strict"

const state = window.NovaState || {}
const api = window.NovaAPI || null

if(!state || !api){
  console.error("Nova boot failed: missing state or api")
  return
}

function byId(...ids){
  for(const id of ids){
    const el = document.getElementById(id)
    if(el){
      return el
    }
  }
  return null
}

function toChatId(value){
  return String(value?.chat_id || value?.id || value || "").trim()
}

function getActiveChatId(){
  return String(state.activeChatId || state.chatId || "").trim()
}

function getChats(){
  return Array.isArray(state.chats) ? state.chats : []
}

function getNewestChatId(previousIds = []){
  const previous = new Set(previousIds.map(String))
  const chats = getChats()

  const fresh = chats.find((chat) => !previous.has(toChatId(chat)))
  if(fresh){
    return toChatId(fresh)
  }

  if(chats.length > 0){
    return toChatId(chats[0])
  }

  return ""
}

const el = {
  sidebar: byId("sidebar"),
  mobileOverlay: byId("mobileOverlay"),
  btnSidebarToggle: byId("btnSidebarToggle"),
  btnNewChat: byId("btnNewChat"),
  btnSettings: byId("btnSettings"),
  chatList: byId("chatList"),
  messages: byId("messages"),
  input: byId("input", "messageInput"),
  sendBtn: byId("sendBtn"),
  stopBtn: byId("stopBtn"),
  attachBtn: byId("attachBtn"),
  fileInput: byId("fileInput"),
  composerForm: byId("composerForm"),
  chatTitle: byId("chatTitle", "topbarTitle")
}

const renderService = window.NovaRenderService?.create?.({
  state,
  elements: {
    messages: el.messages,
    chatList: el.chatList,
    chatTitle: el.chatTitle
  }
})

const chatService = window.NovaChatService?.create?.({
  state,
  api,
  elements: {
    chatList: el.chatList
  }
})

const attachmentsService = window.NovaAttachmentsService?.create?.({
  state,
  elements: {
    attachBtn: el.attachBtn,
    fileInput: el.fileInput
  }
})

const streamService = window.NovaStreamService?.create?.({
  state,
  api,
  onStart(meta){
    try{
      renderService?.setStreaming?.(meta)
    }catch(error){
      console.error("setStreaming failed:", error)
    }
  },
  onMeta(meta){
    try{
      renderService?.setStreaming?.(meta)
    }catch(error){
      console.error("setStreaming(meta) failed:", error)
    }
  },
  onToken(token){
    try{
      renderService?.appendToken?.(token)
    }catch(error){
      console.error("appendToken failed:", error)
    }
  },
  onDone(payload){
    try{
      renderService?.finishStreaming?.(payload)
    }catch(error){
      console.error("finishStreaming failed:", error)
    }
  },
  onError(error){
    try{
      renderService?.renderError?.(error)
    }catch(renderError){
      console.error("renderError failed:", renderError)
      console.error("Stream error:", error)
    }
  },
  onFinally(){
    try{
      renderService?.scrollToBottom?.()
    }catch(error){
      console.error("scrollToBottom failed:", error)
    }
  }
})

const composerService = window.NovaComposerService?.create?.({
  state,
  elements: {
    input: el.input,
    sendBtn: el.sendBtn,
    stopBtn: el.stopBtn,
    attachBtn: el.attachBtn,
    fileInput: el.fileInput,
    composerForm: el.composerForm
  },
  attachmentsService,
  streamService,
  renderService,
  chatService
})

function openSidebar(){
  el.sidebar?.classList.add("is-open")
  el.mobileOverlay?.classList.add("is-visible")
}

function closeSidebar(){
  el.sidebar?.classList.remove("is-open")
  el.mobileOverlay?.classList.remove("is-visible")
}

function toggleSidebar(){
  el.sidebar?.classList.toggle("is-open")
  el.mobileOverlay?.classList.toggle("is-visible")
}

async function safeListChats(){
  try{
    await chatService?.listChats?.()
  }catch(err){
    console.error("listChats failed", err)
  }
}

async function safeLoadChat(chatId){
  if(!chatId){
    return
  }

  try{
    if(typeof chatService?.loadChat === "function"){
      await chatService.loadChat(chatId)
      return
    }

    if(typeof chatService?.getMessages === "function"){
      const messages = await chatService.getMessages(chatId)
      state.activeChatId = chatId
      state.chatId = chatId
      state.messages = Array.isArray(messages) ? messages : []
      renderService?.renderAll?.()
      return
    }

    console.warn("No loadChat/getMessages method found on chatService.")
  }catch(err){
    console.error("loadChat failed", err)
  }
}

async function createNewChat(){
  const beforeIds = getChats().map((chat) => toChatId(chat))

  try{
    if(typeof chatService?.createChat !== "function"){
      console.error("createChat is not available on chatService")
      return
    }

    const result = await chatService.createChat()
    const returnedId = toChatId(result)

    state.messages = []

    await safeListChats()

    const newId = returnedId || getNewestChatId(beforeIds)

    if(newId){
      state.activeChatId = newId
      state.chatId = newId
      await safeLoadChat(newId)
    }else{
      state.activeChatId = null
      state.chatId = null
      state.messages = []
      renderService?.renderAll?.()
    }

    if(el.input){
      el.input.value = ""
      el.input.focus()
    }

    closeSidebar()
  }catch(err){
    console.error("create chat failed", err)
  }
}

async function renameChatById(chatId){
  const id = String(chatId || getActiveChatId()).trim()
  if(!id){
    return
  }

  const current =
    getChats().find((x) => toChatId(x) === id) || null

  const currentTitle = String(current?.title || "New chat")
  const nextTitle = window.prompt("Rename chat", currentTitle)

  if(nextTitle == null){
    return
  }

  const clean = nextTitle.trim()
  if(!clean){
    return
  }

  if(Array.isArray(state.chats)){
    const chat = state.chats.find((x) => toChatId(x) === id)
    if(chat){
      chat.title = clean
    }
  }

  if(el.chatTitle && getActiveChatId() === id){
    el.chatTitle.textContent = clean
  }

  renderService?.renderAll?.()

  try{
    await chatService?.renameChat?.(id, clean)
    await safeListChats()
    renderService?.renderAll?.()
  }catch(err){
    console.error("rename failed", err)
  }
}

async function deleteChatById(chatId){
  const id = String(chatId || getActiveChatId()).trim()
  if(!id){
    return
  }

  if(!window.confirm("Delete this chat?")){
    return
  }

  const wasActive = getActiveChatId() === id

  if(Array.isArray(state.chats)){
    state.chats = state.chats.filter((x) => toChatId(x) !== id)
  }

  if(wasActive){
    state.activeChatId = null
    state.chatId = null
    state.messages = []
    if(el.chatTitle){
      el.chatTitle.textContent = "New chat"
    }
  }

  renderService?.renderAll?.()

  try{
    await chatService?.deleteChat?.(id)
    await safeListChats()
    renderService?.renderAll?.()
  }catch(err){
    console.error("delete failed", err)
  }

  closeSidebar()
}

el.btnSidebarToggle?.addEventListener("click", toggleSidebar)
el.mobileOverlay?.addEventListener("click", closeSidebar)

el.btnNewChat?.addEventListener("click", async () => {
  try{
    state.activeChatId = ""
    state.chatId = ""
    state.messages = []

    if(Array.isArray(state.pendingAttachments)){
      state.pendingAttachments = []
    }

    if(Array.isArray(state.pendingFiles)){
      state.pendingFiles = []
    }

    if(el.input){
      el.input.value = ""
      el.input.focus()
    }

    if(el.fileInput){
      el.fileInput.value = ""
    }

    if(el.chatTitle){
      el.chatTitle.textContent = "New chat"
    }

    renderService?.renderAll?.()
    closeSidebar()
  }catch(error){
    console.error("New chat reset failed:", error)
  }
})

el.btnSettings?.addEventListener("click", () => {
  const panel = byId("settingsDialog", "settingsModal", "settingsPanel")

  if(panel?.showModal){
    panel.showModal()
  }else if(panel){
    panel.classList.toggle("is-open")
  }else{
    console.warn("Settings panel not found.")
  }
})

el.chatList?.addEventListener("click", async (event) => {
  const actionBtn = event.target.closest("[data-chat-action]")

  if(actionBtn){
    const action = String(actionBtn.dataset.chatAction || "").toLowerCase()
    const chatId =
      actionBtn.dataset.chatId ||
      actionBtn.closest("[data-chat-id]")?.dataset.chatId ||
      ""

    if(action === "rename"){
      await renameChatById(chatId)
      return
    }

    if(action === "delete"){
      await deleteChatById(chatId)
      return
    }

    if(action === "open"){
      await safeLoadChat(chatId)
      closeSidebar()
      return
    }
  }

  const item = event.target.closest("[data-chat-id]")
  if(!item){
    return
  }

  const chatId = String(item.dataset.chatId || "").trim()
  if(!chatId){
    return
  }

  await safeLoadChat(chatId)
  closeSidebar()
})

window.addEventListener("keydown", (event) => {
  if(event.key === "Escape"){
    closeSidebar()
  }
})

window.NovaChat = {
  state,
  elements: el,
  renderService,
  chatService,
  composerService,
  streamService,
  createNewChat,
  renameChatById,
  deleteChatById,
  openSidebar,
  closeSidebar,
  toggleSidebar
}

;(async () => {
  await safeListChats()
  renderService?.renderAll?.()
})()

})()