(() => {
"use strict"

const chatStateApi = window.NovaChatState

if(!chatStateApi){
  throw new Error("NovaChatMessages: window.NovaChatState is required")
}

const { state } = chatStateApi

const el = {
  messages: document.getElementById("messages"),
  messagesScroll: document.getElementById("messagesScroll"),
  emptyState: document.getElementById("emptyState"),
  jumpToLatestBtn: document.getElementById("jumpToLatestBtn"),
}

const SCROLL_LOCK_THRESHOLD = 140
const COPY_FEEDBACK_MS = 1200
const COPY_CODE_FEEDBACK_MS = 1200

let eventsBound = false
let thinkingIndicatorId = ""
let copiedMessageId = ""
let copyFeedbackTimer = null
let copiedCodeKey = ""
let copyCodeFeedbackTimer = null
let finishedStreamingMessageIds = new Set()

let callbacks = {
  onRetry: null,
  onDelete: null,
  onEdit: null,
}

function ensureMessagesArray(){
  if(!Array.isArray(state.messages)){
    state.messages = []
  }
  return state.messages
}

function escapeHtml(value){
  return String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;")
}

function getMessageId(message){
  return String(message?.message_id || message?.id || "").trim()
}

function getMessageRole(message){
  return String(message?.role || "assistant").toLowerCase() === "user"
    ? "user"
    : "assistant"
}

function getDistanceFromBottom(){
  if(!el.messagesScroll){
    return 0
  }

  return el.messagesScroll.scrollHeight - el.messagesScroll.scrollTop - el.messagesScroll.clientHeight
}

function isNearBottom(){
  return getDistanceFromBottom() <= SCROLL_LOCK_THRESHOLD
}

function updateUserScrolledState(){
  state.userScrolledUp = !isNearBottom()
  updateJumpButton()
}

function updateJumpButton(){
  if(!el.jumpToLatestBtn){
    return
  }

  const hasMessages = ensureMessagesArray().length > 0 || !!thinkingIndicatorId
  el.jumpToLatestBtn.hidden = !hasMessages || !state.userScrolledUp
}

function normalizeAttachment(att = {}){
  const name = String(att?.filename || att?.name || "file")
  const href = String(att?.url || att?.storage_path || att?.path || "").trim()
  const meta = String(att?.mime_type || att?.type || "").trim()
  const size = Number(att?.size || att?.bytes || 0)

  return {
    name,
    href,
    meta,
    size,
  }
}

function formatBytes(bytes){
  const value = Number(bytes || 0)

  if(!Number.isFinite(value) || value <= 0){
    return ""
  }

  const units = ["B", "KB", "MB", "GB", "TB"]
  let size = value
  let unitIndex = 0

  while(size >= 1024 && unitIndex < units.length - 1){
    size /= 1024
    unitIndex += 1
  }

  if(unitIndex === 0){
    return `${Math.round(size)} ${units[unitIndex]}`
  }

  return `${size.toFixed(size >= 10 ? 0 : 1)} ${units[unitIndex]}`
}

function buildAttachmentMeta(att){
  const normalized = normalizeAttachment(att)
  const parts = []

  if(normalized.meta){
    parts.push(normalized.meta)
  }

  const sizeText = formatBytes(normalized.size)
  if(sizeText){
    parts.push(sizeText)
  }

  return parts.join(" • ")
}

function isImageAttachment(att = {}){
  const meta = String(att?.mime_type || att?.type || "").toLowerCase()
  const name = String(att?.filename || att?.name || "").toLowerCase()
  const href = String(att?.url || att?.storage_path || att?.path || "").trim()

  if(!href){
    return false
  }

  return (
    meta.startsWith("image/") ||
    name.endsWith(".png") ||
    name.endsWith(".jpg") ||
    name.endsWith(".jpeg") ||
    name.endsWith(".gif") ||
    name.endsWith(".webp") ||
    name.endsWith(".bmp") ||
    name.endsWith(".svg")
  )
}

function renderAttachment(att){
  const normalized = normalizeAttachment(att)
  const safeName = escapeHtml(normalized.name)
  const safeHref = escapeHtml(normalized.href)
  const safeMeta = escapeHtml(buildAttachmentMeta(att))

  if(isImageAttachment(att)){
    return `
      <a class="message-image" href="${safeHref}" target="_blank" rel="noopener noreferrer">
        <img
          src="${safeHref}"
          alt="${safeName}"
          loading="lazy"
          data-image-fallback-name="${safeName}"
        >
      </a>
    `
  }

  if(normalized.href){
    return `
      <a class="message-attachment" href="${safeHref}" target="_blank" rel="noopener noreferrer">
        <span class="message-attachment-name">${safeName}</span>
        ${safeMeta ? `<span class="message-attachment-meta">${safeMeta}</span>` : ""}
      </a>
    `
  }

  return `
    <div class="message-attachment">
      <span class="message-attachment-name">${safeName}</span>
      ${safeMeta ? `<span class="message-attachment-meta">${safeMeta}</span>` : ""}
    </div>
  `
}

function splitCodeBlocks(text){
  const source = String(text || "")
  const parts = []
  const regex = /```([a-zA-Z0-9_#+.-]+)?\n?([\s\S]*?)```/g

  let lastIndex = 0
  let match = null

  while((match = regex.exec(source)) !== null){
    const matchIndex = match.index

    if(matchIndex > lastIndex){
      parts.push({
        type: "text",
        content: source.slice(lastIndex, matchIndex),
      })
    }

    parts.push({
      type: "code",
      language: String(match[1] || "").trim(),
      content: String(match[2] || "").replace(/\n$/, ""),
    })

    lastIndex = regex.lastIndex
  }

  if(lastIndex < source.length){
    parts.push({
      type: "text",
      content: source.slice(lastIndex),
    })
  }

  if(!parts.length){
    parts.push({
      type: "text",
      content: source,
    })
  }

  return parts
}

function applyInlineMarkdown(line){
  let html = escapeHtml(line)

  html = html.replace(
    /\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g,
    (_match, label, href) => {
      return `<a href="${escapeHtml(href)}" target="_blank" rel="noopener noreferrer">${escapeHtml(label)}</a>`
    }
  )

  html = html.replace(/`([^`]+)`/g, "<code>$1</code>")
  html = html.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
  html = html.replace(/__([^_]+)__/g, "<strong>$1</strong>")
  html = html.replace(/(^|[\s(])\*([^*\n]+)\*(?=[\s).,!?:;]|$)/g, "$1<em>$2</em>")
  html = html.replace(/(^|[\s(])_([^_\n]+)_(?=[\s).,!?:;]|$)/g, "$1<em>$2</em>")
  html = html.replace(/~~([^~]+)~~/g, "<s>$1</s>")

  return html
}

function renderTextBlock(block){
  const lines = String(block || "").split("\n")
  const htmlParts = []
  let listMode = ""

  function closeList(){
    if(listMode){
      htmlParts.push(listMode === "ol" ? "</ol>" : "</ul>")
      listMode = ""
    }
  }

  for(const rawLine of lines){
    const line = String(rawLine || "")
    const trimmed = line.trim()

    if(!trimmed){
      closeList()
      continue
    }

    const headingMatch = trimmed.match(/^(#{1,6})\s+(.*)$/)
    if(headingMatch){
      closeList()
      const level = headingMatch[1].length
      htmlParts.push(`<h${level}>${applyInlineMarkdown(headingMatch[2])}</h${level}>`)
      continue
    }

    const bulletMatch = trimmed.match(/^[-*]\s+(.*)$/)
    if(bulletMatch){
      if(listMode !== "ul"){
        closeList()
        listMode = "ul"
        htmlParts.push("<ul>")
      }
      htmlParts.push(`<li>${applyInlineMarkdown(bulletMatch[1])}</li>`)
      continue
    }

    const orderedMatch = trimmed.match(/^\d+\.\s+(.*)$/)
    if(orderedMatch){
      if(listMode !== "ol"){
        closeList()
        listMode = "ol"
        htmlParts.push("<ol>")
      }
      htmlParts.push(`<li>${applyInlineMarkdown(orderedMatch[1])}</li>`)
      continue
    }

    if(/^\>\s+/.test(trimmed)){
      closeList()
      htmlParts.push(`<blockquote>${applyInlineMarkdown(trimmed.replace(/^\>\s+/, ""))}</blockquote>`)
      continue
    }

    closeList()
    htmlParts.push(`<p>${applyInlineMarkdown(trimmed)}</p>`)
  }

  closeList()
  return htmlParts.join("")
}

function renderTextPart(text){
  const content = String(text || "")

  if(!content){
    return ""
  }

  const blocks = content.replace(/\r\n/g, "\n").split(/\n{2,}/)
  let html = blocks.map(renderTextBlock).join("")

  if(!html){
    html = `<p>${applyInlineMarkdown(content)}</p>`
  }

  return html
}

function renderCodeBlock(code, language, messageId, codeBlockIndex){
  const safeLanguage = escapeHtml(language || "")
  const safeCode = escapeHtml(code || "")
  const codeKey = `${String(messageId || "")}::${String(codeBlockIndex || 0)}`
  const copied = copiedCodeKey === codeKey

  return `
    <div class="message-code-block">
      <div class="message-code-toolbar">
        <div class="message-code-language">${safeLanguage || "code"}</div>
        <button
          type="button"
          class="message-code-copy-btn"
          data-action="copy-code"
          data-code-key="${escapeHtml(codeKey)}"
        >
          ${copied ? "Copied" : "Copy"}
        </button>
      </div>
      <pre><code>${safeCode}</code></pre>
    </div>
  `
}

function renderStreamingTail(){
  return `
    <span class="message-streaming-tail" aria-hidden="true">
      <span class="message-streaming-tail-dot"></span>
    </span>
  `
}

function formatContentToHtml(content, options = {}){
  const text = String(content || "")
  const streaming = !!options.streaming
  const messageId = String(options.messageId || "")

  if(!text && streaming){
    return renderStreamingTail()
  }

  if(!text){
    return "&nbsp;"
  }

  let seenCodeBlocks = 0

  const parts = splitCodeBlocks(text)
  let html = parts.map((part) => {
    if(part.type === "code"){
      const blockHtml = renderCodeBlock(part.content, part.language, messageId, seenCodeBlocks)
      seenCodeBlocks += 1
      return blockHtml
    }

    return renderTextPart(part.content)
  }).join("")

  if(!html){
    html = "&nbsp;"
  }

  if(streaming){
    html += renderStreamingTail()
  }

  return html
}

function renderMessageActions(message){
  const role = getMessageRole(message)
  const messageId = escapeHtml(getMessageId(message))
  const isCopied = copiedMessageId && copiedMessageId === getMessageId(message)

  if(role === "assistant"){
    return `
      <div class="message-actions">
        <button type="button" class="message-action-btn" data-action="copy" data-message-id="${messageId}">
          ${isCopied ? "Copied" : "Copy"}
        </button>
        <button type="button" class="message-action-btn" data-action="retry" data-message-id="${messageId}">
          Regenerate
        </button>
        <button type="button" class="message-action-btn" data-action="delete" data-message-id="${messageId}">
          Delete
        </button>
      </div>
    `
  }

  return `
    <div class="message-actions">
      <button type="button" class="message-action-btn" data-action="copy" data-message-id="${messageId}">
        ${isCopied ? "Copied" : "Copy"}
      </button>
      <button type="button" class="message-action-btn" data-action="edit" data-message-id="${messageId}">
        Edit
      </button>
      <button type="button" class="message-action-btn" data-action="retry" data-message-id="${messageId}">
        Reply
      </button>
      <button type="button" class="message-action-btn" data-action="delete" data-message-id="${messageId}">
        Delete
      </button>
    </div>
  `
}

function renderMessage(message, index){
  const role = getMessageRole(message)
  const rawMessageId = getMessageId(message) || `msg_${index}`
  const messageId = escapeHtml(rawMessageId)
  const attachments = Array.isArray(message?.attachments) ? message.attachments : []
  const isStreaming = String(state.streamingMessageId || "").trim() === rawMessageId && !!state.isStreaming

  return `
    <div class="message-row message-row-${role}">
      <article class="message message-${role}" data-message-id="${messageId}">
        <div class="message-bubble ${isStreaming ? "is-streaming" : ""}">
          <div class="message-content">${formatContentToHtml(message?.content || "", { streaming: isStreaming, messageId: rawMessageId })}</div>
          ${attachments.length ? `<div class="message-attachments">${attachments.map(renderAttachment).join("")}</div>` : ""}
        </div>
        ${renderMessageActions(message)}
      </article>
    </div>
  `
}

function renderThinkingIndicator(){
  if(!thinkingIndicatorId){
    return ""
  }

  return `
    <div class="message-row message-row-assistant" data-thinking-row="true">
      <article class="message message-assistant" data-message-id="${escapeHtml(thinkingIndicatorId)}" data-thinking-indicator="true">
        <div class="message-bubble is-thinking">
          <div class="message-content">
            <span class="thinking-dots" aria-label="Nova is thinking">
              <span></span>
              <span></span>
              <span></span>
            </span>
          </div>
        </div>
      </article>
    </div>
  `
}

function renderAllMessagesHtml(){
  const messages = ensureMessagesArray()
  const parts = messages.map(renderMessage)

  if(thinkingIndicatorId){
    parts.push(renderThinkingIndicator())
  }

  return parts.join("")
}

function getMessageElement(messageId){
  if(!el.messages){
    return null
  }

  const safeId = typeof CSS !== "undefined" && typeof CSS.escape === "function"
    ? CSS.escape(String(messageId || ""))
    : String(messageId || "").replace(/"/g, '\\"')

  return el.messages.querySelector(`[data-message-id="${safeId}"]`)
}

function getMessageContentElement(messageId){
  const messageEl = getMessageElement(messageId)
  if(!messageEl){
    return null
  }

  return messageEl.querySelector(".message-content")
}

function getMessageActionsElement(messageId){
  const messageEl = getMessageElement(messageId)
  if(!messageEl){
    return null
  }

  return messageEl.querySelector(".message-actions")
}

function bindImageFallbacks(){
  if(!el.messages){
    return
  }

  const images = el.messages.querySelectorAll(".message-image img")

  images.forEach((img) => {
    if(img.dataset.fallbackBound === "true"){
      return
    }

    img.dataset.fallbackBound = "true"

    img.addEventListener("error", () => {
      const anchor = img.closest(".message-image")
      if(!anchor){
        return
      }

      const name = img.getAttribute("data-image-fallback-name") || "image"
      const href = anchor.getAttribute("href") || ""

      anchor.outerHTML = `
        <a class="message-attachment" href="${escapeHtml(href)}" target="_blank" rel="noopener noreferrer">
          <span class="message-attachment-name">${escapeHtml(name)}</span>
          <span class="message-attachment-meta">image</span>
        </a>
      `
    }, { once: true })
  })
}

function patchMessageContent(messageId, content){
  const contentEl = getMessageContentElement(messageId)
  if(!contentEl){
    return false
  }

  const isStreaming =
    String(state.streamingMessageId || "").trim() === String(messageId || "").trim() &&
    !!state.isStreaming

  contentEl.innerHTML = formatContentToHtml(content, {
    streaming: isStreaming,
    messageId,
  })

  bindImageFallbacks()
  return true
}

function patchMessageActions(message){
  const actionsEl = getMessageActionsElement(getMessageId(message))
  if(!actionsEl){
    return false
  }

  const wrapper = document.createElement("div")
  wrapper.innerHTML = renderMessageActions(message)
  const nextActions = wrapper.firstElementChild

  if(!nextActions){
    return false
  }

  actionsEl.replaceWith(nextActions)
  return true
}

function renderMessages(){
  if(!el.messages){
    return
  }

  const messages = ensureMessagesArray()

  if(el.emptyState){
    el.emptyState.hidden = messages.length > 0 || !!thinkingIndicatorId
  }

  if(!messages.length && !thinkingIndicatorId){
    el.messages.innerHTML = ""
    updateJumpButton()
    return
  }

  el.messages.innerHTML = renderAllMessagesHtml()
  bindImageFallbacks()
  updateJumpButton()
}

function syncMessagesFromStorage(messages){
  state.messages = Array.isArray(messages) ? messages.slice() : []
  finishedStreamingMessageIds = new Set()
  renderMessages()
}

function addMessage(message){
  ensureMessagesArray().push(message)
  renderMessages()
}

function clearMessages(){
  state.messages = []
  state.userScrolledUp = false
  thinkingIndicatorId = ""
  finishedStreamingMessageIds = new Set()
  clearCopyFeedback()
  clearCodeCopyFeedback()
  renderMessages()
}

function findMessageById(id){
  const targetId = String(id || "").trim()
  return ensureMessagesArray().find(message => getMessageId(message) === targetId) || null
}

function replaceMessage(id, patch){
  const targetId = String(id || "").trim()
  const messages = ensureMessagesArray()
  const index = messages.findIndex(message => getMessageId(message) === targetId)

  if(index === -1){
    return null
  }

  messages[index] = {
    ...messages[index],
    ...patch,
  }

  const updated = messages[index]

  if(!patchMessageContent(targetId, updated.content || "")){
    renderMessages()
    return updated
  }

  patchMessageActions(updated)
  updateJumpButton()
  return updated
}

function removeMessage(id){
  const targetId = String(id || "").trim()
  state.messages = ensureMessagesArray().filter(message => getMessageId(message) !== targetId)
  finishedStreamingMessageIds.delete(targetId)

  if(copiedMessageId === targetId){
    clearCopyFeedback()
  }

  if(copiedCodeKey.startsWith(`${targetId}::`)){
    clearCodeCopyFeedback()
  }

  renderMessages()
}

function upsertStreamingAssistantMessage(messageId){
  const id = String(messageId || "").trim()
  if(!id){
    return null
  }

  removeThinkingIndicator()

  const existing = findMessageById(id)
  if(existing){
    return existing
  }

  const messages = ensureMessagesArray()
  const lastMessage = messages[messages.length - 1] || null
  const currentStreamingId = String(state.streamingMessageId || "").trim()

  if(
    lastMessage &&
    getMessageRole(lastMessage) === "assistant" &&
    getMessageId(lastMessage) === currentStreamingId &&
    !finishedStreamingMessageIds.has(getMessageId(lastMessage))
  ){
    lastMessage.message_id = id
    lastMessage.id = id
    renderMessages()
    return lastMessage
  }

  const message = {
    message_id: id,
    id,
    role: "assistant",
    content: "",
    attachments: [],
    created_at: new Date().toISOString(),
  }

  messages.push(message)
  renderMessages()
  return message
}

function appendToStreamingMessage(messageId, token){
  const id = String(messageId || "").trim()
  if(!id){
    return null
  }

  const msg = upsertStreamingAssistantMessage(id)
  if(!msg){
    return null
  }

  msg.content = String(msg.content || "") + String(token || "")
  finishedStreamingMessageIds.delete(id)

  if(!patchMessageContent(id, msg.content)){
    renderMessages()
    return msg
  }

  patchMessageActions(msg)
  updateJumpButton()
  return msg
}

function finishStreamingMessage(messageId = ""){
  removeThinkingIndicator()

  const resolvedId = String(messageId || state.streamingMessageId || "").trim()
  if(!resolvedId){
    updateJumpButton()
    scrollToBottom(false)
    return null
  }

  const streamingMessage = findMessageById(resolvedId)
  if(!streamingMessage){
    updateJumpButton()
    scrollToBottom(false)
    return null
  }

  if(finishedStreamingMessageIds.has(resolvedId)){
    updateJumpButton()
    scrollToBottom(false)
    return streamingMessage
  }

  finishedStreamingMessageIds.add(resolvedId)

  if(!patchMessageContent(resolvedId, streamingMessage.content || "")){
    renderMessages()
  }else{
    patchMessageActions(streamingMessage)
    updateJumpButton()
  }

  scrollToBottom(false)
  return streamingMessage
}

function showThinkingIndicator(){
  if(thinkingIndicatorId){
    return
  }

  thinkingIndicatorId = `thinking_${Date.now()}`
  renderMessages()
}

function removeThinkingIndicator(){
  if(!thinkingIndicatorId){
    return
  }

  thinkingIndicatorId = ""
  renderMessages()
}

function scrollToBottom(force = false){
  if(!el.messagesScroll){
    return
  }

  if(force || !state.userScrolledUp){
    el.messagesScroll.scrollTop = el.messagesScroll.scrollHeight
    state.userScrolledUp = false
    updateJumpButton()
    return
  }

  if(isNearBottom()){
    el.messagesScroll.scrollTop = el.messagesScroll.scrollHeight
    state.userScrolledUp = false
    updateJumpButton()
  }
}

function updateScrollState(){
  updateUserScrolledState()
}

function clearCopyFeedback(){
  copiedMessageId = ""

  if(copyFeedbackTimer){
    clearTimeout(copyFeedbackTimer)
    copyFeedbackTimer = null
  }
}

function scheduleCopyFeedbackReset(){
  if(copyFeedbackTimer){
    clearTimeout(copyFeedbackTimer)
  }

  copyFeedbackTimer = setTimeout(() => {
    copiedMessageId = ""
    copyFeedbackTimer = null
    renderMessages()
  }, COPY_FEEDBACK_MS)
}

function clearCodeCopyFeedback(){
  copiedCodeKey = ""

  if(copyCodeFeedbackTimer){
    clearTimeout(copyCodeFeedbackTimer)
    copyCodeFeedbackTimer = null
  }
}

function scheduleCodeCopyFeedbackReset(){
  if(copyCodeFeedbackTimer){
    clearTimeout(copyCodeFeedbackTimer)
  }

  copyCodeFeedbackTimer = setTimeout(() => {
    copiedCodeKey = ""
    copyCodeFeedbackTimer = null
    renderMessages()
  }, COPY_CODE_FEEDBACK_MS)
}

async function copyText(text){
  const value = String(text || "")

  try{
    await navigator.clipboard.writeText(value)
  }catch(_error){
    const temp = document.createElement("textarea")
    temp.value = value
    document.body.appendChild(temp)
    temp.select()
    document.execCommand("copy")
    temp.remove()
  }
}

async function copyMessageById(messageId){
  const msg = findMessageById(messageId)
  if(!msg){
    return
  }

  await copyText(String(msg.content || ""))

  copiedMessageId = String(messageId || "").trim()
  scheduleCopyFeedbackReset()
  renderMessages()
}

async function copyCodeByKey(codeKey){
  const rawKey = String(codeKey || "")
  if(!rawKey){
    return
  }

  const parts = rawKey.split("::")
  const messageId = String(parts[0] || "").trim()
  const codeBlockIndex = Number(parts[1] || 0)

  const msg = findMessageById(messageId)
  if(!msg){
    return
  }

  const codeBlocks = splitCodeBlocks(String(msg.content || "")).filter(part => part.type === "code")
  const codeBlock = codeBlocks[codeBlockIndex]

  if(!codeBlock){
    return
  }

  await copyText(String(codeBlock.content || ""))

  copiedCodeKey = rawKey
  scheduleCodeCopyFeedbackReset()
  renderMessages()
}

async function handleActionClick(action, messageId, extra = {}){
  const id = String(messageId || "").trim()

  if(action === "copy-code"){
    await copyCodeByKey(extra.codeKey || "")
    return
  }

  if(!id){
    return
  }

  if(action === "copy"){
    await copyMessageById(id)
    return
  }

  if(action === "retry" && typeof callbacks.onRetry === "function"){
    await callbacks.onRetry(id)
    return
  }

  if(action === "delete"){
    if(typeof callbacks.onDelete === "function"){
      await callbacks.onDelete(id)
      return
    }

    removeMessage(id)
    return
  }

  if(action === "edit" && typeof callbacks.onEdit === "function"){
    await callbacks.onEdit(id)
  }
}

function bindEvents({ onRetry, onDelete, onEdit } = {}){
  callbacks.onRetry = onRetry || callbacks.onRetry
  callbacks.onDelete = onDelete || callbacks.onDelete
  callbacks.onEdit = onEdit || callbacks.onEdit

  if(eventsBound || !el.messages){
    return
  }

  el.messages.addEventListener("click", async (event) => {
    const target = event.target instanceof Element ? event.target : null
    const actionBtn = target ? target.closest("[data-action]") : null
    if(!actionBtn){
      return
    }

    const action = actionBtn.getAttribute("data-action") || ""
    const messageId = actionBtn.getAttribute("data-message-id") || ""
    const codeKey = actionBtn.getAttribute("data-code-key") || ""

    await handleActionClick(action, messageId, { codeKey })
  })

  el.messagesScroll?.addEventListener("scroll", () => {
    updateUserScrolledState()
  })

  el.jumpToLatestBtn?.addEventListener("click", () => {
    scrollToBottom(true)
  })

  eventsBound = true
  updateJumpButton()
}

