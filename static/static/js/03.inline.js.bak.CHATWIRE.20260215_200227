/* --- NOVA_CHAT_WIRE v1: /api/chat + /api/chat_stream --- */
function __novaUpstream(){
  try{
    const u = (localStorage.getItem("NOVA_UPSTREAM") || "").trim().toLowerCase();
    return (u === "openai" || u === "ollama") ? u : "";
  }catch(e){ return ""; }
}
function __novaModel(){
  try{ return (localStorage.getItem("NOVA_MODEL") || "").trim(); }catch(e){ return ""; }
}
function __novaChatPayload(text){
  const model = __novaModel();
  const upstream = __novaUpstream();
  const payload = {
    messages: [{ role: "user", content: String(text ?? "") }]
  };
  if(upstream) payload.upstream = upstream;
  if(model) payload.model = model;
  return payload;
}
/* --- /NOVA_CHAT_WIRE v1 --- */
(function(){
  let __NOVA_SESSION_ID = null;

  async function novaEnsureSession(){
    if(__NOVA_SESSION_ID) return __NOVA_SESSION_ID;
    const k = (window.__novaGetKey ? window.__novaGetKey() : (window.NOVA_API_KEY || '')).trim();
    const r = await fetch("/api/session/new", { method:"GET", headers:{ "x-api-key": k }, cache:"no-store" });
    const j = await r.json().catch(()=>({}));
    if(!r.ok || !j.session_id) throw new Error(j.detail || j.error || ("HTTP " + r.status));
    __NOVA_SESSION_ID = j.session_id;
    return __NOVA_SESSION_ID;
  }

  const origFetch = window.fetch;
  window.fetch = async function(input, init){
    const url = (typeof input === "string") ? input : (input && input.url) ? input.url : "";
    init = init || {};
    // Only patch chat_ui POST body
    if(url.includes("/api/chat_ui") && init.body && typeof init.body === "string"){
      try{
        const sid = await novaEnsureSession();
        const obj = JSON.parse(init.body);
        if(!obj.session_id) obj.session_id = sid;
        init.body = JSON.stringify(obj);
      }catch(e){}
    }
    return origFetch(input, init);
  };
})();

