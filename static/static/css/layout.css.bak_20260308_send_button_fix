html,
body{
  margin:0;
  padding:0;
  width:100%;
  min-height:100%;
}

body{
  background:var(--bg);
  color:var(--text);
}

/* ================================
   APP GRID
================================ */

#appShell.app-shell{
  min-height:100vh !important;
  width:100% !important;
  display:grid !important;
  grid-template-columns:320px minmax(0,1fr) !important;
  align-items:stretch !important;
  background:var(--bg) !important;
  transition:grid-template-columns 180ms ease !important;
}

/* ================================
   SIDEBAR
================================ */

#sidebar.sidebar{
  position:relative !important;
  z-index:30 !important;
  display:flex !important;
  flex-direction:column !important;
  min-width:0 !important;
  min-height:100vh !important;
  background:var(--panel) !important;
  border-right:1px solid var(--border) !important;
  overflow:hidden !important;
}

.sidebar-header{
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:12px !important;
  padding:16px !important;
  border-bottom:1px solid var(--border) !important;
}

.sidebar-title{
  font-size:.95rem !important;
  font-weight:700 !important;
}

.sidebar-actions{
  display:flex !important;
  flex-direction:column !important;
  gap:10px !important;
  padding:14px 16px !important;
  border-bottom:1px solid var(--border) !important;
}

#chatList.chat-list{
  flex:1 !important;
  overflow:auto !important;
  padding:12px !important;
}

.chat-list-empty{
  padding:18px 14px !important;
  border:1px dashed var(--border) !important;
  border-radius:14px !important;
  text-align:center !important;
  color:var(--text-soft) !important;
}

/* ================================
   MAIN PANEL
================================ */

.main-panel{
  min-width:0 !important;
  width:100% !important;
  display:flex !important;
  flex-direction:column !important;
  min-height:100vh !important;
}

/* ================================
   TOP BAR
================================ */

.topbar{
  position:sticky !important;
  top:0 !important;
  z-index:20 !important;
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:12px !important;
  min-height:64px !important;
  padding:14px 18px !important;
  border-bottom:1px solid var(--border) !important;
  background:rgba(11,16,32,.88) !important;
  backdrop-filter:blur(10px) !important;
}

.topbar-left,
.topbar-right{
  display:flex !important;
  align-items:center !important;
  gap:10px !important;
  min-width:0 !important;
}

.topbar-title{
  font-size:.98rem !important;
  font-weight:700 !important;
  white-space:nowrap !important;
  overflow:hidden !important;
  text-overflow:ellipsis !important;
}

/* ================================
   SIDEBAR TOGGLE (FORCED VISIBLE)
================================ */

#btnSidebarToggle{
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  width:40px !important;
  height:40px !important;
  min-width:40px !important;
  border:1px solid var(--border) !important;
  border-radius:12px !important;
  background:var(--panel-2) !important;
  color:var(--text) !important;
  cursor:pointer !important;
}

/* ================================
   MESSAGES AREA
================================ */

.messages-scroll{
  flex:1 !important;
  min-height:0 !important;
  overflow:auto !important;
}

#messages.messages{
  width:min(900px,100%) !important;
  max-width:900px !important;
  margin:0 auto !important;
  padding:22px 18px 160px !important;
}

.message{
  display:grid !important;
  grid-template-columns:44px minmax(0,1fr) !important;
  gap:14px !important;
  margin-bottom:18px !important;
}

.message-avatar{
  width:44px !important;
  height:44px !important;
  border:1px solid var(--border) !important;
  border-radius:14px !important;
  display:grid !important;
  place-items:center !important;
  font-weight:700 !important;
}

.message-bubble{
  border:1px solid var(--border) !important;
  border-radius:18px !important;
  padding:14px 16px !important;
  background:rgba(255,255,255,.03) !important;
}

/* ================================
   COMPOSER
================================ */

.composer-wrap{
  position:sticky !important;
  bottom:0 !important;
  z-index:15 !important;
  padding:14px 18px 18px !important;
  background:linear-gradient(180deg,rgba(11,16,32,0),rgba(11,16,32,.92) 28%,rgba(11,16,32,.98)) !important;
}

.composer-shell{
  width:min(900px,100%) !important;
  max-width:900px !important;
  margin:0 auto !important;
}

.composer-form{
  display:flex !important;
  flex-direction:column !important;
  gap:10px !important;
  padding:12px !important;
  border:1px solid var(--border) !important;
  border-radius:22px !important;
  background:rgba(15,23,42,.92) !important;
}

#input{
  width:100% !important;
  min-height:52px !important;
  max-height:280px !important;
  resize:none !important;
  border:1px solid var(--border) !important;
  border-radius:14px !important;
  padding:12px 14px !important;
}

/* ================================
   DESKTOP SIDEBAR COLLAPSE
================================ */

@media (min-width:621px){

  body:not(.sidebar-open) #appShell.app-shell{
    grid-template-columns:0 minmax(0,1fr) !important;
  }

  body:not(.sidebar-open) #sidebar.sidebar{
    width:0 !important;
    border-right:0 !important;
    padding:0 !important;
  }

  body:not(.sidebar-open) #sidebar.sidebar > *{
    opacity:0 !important;
    pointer-events:none !important;
  }

}

/* ================================
   MOBILE SIDEBAR
================================ */

@media (max-width:620px){

  #appShell.app-shell{
    grid-template-columns:minmax(0,1fr) !important;
  }

  #sidebar.sidebar{
    position:fixed !important;
    top:0 !important;
    left:0 !important;
    bottom:0 !important;
    z-index:40 !important;
    width:min(86vw,320px) !important;
    transform:translateX(-100%) !important;
    transition:transform 180ms ease !important;
  }

  #sidebar.sidebar.is-open,
  #sidebar.sidebar[data-open="true"]{
    transform:translateX(0) !important;
  }

}

/* ================================
   COMPOSER ACTIONS / BUTTON FIX
================================ */

.composer-actions{
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:10px !important;
  width:100% !important;
  flex-wrap:nowrap !important;
}

.composer-actions-left,
.composer-actions-right{
  display:flex !important;
  align-items:center !important;
  gap:10px !important;
}

#sendBtn,
#stopBtn,
#attachBtn{
  position:relative !important;
  inset:auto !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  min-width:44px !important;
  height:44px !important;
  padding:0 14px !important;
  border-radius:12px !important;
  flex:0 0 auto !important;
}

#sendBtn,
#stopBtn{
  min-width:96px !important;
}

#stopBtn{
  margin-left:0 !important;
}