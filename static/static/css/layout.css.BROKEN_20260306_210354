.app-shell {
  display: grid;
  grid-template-columns: 290px minmax(0, 1fr);
  min-height: 100vh;
}

.sidebar {
  position: sticky;
  top: 0;
  height: 100vh;
  border-right: 1px solid var(--border);
  background: var(--panel);
  backdrop-filter: blur(18px);
  padding: 18px 16px;
  z-index: 30;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.sidebar-top {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.sidebar-brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.sidebar-brand-title {
  font-size: 20px;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.sidebar-brand-subtitle {
  font-size: 12px;
  color: var(--muted);
}

.sidebar-section-label {
  color: var(--muted);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin: 2px 4px 0;
}

.chat-list {
  flex: 1;
  min-height: 0;
  overflow: auto;
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding-right: 2px;
}

.chat-item {
  width: 100%;
  text-align: left;
  border: 1px solid transparent;
  background: var(--surface);
  color: var(--text);
  border-radius: 16px;
  padding: 12px 13px;
}

.chat-item:hover {
  background: var(--surface-2);
  transform: translateY(-1px);
}

.chat-item.active {
  border-color: var(--border-strong);
  background: rgba(124, 156, 255, 0.12);
  box-shadow: var(--shadow-soft);
}

.chat-title {
  font-weight: 700;
  margin-bottom: 4px;
  line-height: 1.35;
}

.chat-meta {
  font-size: 12px;
  color: var(--muted);
}

.sidebar-bottom {
  padding-top: 8px;
  border-top: 1px solid var(--border);
}

.main-panel {
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  min-width: 0;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 16px 24px;
  border-bottom: 1px solid var(--border);
  background: rgba(11, 16, 32, 0.52);
  backdrop-filter: blur(14px);
}

body.light .topbar {
  background: rgba(238, 243, 255, 0.72);
}

.topbar-left,
.topbar-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.topbar-brand-wrap {
  min-width: 0;
}

.brand {
  font-size: 20px;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.subbrand {
  color: var(--muted);
  font-size: 13px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 420px;
}

.messages {
  width: 100%;
  max-width: 980px;
  margin: 0 auto;
  padding: 26px 20px 176px;
}

.message-row {
  display: flex;
  margin-bottom: 18px;
}

.message-row.user {
  justify-content: flex-end;
}

.message-row.assistant {
  justify-content: flex-start;
}

.message-bubble {
  width: min(100%, 800px);
  border: 1px solid var(--border);
  border-radius: 22px;
  padding: 16px 18px;
  box-shadow: var(--shadow);
}

.message-row.user .message-bubble {
  background: var(--user);
}

.message-row.assistant .message-bubble {
  background: var(--assistant);
}

.message-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 10px;
}

.message-role {
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  font-weight: 700;
}

.message-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.msg-action {
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text);
  border-radius: 11px;
  padding: 6px 10px;
  font-size: 12px;
}

.msg-action:hover {
  background: var(--surface-2);
}

.empty-state {
  width: 100%;
  max-width: 820px;
  margin: 56px auto 0;
  border: 1px solid var(--border);
  background: var(--panel-2);
  border-radius: 28px;
  padding: 34px 28px;
  text-align: left;
  box-shadow: var(--shadow);
}

.empty-kicker {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--accent-2);
  margin-bottom: 10px;
  font-weight: 700;
}

.empty-title {
  font-size: 34px;
  line-height: 1.12;
  font-weight: 800;
  margin-bottom: 12px;
  letter-spacing: -0.03em;
}

.empty-copy {
  color: var(--muted);
  line-height: 1.7;
  max-width: 720px;
  margin-bottom: 20px;
}

.empty-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.empty-card {
  border: 1px solid var(--border);
  background: var(--surface);
  border-radius: 18px;
  padding: 14px;
}

.empty-card-title {
  font-weight: 700;
  margin-bottom: 6px;
}

.empty-card-copy {
  color: var(--muted);
  font-size: 14px;
  line-height: 1.55;
}

.composer-wrap {
  position: fixed;
  left: 290px;
  right: 0;
  bottom: 0;
  padding: 16px 20px 22px;
  background: linear-gradient(180deg, rgba(11, 16, 32, 0) 0%, rgba(11, 16, 32, 0.95) 30%);
  z-index: 25;
}

body.light .composer-wrap {
  background: linear-gradient(180deg, rgba(238, 243, 255, 0) 0%, rgba(238, 243, 255, 0.96) 34%);
}

.composer-card {
  width: 100%;
  max-width: 980px;
  margin: 0 auto;
  background: var(--panel-2);
  border: 1px solid var(--border);
  border-radius: 26px;
  box-shadow: var(--shadow);
  padding: 12px;
  backdrop-filter: blur(16px);
}

.attachment-tray {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  padding: 2px 2px 10px;
}

.attachment-chip {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1px solid var(--border);
  background: var(--surface);
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 13px;
  max-width: 100%;
}

.attachment-chip-name {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 230px;
}

.attachment-chip-remove {
  border: none;
  background: transparent;
  color: var(--muted);
  padding: 0;
  font-size: 14px;
  cursor: pointer;
}

.composer-main {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  gap: 10px;
  align-items: end;
}

.attach-btn {
  align-self: center;
}

.composer-input {
  width: 100%;
  min-height: 56px;
  max-height: 240px;
  resize: none;
  border: none;
  outline: none;
  background: transparent;
  color: var(--text);
  font-size: 16px;
  line-height: 1.55;
  padding: 10px 2px 6px;
}

.composer-input::placeholder {
  color: var(--muted);
}

.composer-actions {
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.composer-left {
  display: flex;
  gap: 8px;
}

.composer-hint {
  color: var(--muted);
  font-size: 12px;
}

.typing-dot-wrap {
  display: inline-flex;
  gap: 6px;
  align-items: center;
}

.typing-dot {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: var(--accent-2);
  opacity: 0.35;
  animation: blink 1s infinite ease-in-out;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.14s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.28s;
}

.send-btn.is-loading {
  position: relative;
}

.send-btn.is-loading::after {
  content: "";
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255, 255, 255, 0.35);
  border-top-color: #fff;
  border-radius: 999px;
  display: inline-block;
  animation: spin 0.8s linear infinite;
  vertical-align: middle;
}

.send-btn.is-loading #sendBtnText {
  display: none;
}

.settings-panel {
  position: fixed;
  top: 0;
  right: -360px;
  width: 340px;
  max-width: calc(100vw - 28px);
  height: 100vh;
  background: var(--panel-2);
  border-left: 1px solid var(--border);
  box-shadow: var(--shadow);
  z-index: 45;
  transition: right 0.22s ease;
  display: flex;
  flex-direction: column;
}

.settings-panel.open {
  right: 0;
}

.settings-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 18px;
  border-bottom: 1px solid var(--border);
}

.settings-title {
  font-size: 20px;
  font-weight: 800;
}

.settings-subtitle {
  color: var(--muted);
  font-size: 13px;
}

.settings-body {
  padding: 18px;
  overflow: auto;
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.settings-group {
  border: 1px solid var(--border);
  background: var(--surface);
  border-radius: 18px;
  padding: 14px;
}

.settings-label {
  font-weight: 700;
  margin-bottom: 10px;
}

.settings-row {
  display: flex;
  gap: 10px;
}

.settings-note {
  color: var(--muted);
  line-height: 1.65;
  font-size: 14px;
}

.mobile-overlay {
  display: none;
}

.mobile-overlay.show {
  display: block;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.42);
  z-index: 35;
}

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; transform: translateY(0); }
  40% { opacity: 1; transform: translateY(-2px); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@media (max-width: 980px) {
  .empty-grid {
    grid-template-columns: 1fr;
  }

  .subbrand {
    max-width: 240px;
  }
}

@media (max-width: 900px) {
  .app-shell {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: fixed;
    top: 0;
    left: -310px;
    width: 290px;
    transition: left 0.2s ease;
    box-shadow: var(--shadow);
  }

  .sidebar.open {
    left: 0;
  }

  .mobile-only {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .topbar {
    padding: 14px 16px;
  }

  .topbar-right {
    gap: 8px;
  }

  .topbar-right .model-pill {
    display: none;
  }

  .messages {
    padding: 18px 14px 176px;
  }

  .composer-wrap {
    left: 0;
    padding: 12px 12px 16px;
  }

  .composer-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .composer-left {
    width: 100%;
  }

  .composer-left .btn {
    flex: 1;
  }

  .composer-hint {
    text-align: center;
  }

  .settings-panel {
    width: 100%;
    max-width: 100%;
    right: -100%;
  }
}

@media (max-width: 640px) {
  .brand {
    font-size: 18px;
  }

  .subbrand {
    max-width: 170px;
  }

  .empty-title {
    font-size: 28px;
  }

  .message-bubble {
    padding: 14px 14px;
    border-radius: 18px;
  }

  .composer-main {
    grid-template-columns: auto minmax(0, 1fr);
  }

  .send-btn {
    grid-column: 1 / -1;
    width: 100%;
  }
}