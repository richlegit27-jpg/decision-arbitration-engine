(() => {
"use strict"

function byId(id){
  return document.getElementById(id)
}

function escapeHtml(value){
  return String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;")
}

function makeId(prefix){
  if(window.crypto && typeof window.crypto.randomUUID === "function"){
    return window.crypto.randomUUID()
  }
  return `${prefix}_${Date.now()}_${Math.random().toString(16).slice(2)}`
}

const STORAGE_KEYS = {
  activeChatId: "nova_active_chat_id",
}

const SCROLL_LOCK_THRESHOLD = 120

const el = {
  body: document.body,
  appShell: byId("appShell"),
  sidebar: byId("sidebar"),
  mobileOverlay: byId("mobileOverlay"),
  btnSidebarToggle: byId("btnSidebarToggle"),
  btnCloseSidebar: byId("btnCloseSidebar"),
  btnNewChat: byId("btnNewChat"),
  chatList: byId("chatList"),
  messagesScroll: byId("messagesScroll"),
  messages: byId("messages"),
  composerWrap: byId("composerWrap"),
  composerForm: byId("composerForm"),
  input: byId("input"),
  sendBtn: byId("sendBtn"),
  stopBtn: byId("stopBtn"),
  attachBtn: byId("attachBtn"),
  topbarTitle: byId("topbarTitle"),
  jumpToLatestBtn: byId("jumpToLatestBtn"),
  emptyState: byId("emptyState"),
  emptySuggestions: byId("emptySuggestions"),
  pendingAttachments: byId("pendingAttachments"),
}

const state = {
  chats: [],
  activeChatId: null,
  messages: [],
  renamingChatId: null,
  isStreaming: false,
  isLoadingChats: false,
  isLoadingMessages: false,
  hasUserScrolledUp: false,
  pendingAttachments: [],
  pendingFiles: [],
  draftByChatId: {},
}

let renderService = null
let uiService = null

function getStoredActiveChatId(){
  try{
    return localStorage.getItem(STORAGE_KEYS.activeChatId) || null
  }catch(_error){
    return null
  }
}

function setStoredActiveChatId(value){
  try{
    if(value){
      localStorage.setItem(STORAGE_KEYS.activeChatId, String(value))
    }else{
      localStorage.removeItem(STORAGE_KEYS.activeChatId)
    }
  }catch(_error){
    // ignore storage failures
  }
}

function ensureChatsArray(){
  if(!Array.isArray(state.chats)){
    state.chats = []
  }
  return state.chats
}

function ensureMessagesArray(){
  if(!Array.isArray(state.messages)){
    state.messages = []
  }
  return state.messages
}

function getActiveChat(){
  const chatId = String(state.activeChatId || "")
  if(!chatId){
    return null
  }
  return ensureChatsArray().find((chat) => String(chat.chat_id || chat.id || "") === chatId) || null
}

function getChatTitle(chat){
  if(!chat){
    return "New chat"
  }
  return String(chat.title || chat.name || "New chat").trim() || "New chat"
}

function getChatId(chat){
  return String(chat?.chat_id || chat?.id || "")
}

function normalizeChat(chat){
  const chatId = String(chat?.chat_id || chat?.id || makeId("chat"))
  return {
    ...chat,
    id: chatId,
    chat_id: chatId,
    title: String(chat?.title || chat?.name || "New chat").trim() || "New chat",
  }
}

function normalizeMessage(message){
  const role = String(message?.role || "assistant").trim() || "assistant"
  return {
    ...message,
    id: String(message?.id || message?.message_id || makeId("msg")),
    role,
    content: String(message?.content || message?.text || ""),
    attachments: Array.isArray(message?.attachments) ? message.attachments : [],
  }
}

function saveDraftForActiveChat(){
  const chatId = String(state.activeChatId || "")
  if(!chatId || !el.input){
    return
  }
  state.draftByChatId[chatId] = el.input.value || ""
}

function restoreDraftForActiveChat(){
  if(!el.input){
    return
  }

  const chatId = String(state.activeChatId || "")
  const nextValue = chatId ? String(state.draftByChatId[chatId] || "") : ""
  el.input.value = nextValue
  autoResizeInput()
  updateComposerState()
}

function autoResizeInput(){
  uiService?.autoResizeInput?.()
}

function focusInput(){
  uiService?.focusInput?.()
}

function isNearBottom(){
  return uiService?.isNearBottom?.() ?? true
}

function scrollToBottom(force = false){
  uiService?.scrollToBottom?.(force)
}

function openSidebar(){
  uiService?.openSidebar?.()
}

function closeSidebar(){
  uiService?.closeSidebar?.()
}

function syncSidebarForViewport(){
  uiService?.syncSidebarForViewport?.()
}

function handleMessagesScroll(){
  uiService?.handleMessagesScroll?.()
}

function updateComposerState(){
  renderService?.updateComposerState?.()
}

function renderMessages(){
  renderService?.renderMessages?.()
}

function renderPendingAttachments(){
  renderService?.renderPendingAttachments?.()
}

function renderAll(){
  renderService?.renderAll?.()
}

const api = window.NovaAPI || null

const chatService = window.NovaChatService?.create?.({
  state,
  api,
  elements: el,
}) || null

const attachmentsService = window.NovaAttachmentsService?.create?.({
  state,
  elements: el,
  onChange(files){
    setPendingFiles(files)
  },
}) || null

const streamFactory =
  window.NovaStreamService?.create ||
  window.NovaStreamService?.createStreamService ||
  null

const streamService = typeof streamFactory === "function"
  ? streamFactory({
      state,
      api,
      elements: {
        messages: el.messages,
      },
      onStart(){
        state.isStreaming = true
        renderAll()
        scrollToBottom(true)
      },
      onMeta(payload = {}){
        if(payload?.chat){
          const incoming = normalizeChat(payload.chat)
          const existingIndex = state.chats.findIndex((chat) => getChatId(chat) === getChatId(incoming))

          if(existingIndex >= 0){
            state.chats[existingIndex] = incoming
          }else{
            state.chats.unshift(incoming)
          }

          if(!state.activeChatId){
            state.activeChatId = getChatId(incoming)
            setStoredActiveChatId(state.activeChatId)
          }
        }

        renderAll()
      },
      onToken(token){
        const messages = ensureMessagesArray()
        let lastMessage = messages[messages.length - 1]

        if(!lastMessage || String(lastMessage.role) !== "assistant"){
          lastMessage = normalizeMessage({
            id: makeId("msg"),
            role: "assistant",
            content: "",
          })
          messages.push(lastMessage)
        }

        lastMessage.content = `${lastMessage.content || ""}${token || ""}`
        renderMessages()
        renderService?.updateJumpButton?.()
        scrollToBottom()
      },
      onDone(payload = {}){
        state.isStreaming = false

        if(Array.isArray(payload?.messages)){
          state.messages = payload.messages.map(normalizeMessage)
        }

        if(payload?.chat){
          const incoming = normalizeChat(payload.chat)
          const existingIndex = state.chats.findIndex((chat) => getChatId(chat) === getChatId(incoming))

          if(existingIndex >= 0){
            state.chats[existingIndex] = incoming
          }else{
            state.chats.unshift(incoming)
          }

          state.activeChatId = getChatId(incoming)
          setStoredActiveChatId(state.activeChatId)
        }

        renderAll()
        scrollToBottom(true)
      },
      onError(error){
        console.error("Nova stream error:", error)
        state.isStreaming = false
        renderAll()
      },
      onFinally(){
        state.isStreaming = false
        updateComposerState()
        renderAll()
      },
    })
  : null

if(!streamService){
  console.error("Nova stream service failed to initialize.", {
    NovaStreamService: window.NovaStreamService,
    hasCreate: typeof window.NovaStreamService?.create,
    hasCreateStreamService: typeof window.NovaStreamService?.createStreamService,
  })
}

async function loadChats(){
  if(!chatService || typeof chatService.listChats !== "function"){
    return []
  }

  state.isLoadingChats = true

  try{
    const result = await chatService.listChats()
    const chats = Array.isArray(result) ? result : Array.isArray(result?.chats) ? result.chats : []
    state.chats = chats.map(normalizeChat)

    const storedChatId = getStoredActiveChatId()
    const hasStored = storedChatId && state.chats.some((chat) => getChatId(chat) === storedChatId)

    if(hasStored){
      state.activeChatId = storedChatId
    }else if(state.activeChatId && state.chats.some((chat) => getChatId(chat) === String(state.activeChatId))){
      state.activeChatId = String(state.activeChatId)
    }else{
      state.activeChatId = state.chats[0] ? getChatId(state.chats[0]) : null
    }

    setStoredActiveChatId(state.activeChatId)
    renderAll()

    return state.chats
  }catch(error){
    console.error("Nova loadChats error:", error)
    state.chats = []
    state.activeChatId = null
    renderAll()
    return []
  }finally{
    state.isLoadingChats = false
  }
}

async function loadChat(chatId, options = {}){
  const nextChatId = String(chatId || "").trim()
  if(!nextChatId){
    state.messages = []
    state.activeChatId = null
    setStoredActiveChatId(null)
    renderAll()
    return []
  }

  const preserveScroll = !!options.preserveScroll
  const shouldStickToBottom = preserveScroll ? isNearBottom() : true

  saveDraftForActiveChat()

  state.activeChatId = nextChatId
  setStoredActiveChatId(nextChatId)
  state.isLoadingMessages = true
  renderAll()

  try{
    if(!chatService || typeof chatService.getMessages !== "function"){
      state.messages = []
      renderAll()
      return []
    }

    const result = await chatService.getMessages(nextChatId)
    const messages = Array.isArray(result) ? result : Array.isArray(result?.messages) ? result.messages : []

    state.messages = messages.map(normalizeMessage)
    state.renamingChatId = null

    restoreDraftForActiveChat()
    renderAll()

    if(shouldStickToBottom){
      requestAnimationFrame(() => scrollToBottom(true))
    }

    return state.messages
  }catch(error){
    console.error("Nova loadChat error:", error)
    state.messages = []
    restoreDraftForActiveChat()
    renderAll()
    return []
  }finally{
    state.isLoadingMessages = false
  }
}

async function createChat(){
  try{
    if(!chatService || typeof chatService.createChat !== "function"){
      const localChat = normalizeChat({
        id: makeId("chat"),
        title: "New chat",
      })
      state.chats.unshift(localChat)
      state.activeChatId = getChatId(localChat)
      state.messages = []
      setStoredActiveChatId(state.activeChatId)
      renderAll()
      restoreDraftForActiveChat()
      scrollToBottom(true)
      return localChat
    }

    const created = await chatService.createChat()
    const chat = normalizeChat(created?.chat || created)
    const existingIndex = state.chats.findIndex((item) => getChatId(item) === getChatId(chat))

    if(existingIndex >= 0){
      state.chats[existingIndex] = chat
    }else{
      state.chats.unshift(chat)
    }

    state.activeChatId = getChatId(chat)
    state.messages = []
    state.renamingChatId = null
    setStoredActiveChatId(state.activeChatId)

    renderAll()
    restoreDraftForActiveChat()
    scrollToBottom(true)

    return chat
  }catch(error){
    console.error("Nova createChat error:", error)
    throw error
  }
}

async function persistRename(chatId, title){
  const safeChatId = String(chatId || "").trim()
  const safeTitle = String(title || "").trim() || "New chat"

  if(!safeChatId){
    return { ok: false }
  }

  try{
    if(chatService && typeof chatService.renameChat === "function"){
      await chatService.renameChat(safeChatId, safeTitle)
    }

    state.chats = ensureChatsArray().map((chat) => {
      if(getChatId(chat) !== safeChatId){
        return chat
      }

      return {
        ...chat,
        title: safeTitle,
      }
    })

    renderAll()
    return { ok: true }
  }catch(error){
    console.error("Nova persistRename error:", error)
    return { ok: false, error }
  }
}

function startRenameChat(chatId){
  const safeChatId = String(chatId || "").trim()
  const chat = ensureChatsArray().find((item) => getChatId(item) === safeChatId)

  if(!safeChatId || !chat){
    return
  }

  state.renamingChatId = safeChatId
  renderAll()

  requestAnimationFrame(() => {
    const input = document.querySelector(`.chat-rename-input[data-rename-chat-id="${CSS.escape(safeChatId)}"]`)
    if(!input){
      return
    }

    input.focus()
    input.select()
  })
}

function cancelRenameChat(){
  state.renamingChatId = null
  renderAll()
}

async function commitRenameFromInput(input){
  if(!input){
    return
  }

  const chatId = String(input.dataset.renameChatId || "").trim()
  const nextTitle = String(input.value || "").trim() || "New chat"

  state.renamingChatId = null
  renderAll()

  const result = await persistRename(chatId, nextTitle)

  if(!result?.ok){
    startRenameChat(chatId)
  }
}

function openFilePicker(){
  if(attachmentsService && typeof attachmentsService.openFilePicker === "function"){
    attachmentsService.openFilePicker()
    return
  }

  const fallbackInput =
    document.querySelector('input[type="file"]') ||
    document.querySelector("#fileInput") ||
    document.querySelector("[data-file-input]")

  if(fallbackInput && typeof fallbackInput.click === "function"){
    fallbackInput.click()
    return
  }

  console.error("Nova attachment picker is not available.")
}

async function deleteChat(chatId){
  const safeChatId = String(chatId || "").trim()
  if(!safeChatId){
    return
  }

  const chat = ensureChatsArray().find((item) => getChatId(item) === safeChatId)
  const chatTitle = getChatTitle(chat)

  const confirmed = window.confirm(`Delete chat "${chatTitle}"?`)
  if(!confirmed){
    return
  }

  try{
    if(chatService && typeof chatService.deleteChat === "function"){
      await chatService.deleteChat(safeChatId)
    }

    const wasActive = String(state.activeChatId || "") === safeChatId
    state.chats = ensureChatsArray().filter((item) => getChatId(item) !== safeChatId)

    if(wasActive){
      const nextChat = state.chats[0] || null
      state.activeChatId = nextChat ? getChatId(nextChat) : null
      setStoredActiveChatId(state.activeChatId)
      state.messages = []
    }

    state.renamingChatId = null
    renderAll()

    if(wasActive && state.activeChatId){
      await loadChat(state.activeChatId)
    }
  }catch(error){
    console.error("Nova deleteChat error:", error)
  }
}

async function copyMessage(messageId){
  const message = ensureMessagesArray().find((item) => String(item.id) === String(messageId))
  if(!message){
    return
  }

  try{
    await navigator.clipboard.writeText(String(message.content || ""))
  }catch(error){
    console.error("Nova copyMessage error:", error)
  }
}

async function retryFromMessage(_messageId){
  if(state.isStreaming){
    return
  }

  const messages = ensureMessagesArray()
  const lastUserMessage = [...messages].reverse().find((item) => String(item.role) === "user")

  if(!lastUserMessage){
    return
  }

  if(el.input){
    el.input.value = String(lastUserMessage.content || "")
    autoResizeInput()
    updateComposerState()
  }

  await sendCurrentMessage()
}

function deleteMessage(messageId){
  state.messages = ensureMessagesArray().filter((item) => String(item.id) !== String(messageId))
  renderAll()
}

function setPendingFiles(files){
  state.pendingFiles = Array.isArray(files) ? files.slice() : []
  renderPendingAttachments()
  updateComposerState()
}

function removePendingFileByIndex(index){
  const nextIndex = Number(index)
  if(Number.isNaN(nextIndex)){
    return
  }

  const files = Array.isArray(state.pendingFiles) ? state.pendingFiles.slice() : []
  files.splice(nextIndex, 1)
  setPendingFiles(files)

  if(attachmentsService && typeof attachmentsService.setPendingFiles === "function"){
    attachmentsService.setPendingFiles(files)
  }
}

function getStreamSendMethod(){
  if(streamService && typeof streamService.send === "function"){
    return streamService.send.bind(streamService)
  }

  if(streamService && typeof streamService.sendMessage === "function"){
    return streamService.sendMessage.bind(streamService)
  }

  return null
}

function getStreamStopMethod(){
  if(streamService && typeof streamService.stop === "function"){
    return streamService.stop.bind(streamService)
  }

  if(streamService && typeof streamService.abortActiveStream === "function"){
    return streamService.abortActiveStream.bind(streamService)
  }

  return null
}

async function sendCurrentMessage(){
  if(state.isStreaming){
    return { ok: false }
  }

  const text = String(el.input?.value || "")
  const trimmed = text.trim()
  const files = Array.isArray(state.pendingFiles) ? state.pendingFiles.slice() : []

  if(!trimmed && !files.length){
    updateComposerState()
    return { ok: false }
  }

  let activeChatId = String(state.activeChatId || "").trim()

  try{
    if(!activeChatId){
      const created = await createChat()
      activeChatId = getChatId(created)
    }

    const userMessage = normalizeMessage({
      id: makeId("msg"),
      role: "user",
      content: trimmed,
      attachments: files.map((file) => ({
        name: file?.name || "Attachment",
        filename: file?.name || "Attachment",
      })),
    })

    ensureMessagesArray().push(userMessage)

    if(el.input){
      el.input.value = ""
    }

    autoResizeInput()

    state.pendingFiles = []
    if(attachmentsService?.clearPendingFiles){
      attachmentsService.clearPendingFiles()
    }
    if(attachmentsService?.clearPending){
      attachmentsService.clearPending()
    }

    renderAll()
    scrollToBottom(true)

    state.isStreaming = true
    updateComposerState()

    const streamSend = getStreamSendMethod()

    if(streamSend){
      const result = await streamSend({
        chatId: activeChatId,
        message: trimmed,
        text: trimmed,
        files,
      })

      state.isStreaming = false
      updateComposerState()
      renderAll()
      scrollToBottom(true)

      return result || { ok: true }
    }

    console.error("Nova stream send method not found.", {
      streamService,
      hasSend: typeof streamService?.send,
      hasSendMessage: typeof streamService?.sendMessage,
    })

    state.isStreaming = false
    updateComposerState()
    renderAll()
    return { ok: false, error: new Error("Stream send method not found") }
  }catch(error){
    console.error("Nova sendCurrentMessage error:", error)
    state.isStreaming = false
    updateComposerState()
    renderAll()
    return { ok: false, error }
  }finally{
    focusInput()
  }
}

function stopStreaming(){
  try{
    const streamStop = getStreamStopMethod()
    if(streamStop){
      streamStop()
    }
  }catch(error){
    console.error("Nova stopStreaming error:", error)
  }finally{
    state.isStreaming = false
    updateComposerState()
    renderAll()
  }
}

function handleInput(){
  saveDraftForActiveChat()
  autoResizeInput()
  updateComposerState()
}

async function handleComposerSubmit(event){
  if(event){
    event.preventDefault()
  }

  saveDraftForActiveChat()
  autoResizeInput()
  updateComposerState()

  await sendCurrentMessage()
}

async function handleKeyDown(event){
  if(!event){
    return
  }

  if(event.key === "Enter" && !event.shiftKey){
    event.preventDefault()
    await sendCurrentMessage()
  }
}

function bindSuggestionClicks(){
  document.addEventListener("click", (event) => {
    const button = event.target.closest("[data-suggestion]")
    if(!button || !el.input){
      return
    }

    const suggestion = String(button.dataset.suggestion || "").trim()
    if(!suggestion){
      return
    }

    el.input.value = suggestion
    handleInput()
    focusInput()
  })
}

function wireDomEvents(){
  el.btnSidebarToggle?.addEventListener("click", () => {
    if(window.innerWidth <= 620){
      if(el.body.classList.contains("sidebar-open")){
        closeSidebar()
      }else{
        openSidebar()
      }
      return
    }

    if(el.body.classList.contains("sidebar-open")){
      closeSidebar()
    }else{
      openSidebar()
    }
  })

  el.btnCloseSidebar?.addEventListener("click", closeSidebar)
  el.mobileOverlay?.addEventListener("click", closeSidebar)

  el.btnNewChat?.addEventListener("click", async () => {
    await createChat()
    focusInput()
    if(window.innerWidth <= 620){
      closeSidebar()
    }
  })

  el.messagesScroll?.addEventListener("scroll", handleMessagesScroll)
  el.jumpToLatestBtn?.addEventListener("click", () => scrollToBottom(true))

  el.input?.addEventListener("input", handleInput)
  el.input?.addEventListener("keydown", handleKeyDown)
  el.composerForm?.addEventListener("submit", handleComposerSubmit)
  el.sendBtn?.addEventListener("click", handleComposerSubmit)
  el.stopBtn?.addEventListener("click", stopStreaming)
  el.attachBtn?.addEventListener("click", openFilePicker)

  window.addEventListener("resize", () => {
    syncSidebarForViewport()
    renderService?.updateJumpButton?.()
  })

  el.chatList?.addEventListener("click", async (event) => {
    const deleteBtn = event.target.closest("[data-delete-chat-id]")
    if(deleteBtn){
      event.preventDefault()
      event.stopPropagation()
      await deleteChat(deleteBtn.dataset.deleteChatId)
      return
    }

    const renameTrigger = event.target.closest("[data-rename-trigger='true']")
    if(renameTrigger){
      event.preventDefault()
      event.stopPropagation()
      startRenameChat(renameTrigger.dataset.chatId)
      return
    }

    const chatButton = event.target.closest("[data-chat-id]")
    if(chatButton){
      const chatId = String(chatButton.dataset.chatId || "").trim()
      if(chatId){
        await loadChat(chatId)
        if(window.innerWidth <= 620){
          closeSidebar()
        }
      }
    }
  })

  el.chatList?.addEventListener("dblclick", (event) => {
    const chatButton = event.target.closest("[data-chat-id]")
    if(chatButton){
      event.preventDefault()
      startRenameChat(chatButton.dataset.chatId)
    }
  })

  el.chatList?.addEventListener("keydown", async (event) => {
    const renameInput = event.target.closest(".chat-rename-input")
    if(!renameInput){
      return
    }

    if(event.key === "Enter"){
      event.preventDefault()
      await commitRenameFromInput(renameInput)
      return
    }

    if(event.key === "Escape"){
      event.preventDefault()
      cancelRenameChat()
    }
  })

  el.chatList?.addEventListener("blur", async (event) => {
    const renameInput = event.target.closest(".chat-rename-input")
    if(renameInput){
      await commitRenameFromInput(renameInput)
    }
  }, true)

  el.messages?.addEventListener("click", async (event) => {
    const copyBtn = event.target.closest("[data-copy-message-id]")
    if(copyBtn){
      await copyMessage(copyBtn.dataset.copyMessageId)
      return
    }

    const retryBtn = event.target.closest("[data-retry-message-id]")
    if(retryBtn){
      await retryFromMessage(retryBtn.dataset.retryMessageId)
      return
    }

    const deleteBtn = event.target.closest("[data-delete-message-id]")
    if(deleteBtn){
      deleteMessage(deleteBtn.dataset.deleteMessageId)
    }
  })

  el.pendingAttachments?.addEventListener("click", (event) => {
    const removeBtn = event.target.closest("[data-remove-pending-file-index]")
    if(removeBtn){
      removePendingFileByIndex(removeBtn.dataset.removePendingFileIndex)
    }
  })

  bindSuggestionClicks()
}

async function initRenderService(){
  const renderFactory =
    window.NovaChatRender?.create ||
    window.NovaChatRender?.createRenderService ||
    null

  if(typeof renderFactory !== "function"){
    throw new Error("Nova chat render service failed to initialize.")
  }

  renderService = renderFactory({
    state,
    elements: el,
    utils: {
      escapeHtml,
      getChatTitle,
      getChatId,
      ensureChatsArray,
      ensureMessagesArray,
      getActiveChat,
    },
  })
}

async function initUiService(){
  const uiFactory =
    window.NovaChatUi?.create ||
    window.NovaChatUi?.createChatUiService ||
    null

  if(typeof uiFactory !== "function"){
    throw new Error("Nova chat ui service failed to initialize.")
  }

  uiService = uiFactory({
    state,
    elements: el,
    renderService,
    constants: {
      SCROLL_LOCK_THRESHOLD,
    },
  })
}

async function boot(){
  await initRenderService()
  await initUiService()

  wireDomEvents()
  syncSidebarForViewport()
  autoResizeInput()
  updateComposerState()
  renderAll()

  try{
    await loadChats()

    if(state.activeChatId){
      await loadChat(state.activeChatId)
    }else{
      renderAll()
      focusInput()
    }
  }catch(error){
    console.error("Nova boot error:", error)
    renderAll()
  }
}

window.NovaChatApp = {
  state,
  elements: el,
  renderAll,
  loadChats,
  loadChat,
  createChat,
  deleteChat,
  startRenameChat,
  cancelRenameChat,
  persistRename,
  sendCurrentMessage,
  stopStreaming,
  scrollToBottom,
  setPendingFiles,
}

if(document.readyState === "loading"){
  document.addEventListener("DOMContentLoaded", () => {
    boot().catch((error) => {
      console.error("Nova boot failure:", error)
    })
  }, { once: true })
}else{
  boot().catch((error) => {
    console.error("Nova boot failure:", error)
  })
}

})()