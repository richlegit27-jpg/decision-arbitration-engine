(() => {
"use strict"

function createChatActionsService(options = {}){
  const {
    state,
    elements = {},
    services = {},
    utils = {},
    ui = {},
    render = {},
  } = options

  if(!state){
    throw new Error("NovaChatActions: state is required")
  }

  const el = {
    input: elements.input || null,
  }

  const chatService = services.chatService || null
  const attachmentsService = services.attachmentsService || null
  const streamService = services.streamService || null

  const ensureChatsArray =
    utils.ensureChatsArray ||
    (() => Array.isArray(state.chats) ? state.chats : [])

  const ensureMessagesArray =
    utils.ensureMessagesArray ||
    (() => Array.isArray(state.messages) ? state.messages : [])

  const getChatId =
    utils.getChatId ||
    ((chat) => String(chat?.chat_id || chat?.id || ""))

  const getChatTitle =
    utils.getChatTitle ||
    ((chat) => String(chat?.title || chat?.name || "New chat").trim() || "New chat")

  const normalizeChat =
    utils.normalizeChat ||
    ((chat) => chat)

  const normalizeMessage =
    utils.normalizeMessage ||
    ((message) => message)

  const makeId =
    utils.makeId ||
    ((prefix) => `${prefix}_${Date.now()}_${Math.random().toString(16).slice(2)}`)

  const getStoredActiveChatId =
    utils.getStoredActiveChatId ||
    (() => null)

  const setStoredActiveChatId =
    utils.setStoredActiveChatId ||
    (() => {})

  const saveDraftForActiveChat =
    utils.saveDraftForActiveChat ||
    (() => {})

  const restoreDraftForActiveChat =
    utils.restoreDraftForActiveChat ||
    (() => {})

  const autoResizeInput = ui.autoResizeInput || (() => {})
  const focusInput = ui.focusInput || (() => {})
  const isNearBottom = ui.isNearBottom || (() => true)
  const scrollToBottom = ui.scrollToBottom || (() => {})

  const updateComposerState = render.updateComposerState || (() => {})
  const renderMessages = render.renderMessages || (() => {})
  const renderPendingAttachments = render.renderPendingAttachments || (() => {})
  const renderAll = render.renderAll || (() => {})

  function getStreamSendMethod(){
    if(streamService && typeof streamService.send === "function"){
      return streamService.send.bind(streamService)
    }

    if(streamService && typeof streamService.sendMessage === "function"){
      return streamService.sendMessage.bind(streamService)
    }

    return null
  }

  function getStreamStopMethod(){
    if(streamService && typeof streamService.stop === "function"){
      return streamService.stop.bind(streamService)
    }

    if(streamService && typeof streamService.abortActiveStream === "function"){
      return streamService.abortActiveStream.bind(streamService)
    }

    return null
  }

  async function loadChats(){
    if(!chatService || typeof chatService.listChats !== "function"){
      return []
    }

    state.isLoadingChats = true

    try{
      const result = await chatService.listChats()
      const chats = Array.isArray(result)
        ? result
        : Array.isArray(result?.chats)
          ? result.chats
          : []

      state.chats = chats.map(normalizeChat)

      const storedChatId = getStoredActiveChatId()
      const hasStored = storedChatId && state.chats.some((chat) => getChatId(chat) === storedChatId)

      if(hasStored){
        state.activeChatId = storedChatId
      }else if(state.activeChatId && state.chats.some((chat) => getChatId(chat) === String(state.activeChatId))){
        state.activeChatId = String(state.activeChatId)
      }else{
        state.activeChatId = state.chats[0] ? getChatId(state.chats[0]) : null
      }

      setStoredActiveChatId(state.activeChatId)
      renderAll()

      return state.chats
    }catch(error){
      console.error("Nova loadChats error:", error)
      state.chats = []
      state.activeChatId = null
      renderAll()
      return []
    }finally{
      state.isLoadingChats = false
    }
  }

  async function loadChat(chatId, options = {}){
    const nextChatId = String(chatId || "").trim()
    if(!nextChatId){
      state.messages = []
      state.activeChatId = null
      setStoredActiveChatId(null)
      renderAll()
      return []
    }

    const preserveScroll = !!options.preserveScroll
    const shouldStickToBottom = preserveScroll ? isNearBottom() : true

    saveDraftForActiveChat()

    state.activeChatId = nextChatId
    setStoredActiveChatId(nextChatId)
    state.isLoadingMessages = true
    renderAll()

    try{
      if(!chatService || typeof chatService.getMessages !== "function"){
        state.messages = []
        renderAll()
        return []
      }

      const result = await chatService.getMessages(nextChatId)
      const messages = Array.isArray(result)
        ? result
        : Array.isArray(result?.messages)
          ? result.messages
          : []

      state.messages = messages.map(normalizeMessage)
      state.renamingChatId = null

      restoreDraftForActiveChat()
      renderAll()

      if(shouldStickToBottom){
        requestAnimationFrame(() => scrollToBottom(true))
      }

      return state.messages
    }catch(error){
      console.error("Nova loadChat error:", error)
      state.messages = []
      restoreDraftForActiveChat()
      renderAll()
      return []
    }finally{
      state.isLoadingMessages = false
    }
  }

  async function createChat(){
    try{
      if(!chatService || typeof chatService.createChat !== "function"){
        const localChat = normalizeChat({
          id: makeId("chat"),
          title: "New chat",
        })

        ensureChatsArray().unshift(localChat)
        state.activeChatId = getChatId(localChat)
        state.messages = []
        setStoredActiveChatId(state.activeChatId)

        renderAll()
        restoreDraftForActiveChat()
        scrollToBottom(true)

        return localChat
      }

      const created = await chatService.createChat()
      const chat = normalizeChat(created?.chat || created)
      const existingIndex = ensureChatsArray().findIndex((item) => getChatId(item) === getChatId(chat))

      if(existingIndex >= 0){
        state.chats[existingIndex] = chat
      }else{
        state.chats.unshift(chat)
      }

      state.activeChatId = getChatId(chat)
      state.messages = []
      state.renamingChatId = null
      setStoredActiveChatId(state.activeChatId)

      renderAll()
      restoreDraftForActiveChat()
      scrollToBottom(true)

      return chat
    }catch(error){
      console.error("Nova createChat error:", error)
      throw error
    }
  }

  async function persistRename(chatId, title){
    const safeChatId = String(chatId || "").trim()
    const safeTitle = String(title || "").trim() || "New chat"

    if(!safeChatId){
      return { ok: false }
    }

    try{
      if(chatService && typeof chatService.renameChat === "function"){
        await chatService.renameChat(safeChatId, safeTitle)
      }

      state.chats = ensureChatsArray().map((chat) => {
        if(getChatId(chat) !== safeChatId){
          return chat
        }

        return {
          ...chat,
          title: safeTitle,
        }
      })

      renderAll()
      return { ok: true }
    }catch(error){
      console.error("Nova persistRename error:", error)
      return { ok: false, error }
    }
  }

  function startRenameChat(chatId){
    const safeChatId = String(chatId || "").trim()
    const chat = ensureChatsArray().find((item) => getChatId(item) === safeChatId)

    if(!safeChatId || !chat){
      return
    }

    state.renamingChatId = safeChatId
    renderAll()

    requestAnimationFrame(() => {
      const input = document.querySelector(`.chat-rename-input[data-rename-chat-id="${CSS.escape(safeChatId)}"]`)
      if(!input){
        return
      }

      input.focus()
      input.select()
    })
  }

  function cancelRenameChat(){
    state.renamingChatId = null
    renderAll()
  }

  async function commitRenameFromInput(input){
    if(!input){
      return
    }

    const chatId = String(input.dataset.renameChatId || "").trim()
    const nextTitle = String(input.value || "").trim() || "New chat"

    state.renamingChatId = null
    renderAll()

    const result = await persistRename(chatId, nextTitle)

    if(!result?.ok){
      startRenameChat(chatId)
    }
  }

  function openFilePicker(){
    if(attachmentsService && typeof attachmentsService.openFilePicker === "function"){
      attachmentsService.openFilePicker()
      return
    }

    const fallbackInput =
      document.querySelector('input[type="file"]') ||
      document.querySelector("#fileInput") ||
      document.querySelector("[data-file-input]")

    if(fallbackInput && typeof fallbackInput.click === "function"){
      fallbackInput.click()
      return
    }

    console.error("Nova attachment picker is not available.")
  }

  async function deleteChat(chatId){
    const safeChatId = String(chatId || "").trim()
    if(!safeChatId){
      return
    }

    const chat = ensureChatsArray().find((item) => getChatId(item) === safeChatId)
    const chatTitle = getChatTitle(chat)

    const confirmed = window.confirm(`Delete chat "${chatTitle}"?`)
    if(!confirmed){
      return
    }

    try{
      if(chatService && typeof chatService.deleteChat === "function"){
        await chatService.deleteChat(safeChatId)
      }

      const wasActive = String(state.activeChatId || "") === safeChatId
      state.chats = ensureChatsArray().filter((item) => getChatId(item) !== safeChatId)

      if(wasActive){
        const nextChat = state.chats[0] || null
        state.activeChatId = nextChat ? getChatId(nextChat) : null
        setStoredActiveChatId(state.activeChatId)
        state.messages = []
      }

      state.renamingChatId = null
      renderAll()

      if(wasActive && state.activeChatId){
        await loadChat(state.activeChatId)
      }
    }catch(error){
      console.error("Nova deleteChat error:", error)
    }
  }

  async function copyMessage(messageId){
    const message = ensureMessagesArray().find((item) => String(item.id) === String(messageId))
    if(!message){
      return
    }

    try{
      await navigator.clipboard.writeText(String(message.content || ""))
    }catch(error){
      console.error("Nova copyMessage error:", error)
    }
  }

  async function retryFromMessage(_messageId){
    if(state.isStreaming){
      return
    }

    const messages = ensureMessagesArray()
    const lastUserMessage = [...messages].reverse().find((item) => String(item.role) === "user")

    if(!lastUserMessage){
      return
    }

    if(el.input){
      el.input.value = String(lastUserMessage.content || "")
      autoResizeInput()
      updateComposerState()
    }

    await sendCurrentMessage()
  }

  function deleteMessage(messageId){
    state.messages = ensureMessagesArray().filter((item) => String(item.id) !== String(messageId))
    renderAll()
  }

  function setPendingFiles(files){
    state.pendingFiles = Array.isArray(files) ? files.slice() : []
    renderPendingAttachments()
    updateComposerState()
  }

  function removePendingFileByIndex(index){
    const nextIndex = Number(index)
    if(Number.isNaN(nextIndex)){
      return
    }

    const files = Array.isArray(state.pendingFiles) ? state.pendingFiles.slice() : []
    files.splice(nextIndex, 1)
    setPendingFiles(files)

    if(attachmentsService && typeof attachmentsService.setPendingFiles === "function"){
      attachmentsService.setPendingFiles(files)
    }
  }

  async function sendCurrentMessage(){
    if(state.isStreaming){
      return { ok: false }
    }

    const text = String(el.input?.value || "")
    const trimmed = text.trim()
    const files = Array.isArray(state.pendingFiles) ? state.pendingFiles.slice() : []

    if(!trimmed && !files.length){
      updateComposerState()
      return { ok: false }
    }

    let activeChatId = String(state.activeChatId || "").trim()

    try{
      if(!activeChatId){
        const created = await createChat()
        activeChatId = getChatId(created)
      }

      const userMessage = normalizeMessage({
        id: makeId("msg"),
        role: "user",
        content: trimmed,
        attachments: files.map((file) => ({
          name: file?.name || "Attachment",
          filename: file?.name || "Attachment",
        })),
      })

      ensureMessagesArray().push(userMessage)

      if(el.input){
        el.input.value = ""
      }

      autoResizeInput()

      state.pendingFiles = []
      if(attachmentsService?.clearPendingFiles){
        attachmentsService.clearPendingFiles()
      }
      if(attachmentsService?.clearPending){
        attachmentsService.clearPending()
      }

      renderAll()
      scrollToBottom(true)

      state.isStreaming = true
      updateComposerState()

      const streamSend = getStreamSendMethod()

      if(streamSend){
        const result = await streamSend({
          chatId: activeChatId,
          message: trimmed,
          text: trimmed,
          files,
        })

        state.isStreaming = false
        updateComposerState()
        renderAll()
        scrollToBottom(true)

        return result || { ok: true }
      }

      console.error("Nova stream send method not found.", {
        streamService,
        hasSend: typeof streamService?.send,
        hasSendMessage: typeof streamService?.sendMessage,
      })

      state.isStreaming = false
      updateComposerState()
      renderAll()
      return { ok: false, error: new Error("Stream send method not found") }
    }catch(error){
      console.error("Nova sendCurrentMessage error:", error)
      state.isStreaming = false
      updateComposerState()
      renderAll()
      return { ok: false, error }
    }finally{
      focusInput()
    }
  }

  function stopStreaming(){
    try{
      const streamStop = getStreamStopMethod()
      if(streamStop){
        streamStop()
      }
    }catch(error){
      console.error("Nova stopStreaming error:", error)
    }finally{
      state.isStreaming = false
      updateComposerState()
      renderAll()
    }
  }

  return {
    loadChats,
    loadChat,
    createChat,
    persistRename,
    startRenameChat,
    cancelRenameChat,
    commitRenameFromInput,
    openFilePicker,
    deleteChat,
    copyMessage,
    retryFromMessage,
    deleteMessage,
    setPendingFiles,
    removePendingFileByIndex,
    sendCurrentMessage,
    stopStreaming,
  }
}

window.NovaChatActions = {
  create: createChatActionsService,
  createChatActionsService,
}

})()