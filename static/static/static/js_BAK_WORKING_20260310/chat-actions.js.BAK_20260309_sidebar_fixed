(() => {
"use strict"

function createChatActionsService(options = {}){
  const {
    state,
    elements = {},
    services = {},
    utils = {},
    ui = {},
    render = {},
  } = options

  if(!state){
    throw new Error("NovaChatActions: state is required")
  }

  const el = {
    input: elements.input || null,
  }

  const chatService = services.chatService || null
  const attachmentsService = services.attachmentsService || null
  const streamService = services.streamService || null

  const ensureChatsArray =
    typeof utils.ensureChatsArray === "function"
      ? utils.ensureChatsArray
      : (() => {
          if(!Array.isArray(state.chats)){
            state.chats = []
          }
          return state.chats
        })

  const ensureMessagesArray =
    typeof utils.ensureMessagesArray === "function"
      ? utils.ensureMessagesArray
      : (() => {
          if(!Array.isArray(state.messages)){
            state.messages = []
          }
          return state.messages
        })

  const getChatId =
    typeof utils.getChatId === "function"
      ? utils.getChatId
      : ((chat) => String(chat?.chat_id || chat?.id || ""))

  const getChatTitle =
    typeof utils.getChatTitle === "function"
      ? utils.getChatTitle
      : ((chat) => String(chat?.title || chat?.name || "New chat").trim() || "New chat")

  const normalizeChat =
    typeof utils.normalizeChat === "function"
      ? utils.normalizeChat
      : ((chat) => {
          const chatId = String(chat?.chat_id || chat?.id || makeId("chat"))
          return {
            ...chat,
            id: chatId,
            chat_id: chatId,
            title: String(chat?.title || chat?.name || "New chat").trim() || "New chat",
          }
        })

  const normalizeMessage =
    typeof utils.normalizeMessage === "function"
      ? utils.normalizeMessage
      : ((message) => ({
          ...message,
          id: String(message?.id || message?.message_id || makeId("msg")),
          role: String(message?.role || "assistant").trim() || "assistant",
          content: String(message?.content || message?.text || ""),
          attachments: Array.isArray(message?.attachments) ? message.attachments : [],
        }))

  const makeId =
    typeof utils.makeId === "function"
      ? utils.makeId
      : ((prefix) => `${prefix}_${Date.now()}_${Math.random().toString(16).slice(2)}`)

  const getStoredActiveChatId =
    typeof utils.getStoredActiveChatId === "function"
      ? utils.getStoredActiveChatId
      : (() => null)

  const setStoredActiveChatId =
    typeof utils.setStoredActiveChatId === "function"
      ? utils.setStoredActiveChatId
      : (() => {})

  const saveDraftForActiveChat =
    typeof utils.saveDraftForActiveChat === "function"
      ? utils.saveDraftForActiveChat
      : (() => {})

  const restoreDraftForActiveChat =
    typeof utils.restoreDraftForActiveChat === "function"
      ? utils.restoreDraftForActiveChat
      : (() => {})

  const autoResizeInput =
    typeof ui.autoResizeInput === "function"
      ? ui.autoResizeInput
      : (() => {})

  const focusInput =
    typeof ui.focusInput === "function"
      ? ui.focusInput
      : (() => {})

  const isNearBottom =
    typeof ui.isNearBottom === "function"
      ? ui.isNearBottom
      : (() => true)

  const scrollToBottom =
    typeof ui.scrollToBottom === "function"
      ? ui.scrollToBottom
      : (() => {})

  const updateComposerState =
    typeof render.updateComposerState === "function"
      ? render.updateComposerState
      : (() => {})

  const renderMessages =
    typeof render.renderMessages === "function"
      ? render.renderMessages
      : (() => {})

  const renderPendingAttachments =
    typeof render.renderPendingAttachments === "function"
      ? render.renderPendingAttachments
      : (() => {})

  const renderAll =
    typeof render.renderAll === "function"
      ? render.renderAll
      : (() => {})

  function setPendingFiles(files = []){
    const normalized = Array.isArray(files) ? files.filter(Boolean) : []
    state.pendingFiles = normalized
    state.pendingAttachments = normalized
    renderPendingAttachments()
    updateComposerState()
  }

  async function loadChats(){
    state.isLoadingChats = true
    renderAll()

    try{
      const result = await chatService?.listChats?.()
      const incomingChats = Array.isArray(result)
        ? result
        : Array.isArray(result?.chats)
          ? result.chats
          : []

      state.chats = incomingChats.map(normalizeChat)

      const storedChatId = String(getStoredActiveChatId() || "")
      const currentActiveId = String(state.activeChatId || "")

      let nextActiveId = ""

      if(currentActiveId && state.chats.some((chat) => getChatId(chat) === currentActiveId)){
        nextActiveId = currentActiveId
      }else if(storedChatId && state.chats.some((chat) => getChatId(chat) === storedChatId)){
        nextActiveId = storedChatId
      }else if(state.chats[0]){
        nextActiveId = getChatId(state.chats[0])
      }

      state.activeChatId = nextActiveId || null
      setStoredActiveChatId(state.activeChatId)
    }catch(error){
      console.error("Nova loadChats error:", error)
      state.chats = []
      state.activeChatId = null
      setStoredActiveChatId(null)
    }finally{
      state.isLoadingChats = false
      renderAll()
    }

    return ensureChatsArray()
  }

  async function loadChat(chatId){
    const normalizedChatId = String(chatId || "").trim()
    if(!normalizedChatId){
      state.messages = []
      renderAll()
      return []
    }

    saveDraftForActiveChat()

    state.activeChatId = normalizedChatId
    setStoredActiveChatId(normalizedChatId)
    state.isLoadingMessages = true
    renderAll()

    try{
      const result = await chatService?.getMessages?.(normalizedChatId)
      const incomingMessages = Array.isArray(result)
        ? result
        : Array.isArray(result?.messages)
          ? result.messages
          : []

      state.messages = incomingMessages.map(normalizeMessage)
      state.hasUserScrolledUp = false
      renderAll()
      restoreDraftForActiveChat()
      scrollToBottom(true)
      focusInput()
    }catch(error){
      console.error("Nova loadChat error:", error)
      state.messages = []
      renderAll()
    }finally{
      state.isLoadingMessages = false
      renderAll()
    }

    return ensureMessagesArray()
  }

  async function createChat(){
    saveDraftForActiveChat()

    try{
      const created = await chatService?.createChat?.()
      const chat = normalizeChat(created || {})
      const chats = ensureChatsArray()
      const existingIndex = chats.findIndex((item) => getChatId(item) === getChatId(chat))

      if(existingIndex >= 0){
        chats[existingIndex] = chat
      }else{
        chats.unshift(chat)
      }

      state.activeChatId = getChatId(chat)
      setStoredActiveChatId(state.activeChatId)
      state.messages = []
      state.hasUserScrolledUp = false
      renderAll()
      restoreDraftForActiveChat()
      focusInput()
      return chat
    }catch(error){
      console.error("Nova createChat error:", error)

      const fallback = normalizeChat({
        id: makeId("chat"),
        title: "New chat",
      })

      const chats = ensureChatsArray()
      chats.unshift(fallback)
      state.activeChatId = getChatId(fallback)
      setStoredActiveChatId(state.activeChatId)
      state.messages = []
      renderAll()
      restoreDraftForActiveChat()
      focusInput()
      return fallback
    }
  }

  async function deleteChat(chatId){
    const normalizedChatId = String(chatId || state.activeChatId || "").trim()
    if(!normalizedChatId){
      return
    }

    try{
      await chatService?.deleteChat?.(normalizedChatId)
    }catch(error){
      console.error("Nova deleteChat error:", error)
    }

    state.chats = ensureChatsArray().filter((chat) => getChatId(chat) !== normalizedChatId)

    if(String(state.activeChatId || "") === normalizedChatId){
      const nextChat = state.chats[0] || null
      state.activeChatId = nextChat ? getChatId(nextChat) : null
      setStoredActiveChatId(state.activeChatId)

      if(state.activeChatId){
        await loadChat(state.activeChatId)
      }else{
        state.messages = []
        renderAll()
        restoreDraftForActiveChat()
        focusInput()
      }
    }else{
      renderAll()
    }
  }

  function startRenameChat(chatId){
    const normalizedChatId = String(chatId || "").trim()
    if(!normalizedChatId){
      return
    }

    state.renamingChatId = normalizedChatId
    renderAll()

    requestAnimationFrame(() => {
      const selector = `.chat-rename-input[data-rename-chat-id="${CSS.escape(normalizedChatId)}"]`
      const input = document.querySelector(selector)

      if(input){
        input.focus()
        if(typeof input.select === "function"){
          input.select()
        }
      }
    })
  }

  function cancelRenameChat(){
    state.renamingChatId = null
    renderAll()
  }

  async function persistRename(chatId, title){
    const normalizedChatId = String(chatId || "").trim()
    const normalizedTitle = String(title || "").trim() || "New chat"

    if(!normalizedChatId){
      return
    }

    try{
      const updated = await chatService?.renameChat?.(normalizedChatId, normalizedTitle)
      const incoming = normalizeChat({
        ...(ensureChatsArray().find((chat) => getChatId(chat) === normalizedChatId) || {}),
        ...(updated || {}),
        id: normalizedChatId,
        chat_id: normalizedChatId,
        title: normalizedTitle,
      })

      const index = state.chats.findIndex((chat) => getChatId(chat) === normalizedChatId)
      if(index >= 0){
        state.chats[index] = incoming
      }
    }catch(error){
      console.error("Nova persistRename error:", error)
      const index = state.chats.findIndex((chat) => getChatId(chat) === normalizedChatId)
      if(index >= 0){
        state.chats[index] = {
          ...state.chats[index],
          title: normalizedTitle,
        }
      }
    }finally{
      state.renamingChatId = null
      renderAll()
    }
  }

  async function commitRenameFromInput(input){
    const chatId = String(input?.dataset?.renameChatId || "").trim()
    const title = String(input?.value || "").trim() || "New chat"

    if(!chatId){
      cancelRenameChat()
      return
    }

    await persistRename(chatId, title)
  }

  async function copyMessage(messageId){
    const message = ensureMessagesArray().find((item) => String(item.id || "") === String(messageId || ""))
    if(!message){
      return false
    }

    const text = String(message.content || "")
    if(!text){
      return false
    }

    try{
      await navigator.clipboard.writeText(text)
      return true
    }catch(error){
      console.error("Nova copyMessage error:", error)
      return false
    }
  }

  async function retryFromMessage(messageId){
    const messages = ensureMessagesArray()
    const index = messages.findIndex((item) => String(item.id || "") === String(messageId || ""))
    if(index < 0){
      return
    }

    const target = messages[index]
    if(String(target.role || "") !== "user"){
      return
    }

    if(el.input){
      el.input.value = String(target.content || "")
      autoResizeInput()
      updateComposerState()
      await sendCurrentMessage()
    }
  }

  function deleteMessage(messageId){
    const normalizedMessageId = String(messageId || "").trim()
    if(!normalizedMessageId){
      return
    }

    state.messages = ensureMessagesArray().filter((message) => String(message.id || "") !== normalizedMessageId)
    renderMessages()
    updateComposerState()
  }

  function removePendingFileByIndex(index){
    const fileIndex = Number(index)
    if(!Number.isFinite(fileIndex) || fileIndex < 0){
      return
    }

    const nextFiles = [...(Array.isArray(state.pendingFiles) ? state.pendingFiles : [])]
    nextFiles.splice(fileIndex, 1)
    setPendingFiles(nextFiles)

    if(typeof attachmentsService?.setPendingFiles === "function"){
      attachmentsService.setPendingFiles(nextFiles)
    }
  }

  function stopStreaming(){
    try{
      streamService?.stop?.()
      streamService?.abort?.()
      streamService?.cancel?.()
    }catch(error){
      console.error("Nova stopStreaming error:", error)
    }finally{
      state.isStreaming = false
      updateComposerState()
      renderAll()
    }
  }

  function openFilePicker(){
    attachmentsService?.openPicker?.()
    attachmentsService?.openFilePicker?.()
    attachmentsService?.pickFiles?.()
  }

  async function sendCurrentMessage(){
    if(state.isStreaming){
      return { ok: false, reason: "streaming" }
    }

    const text = String(el.input?.value || "").trim()
    const files = Array.isArray(state.pendingFiles) ? [...state.pendingFiles] : []

    if(!text && files.length === 0){
      updateComposerState()
      return { ok: false, reason: "empty" }
    }

    let activeChatId = String(state.activeChatId || "").trim()

    if(!activeChatId){
      const createdChat = await createChat()
      activeChatId = String(getChatId(createdChat) || "").trim()
    }

    const messages = ensureMessagesArray()
    messages.push(normalizeMessage({
      id: makeId("msg"),
      role: "user",
      content: text,
      attachments: files,
    }))

    if(el.input){
      el.input.value = ""
    }

    state.pendingFiles = []
    state.pendingAttachments = []
    state.hasUserScrolledUp = false

    try{
      attachmentsService?.clearPendingFiles?.()
      attachmentsService?.clearPending?.()
    }catch(error){
      console.error("Nova clearPendingFiles error:", error)
    }

    autoResizeInput()
    renderAll()
    scrollToBottom(true)

    try{
      if(typeof streamService?.send === "function"){
        await streamService.send({
          chatId: activeChatId,
          message: text,
          files,
        })
      }else if(typeof streamService?.streamChat === "function"){
        await streamService.streamChat({
          chatId: activeChatId,
          message: text,
          files,
        })
      }else{
        throw new Error("Nova stream service send method is unavailable.")
      }

      return { ok: true }
    }catch(error){
      console.error("Nova sendCurrentMessage error:", error)
      state.isStreaming = false
      renderAll()
      return { ok: false, error }
    }finally{
      autoResizeInput()
      updateComposerState()
      focusInput()
    }
  }

  return {
    loadChats,
    loadChat,
    createChat,
    deleteChat,
    startRenameChat,
    cancelRenameChat,
    persistRename,
    commitRenameFromInput,
    copyMessage,
    retryFromMessage,
    deleteMessage,
    setPendingFiles,
    removePendingFileByIndex,
    sendCurrentMessage,
    stopStreaming,
    openFilePicker,
  }
}

window.NovaChatActions = {
  create: createChatActionsService,
  createChatActionsService,
}

})()