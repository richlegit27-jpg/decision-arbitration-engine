/* ================================
   MARKDOWN RENDERING
================================ */

.message-content{
  color:var(--text) !important;
  line-height:1.65 !important;
  word-break:break-word !important;
}

.message-content .md-paragraph{
  margin:0 0 12px !important;
}

.message-content .md-paragraph:last-child{
  margin-bottom:0 !important;
}

.message-content .md-heading{
  margin:0 0 12px !important;
  line-height:1.2 !important;
  letter-spacing:-0.02em !important;
}

.message-content .md-heading-1{ font-size:1.6rem !important; }
.message-content .md-heading-2{ font-size:1.35rem !important; }
.message-content .md-heading-3{ font-size:1.15rem !important; }
.message-content .md-heading-4,
.message-content .md-heading-5,
.message-content .md-heading-6{ font-size:1rem !important; }

.message-content .md-list{
  margin:0 0 12px 20px !important;
  padding:0 !important;
}

.message-content .md-list li{
  margin:0 0 6px !important;
}

.message-content .md-blockquote{
  margin:0 0 12px !important;
  padding:10px 14px !important;
  border-left:3px solid rgba(139,92,246,.5) !important;
  background:rgba(255,255,255,.03) !important;
  border-radius:10px !important;
  color:var(--text-soft) !important;
}

.message-content .md-inline-code{
  padding:2px 6px !important;
  border:1px solid var(--border) !important;
  border-radius:8px !important;
  background:rgba(255,255,255,.05) !important;
  font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace !important;
  font-size:.92em !important;
}

.message-content .md-code-block{
  margin:0 0 12px !important;
  padding:14px 16px !important;
  overflow:auto !important;
  border:1px solid var(--border) !important;
  border-radius:14px !important;
  background:rgba(2,6,23,.9) !important;
}

.message-content .md-code-block code{
  display:block !important;
  white-space:pre !important;
  color:#e2e8f0 !important;
  font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace !important;
  font-size:.92rem !important;
  line-height:1.6 !important;
}

.message-content a{
  color:#c4b5fd !important;
  text-decoration:none !important;
}

.message-content a:hover{
  text-decoration:underline !important;
}