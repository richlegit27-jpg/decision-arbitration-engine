(() => {
"use strict"

function createChatService(options = {}){
  const {
    state,
    api,
  } = options

  if(!state){
    throw new Error("NovaChatService: state is required")
  }

  const apiClient = api || window.NovaAPI

  if(!apiClient){
    throw new Error("NovaChatService: api is required")
  }

  async function listChats(){
    const chats = await apiClient.listChats()

    if(!Array.isArray(chats)){
      return []
    }

    return chats
      .map(normalizeChat)
      .filter(Boolean)
      .sort(sortChatsNewestFirst)
  }

  async function getMessages(chatId){
    if(!chatId){
      return []
    }

    const messages = await apiClient.getMessages(chatId)

    if(!Array.isArray(messages)){
      return []
    }

    return messages
      .map(normalizeMessage)
      .filter(Boolean)
  }

  async function createChat(payload = {}){
    const result = await apiClient.createChat(payload)
    return normalizeChat(result?.chat || result)
  }

  async function renameChat(chatId, title){
    if(!chatId){
      throw new Error("chatId is required")
    }

    const cleanTitle = String(title || "").trim()
    if(!cleanTitle){
      throw new Error("title is required")
    }

    const result = await apiClient.renameChat(chatId, cleanTitle)
    return normalizeChat(result?.chat || result) || {
      chat_id: chatId,
      title: cleanTitle,
    }
  }

  async function deleteChat(chatId){
    if(!chatId){
      throw new Error("chatId is required")
    }

    return apiClient.deleteChat(chatId)
  }

  function normalizeChat(chat){
    if(!chat || typeof chat !== "object"){
      return null
    }

    const chatId = String(
      chat.chat_id ||
      chat.id ||
      ""
    ).trim()

    if(!chatId){
      return null
    }

    const title = String(
      chat.title ||
      chat.name ||
      "New chat"
    ).trim() || "New chat"

    const createdAt =
      chat.created_at ||
      chat.created ||
      null

    const updatedAt =
      chat.updated_at ||
      chat.updated ||
      createdAt ||
      null

    return {
      chat_id: chatId,
      title,
      created_at: createdAt,
      updated_at: updatedAt,
      updated: updatedAt,
    }
  }

  function normalizeMessage(message){
    if(!message || typeof message !== "object"){
      return null
    }

    const messageId = String(
      message.message_id ||
      message.id ||
      ""
    ).trim()

    const role = normalizeRole(message.role)
    const content = String(
      message.content ??
      message.text ??
      ""
    )

    const attachments = normalizeAttachments(
      message.attachments ||
      message.files ||
      []
    )

    const createdAt =
      message.created_at ||
      message.created ||
      message.timestamp ||
      null

    const updatedAt =
      message.updated_at ||
      message.updated ||
      createdAt ||
      null

    return {
      message_id: messageId || `message-${Date.now()}-${Math.random().toString(16).slice(2)}`,
      role,
      content,
      attachments,
      created_at: createdAt,
      updated_at: updatedAt,
      status: normalizeStatus(message.status),
    }
  }

  function normalizeAttachments(attachments){
    if(!Array.isArray(attachments)){
      return []
    }

    return attachments
      .map((attachment, index) => {
        if(!attachment || typeof attachment !== "object"){
          return null
        }

        return {
          attachment_id: String(
            attachment.attachment_id ||
            attachment.id ||
            `attachment-${index}`
          ),
          name: attachment.name || attachment.filename || "Attachment",
          filename: attachment.filename || attachment.name || "Attachment",
          content_type: attachment.content_type || attachment.mime_type || "application/octet-stream",
          size: Number(attachment.size || 0),
        }
      })
      .filter(Boolean)
  }

  function normalizeRole(role){
    return String(role || "").toLowerCase() === "user" ? "user" : "assistant"
  }

  function normalizeStatus(status){
    const value = String(status || "").toLowerCase()

    if(value === "sending" || value === "error" || value === "thinking" || value === "stopped"){
      return value
    }

    return "done"
  }

  function sortChatsNewestFirst(a, b){
    const aTime = getTimeValue(a?.updated_at || a?.created_at)
    const bTime = getTimeValue(b?.updated_at || b?.created_at)
    return bTime - aTime
  }

  function getTimeValue(value){
    const ms = new Date(value || 0).getTime()
    return Number.isFinite(ms) ? ms : 0
  }

  return {
    listChats,
    getMessages,
    createChat,
    renameChat,
    deleteChat,
  }
}

window.NovaChatService = {
  create: createChatService,
  createChatService
}})()