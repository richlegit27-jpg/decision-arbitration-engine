  const badRe = /\[worker\]\s*usage:\s*\/ask\s*<prompt>/i;

  function scrubText(txt){
    if(!txt || !badRe.test(txt)) return null;
    const cleaned = txt
      .split(/\r?\n/)
      .filter(line => !badRe.test(line))
      .join("\n")
      .trim();
    return cleaned;
  }

  function cleanNode(node){
    if(!node) return;
    try{
      const t = node.textContent || "";
      if(!badRe.test(t)) return;

      const cleaned = scrubText(t);
      if(!cleaned || cleaned === "<<__NOVA_DONE__>>"){
        node.remove();
      }else{
        node.textContent = cleaned;
      }
    }catch(_){}
  }

  function scanRoot(root){
    if(!root) return;
    try{
      // search common containers first, then fallback to everything
      const scope = root.querySelectorAll
        ? root
        : null;
      if(!scope) return;

      const nodes = scope.querySelectorAll("pre, .nova-force-send-block, .msg, .message, [role='log'], [aria-live], div, span, p");
      for(const n of nodes) cleanNode(n);
    }catch(_){}
  }

  function scanAll(){
    // light DOM
    scanRoot(document);

    // shadow DOM: walk all elements and scan open shadow roots
    const all = document.querySelectorAll("*");
    for(const el of all){
      const sr = el.shadowRoot;
      if(sr) scanRoot(sr);
    }
  }

  // run now and on updates (both body + subtree)
  scanAll();
  new MutationObserver(scanAll).observe(document.documentElement, {subtree:true, childList:true, attributes:true});

