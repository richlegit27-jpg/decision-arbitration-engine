   Adds "Stop generating" button and aborts in-flight /api/chat fetch.
*/
(() => {
  try {
    if (typeof window === "undefined") return;
    if (window.__NOVA_STOPGEN_V1__) return;
    window.__NOVA_STOPGEN_V1__ = true;

    window.NOVA_ACTIVE_CHAT_ABORT = null;   // AbortController
    window.NOVA_ACTIVE_CHAT_ID = 0;         // increments per request
    window.NOVA_GENERATING = false;

    function setGenerating(on){
      window.NOVA_GENERATING = !!on;
      const btn = document.getElementById("btnStopGen");
      if(btn){
        btn.style.display = on ? "inline-flex" : "none";
        btn.disabled = !on ? true : false;
      }
    }
    window.NOVA_SET_GENERATING = setGenerating;

    function stopNow(){
      try{
        const ac = window.NOVA_ACTIVE_CHAT_ABORT;
        if(ac) ac.abort();
      }catch(e){}
    }
    window.NOVA_STOP = stopNow;

    function ensureButton(){
      const hint = document.getElementById("hint");
      if(!hint || hint.__nova_stop_added) return;
      hint.__nova_stop_added = true;

      const sp = document.createTextNode(" â€¢ ");
      const btn = document.createElement("button");
      btn.id = "btnStopGen";
      btn.className = "btnStop";
      btn.type = "button";
      btn.textContent = "Stop generating";
      btn.style.display = "none";
      btn.disabled = true;
      btn.addEventListener("click", () => {
        btn.disabled = true;
        stopNow();
      });

      hint.appendChild(sp);
      hint.appendChild(btn);
    }

    if(document.readyState === "loading"){
      document.addEventListener("DOMContentLoaded", ensureButton);
    } else {
      ensureButton();
    }

    // Hook fetch: abortable POST /api/chat
    const _fetch = window.fetch.bind(window);

    function isApiChat(url) {
      try { return new URL(url, window.location.href).pathname === "/api/chat"; }
      catch { return (typeof url === "string" && url.includes("/api/chat")); }
    }

    window.fetch = async (input, init) => {
      const url = (typeof input === "string") ? input : (input && input.url) ? input.url : "";
      const method = (init && init.method) ? String(init.method).toUpperCase() : "GET";

      if(!(isApiChat(url) && method === "POST")){
        return _fetch(input, init);
      }

      // If caller already supplied a signal, respect it and don't override.
      // Otherwise attach our AbortController so Stop can work.
      const hasSignal = !!(init && init.signal);
      const ac = hasSignal ? null : new AbortController();

      // Track active request id so late responses can be ignored by bubble logic
      const myId = (window.NOVA_ACTIVE_CHAT_ID || 0) + 1;
      window.NOVA_ACTIVE_CHAT_ID = myId;

      if(!hasSignal){
        window.NOVA_ACTIVE_CHAT_ABORT = ac;
        init = Object.assign({}, init, { signal: ac.signal });
      }

      setGenerating(true);

      try{
        const resp = await _fetch(input, init);
        // Only clear generating if this is still the latest request
        if(window.NOVA_ACTIVE_CHAT_ID === myId){
          setGenerating(false);
          window.NOVA_ACTIVE_CHAT_ABORT = null;
        }
        return resp;
      } catch (e){
        // Aborted or failed
        if(window.NOVA_ACTIVE_CHAT_ID === myId){
          setGenerating(false);
          window.NOVA_ACTIVE_CHAT_ABORT = null;
        }
        throw e;
      }
    };

  } catch (e) {}
})();
