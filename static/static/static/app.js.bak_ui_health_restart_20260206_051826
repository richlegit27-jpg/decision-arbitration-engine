async function callNovaAPI(text){
  const t = String(text ?? '').trim();

  // If user types a command like /qstatus, pass it through.
  // Otherwise treat it as chat and force the /ask router path.
  const payloadText = t.startsWith('/') ? t : ('/ask ' + t);

  const r = fetch('/api/chat', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ prompt: payloadText, mode: 'cmd', model: (window.__NOVA_SELECTED_MODEL__ || localStorage.getItem("nova_selected_model_v1") || "gpt-5-mini"), timeout_ms: 60000 })
  });

  let j = null;
  try { j = await r.text(); }
  catch { j = { ok:false, error: r.text() }; }

  if(!r.ok || !j || j.ok === false){
    const msg = (j && (j.error || j.detail)) ? (j.error || j.detail) : ('HTTP ' + r.status);
    throw new Error(msg);
  }

  return String(j.output ?? '').trim();
}


async function fakeModel(text){
  // real backend call now
  const out = callNovaAPI(text);
  addMessage('Nova', out || '(no output)', head);
}

/* ---------- copy helpers ---------- */
function copyMessage(id){
  const m=tree[id]; if(!m) return;
  copyText(`[${m.ts||''}] ${m.who||''}\n${m.text||''}`.trim());
}
function copyChat(){
  const lines=[];
  (function walk(id){
    const m=tree[id]; if(!m) return;
    if(m.who!=='sys'){
      lines.push(`[${m.ts||''}] ${m.who||''}`.trim());
      lines.push(String(m.text||'')); lines.push('');
    }
    for(const c of (m.children||[])) walk(c);
  })(tree.root.id);
  copyText(lines.join('\n').trim());
}

/* ---------- graph ---------- */
const graph={canvas:null,ctx:null,nodes:[],edges:[]};

function buildGraph(){
  graph.nodes=[]; graph.edges=[];
  const rootId = tree.root?.id;
  if(!rootId) return;

  function walk(id,depth,x){
    const m=tree[id]; if(!m) return;
    const y=depth*80;
    graph.nodes.push({id,x,y,who:m.who});
    const kids=m.children||[];
    const span=Math.max(1,kids.length);
    let cx = x - ((span-1)*160)/2;
    for(const c of kids){
      graph.edges.push({from:id,to:c});
      walk(c, depth+1, cx);
      cx += 160;
    }
  }
  walk(rootId,0,0);
}

function drawGraph(){
  const {ctx,canvas}=graph;
  if(!ctx||!canvas) return;

  ctx.setTransform(1,0,0,1,0,0);
  ctx.clearRect(0,0,canvas.width,canvas.height);

  ctx.translate(canvas.width/2, 40);

  ctx.strokeStyle = getTheme()==='dark' ? '#666' : '#999';
  ctx.lineWidth = 2;

  for(const e of graph.edges){
    const a=graph.nodes.find(n=>n.id===e.from);
    const b=graph.nodes.find(n=>n.id===e.to);
    if(!a||!b) continue;
    ctx.beginPath();
    ctx.moveTo(a.x,a.y);
    ctx.lineTo(b.x,b.y);
    ctx.stroke();
  }

  for(const n of graph.nodes){
    ctx.fillStyle = (n.who==='You') ? '#3b82f6' : (n.who==='Nova' ? '#22c55e' : '#888');
    ctx.beginPath();
    ctx.arc(n.x,n.y,14,0,Math.PI*2);
    ctx.fill();
  }
}

function renderGraph(){ buildGraph(); drawGraph(); }

