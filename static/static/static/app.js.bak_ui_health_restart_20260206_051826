/* ---------- storage ---------- */
function save(){ localStorage.setItem(KEY_TREE,JSON.stringify(tree)); }
function load(){
  tree=JSON.parse(localStorage.getItem(KEY_TREE)||'{}');
  if(!tree.root){
    const r={id:uid(),who:'sys',text:'',parent:null,children:[],hash:'',locked:true,ts:now()};
    tree.root=r; tree[r.id]=r; head=r.id; save();
  }
  head ||= tree.root.id;
}

/* ---------- core ---------- */
async function addMessage(who,text,parent){
  const h=sha256(who+text+(parent||''));
  const m={id:uid(),who,text,parent,children:[],hash:h,locked:false,ts:now()};
  tree[m.id]=m;
  tree[parent].children.push(m.id);
  head=m.id;
  save();
}

function editMessage(id){
  const m=tree[id];
  if(!m || m.locked) return toast('Locked');
  const t=prompt('Edit message:',m.text);
  if(t==null) return;
  m.text=t; m.hash='âš  invalidated'; m.ts=now();
  save(); render();
}

function deleteBranch(id){
  const m=tree[id];
  if(!m || m.locked) return toast('Locked');
  if(!confirm('Delete this message and all children?')) return;
  const p=tree[m.parent];
  if(p) p.children = p.children.filter(x=>x!==id);
  (function kill(x){
    const n=tree[x]; if(!n) return;
    for(const c of (n.children||[])) kill(c);
    delete tree[x];
  })(id);
  head = tree.root?.id || head;
  save(); render();
}

function lockBranch(id){
  const m=tree[id]; if(!m) return;
  (function walk(x){
    const n=tree[x]; if(!n) return;
    n.locked=true;
    for(const c of (n.children||[])) walk(c);
  })(id);
  save(); render(); toast('Locked');
}

/* ---------- replay ---------- */
async function replayFrom(id){
  const m=tree[id]; if(!m) return;
  const path=[]; let cur=id;
  while(cur && tree[cur]){ path.unshift(tree[cur]); cur=tree[cur].parent; }
  let p = tree[id].parent;
  for(const n of path){
    if(n.who==='You'){
      addMessage('You', n.text, p);
      fakeModel(n.text);
      p = head;
    }
  }
  toast('Re-ran');
}

