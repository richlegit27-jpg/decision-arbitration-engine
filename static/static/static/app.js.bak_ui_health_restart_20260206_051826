        return u.trim();
      }catch(e){}
      return "";
    };

    // Ctrl+Alt modes => quote blocks
    if(ev.altKey){
      // Ctrl+Alt+Shift => quote nearest code block only
      if(ev.shiftKey){
        const node = _nearestCodeNode();
        const codeTxt = node ? (node.innerText ?? node.textContent ?? "").toString() : "";
        const lang = node ? _pickLang(node) : "";
        const t2 = codeTxt.replace(/\r\n/g,"\n").replace(/\s+$/,"");

        const q = [];
        q.push("> **" + header + "**");
        q.push(">");

        if(t2){
