function render(){
  const log=el('log'); if(!log) return;
  log.innerHTML='';

  const rootId = tree.root?.id;
  if(!rootId){
    log.innerHTML = `<div class="bubble"><b>Nova</b><pre>Missing root node.</pre></div>`;
    return;
  }

  function walk(id,depth){
    const m=tree[id]; if(!m) return;

    if(m.who!=='sys'){
      const div=document.createElement('div');
      div.className='bubble' + (m.who==='You'?' you':'');
