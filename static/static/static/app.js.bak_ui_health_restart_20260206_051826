(() => {
  const _novaCopyTextV1 = async (text) => {
    try{
      if(navigator.clipboard && navigator.clipboard.writeText){
        await navigator.clipboard.writeText(text);
        return true;
      }
    }catch(e){}
    try{
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.style.position = "fixed";
      ta.style.left = "-9999px";
      ta.style.top = "0";
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      document.execCommand("copy");
      document.body.removeChild(ta);
      return true;
    }catch(e){}
    return false;
  };

  const _novaDetectRoleV1 = (el) => {
    try{
      const d = el?.dataset || {};
      const r = (d.role || d.author || d.sender || "").toLowerCase();
      if(r.includes("user")) return "You";
      if(r.includes("assistant") || r.includes("nova") || r.includes("bot")) return "Nova";
    }catch(e){}
    const cls = String(el?.className || "").toLowerCase();
    if(cls.includes("user")) return "You";
    if(cls.includes("assistant") || cls.includes("nova") || cls.includes("bot")) return "Nova";
    return "Message";
  };

  const _novaSanitizeMdV1 = (t) => {
    // keep text readable; we do NOT escape everything (markdown is the point)
    return String(t ?? "").replace(/\r\n/g, "\n").trimEnd();
  };

  const _novaCollectMessagesV1 = () => {
    // try obvious containers first
    const roots = [
      document.querySelector("#chat"),
      document.querySelector("[data-role='chat']"),
      document.body
    ].filter(Boolean);

    for(const root of roots){
      const nodes = root.querySelectorAll?.("[data-role='message'], .message, .msg, .chat-message") || [];
      if(nodes && nodes.length) return Array.from(nodes);
    }
    return [];
  };

  window.NOVA_COPY_ALL_V1 = async () => {
    const msgs = _novaCollectMessagesV1();
    if(!msgs.length){
      const fallback = (document.body?.innerText || "").trim();
      if(!fallback){
        console.warn("[NOVA_COPY_ALL_V1] no messages found");
        return false;
      }
      const ok0 = await _novaCopyTextV1(_novaSanitizeMdV1(fallback));
      if(ok0) console.log("[NOVA_COPY_ALL_V1] copied (fallback text)");
      return ok0;
    }

    const parts = [];
    for(const el of msgs){
      const role = _novaDetectRoleV1(el);
      const txt  = _novaSanitizeMdV1(el.innerText || "");
      if(!txt) continue;
      parts.push(`**${role}:**\n\n${txt}`);
    }

    const out = parts.join("\n\n---\n\n");
    const ok = await _novaCopyTextV1(out);
    if(ok) console.log("[NOVA_COPY_ALL_V1] copied (md)");
    else console.warn("[NOVA_COPY_ALL_V1] copy failed");
    return ok;
  };

  console.log("âœ… NOVA_COPY_ALL_V1 installed");
})();
