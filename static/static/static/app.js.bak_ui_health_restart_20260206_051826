(() => {
  function cleanChatReply(raw){
    try{
      let t = String(raw ?? "");

      // Remove common debug prefixes
      t = t.replace(/^\s*ASSISTANT:\s*/i, "");
      t = t.replace(/^\s*USER:\s*/i, "");

      // Some responses include "model_used: xyz" lines
      t = t.replace(/^\s*model_used:\s*[^\n]*\n?/img, "");

      // If it's JSON like {"text":"..."} then use the text field
      const s = t.trim();
      if(s.startsWith("{") && s.endsWith("}")){
        try{
          const j = JSON.parse(s);
          if(j && typeof j === "object"){
            if(typeof j.text === "string") return j.text;
            if(typeof j.message === "string") return j.message;
            if(j.data && typeof j.data.text === "string") return j.data.text;
          }
        }catch(_){}
      }

      // If it contains an embedded JSON object after a label, try to extract it
      const m = t.match(/\{[\s\S]*\}\s*$/);
      if(m && m[0]){
        try{
          const j = JSON.parse(m[0]);
          if(j && typeof j.text === "string") return j.text;
        }catch(_){}
      }

      return t;
    }catch(_){
      return String(raw ?? "");
    }
  }

  // Expose globally
  window.__NOVA_CLEAN_CHAT_REPLY_V1 = cleanChatReply;
  console.log("[NOVA_CLEAN_CHAT_REPLY_V1] installed");
})();
