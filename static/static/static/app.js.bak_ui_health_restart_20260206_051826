      }
    }catch(e){}

    const header = ts ? (`${whoName} Â· ${ts}`) : whoName;

    // default output = header only
    let out = header;

    // Helper: pick language from node/classes/data-attrs
    const _pickLang = (node) => {
      try{
        const codeEl =
          (node && node.tagName && node.tagName.toLowerCase() === "pre" && node.querySelector)
            ? (node.querySelector("code") || node)
            : node;

        const cls = (codeEl && codeEl.className) ? String(codeEl.className) : "";
        const m = cls.match(/\b(language|lang)-([a-z0-9_+-]+)\b/i);
        if(m && m[2]) return m[2].toLowerCase();

        const dl = (codeEl && codeEl.getAttribute) ? (codeEl.getAttribute("data-language") || codeEl.getAttribute("data-lang")) : "";
        if(dl) return String(dl).trim().toLowerCase();
      }catch(e){}
      return "";
    };

    // Helper: find nearest code node in THIS body
    const _nearestCodeNode = () => {
      try{
        if(!body.querySelectorAll) return null;
        const nodes = Array.from(body.querySelectorAll("pre, code"));
        if(!nodes.length) return null;

        const x = ev.clientX ?? 0;
        const y = ev.clientY ?? 0;

        let best = null;
        let bestD = Infinity;

        for(const n of nodes){
          if(!n.getBoundingClientRect) continue;
          const r = n.getBoundingClientRect();

          const dx = (x < r.left) ? (r.left - x) : (x > r.right ? (x - r.right) : 0);
          const dy = (y < r.top)  ? (r.top - y)  : (y > r.bottom ? (y - r.bottom) : 0);
          const d = Math.sqrt(dx*dx + dy*dy);

          if(d < bestD){
            bestD = d;
            best = n;
          }
        }

        // normalize: if it's <code> inside <pre>, prefer the <pre>
        try{
          if(best && best.tagName && best.tagName.toLowerCase() === "code"){
            const p = best.closest?.("pre");
            if(p) best = p;
