          <button data-act="del"  data-id="${m.id}">Delete</button>
          ${m.who==='You' ? `<button data-act="rerun" data-id="${m.id}">Re-run</button>` : ``}
          <button data-act="lock" data-id="${m.id}">Lock</button>
        </div>
      `;

      div.innerHTML = `
        <div class="btop">
          <div class="bwho">${esc(m.who||'')}</div>
          ${actions}
        </div>
        <small>${esc(m.ts||'')} â€¢ ${esc(m.hash||'')}</small>
      `;
const pre = document.createElement("pre");
pre.textContent = String((m && m.text != null) ? m.text : "");
div.insertBefore(pre, div.querySelector("small"));
log.appendChild(div);}

    for(const c of (m.children||[])) walk(c, depth+1);
  }

  walk(rootId,0);

  log.onclick = (ev) => {
    const btn = ev.target.closest('button');
    if(!btn) return;
    const act = btn.getAttribute('data-act');
    const id = btn.getAttribute('data-id');
    if(!act || !id) return;

    if(act==='copy') return copyMessage(id);
    if(act==='edit') return editMessage(id);
    if(act==='del')  return deleteBranch(id);
    if(act==='rerun')return replayFrom(id);
    if(act==='lock') return lockBranch(id);
  };

  renderGraph();
}

/* ---------- send ---------- */
function send(){
  const i=el('input'); if(!i) return;
  const t=i.value.trim(); if(!t) return;
  i.value='';
  addMessage('You', t, head)
  .then(() => fakeModel(t))
  .then(() => render())
  .catch(async (e) => {
    addMessage('Nova', 'âš  ' + (e?.message || String(e)), head);
    render();
  });

}

/* ---------- boot ---------- */
function boot(){
  applyTheme(getTheme());
  load();
  renderHeader();

  const inp = el('input');
  if (inp) {
    inp.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter') return;

      // Shift+Enter = newline
      if (e.shiftKey) return;

      // Enter = send
      e.preventDefault();
      send();
    });
  }


  graph.canvas=el('graph');
  if(graph.canvas){
    graph.ctx=graph.canvas.getContext('2d');
    const resize=()=>{
      graph.canvas.width = graph.canvas.parentElement.clientWidth;
      graph.canvas.height = graph.canvas.parentElement.clientHeight;
      renderGraph();
    };
    window.addEventListener('resize', resize);
    resize();
  }

  render();
}

