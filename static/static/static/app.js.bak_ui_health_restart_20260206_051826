(function(){
  function parseVideo(s){
    // "/video preset seconds rest..."
    const parts = String(s||"").trim().split(/\s+/);
    const preset = (parts[1]||"youtube").toLowerCase();
    const sec = parseInt(parts[2]||"5",10);
    const rest = parts.slice(3).join(" ") || "red square bouncing";
    const prompt = (isFinite(sec) ? (sec + " second ") : "5 second ") + rest;
    return { preset, prompt };
  }

  async function tryHandleVideo(text){
    const t = String(text||"").trim();
    if(!t.toLowerCase().startsWith("/video")) return false;
    if(typeof window.NOVA_VIDEO !== "function"){
      alert("Video not ready: window.NOVA_VIDEO missing");
      return true;
    }
    const {preset, prompt} = parseVideo(t);
    window.NOVA_VIDEO(prompt, preset);
    return true;
  }

  // Hook into textarea Enter sends by monkeypatching common send function if present
  const _orig = window.doSend;
  if(typeof _orig === "function"){
    window.doSend = async function(){
      const inp = document.getElementById("input");
      const val = inp ? inp.value : "";
      const handled = tryHandleVideo(val);
      if(handled){
        if(inp){ if(("value" in inp)) inp.value=""; else inp.textContent=""; }
        return;
      }
      return _orig.apply(this, arguments);
    };
    console.log("NOVA_VIDEO_SLASH_V1 installed");
  } else {
    console.log("NOVA_VIDEO_SLASH_V1 loaded but doSend not found (ok if your app uses different handler)");
  }
})();
