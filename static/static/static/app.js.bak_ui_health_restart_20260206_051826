(() => {
  if(window.__NOVA_SILENCE_LOGS_V1__) return;
  window.__NOVA_SILENCE_LOGS_V1__ = true;

  const origLog  = console.log.bind(console);
  const origWarn = console.warn.bind(console);
  const origErr  = console.error.bind(console);

  function shouldMute(args){
    try{
      const s = args.map(a => (typeof a === "string" ? a : "")).join(" ");
      // mute common noisy tags but keep real errors
      if(/\bNOVA_[A-Z0-9_]+\b/.test(s)) return true;
      if(/\[NOVA_[A-Z0-9_]+\]/.test(s)) return true;
      if(/\bSEND_COUNT\b/.test(s)) return true;
      return false;
    }catch(_){
      return false;
    }
  }

  console.log = (...args) => { if(!shouldMute(args)) origLog(...args); };
  console.warn = (...args) => { if(!shouldMute(args)) origWarn(...args); };
  // Keep errors by default (don’t hide real problems)
  console.error = (...args) => { origErr(...args); };

  origLog("[NOVA_SILENCE_LOGS_V1] active");
})();
