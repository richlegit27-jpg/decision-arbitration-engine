(() => {
"use strict"

const chatStateApi = window.NovaChatState

if(!chatStateApi){
  throw new Error("NovaChatStorage: window.NovaChatState is required")
}

const {
  state,
  STORAGE_KEYS,
  setActiveChat,
  restoreActiveChat,
} = chatStateApi

function normalizeChat(raw){
  const chatId = String(raw?.chat_id || raw?.id || "").trim()

  return {
    ...raw,
    chat_id: chatId,
    id: chatId,
    title: normalizeTitle(raw?.title),
    created_at: raw?.created_at || null,
    updated_at: raw?.updated_at || null,
  }
}

function normalizeMessage(raw){
  return {
    ...raw,
    id: String(raw?.id || raw?.message_id || `msg_${Date.now()}_${Math.random().toString(16).slice(2)}`),
    message_id: String(raw?.message_id || raw?.id || `msg_${Date.now()}_${Math.random().toString(16).slice(2)}`),
    role: String(raw?.role || "assistant"),
    content: normalizeMessageText(raw?.content),
    created_at: raw?.created_at || null,
    attachments: Array.isArray(raw?.attachments) ? raw.attachments.slice() : [],
  }
}

function normalizeMessageText(value){
  if(value == null){
    return ""
  }

  if(typeof value === "string"){
    return value
  }

  if(typeof value === "number" || typeof value === "boolean"){
    return String(value)
  }

  if(Array.isArray(value)){
    return value
      .map(item => {
        if(item == null){
          return ""
        }
        if(typeof item === "string"){
          return item
        }
        if(typeof item === "number" || typeof item === "boolean"){
          return String(item)
        }
        if(typeof item?.text === "string"){
          return item.text
        }
        if(typeof item?.content === "string"){
          return item.content
        }
        return ""
      })
      .join(" ")
      .trim()
  }

  if(typeof value === "object"){
    if(typeof value.text === "string"){
      return value.text
    }

    if(typeof value.content === "string"){
      return value.content
    }

    if(Array.isArray(value.content)){
      return value.content
        .map(item => {
          if(typeof item === "string"){
            return item
          }
          if(typeof item?.text === "string"){
            return item.text
          }
          if(typeof item?.content === "string"){
            return item.content
          }
          return ""
        })
        .join(" ")
        .trim()
    }
  }

  return ""
}

function normalizeTitle(value){
  let text = normalizeMessageText(value)
  text = String(text || "").replace(/\s+/g, " ").trim()

  if(!text){
    return "New chat"
  }

  return text
}

function safeStorageGet(key){
  try{
    return localStorage.getItem(key)
  }catch(_error){
    return null
  }
}

function safeStorageSet(key, value){
  try{
    localStorage.setItem(key, value)
  }catch(_error){
    // ignore storage failures
  }
}

function safeStorageRemove(key){
  try{
    localStorage.removeItem(key)
  }catch(_error){
    // ignore storage failures
  }
}

function getActiveChatId(){
  return String(state.activeChatId || "").trim()
}

function findChatById(chatId){
  const targetId = String(chatId || "").trim()
  if(!targetId || !Array.isArray(state.chats)){
    return null
  }

  return state.chats.find(chat => String(chat?.chat_id || chat?.id || "").trim() === targetId) || null
}

function sortChatsInPlace(){
  if(!Array.isArray(state.chats)){
    state.chats = []
    return state.chats
  }

  state.chats.sort((a, b) => {
    const aTime = new Date(a?.updated_at || a?.created_at || 0).getTime()
    const bTime = new Date(b?.updated_at || b?.created_at || 0).getTime()
    return bTime - aTime
  })

  return state.chats
}

function persistChats(){
  if(!Array.isArray(state.chats)){
    state.chats = []
  }

  safeStorageSet("nova_chats", JSON.stringify(state.chats))
}

function persistMessages(chatId, messages){
  const id = String(chatId || "").trim()
  if(!id){
    return
  }

  const normalized = Array.isArray(messages)
    ? messages.map(normalizeMessage)
    : []

  safeStorageSet(`nova_messages_${id}`, JSON.stringify(normalized))
}

function loadMessages(chatId){
  const id = String(chatId || "").trim()
  if(!id){
    return []
  }

  const raw = safeStorageGet(`nova_messages_${id}`)
  if(!raw){
    return []
  }

  try{
    const parsed = JSON.parse(raw)
    return Array.isArray(parsed) ? parsed.map(normalizeMessage) : []
  }catch(_error){
    return []
  }
}

function persistAll(){
  persistChats()
  const activeChatId = getActiveChatId()
  if(activeChatId){
    persistMessages(activeChatId, state.messages)
  }
}

function setChats(chats){
  state.chats = Array.isArray(chats)
    ? chats.map(normalizeChat).filter(chat => chat.chat_id)
    : []

  sortChatsInPlace()
  persistChats()
  return state.chats
}

function setMessages(messages){
  state.messages = Array.isArray(messages)
    ? messages.map(normalizeMessage)
    : []

  const activeChatId = getActiveChatId()
  if(activeChatId){
    persistMessages(activeChatId, state.messages)
  }

  return state.messages
}

function createLocalChat(chat = {}){
  const normalized = normalizeChat({
    ...chat,
    chat_id: chat.chat_id || chat.id || `chat_${Date.now()}_${Math.random().toString(16).slice(2)}`,
    title: chat.title || "New chat",
    created_at: chat.created_at || new Date().toISOString(),
    updated_at: chat.updated_at || new Date().toISOString(),
  })

  if(!Array.isArray(state.chats)){
    state.chats = []
  }

  state.chats.unshift(normalized)
  sortChatsInPlace()
  persistChats()
  return normalized
}

function updateChat(chatId, updates = {}){
  const chat = findChatById(chatId)
  if(!chat){
    return null
  }

  Object.assign(chat, updates)

  if("title" in updates){
    chat.title = normalizeTitle(updates.title)
  }

  if(!chat.updated_at){
    chat.updated_at = new Date().toISOString()
  }

  sortChatsInPlace()
  persistChats()
  return chat
}

function removeChat(chatId){
  const id = String(chatId || "").trim()
  if(!id || !Array.isArray(state.chats)){
    return false
  }

  const before = state.chats.length
  state.chats = state.chats.filter(chat => String(chat?.chat_id || chat?.id || "").trim() !== id)

  safeStorageRemove(`nova_messages_${id}`)
  persistChats()

  if(getActiveChatId() === id){
    state.activeChatId = ""
    safeStorageRemove(STORAGE_KEYS.activeChatId)
  }

  return state.chats.length !== before
}

function hydrateChatFromMessageActivity(chatId, messageText){
  const chat = findChatById(chatId)

  if(!chat){
    return null
  }

  const trimmedText = normalizeMessageText(messageText).replace(/\s+/g, " ").trim()

  if((!chat.title || chat.title === "New chat") && trimmedText){
    chat.title = trimmedText.slice(0, 60).trim()
  }else{
    chat.title = normalizeTitle(chat.title)
  }

  chat.updated_at = new Date().toISOString()
  sortChatsInPlace()
  persistChats()

  return chat
}

function renameChat(chatId, title){
  const chat = findChatById(chatId)
  if(!chat){
    return null
  }

  chat.title = normalizeTitle(title)
  chat.updated_at = new Date().toISOString()
  sortChatsInPlace()
  persistChats()

  return chat
}

function restoreChatsFromStorage(){
  const raw = safeStorageGet("nova_chats")
  if(!raw){
    state.chats = Array.isArray(state.chats) ? state.chats : []
    return state.chats
  }

  try{
    const parsed = JSON.parse(raw)
    state.chats = Array.isArray(parsed)
      ? parsed.map(normalizeChat).filter(chat => chat.chat_id)
      : []
  }catch(_error){
    state.chats = []
  }

  sortChatsInPlace()
  return state.chats
}

function restoreMessagesForActiveChat(){
  const activeChatId = getActiveChatId()
  if(!activeChatId){
    state.messages = []
    return state.messages
  }

  state.messages = loadMessages(activeChatId)
  return state.messages
}

function bootFromStorage(){
  restoreChatsFromStorage()
  restoreActiveChat()
  restoreMessagesForActiveChat()
  return {
    chats: state.chats,
    activeChatId: state.activeChatId,
    messages: state.messages,
  }
}

window.NovaChatStorage = {
  normalizeChat,
  normalizeMessage,
  normalizeMessageText,
  normalizeTitle,
  getActiveChatId,
  findChatById,
  sortChatsInPlace,
  persistChats,
  persistMessages,
  loadMessages,
  persistAll,
  setChats,
  setMessages,
  createLocalChat,
  updateChat,
  removeChat,
  hydrateChatFromMessageActivity,
  renameChat,
  restoreChatsFromStorage,
  restoreMessagesForActiveChat,
  bootFromStorage,
  setActiveChat,
}
})()