:root{
  --bg: #0b1020;
  --bg-elev: #11182d;
  --bg-elev-2: #161f38;
  --panel: #0f172a;
  --panel-2: #172036;
  --border: rgba(148,163,184,0.16);
  --border-strong: rgba(148,163,184,0.28);
  --text: #e5e7eb;
  --text-soft: #94a3b8;
  --text-dim: #64748b;
  --accent: #7c3aed;
  --accent-2: #8b5cf6;
  --accent-soft: rgba(124,58,237,0.18);
  --green: #22c55e;
  --red: #ef4444;
  --red-soft: rgba(239,68,68,0.14);

  --sidebar-w: 260px;
  --topbar-h: 56px;
}

*,
*::before,
*::after{
  box-sizing: border-box;
}

html,body{
  margin:0;
  padding:0;
  height:100%;
  background:var(--bg);
  color:var(--text);
  font-family: system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
  -webkit-font-smoothing: antialiased;
}

button{
  font:inherit;
  color:inherit;
  background:none;
  border:none;
  cursor:pointer;
}

input,textarea{
  font:inherit;
  color:inherit;
  background:none;
  border:none;
  outline:none;
}

.message-row{
  display:flex;
  gap:14px;
  align-items:flex-start;
}

.message-avatar{
  width:34px;
  height:34px;
  border-radius:10px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:600;
  font-size:0.85rem;
  background:linear-gradient(180deg,#1f2937,#111827);
}

.role-user .message-avatar{
  background:linear-gradient(180deg,#2563eb,#1e40af);
}

.role-assistant .message-avatar{
  background:linear-gradient(180deg,rgba(15,23,42,0.96),rgba(30,41,59,0.86));
}

.message-body{
  min-width:0;
  flex:1;
}

.message-bubble{
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:12px;
  padding:14px 16px;
}

/* assistant subtle tint */

.role-assistant .message-bubble{
  background:linear-gradient(180deg,rgba(255,255,255,0.055),rgba(255,255,255,0.03));
  border-color:rgba(148,163,184,0.18);
}

.message-content{
  min-width:0;
  color:var(--text);
  font-size:0.98rem;
  line-height:1.7;
  white-space:normal;
  word-break:break-word;
  overflow-wrap:anywhere;
  position:relative;
}

/* streaming cursor */

.message-content.is-streaming::after{
  content:"";
  display:inline-block;
  width:8px;
  height:1.1em;
  margin-left:6px;
  vertical-align:-0.15em;
  border-radius:2px;
  background:rgba(255,255,255,0.85);
  animation:novaBlinkCursor 1s steps(1,end) infinite;
}

@keyframes novaBlinkCursor{
  0%,49%{opacity:1}
  50%,100%{opacity:0.18}
}

.message-actions{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  margin-top:8px;

  opacity:0;
  transform:translateY(4px);
  pointer-events:none;
  transition:opacity 140ms ease,transform 140ms ease;
}

.message-row:hover .message-actions,
.message-row:focus-within .message-actions{
  opacity:1;
  transform:translateY(0);
  pointer-events:auto;
}

.message-action{
  font-size:0.8rem;
  color:var(--text-soft);
  padding:4px 8px;
  border-radius:6px;
  border:1px solid transparent;
}

.message-action:hover{
  background:var(--panel-2);
  border-color:var(--border);
  color:var(--text);
}

.composer-input{
  width:100%;
  resize:none;
  padding:12px 14px;
  border-radius:10px;
  border:1px solid var(--border);
  background:var(--panel);
  line-height:1.5;
}

.composer-send{
  background:var(--accent);
  color:white;
  padding:10px 14px;
  border-radius:8px;
}

.composer-send:hover{
  background:var(--accent-2);
}

.composer-stop{
  background:var(--red-soft);
  color:var(--red);
  padding:10px 14px;
  border-radius:8px;
}

.chat-item{
  padding:10px 12px;
  border-radius:8px;
  cursor:pointer;
  color:var(--text-soft);
}

.chat-item:hover{
  background:var(--panel-2);
  color:var(--text);
}

.chat-item.active{
  background:var(--panel-2);
  color:var(--text);
}