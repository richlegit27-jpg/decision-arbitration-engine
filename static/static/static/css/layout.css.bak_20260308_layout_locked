.app{
  width: 100%;
  height: 100vh;
  display: grid;
  grid-template-columns: var(--sidebar-w) minmax(0, 1fr);
}

.sidebar{
  position: relative;
  z-index: 30;
  height: 100vh;
  display: grid;
  grid-template-rows: auto auto minmax(0, 1fr);
  gap: 16px;
  padding: 18px 16px 16px;
  border-right: 1px solid var(--border);
  background:
    linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.92)),
    linear-gradient(180deg, rgba(124, 58, 237, 0.06), transparent);
  backdrop-filter: blur(18px);
  overflow: hidden;
}

.sidebar-header{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  min-width: 0;
}

.sidebar-controls{
  display: block;
}

.chat-list{
  min-height: 0;
  overflow-y: auto;
  padding-right: 4px;
}

.main{
  min-width: 0;
  height: 100vh;
  display: grid;
  grid-template-rows: var(--topbar-h) minmax(0, 1fr) auto auto;
  overflow: hidden;
}

.topbar{
  display: flex;
  align-items: center;
  gap: 14px;
  min-width: 0;
  height: var(--topbar-h);
  padding: 0 24px;
  border-bottom: 1px solid rgba(148, 163, 184, 0.08);
  background: rgba(11, 16, 32, 0.72);
  backdrop-filter: blur(12px);
}

.messages{
  min-width: 0;
  min-height: 0;
  overflow-y: auto;
  padding: 26px 24px 10px;
  scroll-behavior: smooth;
}

.messages > *{
  width: min(900px, 100%);
  margin-left: auto;
  margin-right: auto;
}

.messages-empty{
  display: grid;
  place-items: center;
  min-height: calc(100vh - 260px);
  text-align: center;
  padding: 20px;
}

.messages .message-row{
  margin-top: 0;
  margin-bottom: 22px;
}

.messages .message-row:last-child{
  margin-bottom: 8px;
}

.empty-state{
  width: min(900px, calc(100% - 48px));
  margin: 0 auto;
  padding-top: 4px;
}

.pending-attachments{
  width: min(900px, calc(100% - 48px));
  margin: 0 auto;
  padding: 8px 0 10px;
}

.composer{
  width: min(900px, calc(100% - 48px));
  margin: 0 auto 22px;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto auto;
  align-items: end;
  gap: 12px;
  padding: 12px;
}

/* MOBILE OVERLAY */

.mobile-overlay{
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(2, 6, 23, 0.56);
  opacity: 0;
  pointer-events: none;
  transition: opacity 160ms ease;
}

.mobile-overlay.show,
.mobile-overlay.is-open{
  opacity: 1;
  pointer-events: auto;
}

#btnSidebarClose{
  display: none;
}

/* MOBILE */

@media (max-width: 959px){

  .app{
    grid-template-columns: minmax(0, 1fr);
  }

  .sidebar{
    position: fixed;
    inset: 0 auto 0 0;
    width: min(88vw, 320px);
    transform: translateX(-100%);
    transition: transform 180ms ease;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.46);
  }

  .sidebar.open,
  .sidebar.is-open{
    transform: translateX(0);
  }

  #btnSidebarClose{
    display: inline-flex;
  }

  .main{
    width: 100%;
    grid-template-rows: var(--topbar-h) minmax(0, 1fr) auto auto;
  }

  .topbar{
    padding: 0 14px;
  }

  .messages{
    padding: 18px 14px 8px;
  }

  .messages > *{
    width: 100%;
  }

  .empty-state{
    width: calc(100% - 28px);
  }

  .pending-attachments{
    width: calc(100% - 28px);
    padding: 8px 0;
  }

  .composer{
    width: calc(100% - 28px);
    margin-bottom: 14px;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 10px;
  }

  .composer-input{
    grid-column: 1 / -1;
    order: 3;
    padding-top: 8px;
    padding-bottom: 8px;
  }

  .composer-send,
  .composer-stop{
    justify-self: end;
  }

}

/* DESKTOP */

@media (min-width: 960px){

  .mobile-sidebar-btn{
    display: none;
  }

  #btnSidebarClose{
    display: none !important;
  }

  .sidebar{
    transform: none !important;
  }

}