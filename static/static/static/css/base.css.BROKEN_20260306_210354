:root {
  --bg: #0b1020;
  --bg-2: #0f1630;
  --panel: rgba(18, 25, 51, 0.88);
  --panel-2: rgba(24, 33, 63, 0.96);
  --panel-3: rgba(31, 43, 82, 0.98);
  --surface: rgba(255, 255, 255, 0.04);
  --surface-2: rgba(255, 255, 255, 0.07);
  --border: rgba(255, 255, 255, 0.09);
  --border-strong: rgba(124, 156, 255, 0.28);
  --text: #eef2ff;
  --muted: #9ba7cc;
  --accent: #7c9cff;
  --accent-2: #9eb5ff;
  --accent-3: #5f80ea;
  --danger: #ff6b81;
  --danger-bg: rgba(255, 107, 129, 0.12);
  --user: linear-gradient(180deg, #243567 0%, #1d2b56 100%);
  --assistant: linear-gradient(180deg, #111933 0%, #0c1429 100%);
  --shadow: 0 18px 50px rgba(0, 0, 0, 0.32);
  --shadow-soft: 0 8px 30px rgba(0, 0, 0, 0.18);
  --radius: 20px;
  --radius-sm: 14px;
}

body.light {
  --bg: #eef3ff;
  --bg-2: #e7eefc;
  --panel: rgba(255, 255, 255, 0.85);
  --panel-2: rgba(255, 255, 255, 0.98);
  --panel-3: rgba(248, 250, 255, 0.98);
  --surface: rgba(27, 39, 84, 0.04);
  --surface-2: rgba(27, 39, 84, 0.08);
  --border: rgba(18, 25, 51, 0.10);
  --border-strong: rgba(95, 128, 234, 0.28);
  --text: #13203f;
  --muted: #5d6b93;
  --accent: #5f80ea;
  --accent-2: #7996f0;
  --accent-3: #4c6bdd;
  --danger: #d94b63;
  --danger-bg: rgba(217, 75, 99, 0.10);
  --user: linear-gradient(180deg, #dbe6ff 0%, #cadbff 100%);
  --assistant: linear-gradient(180deg, #ffffff 0%, #f5f8ff 100%);
  --shadow: 0 18px 50px rgba(45, 66, 130, 0.12);
  --shadow-soft: 0 8px 30px rgba(45, 66, 130, 0.10);
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  padding: 0;
  min-height: 100%;
  background:
    radial-gradient(circle at top, rgba(124, 156, 255, 0.14), transparent 28%),
    linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
  color: var(--text);
  font-family: Inter, Segoe UI, Arial, sans-serif;
}

body {
  overflow-x: hidden;
}

button,
textarea,
input {
  font: inherit;
}

button {
  cursor: pointer;
}

.hidden {
  display: none !important;
}

.btn,
.icon-btn,
.send-btn,
.chat-item,
.msg-action,
.attachment-chip,
.toast {
  transition:
    transform 0.16s ease,
    background 0.16s ease,
    border-color 0.16s ease,
    color 0.16s ease,
    box-shadow 0.16s ease,
    opacity 0.16s ease;
}

.btn {
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text);
  border-radius: 14px;
  padding: 10px 14px;
}

.btn:hover:not(:disabled) {
  transform: translateY(-1px);
  background: var(--surface-2);
}

.btn:disabled,
.icon-btn:disabled,
.send-btn:disabled {
  opacity: 0.58;
  cursor: not-allowed;
  transform: none;
}

.btn-primary {
  background: linear-gradient(180deg, var(--accent), var(--accent-3));
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 8px 24px rgba(95, 128, 234, 0.28);
}

.btn-primary:hover:not(:disabled) {
  background: linear-gradient(180deg, var(--accent-2), var(--accent));
}

.btn-danger {
  background: var(--danger-bg);
  color: var(--danger);
  border-color: rgba(255, 107, 129, 0.24);
}

.btn-danger:hover:not(:disabled) {
  background: rgba(255, 107, 129, 0.16);
}

.btn-quiet {
  background: transparent;
}

.btn-block {
  width: 100%;
}

.icon-btn {
  width: 42px;
  height: 42px;
  border: 1px solid var(--border);
  border-radius: 14px;
  background: var(--surface);
  color: var(--text);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.icon-btn:hover:not(:disabled) {
  transform: translateY(-1px);
  background: var(--surface-2);
}

.send-btn {
  min-width: 96px;
  height: 48px;
  border: 1px solid transparent;
  border-radius: 16px;
  background: linear-gradient(180deg, var(--accent), var(--accent-3));
  color: #fff;
  font-weight: 700;
  padding: 0 18px;
  box-shadow: 0 10px 26px rgba(95, 128, 234, 0.28);
}

.send-btn:hover:not(:disabled) {
  transform: translateY(-1px);
  background: linear-gradient(180deg, var(--accent-2), var(--accent));
}

.mobile-only {
  display: none;
}

.model-pill {
  border: 1px solid var(--border-strong);
  background: rgba(124, 156, 255, 0.10);
  color: var(--accent-2);
  border-radius: 999px;
  padding: 7px 12px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.04em;
}

.message-markdown {
  color: var(--text);
  line-height: 1.7;
  word-break: break-word;
}

.message-markdown p {
  margin: 0 0 12px;
}

.message-markdown p:last-child {
  margin-bottom: 0;
}

.message-markdown h1,
.message-markdown h2,
.message-markdown h3,
.message-markdown h4 {
  margin: 0 0 14px;
  line-height: 1.28;
}

.message-markdown ul,
.message-markdown ol {
  margin: 0 0 12px 22px;
}

.message-markdown li {
  margin-bottom: 6px;
}

.message-markdown pre {
  overflow: auto;
  padding: 15px;
  border-radius: 16px;
  background: #0a1022;
  border: 1px solid var(--border);
}

body.light .message-markdown pre {
  background: #edf2ff;
}

.message-markdown code {
  font-family: Consolas, Monaco, monospace;
}

.message-markdown :not(pre) > code {
  background: var(--surface-2);
  padding: 2px 7px;
  border-radius: 8px;
}

.message-markdown table {
  width: 100%;
  border-collapse: collapse;
  margin: 12px 0;
  overflow: hidden;
}

.message-markdown th,
.message-markdown td {
  border: 1px solid var(--border);
  padding: 10px;
  text-align: left;
}

.message-markdown blockquote {
  margin: 14px 0;
  padding: 4px 0 4px 14px;
  border-left: 3px solid var(--accent);
  color: var(--muted);
}

.toast-host {
  position: fixed;
  right: 16px;
  bottom: 18px;
  z-index: 60;
  display: flex;
  flex-direction: column;
  gap: 10px;
  pointer-events: none;
}

.toast {
  pointer-events: auto;
  min-width: 220px;
  max-width: 320px;
  padding: 12px 14px;
  border-radius: 14px;
  border: 1px solid var(--border);
  background: var(--panel-2);
  box-shadow: var(--shadow);
  color: var(--text);
  transform: translateY(8px);
  opacity: 0;
}

.toast.show {
  transform: translateY(0);
  opacity: 1;
}

.toast.success {
  border-color: rgba(124, 156, 255, 0.24);
}

.toast.error {
  border-color: rgba(255, 107, 129, 0.24);
}

::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.14);
  border-radius: 999px;
}

body.light ::-webkit-scrollbar-thumb {
  background: rgba(27, 39, 84, 0.18);
}

::-webkit-scrollbar-track {
  background: transparent;
}