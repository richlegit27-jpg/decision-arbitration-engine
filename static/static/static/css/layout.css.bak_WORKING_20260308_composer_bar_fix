html,
body{
  margin:0;
  padding:0;
  width:100%;
  height:100%;
  overflow:hidden;
}

body{
  background:var(--bg);
  color:var(--text);
}

/* ================================
   APP GRID
================================ */

#appShell.app-shell{
  height:100vh;
  width:100%;
  display:grid;
  grid-template-columns:320px minmax(0,1fr);
  background:var(--bg);
  overflow:hidden;
}

/* ================================
   SIDEBAR
================================ */

#sidebar.sidebar{
  display:flex;
  flex-direction:column;
  min-height:0;
  background:var(--panel);
  border-right:1px solid var(--border);
}

.sidebar-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:16px;
  border-bottom:1px solid var(--border);
}

.sidebar-actions{
  padding:14px;
  border-bottom:1px solid var(--border);
}

#chatList.chat-list{
  flex:1;
  overflow:auto;
  padding:12px;
}

/* ================================
   MAIN PANEL
================================ */

.main-panel{
  display:flex;
  flex-direction:column;
  height:100vh;
  min-height:0;
  overflow:hidden;
}

/* ================================
   TOPBAR
================================ */

.topbar{
  flex:0 0 auto;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:14px 18px;
  border-bottom:1px solid var(--border);
  background:var(--panel);
}

/* ================================
   MESSAGES AREA
================================ */

.messages-scroll{
  flex:1 1 auto;
  min-height:0;
  overflow-y:auto;
  overflow-x:hidden;
  scroll-behavior:smooth;
}

#messages.messages{
  width:min(900px,100%);
  margin:0 auto;
  padding:22px 18px 160px;
}

.message{
  display:grid;
  grid-template-columns:44px minmax(0,1fr);
  gap:14px;
  margin-bottom:18px;
}

.message-avatar{
  width:44px;
  height:44px;
  border:1px solid var(--border);
  border-radius:14px;
  display:grid;
  place-items:center;
  font-weight:700;
}

.message-bubble{
  border:1px solid rgba(148,163,184,.14);
  border-radius:18px;
  padding:14px 16px;
  background:rgba(255,255,255,.035);
}

/* ================================
   COMPOSER
================================ */

.composer-wrap{
  flex:0 0 auto;
  padding:14px 18px 18px;
  background:var(--panel);
}

.composer-shell{
  width:min(900px,100%);
  margin:0 auto;
}

.composer-form{
  display:flex;
  flex-direction:column;
  gap:10px;
  padding:12px;
  border:1px solid var(--border);
  border-radius:22px;
  background:rgba(15,23,42,.92);
}

#input{
  width:100%;
  min-height:52px;
  max-height:280px;
  resize:none;
  border:1px solid var(--border);
  border-radius:14px;
  padding:12px 14px;
}

/* ================================
   MOBILE
================================ */

@media (max-width:620px){

  #appShell.app-shell{
    grid-template-columns:minmax(0,1fr);
  }

  #sidebar.sidebar{
    position:fixed;
    top:0;
    bottom:0;
    left:0;
    width:320px;
    transform:translateX(-100%);
    transition:transform 180ms ease;
  }

  #sidebar.sidebar.is-open{
    transform:translateX(0);
  }

}