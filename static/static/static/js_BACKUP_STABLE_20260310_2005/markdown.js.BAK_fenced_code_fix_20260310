(() => {
"use strict"

function escapeHtml(value){
  return String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;")
}

function applyInlineFormatting(text){
  let html = String(text || "")

  html = html.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
  html = html.replace(/`([^`]+)`/g, "<code>$1</code>")

  return html
}

function renderMarkdown(text){
  if(!text){
    return ""
  }

  const source = String(text).replace(/\r\n/g, "\n").replace(/\r/g, "\n")
  const lines = source.split("\n")

  let html = ""
  let inBulletList = false
  let inNumberList = false
  let inCodeBlock = false
  let codeLang = ""
  let codeLines = []

  function closeLists(){
    if(inBulletList){
      html += "</ul>"
      inBulletList = false
    }

    if(inNumberList){
      html += "</ol>"
      inNumberList = false
    }
  }

  function closeCodeBlock(){
    if(!inCodeBlock){
      return
    }

    const codeText = escapeHtml(codeLines.join("\n"))
    const langClass = codeLang ? ` class="language-${escapeHtml(codeLang)}"` : ""

    html += `<pre><code${langClass}>${codeText}</code></pre>`

    inCodeBlock = false
    codeLang = ""
    codeLines = []
  }

  for(const rawLine of lines){
    const line = String(rawLine || "")

    if(inCodeBlock){
      if(/^```/.test(line.trim())){
        closeCodeBlock()
      }else{
        codeLines.push(line)
      }
      continue
    }

    const fenceMatch = line.trim().match(/^```([\w+-]*)\s*$/)
    if(fenceMatch){
      closeLists()
      inCodeBlock = true
      codeLang = String(fenceMatch[1] || "").trim()
      codeLines = []
      continue
    }

    if(/^\s*[-*]\s+/.test(line)){
      if(inNumberList){
        html += "</ol>"
        inNumberList = false
      }

      if(!inBulletList){
        html += "<ul>"
        inBulletList = true
      }

      const item = escapeHtml(line.replace(/^\s*[-*]\s+/, ""))
      html += `<li>${applyInlineFormatting(item)}</li>`
      continue
    }

    if(/^\s*\d+\.\s+/.test(line)){
      if(inBulletList){
        html += "</ul>"
        inBulletList = false
      }

      if(!inNumberList){
        html += "<ol>"
        inNumberList = true
      }

      const item = escapeHtml(line.replace(/^\s*\d+\.\s+/, ""))
      html += `<li>${applyInlineFormatting(item)}</li>`
      continue
    }

    closeLists()

    if(line.trim() === ""){
      html += "<br>"
      continue
    }

    const safeLine = escapeHtml(line)

    if(/^#{1,6}\s/.test(line)){
      const headingMatch = line.match(/^(#{1,6})\s+(.*)$/)
      const level = headingMatch ? headingMatch[1].length : 1
      const content = headingMatch ? escapeHtml(headingMatch[2]) : safeLine
      html += `<h${level}>${applyInlineFormatting(content)}</h${level}>`
      continue
    }

    html += `<p>${applyInlineFormatting(safeLine)}</p>`
  }

  closeLists()
  closeCodeBlock()

  return html
}

window.NovaMarkdown = {
  render: renderMarkdown,
}

})()