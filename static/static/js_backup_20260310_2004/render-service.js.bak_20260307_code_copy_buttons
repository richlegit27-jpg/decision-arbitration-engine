(() => {
"use strict"

function createRenderService(options = {}){
  const {
    state,
    elements = {},
    utils = {},
    attachmentsService,
  } = options

  if(!state){
    throw new Error("NovaRenderService: state is required")
  }

  const el = {
    messages: elements.messages || null,
    chatList: elements.chatList || null,
    pendingAttachments: elements.pendingAttachments || null,
  }

  const escapeHtml = utils.escapeHtml || ((value) => String(value ?? ""))
  const formatBytes =
    utils.formatBytes ||
    ((bytes) => {
      const n = Number(bytes || 0)

      if(!Number.isFinite(n) || n <= 0){
        return "0 B"
      }

      const units = ["B", "KB", "MB", "GB", "TB"]
      let size = n
      let i = 0

      while(size >= 1024 && i < units.length - 1){
        size /= 1024
        i += 1
      }

      if(i === 0){
        return `${Math.round(size)} ${units[i]}`
      }

      return `${size < 10 ? size.toFixed(1) : Math.round(size)} ${units[i]}`
    })

  let scrollFrame = null

  function ensureChatsArray(){
    if(!Array.isArray(state.chats)){
      state.chats = []
    }

    return state.chats
  }

  function ensureMessagesArray(){
    if(!Array.isArray(state.messages)){
      state.messages = []
    }

    return state.messages
  }

  function isNearBottom(){
    if(!el.messages){
      return true
    }

    const threshold = 120
    const distanceFromBottom =
      el.messages.scrollHeight - el.messages.scrollTop - el.messages.clientHeight

    return distanceFromBottom <= threshold
  }

  function scrollToBottom(force = false){
    try {
      if(!el.messages){
        return
      }

      if(!force && !isNearBottom()){
        return
      }

      if(scrollFrame){
        cancelAnimationFrame(scrollFrame)
      }

      scrollFrame = requestAnimationFrame(() => {
        el.messages.scrollTop = el.messages.scrollHeight
        scrollFrame = null
      })
    } catch(error){
      console.error("Nova scrollToBottom error:", error)
    }
  }

  function renderInlineMarkdown(text){
    let value = escapeHtml(text || "")

    value = value.replace(/`([^`\n]+)`/g, "<code>$1</code>")
    value = value.replace(/\*\*([^\n*][\s\S]*?[^\n*]?)\*\*/g, "<strong>$1</strong>")
    value = value.replace(/\*([^\n*][\s\S]*?[^\n*]?)\*/g, "<em>$1</em>")

    return value
  }

  function renderMessageText(content){
    const source = String(content || "")

    if(!source.trim()){
      return ""
    }

    const lines = source.replace(/\r\n/g, "\n").split("\n")
    const html = []

    let inCodeBlock = false
    let codeLines = []
    let inList = false
    let paragraphLines = []

    function flushParagraph(){
      if(paragraphLines.length === 0){
        return
      }

      const text = paragraphLines.join("<br>")
      html.push(`<p>${renderInlineMarkdown(text)}</p>`)
      paragraphLines = []
    }

    function flushList(){
      if(inList){
        html.push("</ul>")
        inList = false
      }
    }

    function flushCodeBlock(){
      if(!inCodeBlock){
        return
      }

      html.push(`<pre><code>${escapeHtml(codeLines.join("\n"))}</code></pre>`)
      codeLines = []
      inCodeBlock = false
    }

    for(const rawLine of lines){
      const line = String(rawLine || "")
      const trimmed = line.trim()

      if(trimmed.startsWith("```")){
        flushParagraph()
        flushList()

        if(inCodeBlock){
          flushCodeBlock()
        } else {
          inCodeBlock = true
          codeLines = []
        }

        continue
      }

      if(inCodeBlock){
        codeLines.push(line)
        continue
      }

      if(!trimmed){
        flushParagraph()
        flushList()
        continue
      }

      const headingMatch = trimmed.match(/^(#{1,3})\s+(.+)$/)

      if(headingMatch){
        flushParagraph()
        flushList()

        const level = headingMatch[1].length
        const text = renderInlineMarkdown(headingMatch[2])
        html.push(`<h${level}>${text}</h${level}>`)
        continue
      }

      const bulletMatch = trimmed.match(/^[-*]\s+(.+)$/)

      if(bulletMatch){
        flushParagraph()

        if(!inList){
          html.push("<ul>")
          inList = true
        }

        html.push(`<li>${renderInlineMarkdown(bulletMatch[1])}</li>`)
        continue
      }

      paragraphLines.push(line)
    }

    flushParagraph()
    flushList()
    flushCodeBlock()

    return html.join("")
  }

  function renderChats(){
    if(!el.chatList){
      return
    }

    const chats = ensureChatsArray()
    const activeChatId = String(state.activeChatId || state.chatId || "").trim()

    el.chatList.innerHTML = chats.map((chat) => {
      const chatId = String(chat?.chat_id || "").trim()
      const title = escapeHtml(chat?.title || "New Chat")
      const activeClass = chatId === activeChatId ? " active" : ""

      return `
        <div class="chat-item${activeClass}" data-chat-id="${escapeHtml(chatId)}">
          <button
            type="button"
            class="chat-main"
            data-chat-id="${escapeHtml(chatId)}"
            title="${title}"
          >
            <span class="chat-title">${title}</span>
          </button>

          <div class="chat-actions">
            <button
              type="button"
              class="chat-action-btn"
              data-chat-action="rename"
              data-chat-id="${escapeHtml(chatId)}"
              aria-label="Rename chat"
              title="Rename"
            >
              ✎
            </button>

            <button
              type="button"
              class="chat-action-btn"
              data-chat-action="delete"
              data-chat-id="${escapeHtml(chatId)}"
              aria-label="Delete chat"
              title="Delete"
            >
              🗑
            </button>
          </div>
        </div>
      `
    }).join("")
  }

  function renderMessageAttachments(attachments){
    if(!Array.isArray(attachments) || attachments.length === 0){
      return ""
    }

    return `
      <div class="message-attachments">
        ${attachments.map((attachment) => {
          const name = escapeHtml(attachment?.name || "file")
          const size = escapeHtml(formatBytes(attachment?.size || 0))

          return `
            <div class="message-attachment">
              <div class="message-attachment-name">${name}</div>
              <div class="message-attachment-size">${size}</div>
            </div>
          `
        }).join("")}
      </div>
    `
  }

  function renderMessageActions(msg){
    const role = String(msg?.role || "assistant")
    const id = escapeHtml(msg?.id || "")

    if(role === "user"){
      return `
        <div class="message-actions">
          <button
            type="button"
            class="message-action-btn"
            data-message-action="edit"
            data-message-id="${id}"
            title="Edit"
            aria-label="Edit message"
          >
            Edit
          </button>
        </div>
      `
    }

    return `
      <div class="message-actions">
        <button
          type="button"
          class="message-action-btn"
          data-message-action="copy"
          data-message-id="${id}"
          title="Copy"
          aria-label="Copy message"
        >
          Copy
        </button>

        <button
          type="button"
          class="message-action-btn"
          data-message-action="regenerate"
          data-message-id="${id}"
          title="Regenerate response"
          aria-label="Regenerate response"
        >
          Regenerate
        </button>
      </div>
    `
  }

  function renderMessages(){
    if(!el.messages){
      return
    }

    const shouldFollow = isNearBottom()
    const messages = ensureMessagesArray()

    el.messages.innerHTML = messages.map((msg) => {
      const id = escapeHtml(msg?.id || "")
      const role = escapeHtml(msg?.role || "assistant")
      const pendingClass = msg?.pending ? " pending" : ""
      const errorClass = msg?.error ? " error" : ""
      const content = renderMessageText(msg?.content || "")
      const attachmentsHtml = renderMessageAttachments(msg?.attachments)
      const actionsHtml = renderMessageActions(msg)
      const cursorHtml = msg?.pending ? '<span class="streaming-cursor"></span>' : ""

      return `
        <div class="message ${role}${pendingClass}${errorClass}" data-message-id="${id}">
          <div class="bubble">
            ${attachmentsHtml}
            <div class="message-text">${content}${cursorHtml}</div>
          </div>
          ${actionsHtml}
        </div>
      `
    }).join("")

    scrollToBottom(shouldFollow)
  }

  function renderPendingAttachments(){
    if(!el.pendingAttachments){
      return
    }

    const files = attachmentsService?.getPendingFiles?.() || state.pendingFiles || []

    if(!Array.isArray(files) || files.length === 0){
      el.pendingAttachments.innerHTML = ""
      return
    }

    el.pendingAttachments.innerHTML = files.map((file, index) => {
      const name = escapeHtml(file?.name || "file")
      const size = escapeHtml(formatBytes(file?.size || 0))

      return `
        <div class="pending-file" data-file-index="${index}">
          <div class="pending-file-main">
            <div class="pending-file-name" title="${name}">${name}</div>
            <div class="pending-file-size">${size}</div>
          </div>

          <button
            type="button"
            class="pending-file-remove"
            data-remove-file="${index}"
            aria-label="Remove ${name}"
            title="Remove file"
          >
            ×
          </button>
        </div>
      `
    }).join("")
  }

  function renderAll(){
    renderChats()
    renderMessages()
    renderPendingAttachments()
  }

  return {
    renderChats,
    renderMessages,
    renderPendingAttachments,
    renderAll,
    scrollToBottom,
  }
}

window.NovaRenderService = {
  createRenderService,
}

})()