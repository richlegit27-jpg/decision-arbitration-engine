    try { if (typeof window.novaOpenPalette === "function") { window.novaOpenPalette(); return true; } } catch(e){}
    return false;
  }

  window.addEventListener("keydown", (e) => {
    const k = String(e.key || "").toLowerCase();
    const wants = (k === "f2") || (e.altKey && !e.ctrlKey && k === "k") || (e.ctrlKey && !e.altKey && k === "k");
    if (!wants) return;

    if (!openPalette()) return;

    e.preventDefault();
    e.stopPropagation();
    if (e.stopImmediatePropagation) e.stopImmediatePropagation();
  }, true);
})();








