const log=document.getElementById("log");
 const msg=document.getElementById("msg");
 const send=document.getElementById("send");
 const stop=document.getElementById("stop");
 const clearBtn=document.getElementById("clear");
 const regen=document.getElementById("regen");
const statusEl=document.getElementById("status");
 loadHistory();
  function replayHistory(){
   try{
     if(!Array.isArray(history) || history.length===0) return;
     for(const m of history){
       if(!m || !m.role) continue;
       const title = (m.role==="user") ? "You" : (m.role==="assistant" ? "Nova" : "System");
       addCard(title, m.content || "");
     }
   }
catch(_){
}
 }
 replayHistory();
 try{
   statusEl.textContent = "Loaded history: " + (Array.isArray(history) ? history.length : 0) + " messages";
 }
catch(_){
}
 let aborter=null;
 window.__NOVA_ABORTER__ = {
 get:()=>aborter, set:(v)=>{
aborter=v;
}
 }
;
 let history = [];
  const STORE_KEY = "nova_history_v1";
  function saveHistory(){
   try {
 localStorage.setItem(STORE_KEY, JSON.stringify(history));
 }
 catch(_) {
}
 }
 function loadHistory(){
   try {
     const raw = localStorage.getItem(STORE_KEY);
     if(!raw) return;
     const arr = JSON.parse(raw);
     if(Array.isArray(arr)) history = arr;
   }
 catch(_) {
}
 }
 function clearHistory(){
   try {
 localStorage.removeItem(STORE_KEY);
 }
 catch(_) {
}
   history = [];
 }
let lastUserText="";
  function addCard(title,text){
   const c=document.createElement("div");
   c.className="card";
   const m=document.createElement("div");
   m.className="meta";
   m.textContent=title;
   const p=document.createElement("pre");
   p.textContent=text||"";
   c.appendChild(m);
   c.appendChild(p);
   log.prepend(c);
   return p;
 }
  function setBusy(b){
   send.disabled=b;
   stop.disabled=!b;
   if(regen) regen.disabled=b || !lastUserText;
 }
  async function streamChat(userText){
   if(!userText)return;
   setBusy(true);
   statusEl.textContent="Streaming...";
 console.log("[UI] streamChat start", userText);
 addCard("You",userText);
   history.push({
role:"user",content:userText}
);
 saveHistory();
 lastUserText=userText;
 if(regen) regen.disabled=false;
const pre=addCard("Nova","");
    try{
     aborter=new AbortController(); try{ window.__NOVA_ABORTER__ && window.__NOVA_ABORTER__.set && window.__NOVA_ABORTER__.set(aborter); }catch(e){} 
try{ window.__NOVA_ABORTER__ && window.__NOVA_ABORTER__.set && window.__NOVA_ABORTER__.set(aborter); }catch(e){} 
try{
 window.__NOVA_ABORTER__ && window.__NOVA_ABORTER__.set(aborter);
 }
catch(e){
}
;
      addCard("Debug", "Sending history length: " + (Array.isArray(history) ? history.length : 0));
 const r = await fetch("/api/chat_stream", {
       method:"POST",       headers:{
"Content-Type":"application/json"}
,       body: JSON.stringify({
   text: userText,   mode: "ask",   model: (typeof chosenModel !== "undefined" && chosenModel && chosenModel.value) ? chosenModel.value : "llama3.1:8b",   messages: history }
),       signal:aborter.signal     }
);
      if(!r.ok||!r.body){
       throw new Error("HTTP "+r.status);
     }
      const reader=r.body.getReader(); window.__NOVA_READER__ = reader;
     const dec=new TextDecoder();
     let buf="";
     let live="";
      while(true){
       const {
value,done}
=await reader.read();
       if(done)break;
       buf+=dec.decode(value,{
stream:true}
);
 console.log("[UI] chunk bytes", value ? value.length : 0);
 while(true){
         const sep=buf.indexOf("\n\n");
         if(sep===-1)break;
          const frame=buf.slice(0,sep);
         buf=buf.slice(sep+2);
          let ev="";
         let dataLine="";
          for(const line of frame.split("\n")){
           if(line.startsWith("event:"))ev=line.slice(6).trim();
           if(line.startsWith("data:"))dataLine=line.slice(5).trim();
         }
          if(!dataLine)continue;
         const obj=JSON.parse(dataLine);
          if(ev==="token"){
 console.log("[UI] token", (obj.t||""));
 live+=(obj.t||"");
 pre.textContent=live;
 }
          if(ev==="done"){
           statusEl.textContent="Done.";
         }
          if(ev==="error"){
           pre.textContent=obj.error||"Error";
           statusEl.textContent="Error.";
         }
       }
     }
      history.push({
role:"assistant",content:live}
);
 saveHistory();
 }
catch(e){
     if(String(e).includes("AbortError")){
       statusEl.textContent="Stopped.";
     }
else{
       pre.textContent=String(e);
       statusEl.textContent="Error.";
     }
   }
finally{
     aborter=null; try{ window.__NOVA_READER__ = null; }catch(e){} setBusy(false);
   }
 }
  send.onclick = () => {
  const t = msg.value.trim();
  msg.value = "";
  streamChat(t);
};

stop.onclick = () => { try{ window.__NOVA_READER__ && window.__NOVA_READER__.cancel && window.__NOVA_READER__.cancel(); }catch(e){} try{ window.__NOVA_ABORTER__ && window.__NOVA_ABORTER__.get && window.__NOVA_ABORTER__.get() && window.__NOVA_ABORTER__.get().abort(); }catch(e){} try{ if(window.NOVA_STOP) window.NOVA_STOP(); }catch(e){} };



regen.onclick = () => {
  if (!lastUserText) return;
  streamChat(lastUserText);
};

clearBtn.onclick = () => {
  clearHistory();
  log.innerHTML = "";
  statusEl.textContent = "Cleared.";
};

msg.addEventListener("keydown", (e) => {
  if (e.key === "Enter" && !e.shiftKey) {
    e.preventDefault();
    send.click();
  }
});








