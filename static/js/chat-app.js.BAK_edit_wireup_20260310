(() => {
"use strict"

const chatStateApi = window.NovaChatState
const chatSidebar = window.NovaChatSidebar
const chatStorage = window.NovaChatStorage
const composer = window.NovaComposer
const chatMessages = window.NovaChatMessages

if(!chatStateApi){
  throw new Error("NovaChatApp: window.NovaChatState is required")
}

const { state } = chatStateApi

let started = false

async function restoreLastChat(){
  try{
    const savedChatId = localStorage.getItem("nova_active_chat_id")

    if(!savedChatId){
      return
    }

    if(window.NovaChatSidebar?.switchChat){
      await window.NovaChatSidebar.switchChat(savedChatId)
    }
  }catch(error){
    console.error("Nova restoreLastChat failed:", error)
  }
}

function renderAll(){
  try{
    if(chatSidebar?.renderChatList){
      chatSidebar.renderChatList()
    }

    if(window.NovaChatMessages?.renderMessages){
      window.NovaChatMessages.renderMessages()
    }
  }catch(error){
    console.error("NovaChatApp renderAll error:", error)
  }
}

async function start(){
  if(started){
    return
  }

  started = true

  try{
    if(chatStorage?.loadChats){
      await chatStorage.loadChats()
    }

    if(chatSidebar?.bindEvents){
      chatSidebar.bindEvents({})
    }

    if(chatMessages?.bindEvents){
      chatMessages.bindEvents({
        onRetry: async (text) => {
          if(composer?.setInputValue){
            composer.setInputValue(text || "")
          }

          if(composer?.focusInput){
            composer.focusInput()
          }
        },
        onEdit: async ({ content }) => {
          if(composer?.setInputValue){
            composer.setInputValue(content || "")
          }

          if(composer?.focusInput){
            composer.focusInput()
          }
        },
      })
    }

    if(composer?.bindEvents){
      composer.bindEvents({
        onNeedsCreateChat: async () => {
          if(chatSidebar?.createNewChat){
            return await chatSidebar.createNewChat({})
          }
          return null
        },
        onAfterSend: () => {
          renderAll()
        },
      })
    }

    renderAll()

    await restoreLastChat()
  }catch(error){
    console.error("NovaChatApp start error:", error)
  }
}

window.NovaChatApp = {
  start,
  renderAll,
}

document.addEventListener("DOMContentLoaded", () => {
  start()
})

})()