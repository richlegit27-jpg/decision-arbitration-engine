document.addEventListener("DOMContentLoaded",()=>{
  "use strict";
  const Nova=window.Nova=window.Nova||{};
  Nova.state=Nova.state||{};

  const sidebar=document.getElementById("novaSidebar");
  const sidebarToggle=document.getElementById("sidebarToggle");
  sidebarToggle.addEventListener("click",()=>sidebar.classList.toggle("collapsed"));

  // Chat
  const messagesContainer=document.getElementById("messages");
  const inputEl=document.getElementById("composerInput");
  const sendBtn=document.getElementById("sendBtn");

  function renderMessage(role,content){
    const div=document.createElement("div");
    div.className=`chat-message ${role}`;
    div.textContent=content;
    messagesContainer.appendChild(div);
    messagesContainer.scrollTop=messagesContainer.scrollHeight;
  }

  async function saveMessage(role,content){
    try{await fetch("/api/chat/save",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({role,content})})}
    catch(err){console.error(err);}
  }

  async function loadMessages(){
    try{
      const resp=await fetch("/api/chat/load");
      const data=await resp.json();
      if(data.ok&&Array.isArray(data.messages))data.messages.forEach(msg=>renderMessage(msg.role,msg.content));
    }catch(err){console.error(err);}
  }

  async function sendMessage(){
    const content=inputEl.value.trim();
    if(!content)return;
    renderMessage("user",content);
    saveMessage("user",content);
    inputEl.value="";
    try{
      const resp=await fetch("/api/chat",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({content})});
      const data=await resp.json();
      if(data.ok&&data.message){
        renderMessage("assistant",data.message.content);
        saveMessage("assistant",data.message.content);
      }else renderMessage("assistant","Error: Invalid response");
    }catch(err){renderMessage("assistant","Error: Could not reach backend");console.error(err);}
  }

  sendBtn.addEventListener("click",sendMessage);
  inputEl.addEventListener("keydown",e=>{if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();sendMessage();}});

  loadMessages();

  // Memory
  const memoryInput=document.getElementById("novaMemoryInput");
  const memoryAdd=document.getElementById("novaMemoryAdd");
  const memoryList=document.getElementById("novaMemoryList");
  memoryAdd.addEventListener("click",async()=>{
    const value=memoryInput.value.trim();if(!value)return;
    try{
      await fetch("/api/memory/add",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({value})});
      const li=document.createElement("li");li.textContent=value;memoryList.appendChild(li);memoryInput.value="";
    }catch(err){console.error(err);}
  });

  // Attachments
  const mediaInput=document.getElementById("novaMediaInput");
  const assetsList=document.getElementById("novaAssetsList");
  mediaInput?.addEventListener("change",()=>{Array.from(mediaInput.files).forEach(file=>{const div=document.createElement("div");div.className="asset-card";div.textContent=file.name;assetsList.appendChild(div);});});

  // Voice
  const voiceBtn=document.getElementById("novaVoiceBtn");
  if(voiceBtn&&'webkitSpeechRecognition' in window){
    const recognition=new webkitSpeechRecognition();
    recognition.continuous=false;recognition.interimResults=false;recognition.lang='en-US';
    voiceBtn.addEventListener("click",()=>{voiceBtn.disabled=true;voiceBtn.textContent="Listening...";recognition.start();});
    recognition.onresult=(e)=>{inputEl.value=e.results[0][0].transcript;sendMessage();voiceBtn.disabled=false;voiceBtn.textContent="ðŸŽ¤ Voice";};
    recognition.onerror=(e)=>{console.error(e);voiceBtn.disabled=false;voiceBtn.textContent="ðŸŽ¤ Voice";};
    recognition.onend=()=>{voiceBtn.disabled=false;voiceBtn.textContent="ðŸŽ¤ Voice";};
  }else if(voiceBtn)voiceBtn.addEventListener("click",()=>alert("Voice input not supported."));

  // Artifacts pin/delete
  document.querySelectorAll(".artifact-pin-btn").forEach(btn=>btn.addEventListener("click",async()=>{const id=btn.dataset.id;await fetch("/api/artifacts/toggle-pin",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({id})});alert(`Toggled pin for artifact ${id}`);}));
  document.querySelectorAll(".artifact-delete-btn").forEach(btn=>btn.addEventListener("click",async()=>{const id=btn.dataset.id;await fetch("/api/artifacts/delete",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({id})});alert(`Deleted artifact ${id}`);}));

  Nova.ui={renderMessage,sendMessage,loadMessages};
});
