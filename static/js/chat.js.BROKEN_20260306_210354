document.addEventListener("DOMContentLoaded", () => {
  const chatMessages = document.getElementById("chatMessages")
  const chatInput = document.getElementById("chatInput")
  const sendBtn = document.getElementById("sendBtn")
  const sendBtnText = document.getElementById("sendBtnText")
  const stopBtn = document.getElementById("stopBtn")
  const newChatBtn = document.getElementById("newChatBtn")
  const chatList = document.getElementById("chatList")
  const attachBtn = document.getElementById("btnAttach")
  const fileInput = document.getElementById("fileUpload")
  const emptyState = document.getElementById("emptyState")
  const sidebar = document.getElementById("sidebar")
  const sidebarToggle = document.getElementById("sidebarToggle")
  const mobileOverlay = document.getElementById("mobileOverlay")
  const clearComposerBtn = document.getElementById("clearComposerBtn")
  const regenBtn = document.getElementById("regenBtn")
  const renameChatBtn = document.getElementById("renameChatBtn")
  const deleteChatBtn = document.getElementById("deleteChatBtn")
  const chatTitleTop = document.getElementById("chatTitleTop")
  const attachmentTray = document.getElementById("attachmentTray")

  let currentChatId = null
  let isSending = false
  let lastUserMessage = ""
  let currentAttachment = null

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;")
  }

  function setTopTitle(text) {
    if (chatTitleTop) {
      chatTitleTop.textContent = text || "Ready"
    }
  }

  function setEmptyState() {
    if (!emptyState || !chatMessages) return
    const hasMessages = chatMessages.querySelector(".message")
    emptyState.style.display = hasMessages ? "none" : ""
  }

  function scrollToBottom() {
    if (!chatMessages) return
    chatMessages.scrollTop = chatMessages.scrollHeight
  }

  function setSendingState(sending) {
    isSending = sending

    if (sendBtn) sendBtn.disabled = sending
    if (attachBtn) attachBtn.disabled = sending
    if (chatInput) chatInput.disabled = sending

    if (sendBtnText) {
      sendBtnText.textContent = sending ? "Sending..." : "Send"
    } else if (sendBtn) {
      sendBtn.textContent = sending ? "Sending..." : "Send"
    }

    if (stopBtn) {
      stopBtn.hidden = true
      stopBtn.disabled = true
    }
  }

  function getChatIdFromUrl() {
    const url = new URL(window.location.href)
    return url.searchParams.get("chat_id") || null
  }

  function setChatIdInUrl(chatId) {
    const url = new URL(window.location.href)

    if (chatId) {
      url.searchParams.set("chat_id", chatId)
    } else {
      url.searchParams.delete("chat_id")
    }

    window.history.replaceState({}, "", url.toString())
  }

  function closeSidebar() {
    if (sidebar) sidebar.classList.remove("open")
    if (mobileOverlay) mobileOverlay.classList.remove("show")
  }

  function openSidebar() {
    if (sidebar) sidebar.classList.add("open")
    if (mobileOverlay) mobileOverlay.classList.add("show")
  }

  function formatBytes(bytes) {
    const n = Number(bytes || 0)
    if (!n) return ""
    if (n < 1024) return `${n} B`
    if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`
    return `${(n / (1024 * 1024)).toFixed(1)} MB`
  }

  function detectAttachmentKind(file) {
    const name = String(file?.name || "").toLowerCase()
    const type = String(file?.type || "").toLowerCase()

    if (name.endsWith(".csv") || type.includes("csv")) return "csv"
    if (name.endsWith(".json") || type.includes("json")) return "json"
    if (name.endsWith(".md") || type.includes("markdown")) return "markdown"
    if (name.endsWith(".py") || type.includes("python")) return "python"
    if (name.endsWith(".txt") || type.startsWith("text/")) return "text"

    return "file"
  }

  function parseCsvLine(line) {
    const out = []
    let cur = ""
    let inQuotes = false

    for (let i = 0; i < line.length; i++) {
      const ch = line[i]
      const next = line[i + 1]

      if (ch === '"' && inQuotes && next === '"') {
        cur += '"'
        i++
        continue
      }

      if (ch === '"') {
        inQuotes = !inQuotes
        continue
      }

      if (ch === "," && !inQuotes) {
        out.push(cur)
        cur = ""
        continue
      }

      cur += ch
    }

    out.push(cur)
    return out
  }

  function renderCsvPreview(text) {
    const rows = String(text || "")
      .replace(/\r/g, "")
      .split("\n")
      .filter((x) => x.trim() !== "")
      .slice(0, 6)

    if (!rows.length) {
      return `<div class="attachment-meta-line">Empty CSV file.</div>`
    }

    const parsed = rows.map(parseCsvLine)
    const maxCols = parsed.reduce((m, row) => Math.max(m, row.length), 0)
    const head = parsed[0]
    const body = parsed.slice(1)

    let html = `<div class="attachment-table-wrap"><table class="attachment-table"><thead><tr>`

    for (let i = 0; i < maxCols; i++) {
      html += `<th>${escapeHtml(head[i] ?? `col_${i + 1}`)}</th>`
    }

    html += `</tr></thead><tbody>`

    for (const row of body) {
      html += `<tr>`
      for (let i = 0; i < maxCols; i++) {
        html += `<td>${escapeHtml(row[i] ?? "")}</td>`
      }
      html += `</tr>`
    }

    html += `</tbody></table></div>`
    return html
  }

  function buildAttachmentPreviewHtml(file) {
    if (!file) return ""

    const kind = detectAttachmentKind(file)
    const name = escapeHtml(file.name || "attachment")
    const size = escapeHtml(formatBytes(file.size || 0))
    const raw = String(file.content || "")
    const preview = raw.slice(0, 2500)
    const truncated = raw.length > 2500

    let body = `<div class="attachment-meta-line">Attached file ready.</div>`

    if (kind === "csv") {
      body = renderCsvPreview(raw)
    } else if (kind === "json") {
      let pretty = preview
      try {
        pretty = JSON.stringify(JSON.parse(raw), null, 2).slice(0, 2500)
      } catch (_) {}
      body = `<pre class="attachment-code"><code>${escapeHtml(pretty)}${truncated ? "\n…" : ""}</code></pre>`
    } else if (kind === "python" || kind === "text" || kind === "markdown") {
      body = `<pre class="attachment-code"><code>${escapeHtml(preview)}${truncated ? "\n…" : ""}</code></pre>`
    }

    return `
      <div class="attachment-card" data-kind="${escapeHtml(kind)}">
        <div class="attachment-head">
          <div class="attachment-title">📎 ${name}</div>
          <div class="attachment-subtitle">${size}</div>
        </div>
        <div class="attachment-body">
          ${body}
        </div>
      </div>
    `
  }

  function renderAttachmentTray() {
    if (!attachmentTray) return

    if (!currentAttachment) {
      attachmentTray.innerHTML = ""
      attachmentTray.classList.add("hidden")
      return
    }

    attachmentTray.classList.remove("hidden")
    attachmentTray.innerHTML = `
      ${buildAttachmentPreviewHtml(currentAttachment)}
      <div class="pending-attachment-actions">
        <button type="button" id="removeAttachmentBtn" class="btn btn-quiet">Remove</button>
      </div>
    `

    const removeBtn = document.getElementById("removeAttachmentBtn")
    if (removeBtn) {
      removeBtn.addEventListener("click", () => {
        currentAttachment = null
        if (fileInput) fileInput.value = ""
        renderAttachmentTray()
      })
    }
  }

  function renderUserMessage(text, attachment = null) {
    if (!chatMessages) return null

    const el = document.createElement("div")
    el.className = "message user"

    let attachmentHtml = ""
    if (attachment) {
      attachmentHtml = buildAttachmentPreviewHtml(attachment)
    }

    el.innerHTML = `
      <div class="message-inner">
        <div class="message-text">${escapeHtml(text || "").replace(/\n/g, "<br>")}</div>
        ${attachmentHtml}
      </div>
    `
    chatMessages.appendChild(el)
    setEmptyState()
    scrollToBottom()
    return el
  }

  function renderAssistantMessage(text) {
    if (!chatMessages) return null

    const el = document.createElement("div")
    el.className = "message assistant"
    el.innerHTML = `
      <div class="message-inner">
        <div class="message-text"></div>
      </div>
    `
    chatMessages.appendChild(el)
    renderAssistantText(el, text || "")
    setEmptyState()
    scrollToBottom()
    return el
  }

  function renderAssistantText(messageEl, text) {
    if (!messageEl) return
    const textEl = messageEl.querySelector(".message-text")
    if (!textEl) return

    if (window.marked) {
      try {
        textEl.innerHTML = marked.parse(text || "")
      } catch (_) {
        textEl.innerHTML = escapeHtml(text || "").replace(/\n/g, "<br>")
      }
    } else {
      textEl.innerHTML = escapeHtml(text || "").replace(/\n/g, "<br>")
    }

    if (window.hljs) {
      textEl.querySelectorAll("pre code").forEach((block) => {
        try {
          window.hljs.highlightElement(block)
        } catch (_) {}
      })
    }

    scrollToBottom()
  }

  function renderError(text) {
    if (!chatMessages) return

    const el = document.createElement("div")
    el.className = "message error"
    el.innerHTML = `
      <div class="message-inner">
        <div class="message-text">${escapeHtml(text)}</div>
      </div>
    `
    chatMessages.appendChild(el)
    setEmptyState()
    scrollToBottom()
  }

  async function loadChats() {
    if (!chatList) return

    try {
      const res = await fetch("/api/chats", { cache: "no-store" })
      if (!res.ok) throw new Error(`HTTP ${res.status}`)

      const data = await res.json()
      const chats = Array.isArray(data.chats) ? data.chats : []

      chatList.innerHTML = ""

      if (!chats.length) {
        chatList.innerHTML = `<div class="chat-list-empty">No chats yet</div>`
        return
      }

      chats.forEach((chat) => {
        const btn = document.createElement("button")
        btn.type = "button"
        btn.className = "chat-item"
        btn.innerHTML = `
          <div class="chat-item-title">${escapeHtml(chat.title || "New chat")}</div>
          <div class="chat-item-meta">${escapeHtml(chat.updated || "")}</div>
        `

        if (chat.chat_id === currentChatId) {
          btn.classList.add("active")
        }

        btn.addEventListener("click", async () => {
          currentChatId = chat.chat_id
          setChatIdInUrl(currentChatId)
          await loadChats()
          await loadMessages(currentChatId)
          closeSidebar()
        })

        chatList.appendChild(btn)
      })
    } catch (err) {
      chatList.innerHTML = `<div class="chat-list-empty">Failed to load chats</div>`
    }
  }

  async function loadMessages(chatId) {
    if (!chatMessages) return

    chatMessages.innerHTML = ""

    if (!chatId) {
      setTopTitle("Ready")
      setEmptyState()
      return
    }

    try {
      const res = await fetch(`/api/chats/${encodeURIComponent(chatId)}`, {
        cache: "no-store"
      })

      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`)
      }

      const data = await res.json()
      const title = data.title || data.chat_title || "Chat"

      setTopTitle(title)

      const messages = Array.isArray(data.messages) ? data.messages : []

      messages.forEach((msg) => {
        const role = msg.role === "assistant" ? "assistant" : "user"
        const text = msg.content || msg.message || ""
        const attachment = msg.attachment || null

        if (role === "assistant") {
          renderAssistantMessage(text)
        } else {
          renderUserMessage(text, attachment)
        }
      })

      setEmptyState()
      scrollToBottom()
    } catch (err) {
      renderError(`Failed to load messages: ${err.message}`)
    }
  }

  async function createNewChat() {
    currentChatId = null
    setChatIdInUrl(null)
    currentAttachment = null
    renderAttachmentTray()

    if (chatMessages) {
      chatMessages.innerHTML = ""
    }

    setTopTitle("Ready")
    setEmptyState()
    await loadChats()

    if (chatInput) {
      chatInput.value = ""
      chatInput.focus()
    }
  }

  async function sendMessage() {
    if (isSending) return
    if (!chatInput) return

    const message = chatInput.value.trim()
    if (!message && !currentAttachment) return

    const attachmentToSend = currentAttachment
      ? {
          name: currentAttachment.name,
          type: currentAttachment.type,
          size: currentAttachment.size,
          content: currentAttachment.content
        }
      : null

    renderUserMessage(message, attachmentToSend)
    lastUserMessage = message
    chatInput.value = ""
    currentAttachment = null
    if (fileInput) fileInput.value = ""
    renderAttachmentTray()

    setSendingState(true)

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          chat_id: currentChatId,
          message: message,
          attachment: attachmentToSend
        })
      })

      if (!res.ok) {
        let errText = `HTTP ${res.status}`
        try {
          const errJson = await res.json()
          errText = errJson.error || errText
        } catch (_) {}
        throw new Error(errText)
      }

      const data = await res.json()

      currentChatId = data.chat_id || currentChatId

      if (currentChatId) {
        setChatIdInUrl(currentChatId)
      }

      const assistantText =
        data.reply ||
        data.response ||
        data.message ||
        data.content ||
        data.answer ||
        ""

      renderAssistantMessage(assistantText)

      await loadChats()
    } catch (err) {
      renderError(`⚠️ Network error: ${err.message}`)
    } finally {
      setSendingState(false)
      setEmptyState()
      scrollToBottom()
    }
  }

  async function regenerateLast() {
    if (isSending || !currentChatId) return

    setSendingState(true)

    try {
      const res = await fetch("/api/chat/regenerate", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          chat_id: currentChatId,
          message: lastUserMessage
        })
      })

      if (!res.ok) {
        let errText = `HTTP ${res.status}`
        try {
          const errJson = await res.json()
          errText = errJson.error || errText
        } catch (_) {}
        throw new Error(errText)
      }

      const data = await res.json()

      const assistantText =
        data.reply ||
        data.response ||
        data.message ||
        data.content ||
        data.answer ||
        ""

      renderAssistantMessage(assistantText)
      await loadChats()
    } catch (err) {
      renderError(`Regenerate failed: ${err.message}`)
    } finally {
      setSendingState(false)
    }
  }

  async function renameCurrentChat() {
    if (!currentChatId) return

    const nextTitle = window.prompt("Rename chat")
    if (!nextTitle || !nextTitle.trim()) return

    try {
      const res = await fetch(`/api/chats/${encodeURIComponent(currentChatId)}/rename`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          title: nextTitle.trim()
        })
      })

      if (!res.ok) {
        let errText = `HTTP ${res.status}`
        try {
          const errJson = await res.json()
          errText = errJson.error || errText
        } catch (_) {}
        throw new Error(errText)
      }

      setTopTitle(nextTitle.trim())
      await loadChats()
    } catch (err) {
      renderError(`Rename failed: ${err.message}`)
    }
  }

  async function deleteCurrentChat() {
    if (!currentChatId) return

    const ok = window.confirm("Delete this chat?")
    if (!ok) return

    try {
      const res = await fetch(`/api/chats/${encodeURIComponent(currentChatId)}`, {
        method: "DELETE"
      })

      if (!res.ok) {
        let errText = `HTTP ${res.status}`
        try {
          const errJson = await res.json()
          errText = errJson.error || errText
        } catch (_) {}
        throw new Error(errText)
      }

      await createNewChat()
    } catch (err) {
      renderError(`Delete failed: ${err.message}`)
    }
  }

  if (sendBtn) {
    sendBtn.addEventListener("click", sendMessage)
  }

  if (chatInput) {
    chatInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault()
        sendMessage()
      }
    })
  }

  if (newChatBtn) {
    newChatBtn.addEventListener("click", async () => {
      await createNewChat()
      closeSidebar()
    })
  }

  if (attachBtn) {
    attachBtn.addEventListener("click", () => {
      if (!isSending && fileInput) fileInput.click()
    })
  }

  if (fileInput) {
    fileInput.addEventListener("change", async () => {
      const file = fileInput.files && fileInput.files[0]
      if (!file) return

      try {
        const text = await file.text()
        currentAttachment = {
          name: file.name,
          type: file.type || "",
          size: file.size || 0,
          content: text
        }
        renderAttachmentTray()
      } catch (err) {
        currentAttachment = null
        renderAttachmentTray()
        renderError(`Attachment read failed: ${err.message}`)
      }
    })
  }

  if (sidebarToggle) {
    sidebarToggle.addEventListener("click", () => {
      const isOpen = sidebar && sidebar.classList.contains("open")
      if (isOpen) closeSidebar()
      else openSidebar()
    })
  }

  if (mobileOverlay) {
    mobileOverlay.addEventListener("click", closeSidebar)
  }

  if (clearComposerBtn) {
    clearComposerBtn.addEventListener("click", () => {
      if (chatInput) chatInput.value = ""
      currentAttachment = null
      if (fileInput) fileInput.value = ""
      renderAttachmentTray()
    })
  }

  if (regenBtn) {
    regenBtn.addEventListener("click", regenerateLast)
  }

  if (renameChatBtn) {
    renameChatBtn.addEventListener("click", renameCurrentChat)
  }

  if (deleteChatBtn) {
    deleteChatBtn.addEventListener("click", deleteCurrentChat)
  }

  if (stopBtn) {
    stopBtn.hidden = true
    stopBtn.disabled = true
  }

  currentChatId = getChatIdFromUrl()
  renderAttachmentTray()

  loadChats().then(async () => {
    if (currentChatId) {
      await loadMessages(currentChatId)
    } else {
      setTopTitle("Ready")
      setEmptyState()
    }
  })
})