(() => {
"use strict"

function createAttachmentsService(options = {}){
  const {
    state,
    utils = {},
    elements = {},
  } = options

  if(!state){
    throw new Error("NovaAttachmentsService: state is required")
  }

  const el = {
    fileInput: elements.fileInput || null,
    pendingAttachments: elements.pendingAttachments || null,
  }

  const escapeHtml = typeof utils.escapeHtml === "function"
    ? utils.escapeHtml
    : (value) => String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;")

  const formatBytes = typeof utils.formatBytes === "function"
    ? utils.formatBytes
    : (bytes) => {
      const n = Number(bytes || 0)

      if(!Number.isFinite(n) || n <= 0){
        return "0 B"
      }

      const units = ["B", "KB", "MB", "GB", "TB"]
      let size = n
      let i = 0

      while(size >= 1024 && i < units.length - 1){
        size /= 1024
        i += 1
      }

      const fixed = size >= 10 || i === 0 ? 0 : 1
      return `${size.toFixed(fixed)} ${units[i]}`
    }

  function ensurePendingFiles(){
    if(!Array.isArray(state.pendingFiles)){
      state.pendingFiles = []
    }

    return state.pendingFiles
  }

  function makeId(){
    if(typeof crypto !== "undefined" && typeof crypto.randomUUID === "function"){
      return crypto.randomUUID()
    }

    return `${Date.now()}-${Math.random().toString(16).slice(2)}`
  }

  function normalizeFileEntry(input){
    if(!input){
      return null
    }

    if(input instanceof File){
      return {
        id: makeId(),
        file: input,
        name: String(input.name || "attachment"),
        size: Number(input.size || 0),
        type: String(input.type || "application/octet-stream"),
        lastModified: Number(input.lastModified || Date.now()),
      }
    }

    if(input.file instanceof File){
      return {
        id: String(input.id || makeId()),
        file: input.file,
        name: String(input.name || input.file.name || "attachment"),
        size: Number(input.size ?? input.file.size ?? 0),
        type: String(input.type || input.file.type || "application/octet-stream"),
        lastModified: Number(input.lastModified ?? input.file.lastModified ?? Date.now()),
      }
    }

    return null
  }

  function isDuplicateFile(nextEntry, existingEntry){
    if(!nextEntry || !existingEntry){
      return false
    }

    return (
      String(nextEntry.name || "") === String(existingEntry.name || "") &&
      Number(nextEntry.size || 0) === Number(existingEntry.size || 0) &&
      Number(nextEntry.lastModified || 0) === Number(existingEntry.lastModified || 0)
    )
  }

  function getPendingFiles(){
    return ensurePendingFiles()
  }

  function getFilesForUpload(){
    return ensurePendingFiles()
      .map(item => item?.file instanceof File ? item.file : null)
      .filter(Boolean)
  }

  function getPendingFileCount(){
    return ensurePendingFiles().length
  }

  function hasPendingFiles(){
    return getPendingFileCount() > 0
  }

  function getPendingAttachmentPayload(){
    return ensurePendingFiles().map(item => ({
      id: item.id,
      name: item.name,
      size: item.size,
      type: item.type,
      lastModified: item.lastModified,
      file: item.file,
    }))
  }

  function getFileIcon(entry){
    const name = String(entry?.name || "").toLowerCase()
    const type = String(entry?.type || "").toLowerCase()

    if(type.startsWith("image/")){
      return "🖼️"
    }

    if(type.startsWith("video/")){
      return "🎞️"
    }

    if(type.startsWith("audio/")){
      return "🎵"
    }

    if(name.endsWith(".pdf")){
      return "📄"
    }

    if(
      name.endsWith(".py") ||
      name.endsWith(".js") ||
      name.endsWith(".ts") ||
      name.endsWith(".html") ||
      name.endsWith(".css") ||
      name.endsWith(".json") ||
      name.endsWith(".sql") ||
      name.endsWith(".ps1") ||
      name.endsWith(".sh")
    ){
      return "💻"
    }

    if(
      name.endsWith(".zip") ||
      name.endsWith(".rar") ||
      name.endsWith(".7z") ||
      name.endsWith(".tar") ||
      name.endsWith(".gz")
    ){
      return "🗜️"
    }

    return "📎"
  }

  function renderPendingAttachments(){
    if(!el.pendingAttachments){
      return
    }

    const list = ensurePendingFiles()

    if(!list.length){
      el.pendingAttachments.innerHTML = ""
      el.pendingAttachments.hidden = true
      return
    }

    el.pendingAttachments.hidden = false

    el.pendingAttachments.innerHTML = list.map((item) => {
      const id = escapeHtml(item.id)
      const name = escapeHtml(item.name)
      const size = escapeHtml(formatBytes(item.size))
      const icon = escapeHtml(getFileIcon(item))

      return `
        <div class="pending-attachment" data-file-id="${id}">
          <div class="pending-attachment-main">
            <span class="pending-attachment-icon" aria-hidden="true">${icon}</span>
            <div class="pending-attachment-meta">
              <div class="pending-attachment-name" title="${name}">${name}</div>
              <div class="pending-attachment-size">${size}</div>
            </div>
          </div>
          <button
            type="button"
            class="pending-attachment-remove"
            data-remove-file-id="${id}"
            aria-label="Remove ${name}"
            title="Remove attachment"
          >
            ×
          </button>
        </div>
      `
    }).join("")
  }

  function addPendingFiles(files = []){
    const list = ensurePendingFiles()
    const incoming = Array.isArray(files) ? files : Array.from(files || [])

    for(const rawFile of incoming){
      const nextEntry = normalizeFileEntry(rawFile)

      if(!nextEntry){
        continue
      }

      const exists = list.some(existing => isDuplicateFile(nextEntry, existing))
      if(exists){
        continue
      }

      list.push(nextEntry)
    }

    renderPendingAttachments()
    return list
  }

  function removePendingFile(index){
    const list = ensurePendingFiles()
    const i = Number(index)

    if(!Number.isInteger(i) || i < 0 || i >= list.length){
      return false
    }

    list.splice(i, 1)
    renderPendingAttachments()
    return true
  }

  function removePendingFileById(fileId){
    const target = String(fileId || "").trim()

    if(!target){
      return false
    }

    const list = ensurePendingFiles()
    const index = list.findIndex(item => String(item.id || "") === target)

    if(index < 0){
      return false
    }

    list.splice(index, 1)

    if(!list.length && el.fileInput){
      el.fileInput.value = ""
    }

    renderPendingAttachments()
    return true
  }

  function clearPendingFiles(){
    state.pendingFiles = []

    if(el.fileInput){
      el.fileInput.value = ""
    }

    renderPendingAttachments()
    return state.pendingFiles
  }

  function replacePendingFiles(files = []){
    state.pendingFiles = []
    addPendingFiles(files)
    renderPendingAttachments()
    return state.pendingFiles
  }

  function bindUi(){
    if(el.fileInput){
      el.fileInput.addEventListener("change", (event) => {
        const files = Array.from(event.target?.files || [])

        if(!files.length){
          return
        }

        addPendingFiles(files)

        if(el.fileInput){
          el.fileInput.value = ""
        }
      })
    }

    if(el.pendingAttachments){
      el.pendingAttachments.addEventListener("click", (event) => {
        const button = event.target instanceof Element
          ? event.target.closest("[data-remove-file-id]")
          : null

        if(!button){
          return
        }

        const fileId = button.getAttribute("data-remove-file-id") || ""
        removePendingFileById(fileId)
      })
    }
  }

  bindUi()
  renderPendingAttachments()

  return {
    getPendingFiles,
    getFilesForUpload,
    addPendingFiles,
    removePendingFile,
    removePendingFileById,
    clearPendingFiles,
    hasPendingFiles,
    getPendingFileCount,
    replacePendingFiles,
    getPendingAttachmentPayload,
    renderPendingAttachments,
  }
}

window.NovaAttachmentsService = {
  createAttachmentsService,
}

})()