:root{
  color-scheme: dark;
  --bg:#0b0f14;
  --panel:#0f1720;
  --panel2:#101b26;
  --text:#e6edf3;
  --muted:#9fb1c1;
  --border:#223041;
  --accent:#2f81f7;
  --shadow: 0 10px 30px rgba(0,0,0,.45);
  --radius:16px;
  --radius2:12px;
  --pad:14px;
  --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  --sans: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
}

html,body{height:100%}
body{
  margin:0;
  font-family:var(--sans);
  background: radial-gradient(1200px 700px at 10% 0%, #0f1d2b 0%, var(--bg) 55%) fixed;
  color:var(--text);
}

a{color:var(--accent); text-decoration:none}
a:hover{text-decoration:underline}

.wrap{
  max-width: 980px;
  margin: 0 auto;
  padding: 18px;
}

.card{
  background: linear-gradient(180deg, var(--panel) 0%, var(--panel2) 100%);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  padding: 14px 16px;
  border-bottom:1px solid var(--border);
}

.header .title{
  font-weight:650;
  letter-spacing:.2px;
}

.header .sub{
  font-size:12px;
  color:var(--muted);
}

.main{
  display:flex;
  flex-direction:column;
  height: calc(100vh - 48px);
  min-height: 560px;
}

.chat{
  flex:1;
  overflow:auto;
  padding: 14px 14px 0 14px;
}

.msg{
  padding: 12px 12px;
  border:1px solid var(--border);
  border-radius: var(--radius2);
  margin: 10px 0;
  background: rgba(255,255,255,.02);
}

.msg.me{
  background: rgba(47,129,247,.12);
  border-color: rgba(47,129,247,.35);
}

.msg .meta{
  font-size:12px;
  color:var(--muted);
  margin-bottom:6px;
}

.msg pre, .msg code{
  font-family: var(--mono);
  font-size: 12.5px;
  white-space: pre-wrap;
  word-break: break-word;
}

.composer{
  padding: 12px 14px 14px 14px;
  border-top:1px solid var(--border);
  display:flex;
  gap:10px;
  align-items:flex-end;
}

textarea, input[type="text"]{
  flex:1;
  width:100%;
  min-height: 44px;
  max-height: 180px;
  resize: vertical;
  padding: 10px 12px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: rgba(0,0,0,.25);
  color: var(--text);
  outline:none;
}

textarea:focus, input[type="text"]:focus{
  border-color: rgba(47,129,247,.7);
  box-shadow: 0 0 0 3px rgba(47,129,247,.15);
}

button{
  border: 1px solid rgba(47,129,247,.55);
  background: rgba(47,129,247,.15);
  color: var(--text);
  border-radius: 12px;
  padding: 10px 12px;
  cursor:pointer;
  user-select:none;
}

button:hover{ background: rgba(47,129,247,.22); }
button:active{ transform: translateY(1px); }

hr{
  border:0;
  border-top:1px solid var(--border);
  margin: 12px 0;
}

/* Hide obvious dev junk if it exists */
.dev, .debug, #debug, #log, #logs, .logs, .console, .trace{ display:none !important; }

/* ===== NOVA_UI_COMPAT_V1 (matches /app HTML classes) ===== */
.row{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}

.grow{ flex:1; }

h1{
  margin: 10px 0 12px 0;
  font-size: 22px;
  letter-spacing: .2px;
}

.small{
  font-size: 12px;
  color: var(--muted);
}

.btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  padding: 9px 12px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.03);
  color: var(--text);
  cursor:pointer;
  user-select:none;
}

.btn:hover{
  background: rgba(255,255,255,.06);
}

.btn:active{
  transform: translateY(1px);
}

#output{
  background: rgba(0,0,0,.25);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px;
  margin-top: 8px;
  overflow:auto;
  white-space: pre-wrap;
  word-break: break-word;
  font-family: var(--mono);
  font-size: 12.5px;
  line-height: 1.35;
}
/* ===== /NOVA_UI_COMPAT_V1 ===== */

/* ===== NOVA_CHATGPT_THEME_V1 ===== */
:root{
  /* ChatGPT-ish dark neutrals */
  --bg:#0b0f14;
  --panel:#111827;      /* slate-900-ish */
  --panel2:#0f172a;     /* deeper */
  --text:#e5e7eb;       /* gray-200 */
  --muted:#9ca3af;      /* gray-400 */
  --border: rgba(255,255,255,.10);
  --shadow: 0 18px 55px rgba(0,0,0,.55);
  --radius: 18px;
  --radius2: 14px;
  --accent:#22c55e;     /* ChatGPT green-ish accent */
}

/* Page */
body{
  background:
    radial-gradient(900px 520px at 30% -10%, rgba(34,197,94,.10) 0%, rgba(0,0,0,0) 55%),
    radial-gradient(900px 520px at 80% 0%, rgba(59,130,246,.10) 0%, rgba(0,0,0,0) 55%),
    var(--bg);
}

/* Centered, ChatGPT-ish width */
.wrap{
  max-width: 780px;
  margin: 0 auto;
  padding: 18px 16px 28px 16px;
}

/* Title row */
h1{
  font-size: 20px;
  margin: 6px 0 10px 0;
  font-weight: 650;
}

/* Card becomes the main “app shell” */
.card{
  border-radius: 20px;
  border: 1px solid var(--border);
  background: rgba(17,24,39,.85);
  box-shadow: var(--shadow);
  backdrop-filter: blur(10px);
  padding: 14px;
}

/* Buttons as pill tabs */
.btn{
  border-radius: 999px;
  padding: 8px 12px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.04);
}
.btn:hover{ background: rgba(255,255,255,.07); }

/* “status / mode” text */
.small{
  color: var(--muted);
  font-size: 12px;
}

/* Input like ChatGPT composer */
#input{
  border-radius: 16px !important;
  border: 1px solid var(--border) !important;
  background: rgba(0,0,0,.28) !important;
  padding: 12px 14px !important;
  line-height: 1.35;
  font-size: 14px;
}
#input:focus{
  border-color: rgba(34,197,94,.55) !important;
  box-shadow: 0 0 0 3px rgba(34,197,94,.18) !important;
}

/* Output area like a transcript panel (still one block, but styled nicer) */
#output{
  border-radius: 16px !important;
  border: 1px solid var(--border) !important;
  background: rgba(0,0,0,.22) !important;
  padding: 14px !important;
  min-height: 220px !important;
  font-size: 13px !important;
  line-height: 1.45 !important;
}

/* Make the whole thing feel less “form-y” */
label.small input[type="checkbox"]{
  transform: translateY(1px);
}

/* ===== /NOVA_CHATGPT_THEME_V1 ===== */

/* ===== NOVA_CHAT_BUBBLES_CSS_V1 ===== */
.chatlog{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.bubbleRow{
  display:flex;
  width:100%;
}

.bubble{
  max-width: 92%;
  padding: 10px 12px;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.04);
  color: var(--text);
  white-space: pre-wrap;
  word-break: break-word;
  font-size: 13.5px;
  line-height: 1.45;
  box-shadow: 0 8px 24px rgba(0,0,0,.25);
}

.bubble.me{
  margin-left:auto;
  background: rgba(34,197,94,.12);
  border-color: rgba(34,197,94,.30);
}

.bubble.ai{
  margin-right:auto;
  background: rgba(255,255,255,.04);
  border-color: rgba(255,255,255,.10);
}

.bubble .who{
  font-size: 11px;
  color: var(--muted);
  margin-bottom: 6px;
}
/* ===== /NOVA_CHAT_BUBBLES_CSS_V1 ===== */

/* ===== NOVA_STOP_BTN_CSS_V1 ===== */
.btnStop{
  display:none;
  border-radius: 999px;
  padding: 8px 12px;
  border: 1px solid rgba(239,68,68,.45);
  background: rgba(239,68,68,.14);
  color: var(--text);
  cursor:pointer;
  user-select:none;
}
.btnStop:hover{ background: rgba(239,68,68,.20); }
.btnStop:active{ transform: translateY(1px); }
.btnStop[disabled]{ opacity:.5; cursor:not-allowed; }
/* ===== /NOVA_STOP_BTN_CSS_V1 ===== */

/* ===== NOVA_COPY_BTN_CSS_V1 ===== */
.copyBtn{
  margin-left: 8px;
  border-radius: 999px;
  padding: 4px 9px;
  font-size: 11px;
  line-height: 1.1;
  border: 1px solid rgba(255,255,255,.14);
  background: rgba(255,255,255,.06);
  color: var(--text);
  cursor:pointer;
  user-select:none;
  opacity: .85;
}
.copyBtn:hover{ background: rgba(255,255,255,.10); opacity: 1; }
.copyBtn:active{ transform: translateY(1px); }
.copyBtn.ok{
  border-color: rgba(34,197,94,.40);
  background: rgba(34,197,94,.14);
}
.copyBtn.fail{
  border-color: rgba(239,68,68,.40);
  background: rgba(239,68,68,.14);
}
/* ===== /NOVA_COPY_BTN_CSS_V1 ===== */

/* ===== NOVA_COPY_BTN_HOVER_V1 ===== */
/* Hide copy button by default */
.copyBtn{
  opacity: 0;
  pointer-events: none;
  transition: opacity .15s ease;
}

/* Show when hovering a chat bubble */
.chatBubble:hover .copyBtn,
.bubble:hover .copyBtn,
.msg:hover .copyBtn{
  opacity: .85;
  pointer-events: auto;
}
/* ===== /NOVA_COPY_BTN_HOVER_V1 ===== */

/* ===== NOVA_COPY_BTN_TOPRIGHT_V1 ===== */
/* Make common bubble containers positioning contexts */
.chatBubble, .bubble, .msg{
  position: relative;
}

/* Pin the copy button to top-right inside the bubble */
.chatBubble .copyBtn,
.bubble .copyBtn,
.msg .copyBtn{
  position: absolute;
  top: 8px;
  right: 10px;
  margin-left: 0; /* override earlier left spacing */
  z-index: 5;
}

/* If your bubble header row exists, don’t let it fight layout */
.chatBubble .who,
.bubble .who,
.msg .who{
  position: relative;
}
/* ===== /NOVA_COPY_BTN_TOPRIGHT_V1 ===== */

/* ===== NOVA_COPY_BTN_BEST_V1 ===== */

/* Bubble containers */
.chatBubble, .bubble, .msg{
  position: relative;
}

/* Copy button base (top-right) */
.chatBubble .copyBtn,
.bubble .copyBtn,
.msg .copyBtn{
  position: absolute;
  top: 8px;
  right: 10px;
  margin-left: 0;
  z-index: 5;
  transition: opacity .15s ease;
}

/* Desktop: hide by default */
@media (hover: hover) and (pointer: fine){
  .copyBtn{
    opacity: 0;
    pointer-events: none;
  }

  .chatBubble:hover .copyBtn,
  .bubble:hover .copyBtn,
  .msg:hover .copyBtn{
    opacity: .85;
    pointer-events: auto;
  }
}

/* Touch devices: always visible */
@media (hover: none){
  .copyBtn{
    opacity: .85;
    pointer-events: auto;
  }
}

