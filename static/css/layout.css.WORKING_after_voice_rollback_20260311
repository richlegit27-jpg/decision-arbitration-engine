html,
body{
  height:100%;
  margin:0;
}

body{
  min-height:100vh;
  overflow:hidden;
}

body.memory-open{
  overflow:hidden;
}

.app-shell{
  height:100vh;
  min-height:100vh;
  display:grid;
  grid-template-columns:320px minmax(0,1fr);
  background:
    radial-gradient(circle at top, rgba(16,163,127,0.09), transparent 30%),
    var(--bg);
  overflow:hidden;
}

body:not(.sidebar-open) .app-shell{
  grid-template-columns:0 minmax(0,1fr);
}

body:not(.sidebar-open) .sidebar{
  border-right:0;
  overflow:hidden;
}

/* ================= SIDEBAR ================= */

.sidebar{
  position:relative;
  z-index:40;
  display:flex;
  flex-direction:column;
  min-width:0;
  min-height:0;
  background:color-mix(in srgb, var(--panel) 94%, black 6%);
  border-right:1px solid var(--border);
  transform:translateX(0);
  transition:transform 180ms ease;
  overflow:hidden;
}

.sidebar-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  padding:16px;
  border-bottom:1px solid var(--border);
}

.sidebar-title{
  font-size:0.95rem;
  font-weight:700;
  color:var(--text);
  letter-spacing:0.01em;
}

.sidebar-close,
.sidebar-toggle,
.composer-btn,
.message-actions button,
.memory-item-delete,
.chat-list-action,
.nova-pending-card-remove,
.message-code-copy-btn{
  transition:
    border-color 160ms ease,
    background 160ms ease,
    color 160ms ease,
    transform 160ms ease,
    opacity 160ms ease,
    box-shadow 160ms ease;
}

.sidebar-close{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:36px;
  height:36px;
  border:1px solid var(--border);
  border-radius:12px;
  background:transparent;
  color:var(--text);
  cursor:pointer;
}

.sidebar-close:hover{
  border-color:var(--border-strong);
  background:rgba(255,255,255,0.05);
}

.sidebar-actions{
  display:flex;
  flex-direction:column;
  gap:10px;
  padding:14px;
  border-bottom:1px solid var(--border);
}

.sidebar-btn{
  width:100%;
  border:1px solid var(--border);
  background:transparent;
  color:var(--text);
  border-radius:12px;
  padding:10px 12px;
  cursor:pointer;
  transition:border-color 160ms ease, background 160ms ease, transform 160ms ease, color 160ms ease, box-shadow 160ms ease;
}

.sidebar-btn:hover{
  border-color:rgba(16,163,127,0.45);
  background:rgba(16,163,127,0.08);
  box-shadow:0 0 0 1px rgba(16,163,127,0.12) inset;
}

.sidebar-btn:active,
.sidebar-toggle:active,
.composer-btn:active,
.message-actions button:active,
.chat-list-action:active,
.memory-item-delete:active,
.nova-pending-card-remove:active,
.message-code-copy-btn:active{
  transform:translateY(1px);
}

.sidebar-btn:disabled{
  opacity:0.5;
  cursor:not-allowed;
  transform:none;
}

.chat-list{
  flex:1;
  min-height:0;
  overflow-y:auto;
  padding:10px;
}

.chat-list-empty{
  padding:14px;
  color:var(--muted);
  font-size:0.94rem;
  border:1px dashed var(--border);
  border-radius:14px;
  background:rgba(255,255,255,0.02);
}

.chat-list-row{
  display:grid;
  grid-template-columns:minmax(0,1fr) auto;
  gap:8px;
  align-items:stretch;
  margin-bottom:8px;
}

.chat-list-row.is-active .chat-list-item{
  background:rgba(16,163,127,0.08);
  border-color:rgba(16,163,127,0.28);
  box-shadow:0 0 0 1px rgba(16,163,127,0.08) inset;
}

.chat-list-item{
  display:flex;
  align-items:center;
  gap:10px;
  width:100%;
  min-width:0;
  padding:12px;
  border:1px solid var(--border);
  border-radius:14px;
  background:transparent;
  color:var(--text);
  cursor:pointer;
  text-align:left;
  transition:border-color 160ms ease, background 160ms ease, transform 160ms ease, box-shadow 160ms ease;
}

.chat-list-item:hover{
  border-color:var(--border-strong);
  background:rgba(255,255,255,0.03);
}

.chat-list-item.is-active{
  background:rgba(16,163,127,0.08);
  border-color:rgba(16,163,127,0.28);
}

.chat-list-item-copy{
  display:flex;
  flex-direction:column;
  gap:4px;
  min-width:0;
  width:100%;
}

.chat-list-item-title{
  min-width:0;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
  font-size:0.94rem;
  font-weight:600;
  color:var(--text);
}

.chat-list-item-meta{
  min-width:0;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
  font-size:0.78rem;
  color:var(--muted);
  line-height:1.3;
}

.chat-list-actions{
  display:inline-flex;
  align-items:center;
  gap:8px;
}

.chat-list-action{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:38px;
  min-width:38px;
  height:100%;
  min-height:46px;
  border:1px solid var(--border);
  background:transparent;
  color:var(--muted);
  border-radius:12px;
  cursor:pointer;
}

.chat-list-action:hover{
  border-color:rgba(16,163,127,0.35);
  background:rgba(16,163,127,0.08);
  color:var(--text);
}

.chat-rename-input{
  width:100%;
  min-width:0;
  border:1px solid var(--border);
  border-radius:10px;
  background:rgba(255,255,255,0.03);
  color:var(--text);
  padding:8px 10px;
  outline:none;
}

.chat-rename-input:focus{
  border-color:rgba(16,163,127,0.45);
}

/* ================= MAIN ================= */

.main{
  min-width:0;
  height:100vh;
  min-height:0;
  display:flex;
  flex-direction:column;
  overflow:hidden;
}

/* ================= TOP BAR ================= */

.topbar{
  position:sticky;
  top:0;
  z-index:20;
  display:grid;
  grid-template-columns:auto minmax(0,1fr) auto;
  align-items:center;
  gap:12px;
  padding:14px 18px;
  background:color-mix(in srgb, var(--bg) 88%, transparent);
  backdrop-filter:blur(10px);
  border-bottom:1px solid var(--border);
  flex:0 0 auto;
}

.topbar-center{
  min-width:0;
  display:flex;
  flex-direction:column;
  gap:2px;
}

.topbar-eyebrow{
  font-size:0.74rem;
  font-weight:600;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--muted);
}

.topbar-title{
  min-width:0;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
  font-size:1rem;
  font-weight:700;
  color:var(--text);
}

.topbar-actions{
  display:inline-flex;
  align-items:center;
  gap:10px;
}

.sidebar-toggle{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-width:38px;
  height:38px;
  padding:0 12px;
  border:1px solid var(--border);
  border-radius:12px;
  background:transparent;
  color:var(--text);
  cursor:pointer;
}

.sidebar-toggle:hover{
  border-color:rgba(16,163,127,0.45);
  background:rgba(16,163,127,0.08);
  box-shadow:0 0 0 1px rgba(16,163,127,0.12) inset;
}

/* ================= CHAT STAGE ================= */

.chat-stage{
  flex:1;
  min-height:0;
  display:flex;
  flex-direction:column;
  overflow:hidden;
}

/* ================= MESSAGES ================= */

.messages-scroll{
  flex:1 1 auto;
  min-height:0;
  overflow-y:auto;
  overflow-x:hidden;
  overscroll-behavior:contain;
  -webkit-overflow-scrolling:touch;
  padding:18px 18px 72px;
  scroll-padding-bottom:72px;
  scroll-behavior:smooth;
}

.messages{
  width:100%;
  max-width:1280px;
  min-width:0;
  margin:0 auto;
  display:flex;
  flex-direction:column;
  gap:14px;
}

/* ================= EMPTY STATE ================= */

.empty-state{
  width:100%;
  max-width:1280px;
  margin:0 auto;
  padding:28px 0 8px;
}

.empty-state[hidden]{
  display:none !important;
}

.empty-state-badge{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding:8px 12px;
  border:1px solid rgba(16,163,127,0.22);
  border-radius:999px;
  background:rgba(16,163,127,0.07);
  color:#9fd9cb;
  font-size:0.82rem;
  font-weight:600;
  margin-bottom:16px;
}

.empty-state-title{
  margin:0 0 10px;
  font-size:1.95rem;
  line-height:1.08;
  color:var(--text);
  letter-spacing:-0.02em;
}

.empty-state-subtitle{
  margin:0;
  max-width:760px;
  color:var(--muted);
  line-height:1.6;
}

.empty-suggestions{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:12px;
  margin-top:18px;
}

.empty-suggestion{
  display:flex;
  flex-direction:column;
  align-items:flex-start;
  gap:6px;
  text-align:left;
  padding:16px;
  border-radius:16px;
  border:1px solid var(--border);
  background:rgba(255,255,255,0.03);
  color:var(--text);
  cursor:pointer;
  transition:border-color 160ms ease, background 160ms ease, transform 160ms ease, box-shadow 160ms ease;
}

.empty-suggestion:hover{
  border-color:rgba(16,163,127,0.32);
  background:rgba(16,163,127,0.06);
  transform:translateY(-1px);
  box-shadow:0 0 0 1px rgba(16,163,127,0.08) inset;
}

.empty-suggestion-title{
  font-weight:700;
  line-height:1.3;
}

.empty-suggestion-text{
  color:var(--muted);
  line-height:1.45;
  font-size:0.93rem;
}

/* ================= MESSAGE ================= */

@keyframes novaMessageIn{
  from{
    opacity:0;
    transform:translateY(8px) scale(0.985);
  }
  to{
    opacity:1;
    transform:translateY(0) scale(1);
  }
}

@keyframes novaGlow{
  0%{
    box-shadow:0 0 0 rgba(16,163,127,0);
  }
  50%{
    box-shadow:
      0 0 0 1px rgba(16,163,127,0.08) inset,
      0 0 18px rgba(16,163,127,0.18);
  }
  100%{
    box-shadow:0 0 0 rgba(16,163,127,0);
  }
}

.message-row{
  display:flex;
  width:100%;
  min-width:0;
}

.message-row-user{
  justify-content:flex-end;
}

.message-row-assistant{
  justify-content:flex-start;
}

.message{
  display:block;
  width:auto;
  max-width:min(820px, 82%);
  min-width:0;
  animation:novaMessageIn 180ms ease;
}

.message-bubble{
  display:block;
  width:100%;
  min-width:0;
  box-sizing:border-box;
  overflow:hidden;
  white-space:normal;
  word-break:break-word;
  overflow-wrap:anywhere;
  writing-mode:horizontal-tb !important;
  text-orientation:mixed !important;
  border:1px solid var(--border);
  border-radius:20px;
  padding:14px 16px;
  box-shadow:var(--shadow-sm);
  transition:
    border-color 160ms ease,
    background 160ms ease,
    box-shadow 160ms ease,
    transform 160ms ease;
}

.message-user .message-bubble{
  background:linear-gradient(180deg, rgba(16,163,127,0.16), rgba(16,163,127,0.10));
  border-color:rgba(16,163,127,0.28);
}

.message-assistant .message-bubble{
  background:linear-gradient(180deg, rgba(20,27,34,1), rgba(17,22,28,1));
}

.message-bubble.is-streaming{
  border-color:rgba(16,163,127,0.35);
  animation:novaGlow 2s ease-in-out infinite;
}

.message-bubble.is-thinking{
  background:rgba(255,255,255,0.025);
}

.message-content{
  display:block;
  width:100%;
  min-width:0;
  color:var(--text);
  white-space:pre-wrap !important;
  word-break:break-word !important;
  overflow-wrap:anywhere !important;
  writing-mode:horizontal-tb !important;
  text-orientation:mixed !important;
  line-height:1.58;
}

.message-content *{
  writing-mode:horizontal-tb !important;
  text-orientation:mixed !important;
  white-space:inherit;
  word-break:break-word;
  overflow-wrap:anywhere;
}

.message-content p{
  margin:0 0 12px;
}

.message-content p:last-child{
  margin-bottom:0;
}

.message-content ul,
.message-content ol{
  margin:0 0 12px 22px;
  padding:0;
}

.message-content li{
  margin:0 0 6px;
}

.message-content code{
  font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  font-size:0.92em;
  background:rgba(255,255,255,0.07);
  border:1px solid rgba(255,255,255,0.08);
  border-radius:8px;
  padding:0.14em 0.4em;
}

.message-code-block{
  margin:14px 0;
  border-radius:18px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,0.08);
  background:linear-gradient(180deg, rgba(10,14,18,0.94), rgba(8,11,14,0.94));
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.03),
    0 10px 24px rgba(0,0,0,0.18);
}

.message-code-toolbar{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  padding:10px 12px;
  border-bottom:1px solid rgba(255,255,255,0.06);
  background:rgba(255,255,255,0.03);
}

.message-code-language{
  min-width:0;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
  color:var(--muted);
  font-size:0.78rem;
  font-weight:700;
  letter-spacing:0.08em;
  text-transform:uppercase;
}

.message-code-copy-btn{
  flex:0 0 auto;
  border:1px solid rgba(255,255,255,0.10);
  background:rgba(255,255,255,0.04);
  color:var(--text);
  border-radius:10px;
  padding:6px 10px;
  cursor:pointer;
  font-size:0.8rem;
  font-weight:600;
}

.message-code-copy-btn:hover{
  border-color:rgba(16,163,127,0.34);
  background:rgba(16,163,127,0.08);
  color:var(--text);
}

.message-code-block pre{
  margin:0;
  padding:14px;
  overflow:auto;
}

.message-code-block code{
  display:block;
  background:transparent;
  border:0;
  padding:0;
  font-size:0.92rem;
  line-height:1.6;
  white-space:pre;
  word-break:normal;
  overflow-wrap:normal;
}

.message-attachments{
  display:flex;
  flex-direction:column;
  gap:8px;
  margin-top:12px;
  width:100%;
  min-width:0;
}

.message-attachment{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  max-width:100%;
  min-width:0;
  padding:10px 12px;
  border:1px solid var(--border);
  border-radius:14px;
  background:rgba(255,255,255,0.035);
  color:var(--text);
  text-decoration:none;
  box-sizing:border-box;
}

a.message-attachment:hover{
  border-color:rgba(16,163,127,0.32);
  background:rgba(16,163,127,0.06);
}

.message-attachment-name{
  min-width:0;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}

.message-attachment-meta{
  flex:0 0 auto;
  color:var(--muted);
  font-size:0.82rem;
  white-space:nowrap;
}

.message-image{
  position:relative;
  display:block;
  margin-top:12px;
  max-width:min(460px, 100%);
  border-radius:18px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,0.08);
  background:rgba(255,255,255,0.03);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.03),
    0 12px 28px rgba(0,0,0,0.18);
  transition:
    transform 180ms ease,
    border-color 180ms ease,
    box-shadow 180ms ease;
}

.message-image:hover{
  transform:translateY(-1px);
  border-color:rgba(16,163,127,0.28);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.04),
    0 16px 34px rgba(0,0,0,0.24);
}

.message-image::after{
  content:"Open";
  position:absolute;
  top:12px;
  right:12px;
  padding:6px 10px;
  border-radius:999px;
  border:1px solid rgba(255,255,255,0.12);
  background:rgba(8,11,14,0.72);
  color:var(--text);
  font-size:0.76rem;
  font-weight:700;
  letter-spacing:0.03em;
  opacity:0;
  transform:translateY(-4px);
  pointer-events:none;
  transition:opacity 160ms ease, transform 160ms ease;
}

.message-image:hover::after{
  opacity:1;
  transform:translateY(0);
}

.message-image img{
  display:block;
  width:100%;
  height:auto;
  object-fit:cover;
}

.message-actions{
  display:flex;
  gap:8px;
  flex-wrap:wrap;
  margin-top:8px;
  padding:0 4px;
  opacity:0;
  transform:translateY(-2px);
  pointer-events:none;
  transition:opacity 160ms ease, transform 160ms ease;
}

.message:hover .message-actions,
.message:focus-within .message-actions{
  opacity:1;
  transform:translateY(0);
  pointer-events:auto;
}

.message-actions button{
  border:1px solid var(--border);
  background:transparent;
  color:var(--muted);
  border-radius:10px;
  padding:7px 11px;
  cursor:pointer;
  font-size:0.86rem;
  backdrop-filter:blur(8px);
}

.message-actions button:hover{
  border-color:rgba(16,163,127,0.34);
  background:rgba(16,163,127,0.08);
  color:var(--text);
}

.thinking-dots{
  display:inline-flex;
  align-items:center;
  gap:6px;
  min-height:24px;
  color:var(--accent-soft);
}

.thinking-dots span{
  width:7px;
  height:7px;
  border-radius:999px;
  background:currentColor;
  opacity:0.32;
  animation:thinkingDotPulse 1s infinite ease-in-out;
}

.thinking-dots span:nth-child(2){
  animation-delay:0.12s;
}

.thinking-dots span:nth-child(3){
  animation-delay:0.24s;
}

@keyframes thinkingDotPulse{
  0%,80%,100%{
    transform:scale(0.8);
    opacity:0.28;
  }
  40%{
    transform:scale(1);
    opacity:0.82;
  }
}

.message-streaming-tail{
  display:inline-flex;
  align-items:flex-end;
  justify-content:center;
  width:14px;
  margin-left:4px;
  vertical-align:baseline;
}

.message-streaming-tail-dot{
  display:inline-block;
  width:7px;
  height:7px;
  border-radius:999px;
  background:var(--accent-soft);
  opacity:0.72;
  box-shadow:0 0 10px rgba(16,163,127,0.28);
  animation:messageStreamingTailPulse 1.15s ease-in-out infinite;
}

@keyframes messageStreamingTailPulse{
  0%, 100%{
    transform:scale(0.82);
    opacity:0.38;
  }
  50%{
    transform:scale(1);
    opacity:0.9;
  }
}

/* ================= COMPOSER ================= */

.composer-wrap{
  position:sticky;
  bottom:0;
  z-index:25;
  flex:0 0 auto;
  padding:0 18px 18px;
  background:linear-gradient(to top,var(--bg) 70%,rgba(0,0,0,0));
}

.composer-shell{
  width:100%;
  max-width:1280px;
  margin:0 auto;
}

.pending-attachments{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  margin-bottom:10px;
}

.pending-attachments:empty{
  display:none;
}

.pending-attachment{
  display:inline-flex;
  align-items:center;
  gap:8px;
  max-width:100%;
  padding:8px 10px;
  border-radius:12px;
  border:1px solid var(--border);
  background:rgba(255,255,255,0.04);
  color:var(--text);
}

.pending-attachment span{
  min-width:0;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}

.pending-attachment button{
  width:24px;
  height:24px;
  border:0;
  border-radius:999px;
  background:rgba(255,255,255,0.08);
  color:var(--text);
  cursor:pointer;
}

.nova-pending-grid{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  width:100%;
}

.nova-pending-card{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  min-width:0;
  max-width:100%;
  padding:10px 12px;
  border:1px solid var(--border);
  border-radius:14px;
  background:rgba(255,255,255,0.04);
  color:var(--text);
  box-shadow:var(--shadow-sm);
}

.nova-pending-card.has-thumbnail{
  align-items:center;
}

.nova-pending-card-main{
  display:flex;
  align-items:center;
  gap:10px;
  min-width:0;
}

.nova-pending-card-thumb-wrap{
  flex:0 0 auto;
  width:44px;
  height:44px;
  border-radius:12px;
  overflow:hidden;
  border:1px solid var(--border);
  background:rgba(255,255,255,0.03);
}

.nova-pending-card-thumb{
  display:block;
  width:100%;
  height:100%;
  object-fit:cover;
}

.nova-pending-card-icon{
  flex:0 0 auto;
  width:44px;
  height:44px;
  border-radius:12px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:1rem;
  line-height:1;
  border:1px solid var(--border);
  background:rgba(255,255,255,0.03);
}

.nova-pending-card-text{
  min-width:0;
}

.nova-pending-card-name{
  min-width:0;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}

.nova-pending-card-meta{
  font-size:0.84rem;
  color:var(--muted);
  margin-top:2px;
}

.nova-pending-card-remove{
  flex:0 0 auto;
  width:28px;
  height:28px;
  border:1px solid var(--border);
  border-radius:999px;
  background:transparent;
  color:var(--text);
  cursor:pointer;
}

.nova-pending-card-remove:hover{
  border-color:rgba(16,163,127,0.34);
  background:rgba(16,163,127,0.08);
}

.composer{
  display:grid;
  grid-template-columns:auto minmax(0,1fr) auto auto;
  align-items:end;
  gap:10px;
  width:100%;
  padding:14px 16px;
  border:1px solid var(--border);
  border-radius:22px;
  background:color-mix(in srgb, var(--panel) 96%, transparent);
  box-shadow:var(--shadow-lg);
  backdrop-filter:blur(12px);
}

.composer-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-width:42px;
  height:42px;
  border:1px solid var(--border);
  border-radius:14px;
  background:transparent;
  color:var(--text);
  cursor:pointer;
}

.composer-btn:hover{
  border-color:rgba(16,163,127,0.45);
  background:rgba(16,163,127,0.08);
  box-shadow:0 0 0 1px rgba(16,163,127,0.12) inset;
}

.composer-btn[hidden]{
  display:none !important;
}

.composer-btn:disabled{
  opacity:0.45;
  cursor:not-allowed;
}

.composer-input{
  width:100%;
  min-height:28px;
  max-height:240px;
  resize:none;
  border:0;
  outline:none;
  background:transparent;
  color:var(--text);
  line-height:1.55;
  padding:10px 0;
}

/* ================= MEMORY PANEL ================= */

.memory-backdrop[hidden],
.memory-panel[hidden]{
  display:none !important;
}

.memory-backdrop{
  position:fixed;
  inset:0;
  z-index:119;
  background:rgba(0,0,0,0.48);
  backdrop-filter:blur(2px);
}

.memory-panel{
  position:fixed;
  top:0;
  right:0;
  z-index:120;
  width:min(460px, 100vw);
  height:100vh;
  background:var(--panel);
  border-left:1px solid var(--border);
  display:flex;
  flex-direction:column;
  box-shadow:-12px 0 30px rgba(0,0,0,0.28);
}

.memory-panel-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  padding:16px;
  border-bottom:1px solid var(--border);
}

.memory-panel-title{
  font-size:1rem;
  font-weight:700;
  color:var(--text);
}

.memory-panel-subtitle{
  margin-top:4px;
  color:var(--muted);
  line-height:1.45;
  font-size:0.9rem;
}

.memory-panel-body{
  flex:1;
  min-height:0;
  display:flex;
  flex-direction:column;
  gap:14px;
  padding:16px;
  overflow:hidden;
}

.memory-panel-controls{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.memory-input{
  width:100%;
  min-height:88px;
  resize:vertical;
  border:1px solid var(--border);
  background:var(--bg);
  color:var(--text);
  border-radius:14px;
  padding:12px;
  font:inherit;
  outline:none;
  box-sizing:border-box;
}

.memory-input:focus{
  border-color:rgba(16,163,127,0.45);
}

.memory-panel-actions{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
}

.memory-status{
  min-height:20px;
  color:var(--muted);
  font-size:0.9rem;
  line-height:1.35;
}

.memory-list{
  flex:1;
  min-height:0;
  overflow:auto;
  display:flex;
  flex-direction:column;
  gap:10px;
  padding-right:4px;
}

.memory-item{
  border:1px solid var(--border);
  background:var(--bg);
  border-radius:14px;
  padding:12px;
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:12px;
}

.memory-item-text{
  color:var(--text);
  line-height:1.45;
  white-space:pre-wrap;
  word-break:break-word;
  overflow-wrap:anywhere;
  flex:1;
  min-width:0;
}

.memory-item-delete{
  border:1px solid var(--border);
  background:transparent;
  color:var(--text);
  border-radius:10px;
  padding:8px 10px;
  cursor:pointer;
  flex:0 0 auto;
}

.memory-item-delete:hover{
  border-color:rgba(16,163,127,0.34);
  background:rgba(16,163,127,0.08);
}

.memory-empty{
  color:var(--muted);
  border:1px dashed var(--border);
  border-radius:14px;
  padding:16px;
  text-align:center;
}

/* ================= JUMP BUTTON ================= */

.jump-to-latest{
  position:fixed;
  right:22px;
  bottom:108px;
  z-index:35;
  border:1px solid var(--border);
  border-radius:999px;
  padding:10px 14px;
  background:color-mix(in srgb, var(--panel) 92%, transparent);
  color:var(--text);
  box-shadow:var(--shadow-md);
  cursor:pointer;
  transition:border-color 160ms ease, background 160ms ease, transform 160ms ease;
}

.jump-to-latest:hover{
  border-color:rgba(16,163,127,0.35);
  background:rgba(16,163,127,0.08);
}

.jump-to-latest[hidden]{
  display:none !important;
}

.mobile-overlay{
  display:none;
}

/* ================= RESPONSIVE ================= */

@media (max-width:900px){
  .empty-suggestions{
    grid-template-columns:1fr;
  }
}

@media (max-width:620px){
  .app-shell{
    grid-template-columns:minmax(0,1fr);
  }

  body:not(.sidebar-open) .app-shell{
    grid-template-columns:minmax(0,1fr);
  }

  .sidebar{
    position:fixed;
    top:0;
    left:0;
    bottom:0;
    width:320px;
    max-width:86vw;
    transform:translateX(-100%);
    transition:transform 180ms ease;
    z-index:60;
    box-shadow:var(--shadow-lg);
  }

  body.sidebar-open .sidebar{
    transform:translateX(0);
  }

  .mobile-overlay{
    display:block;
    position:fixed;
    inset:0;
    background:rgba(0,0,0,0.45);
    opacity:0;
    pointer-events:none;
    transition:opacity 180ms ease;
    z-index:50;
  }

  body.sidebar-open .mobile-overlay{
    opacity:1;
    pointer-events:auto;
  }

  .sidebar-toggle{
    display:inline-flex;
  }

  .sidebar-close{
    display:inline-flex;
  }

  .topbar{
    padding:12px;
  }

  .topbar-actions{
    gap:8px;
  }

  .messages-scroll{
    padding:14px 12px 68px;
    scroll-padding-bottom:68px;
  }

  .messages{
    gap:12px;
  }

  .message{
    max-width:100%;
  }

  .message-actions{
    opacity:1;
    transform:none;
    pointer-events:auto;
  }

  .message-image::after{
    opacity:1;
    transform:none;
    top:auto;
    bottom:10px;
    right:10px;
  }

  .composer-wrap{
    padding:0 12px 12px;
  }

  .composer{
    grid-template-columns:auto minmax(0,1fr) auto;
    padding:12px 14px;
  }

  .jump-to-latest{
    right:12px;
    bottom:92px;
  }

  .memory-panel{
    width:100vw;
  }

  .memory-panel-body{
    padding:14px;
  }
}

@media (min-width:621px){
  .sidebar{
    position:relative;
    transform:translateX(0);
  }

  .mobile-overlay{
    display:none !important;
  }

  .sidebar-close{
    display:inline-flex !important;
  }

  .sidebar-toggle{
    display:inline-flex;
  }
}

.message-image-grid{
  display:grid;
  grid-template-columns:repeat(2, minmax(0, 1fr));
  gap:10px;
  margin-top:12px;
  width:100%;
  max-width:700px;
}

.message-image-grid:empty{
  display:none;
}

.message-image-grid .message-image{
  margin-top:0;
  max-width:100%;
}

.message-image-grid-1{
  grid-template-columns:minmax(0, 1fr);
  max-width:420px;
}

.message-image-grid-2{
  grid-template-columns:repeat(2, minmax(0, 1fr));
  max-width:700px;
}

.message-image-grid-3{
  grid-template-columns:repeat(2, minmax(0, 1fr));
  max-width:700px;
}

.message-image-grid-3 .message-image:first-child{
  grid-column:1 / -1;
}

.message-image-grid-4{
  grid-template-columns:repeat(2, minmax(0, 1fr));
  max-width:700px;
}

.message-file-list{
  display:flex;
  flex-direction:column;
  gap:8px;
  margin-top:12px;
}

@media (max-width:620px){
  .message-image-grid,
  .message-image-grid-2,
  .message-image-grid-3,
  .message-image-grid-4{
    grid-template-columns:1fr;
    max-width:100%;
  }

  .message-image-grid-3 .message-image:first-child{
    grid-column:auto;
  }
}

.nova-lightbox-open{
  overflow:hidden;
}

.nova-image-lightbox[hidden]{
  display:none !important;
}

.nova-image-lightbox{
  position:fixed;
  inset:0;
  z-index:9999;
}

.nova-image-lightbox-backdrop{
  position:absolute;
