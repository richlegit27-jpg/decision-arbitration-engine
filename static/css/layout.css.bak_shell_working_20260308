html,
body{
  margin: 0;
  padding: 0;
  width: 100%;
  min-height: 100%;
}

body{
  background: var(--bg);
  color: var(--text);
}

#appShell.app-shell{
  min-height: 100vh !important;
  width: 100% !important;
  display: grid !important;
  grid-template-columns: 320px minmax(0, 1fr) !important;
  align-items: stretch !important;
  background: var(--bg) !important;
}

#sidebar.sidebar{
  position: relative !important;
  z-index: 30 !important;
  display: flex !important;
  flex-direction: column !important;
  min-width: 0 !important;
  min-height: 100vh !important;
  width: auto !important;
  max-width: none !important;
  transform: none !important;
  background: var(--panel) !important;
  border-right: 1px solid var(--border) !important;
  box-shadow: none !important;
}

.sidebar-header{
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 12px !important;
  padding: 16px !important;
  border-bottom: 1px solid var(--border) !important;
}

.sidebar-title{
  font-size: 0.95rem !important;
  font-weight: 700 !important;
  color: var(--text) !important;
  letter-spacing: 0.01em !important;
}

.sidebar-close{
  display: none !important;
}

.sidebar-actions{
  display: flex !important;
  flex-direction: column !important;
  gap: 10px !important;
  padding: 14px 16px !important;
  border-bottom: 1px solid var(--border) !important;
}

#chatList.chat-list{
  flex: 1 !important;
  overflow: auto !important;
  padding: 12px !important;
}

.chat-list-item{
  width: 100% !important;
  display: block !important;
  text-align: left !important;
  padding: 12px 14px !important;
  border: 1px solid var(--border) !important;
  border-radius: 14px !important;
  background: transparent !important;
  color: var(--text) !important;
  cursor: pointer !important;
  margin-bottom: 10px !important;
}

.chat-list-item:hover{
  background: rgba(255,255,255,0.03) !important;
}

.chat-list-item.is-active{
  background: rgba(124, 58, 237, 0.14) !important;
  border-color: rgba(124, 58, 237, 0.32) !important;
}

.chat-list-item-title{
  display: block !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

.chat-list-empty{
  padding: 18px 14px !important;
  border: 1px dashed var(--border) !important;
  border-radius: 14px !important;
  color: var(--text-soft) !important;
  text-align: center !important;
  background: rgba(255,255,255,0.02) !important;
}

.main-panel{
  min-width: 0 !important;
  width: 100% !important;
  display: flex !important;
  flex-direction: column !important;
  min-height: 100vh !important;
}

.topbar{
  position: sticky !important;
  top: 0 !important;
  z-index: 20 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 12px !important;
  min-height: 64px !important;
  padding: 14px 18px !important;
  border-bottom: 1px solid var(--border) !important;
  background: rgba(11, 16, 32, 0.88) !important;
  backdrop-filter: blur(10px) !important;
}

.topbar-left,
.topbar-right{
  display: flex !important;
  align-items: center !important;
  gap: 10px !important;
  min-width: 0 !important;
}

.topbar-title{
  font-size: 0.98rem !important;
  font-weight: 700 !important;
  color: var(--text) !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

#btnSidebarToggle.mobile-sidebar-btn{
  display: none !important;
  align-items: center !important;
  justify-content: center !important;
  width: 40px !important;
  height: 40px !important;
  min-width: 40px !important;
  border: 1px solid var(--border) !important;
  border-radius: 12px !important;
  background: var(--panel-2) !important;
  color: var(--text) !important;
  cursor: pointer !important;
}

#btnCloseSidebar.sidebar-close{
  width: 40px !important;
  height: 40px !important;
  min-width: 40px !important;
  border: 1px solid var(--border) !important;
  border-radius: 12px !important;
  background: var(--panel-2) !important;
  color: var(--text) !important;
  cursor: pointer !important;
}

#btnNewChat,
#attachBtn,
#sendBtn,
#stopBtn{
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  min-height: 40px !important;
  padding: 0 14px !important;
  border: 1px solid var(--border) !important;
  border-radius: 12px !important;
  background: var(--panel-2) !important;
  color: var(--text) !important;
  cursor: pointer !important;
}

#sendBtn{
  background: rgba(124, 58, 237, 0.18) !important;
  border-color: rgba(124, 58, 237, 0.35) !important;
}

.content-shell{
  flex: 1 !important;
  min-height: 0 !important;
  display: flex !important;
  flex-direction: column !important;
}

.messages-scroll{
  flex: 1 !important;
  min-height: 0 !important;
  overflow: auto !important;
}

#messages.messages{
  width: min(900px, 100%) !important;
  max-width: 900px !important;
  margin: 0 auto !important;
  padding: 22px 18px 160px !important;
}

.message{
  display: grid !important;
  grid-template-columns: 44px minmax(0, 1fr) !important;
  gap: 14px !important;
  align-items: start !important;
  margin-bottom: 18px !important;
}

.message-avatar{
  width: 44px !important;
  height: 44px !important;
  border: 1px solid var(--border) !important;
  border-radius: 14px !important;
  display: grid !important;
  place-items: center !important;
  font-weight: 700 !important;
  color: #f8fafc !important;
  background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03)) !important;
}

.role-user .message-avatar{
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.38), rgba(124, 58, 237, 0.18)) !important;
  border-color: rgba(124, 58, 237, 0.35) !important;
}

.message-main{
  min-width: 0 !important;
}

.message-bubble{
  border: 1px solid var(--border) !important;
  border-radius: 18px !important;
  padding: 14px 16px !important;
  background: rgba(255,255,255,0.03) !important;
}

.role-user .message-bubble{
  background: rgba(124, 58, 237, 0.10) !important;
  border-color: rgba(124, 58, 237, 0.24) !important;
}

.message-content{
  color: var(--text) !important;
  white-space: normal !important;
  word-break: break-word !important;
}

#emptyState.empty-state-shell{
  width: min(900px, 100%) !important;
  max-width: 900px !important;
  margin: 0 auto !important;
  padding: 48px 18px 24px !important;
}

.empty-state{
  padding: 28px !important;
  border: 1px solid var(--border) !important;
  border-radius: 24px !important;
  background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)) !important;
  box-shadow: var(--shadow-md) !important;
}

.composer-wrap{
  position: sticky !important;
  bottom: 0 !important;
  z-index: 15 !important;
  padding: 14px 18px 18px !important;
  background: linear-gradient(180deg, rgba(11,16,32,0), rgba(11,16,32,0.92) 28%, rgba(11,16,32,0.98)) !important;
}

.composer-shell{
  width: min(900px, 100%) !important;
  max-width: 900px !important;
  margin: 0 auto !important;
}

.pending-attachments{
  margin-bottom: 10px !important;
}

.pending-attachments-list{
  display: flex !important;
  flex-wrap: wrap !important;
  gap: 10px !important;
}

.composer-form{
  display: flex !important;
  flex-direction: column !important;
  gap: 10px !important;
  padding: 12px !important;
  border: 1px solid var(--border) !important;
  border-radius: 22px !important;
  background: rgba(15, 23, 42, 0.92) !important;
  box-shadow: var(--shadow-lg) !important;
}

.composer-input-wrap{
  display: flex !important;
  gap: 10px !important;
  align-items: flex-end !important;
}

#input{
  width: 100% !important;
  min-height: 52px !important;
  max-height: 280px !important;
  resize: none !important;
  border: 1px solid var(--border) !important;
  border-radius: 14px !important;
  background: rgba(255,255,255,0.03) !important;
  color: var(--text) !important;
  padding: 12px 14px !important;
  box-sizing: border-box !important;
}

.composer-actions{
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 12px !important;
}

.composer-actions-left,
.composer-actions-right{
  display: flex !important;
  align-items: center !important;
  gap: 8px !important;
}

#mobileOverlay.mobile-overlay{
  display: none !important;
}

body.sidebar-open{
  overflow: hidden !important;
}

@media (max-width: 620px){  #appShell.app-shell{
    grid-template-columns: minmax(0, 1fr) !important;
  }

  #sidebar.sidebar{
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    bottom: 0 !important;
    z-index: 40 !important;
    width: min(86vw, 320px) !important;
    max-width: 320px !important;
    min-height: 100vh !important;
    transform: translateX(-100%) !important;
    transition: transform 180ms ease !important;
    box-shadow: 0 24px 60px rgba(0,0,0,0.45) !important;
  }

  #sidebar.sidebar.is-open,
  #sidebar.sidebar.open,
  #sidebar.sidebar[data-open="true"]{
    transform: translateX(0) !important;
  }

  #btnCloseSidebar.sidebar-close{
    display: inline-flex !important;
  }

  #btnSidebarToggle.mobile-sidebar-btn{
    display: inline-flex !important;
  }

  #mobileOverlay.mobile-overlay{
    display: block !important;
    position: fixed !important;
    inset: 0 !important;
    z-index: 35 !important;
    background: rgba(2, 6, 23, 0.56) !important;
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
    transition: opacity 180ms ease, visibility 180ms ease !important;
  }

  #mobileOverlay.mobile-overlay.is-visible,
  #mobileOverlay.mobile-overlay.show{
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }

  .topbar{
    padding-inline: 14px !important;
  }

  #messages.messages{
    padding-inline: 14px !important;
  }

  .composer-wrap{
    padding-inline: 14px !important;
  }
}