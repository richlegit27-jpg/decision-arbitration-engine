:root{
  --bg: #0b1020;
  --bg-elev: #11182d;
  --bg-elev-2: #161f38;
  --panel: #0f172a;
  --panel-2: #172036;
  --border: rgba(148, 163, 184, 0.16);
  --border-strong: rgba(148, 163, 184, 0.28);
  --text: #e5e7eb;
  --text-soft: #94a3b8;
  --text-dim: #64748b;
  --accent: #7c3aed;
  --accent-2: #8b5cf6;
  --accent-soft: rgba(124, 58, 237, 0.18);
  --green: #22c55e;
  --red: #ef4444;
  --red-soft: rgba(239, 68, 68, 0.14);
  --shadow-lg: 0 20px 60px rgba(0, 0, 0, 0.35);
  --shadow-md: 0 10px 30px rgba(0, 0, 0, 0.22);
  --radius-sm: 10px;
  --radius-md: 14px;
  --radius-lg: 18px;
  --radius-xl: 24px;
  --sidebar-w: 300px;
  --topbar-h: 64px;
  --composer-h: 88px;
  --font: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

*{
  box-sizing: border-box;
}

html{
  height: 100%;
  color-scheme: dark;
}

body{
  min-height: 100%;
  margin: 0;
  background:
    radial-gradient(circle at top, rgba(124, 58, 237, 0.14), transparent 26%),
    linear-gradient(180deg, #0a1020 0%, #0b1120 100%);
  color: var(--text);
  font-family: var(--font);
  font-size: 15px;
  line-height: 1.5;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
}

body.sidebar-open{
  overflow: hidden;
}

button,
input,
textarea,
select{
  font: inherit;
}

button{
  border: 0;
  outline: none;
  cursor: pointer;
  color: inherit;
  background: none;
}

button:disabled{
  cursor: not-allowed;
  opacity: 0.55;
}

textarea{
  resize: none;
  outline: none;
}

a{
  color: inherit;
  text-decoration: none;
}

[hidden]{
  display: none !important;
}

::selection{
  background: rgba(139, 92, 246, 0.32);
  color: #fff;
}

::-webkit-scrollbar{
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track{
  background: transparent;
}

::-webkit-scrollbar-thumb{
  background: rgba(148, 163, 184, 0.22);
  border: 2px solid transparent;
  background-clip: padding-box;
  border-radius: 999px;
}

::-webkit-scrollbar-thumb:hover{
  background: rgba(148, 163, 184, 0.34);
  border: 2px solid transparent;
  background-clip: padding-box;
}

.sidebar-logo{
  font-size: 1.15rem;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.sidebar-toggle,
.mobile-sidebar-btn{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 42px;
  height: 42px;
  padding: 0 12px;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  color: var(--text);
  transition: background 140ms ease, border-color 140ms ease, transform 140ms ease;
}

.sidebar-toggle:hover,
.mobile-sidebar-btn:hover{
  background: rgba(255, 255, 255, 0.06);
  border-color: var(--border-strong);
}

.sidebar-toggle:active,
.mobile-sidebar-btn:active{
  transform: translateY(1px);
}

.new-chat-btn{
  width: 100%;
  height: 46px;
  padding: 0 16px;
  border: 1px solid rgba(139, 92, 246, 0.34);
  border-radius: 14px;
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.24), rgba(124, 58, 237, 0.16));
  color: #f5f3ff;
  font-weight: 600;
  transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
}

.new-chat-btn:hover{
  border-color: rgba(139, 92, 246, 0.48);
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.3), rgba(124, 58, 237, 0.2));
}

.new-chat-btn:active{
  transform: translateY(1px);
}

.chat-title{
  min-width: 0;
  font-size: 1rem;
  font-weight: 650;
  letter-spacing: 0.01em;
  color: #f8fafc;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-list-empty,
.messages-empty,
.empty-state{
  color: var(--text-soft);
}

.chat-list-empty{
  padding: 12px 6px;
  font-size: 0.95rem;
}

.chat-list-item{
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 8px;
  padding: 8px;
  border: 1px solid transparent;
  border-radius: 16px;
  transition: background 140ms ease, border-color 140ms ease;
}

.chat-list-item:hover{
  background: rgba(255, 255, 255, 0.035);
  border-color: rgba(148, 163, 184, 0.08);
}

.chat-list-item.is-active{
  background: rgba(124, 58, 237, 0.11);
  border-color: rgba(139, 92, 246, 0.22);
}

.chat-list-main{
  width: 100%;
  min-width: 0;
  display: grid;
  gap: 4px;
  text-align: left;
  padding: 8px 10px;
  border-radius: 12px;
}

.chat-list-title{
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 600;
  color: #eef2ff;
}

.chat-list-time{
  font-size: 0.78rem;
  color: var(--text-dim);
}

.chat-list-actions{
  display: flex;
  gap: 8px;
  padding: 0 10px 6px;
}

.chat-list-action{
  padding: 6px 10px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-soft);
  font-size: 0.82rem;
  transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
}

.chat-list-action:hover{
  background: rgba(255, 255, 255, 0.06);
  border-color: var(--border-strong);
  color: var(--text);
}

.chat-list-action.danger:hover{
  color: #fecaca;
  border-color: rgba(239, 68, 68, 0.28);
  background: rgba(239, 68, 68, 0.08);
}

.message-row{
  width: 100%;
  display: grid;
  grid-template-columns: 44px minmax(0, 1fr);
  gap: 14px;
  align-items: start;
}

.message-avatar{
  width: 44px;
  height: 44px;
  border: 1px solid var(--border);
  border-radius: 14px;
  display: grid;
  place-items: center;
  font-weight: 700;
  color: #f8fafc;
  background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
  box-shadow: var(--shadow-md);
}

.role-user .message-avatar{
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.38), rgba(124, 58, 237, 0.18));
  border-color: rgba(139, 92, 246, 0.34);
}

.role-assistant .message-avatar{
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(30, 41, 59, 0.86));
}

.role-system .message-avatar{
  background: linear-gradient(180deg, rgba(239, 68, 68, 0.24), rgba(239, 68, 68, 0.12));
  border-color: rgba(239, 68, 68, 0.28);
}

.message-bubble-wrap{
  min-width: 0;
  display: grid;
  gap: 10px;
}

.message-meta{
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  color: var(--text-soft);
  font-size: 0.83rem;
}

.message-author{
  color: #f8fafc;
  font-weight: 650;
}

.message-time{
  color: var(--text-dim);
}

.message-status{
  display: inline-flex;
  align-items: center;
  height: 24px;
  padding: 0 10px;
  border-radius: 999px;
  font-size: 0.76rem;
  font-weight: 600;
}

.message-status.is-streaming{
  background: rgba(34, 197, 94, 0.12);
  color: #bbf7d0;
  border: 1px solid rgba(34, 197, 94, 0.16);
}

.message-status.is-error{
  background: rgba(239, 68, 68, 0.1);
  color: #fecaca;
  border: 1px solid rgba(239, 68, 68, 0.16);
}

.message-bubble{
  min-width: 0;
  padding: 16px 18px;
  border: 1px solid var(--border);
  border-radius: 18px;
  background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.025));
  box-shadow: var(--shadow-md);
}

.role-user .message-bubble{
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.2), rgba(124, 58, 237, 0.1));
  border-color: rgba(139, 92, 246, 0.28);
}

.role-system .message-bubble,
.message-row.has-error .message-bubble{
  border-color: rgba(239, 68, 68, 0.22);
  background: linear-gradient(180deg, rgba(239, 68, 68, 0.08), rgba(239, 68, 68, 0.04));
}

.message-content{
  min-width: 0;
  color: var(--text);
  font-size: 0.98rem;
  line-height: 1.7;
  white-space: normal;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.message-content p{
  margin: 0 0 1em;
}

.message-content p:last-child{
  margin-bottom: 0;
}

.message-content pre,
.message-content code{
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
}

.message-content pre{
  overflow-x: auto;
  margin: 14px 0 0;
  padding: 14px;
  border: 1px solid rgba(148, 163, 184, 0.14);
  border-radius: 14px;
  background: rgba(2, 6, 23, 0.72);
}

.message-content code{
  padding: 0.15em 0.4em;
  border-radius: 8px;
  background: rgba(148, 163, 184, 0.12);
  font-size: 0.92em;
}

.message-content table{
  width: 100%;
  border-collapse: collapse;
  margin-top: 12px;
  overflow: hidden;
  border: 1px solid var(--border);
  border-radius: 14px;
}

.message-content th,
.message-content td{
  padding: 10px 12px;
  border-bottom: 1px solid var(--border);
  text-align: left;
}

.message-content th{
  color: #f8fafc;
  background: rgba(255,255,255,0.03);
  font-weight: 650;
}

.message-actions{
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.message-action-btn{
  height: 34px;
  padding: 0 12px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: rgba(255,255,255,0.03);
  color: var(--text-soft);
  font-size: 0.84rem;
  transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
}

.message-action-btn:hover{
  background: rgba(255,255,255,0.06);
  border-color: var(--border-strong);
  color: var(--text);
}

.message-error{
  margin-top: 12px;
  padding: 12px 14px;
  border: 1px solid rgba(239, 68, 68, 0.18);
  border-radius: 14px;
  background: var(--red-soft);
  color: #fecaca;
  font-size: 0.92rem;
}

.message-attachments,
.pending-attachments-list{
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.message-attachments{
  margin-top: 14px;
}

.attachment-chip{
  max-width: 100%;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: 14px;
  background: rgba(255,255,255,0.04);
}

.attachment-chip-body{
  min-width: 0;
  display: grid;
  gap: 2px;
}

.attachment-chip-name{
  max-width: 320px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #f8fafc;
  font-size: 0.9rem;
}

.attachment-chip-meta{
  color: var(--text-dim);
  font-size: 0.75rem;
}

.attachment-chip-remove{
  width: 28px;
  height: 28px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255,255,255,0.04);
  color: var(--text-soft);
  flex: 0 0 auto;
}

.attachment-chip-remove:hover{
  background: rgba(239, 68, 68, 0.08);
  border-color: rgba(239, 68, 68, 0.2);
  color: #fecaca;
}

.empty-state{
  display: grid;
  place-items: center;
  gap: 8px;
  text-align: center;
  padding: 30px 20px;
}

.empty-title,
.messages-empty-title{
  color: #f8fafc;
  font-size: 1.35rem;
  font-weight: 700;
}

.empty-text,
.messages-empty-text{
  max-width: 560px;
  color: var(--text-soft);
  font-size: 0.98rem;
}

.composer{
  border: 1px solid var(--border);
  border-radius: 22px;
  background: linear-gradient(180deg, rgba(17, 24, 39, 0.92), rgba(15, 23, 42, 0.94));
  box-shadow: var(--shadow-lg);
}

.composer-input{
  width: 100%;
  min-height: 56px;
  max-height: 220px;
  padding: 16px 4px;
  border: 0;
  background: transparent;
  color: var(--text);
  font-size: 1rem;
  line-height: 1.6;
}

.composer-input::placeholder{
  color: var(--text-dim);
}

.composer-attach,
.composer-send,
.composer-stop{
  height: 46px;
  padding: 0 16px;
  border: 1px solid var(--border);
  border-radius: 14px;
  background: rgba(255,255,255,0.04);
  transition: background 140ms ease, border-color 140ms ease, transform 140ms ease;
}

.composer-attach:hover,
.composer-send:hover,
.composer-stop:hover{
  background: rgba(255,255,255,0.07);
  border-color: var(--border-strong);
}

.composer-send{
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.3), rgba(124, 58, 237, 0.18));
  border-color: rgba(139, 92, 246, 0.26);
  color: #faf5ff;
  font-weight: 700;
}

.composer-send:hover{
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.36), rgba(124, 58, 237, 0.24));
  border-color: rgba(139, 92, 246, 0.42);
}

.composer-stop{
  color: #fecaca;
  border-color: rgba(239, 68, 68, 0.22);
  background: rgba(239, 68, 68, 0.08);
}

.composer-stop:hover{
  border-color: rgba(239, 68, 68, 0.34);
  background: rgba(239, 68, 68, 0.12);
}

.pending-attachments{
  display: block;
}

@media (max-width: 959px){
  body{
    overflow: auto;
  }

  .message-row{
    grid-template-columns: 38px minmax(0, 1fr);
    gap: 12px;
  }

  .message-avatar{
    width: 38px;
    height: 38px;
    border-radius: 12px;
  }

  .message-bubble{
    padding: 14px 15px;
  }

  .attachment-chip-name{
    max-width: 220px;
  }

  .empty-title,
  .messages-empty-title{
    font-size: 1.15rem;
  }
}