.app-shell{
  height: 100vh;
  display: grid;
  grid-template-columns: var(--sidebar-w) minmax(0, 1fr);
  background: transparent;
}

.sidebar{
  position: relative;
  min-width: 0;
  height: 100vh;
  display: grid;
  grid-template-rows: auto auto minmax(0, 1fr);
  gap: 14px;
  padding: 18px 16px 16px;
  border-right: 1px solid var(--border);
  background:
    linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.94));
  backdrop-filter: blur(14px);
  overflow: hidden;
}

.sidebar::after{
  content: "";
  position: absolute;
  inset: 0 0 auto 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.3), transparent);
  pointer-events: none;
}

.sidebar-top{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  min-width: 0;
}

.sidebar-brand{
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12px;
}

.sidebar-brand-mark{
  width: 42px;
  height: 42px;
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  border: 1px solid rgba(139, 92, 246, 0.28);
  border-radius: 14px;
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.28), rgba(124, 58, 237, 0.12));
  color: #f5f3ff;
  box-shadow: var(--shadow-md);
  font-weight: 800;
  letter-spacing: 0.02em;
}

.sidebar-brand-copy{
  min-width: 0;
  display: grid;
  gap: 2px;
}

.sidebar-subtitle{
  color: var(--text-dim);
  font-size: 0.78rem;
  letter-spacing: 0.02em;
}

.sidebar-actions{
  display: grid;
  gap: 12px;
}

.chat-list-wrap{
  min-height: 0;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr);
  gap: 12px;
}

.chat-list-header{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 0 6px;
}

.chat-list-heading{
  color: #f8fafc;
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.01em;
}

.chat-list-count{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 28px;
  height: 24px;
  padding: 0 8px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-dim);
  font-size: 0.74rem;
  font-weight: 700;
}

.chat-list{
  min-height: 0;
  overflow-y: auto;
  padding-right: 4px;
  display: grid;
  align-content: start;
  gap: 10px;
}

.mobile-overlay{
  position: fixed;
  inset: 0;
  background: rgba(2, 6, 23, 0.56);
  backdrop-filter: blur(4px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 180ms ease;
  z-index: 30;
}

.main{
  min-width: 0;
  height: 100vh;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  position: relative;
  overflow: hidden;
}

.main::before{
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top right, rgba(139, 92, 246, 0.08), transparent 28%),
    radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.05), transparent 24%);
  pointer-events: none;
}

.topbar{
  position: relative;
  z-index: 2;
  min-width: 0;
  height: var(--topbar-h);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 14px 24px 10px;
}

.topbar-left,
.topbar-right{
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12px;
}

.topbar-title-wrap{
  min-width: 0;
  display: grid;
  gap: 2px;
}

.topbar-title{
  min-width: 0;
  color: #f8fafc;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.topbar-subtitle{
  color: var(--text-dim);
  font-size: 0.8rem;
}

.topbar-actions{
  display: flex;
  align-items: center;
  gap: 10px;
}

.topbar-action{
  height: 40px;
  padding: 0 14px;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-soft);
  transition: background 140ms ease, border-color 140ms ease, color 140ms ease, transform 140ms ease;
}

.topbar-action:hover{
  background: rgba(255, 255, 255, 0.06);
  border-color: var(--border-strong);
  color: var(--text);
}

.topbar-action:active{
  transform: translateY(1px);
}

.chat-stage{
  position: relative;
  z-index: 1;
  min-height: 0;
  display: grid;
  grid-template-rows: minmax(0, 1fr);
  padding: 0 24px;
}

.messages-panel{
  min-width: 0;
  min-height: 0;
  height: 100%;
  display: grid;
  grid-template-rows: minmax(0, 1fr);
}

.messages-scroll{
  min-height: 0;
  overflow-y: auto;
  overscroll-behavior: contain;
  scroll-behavior: smooth;
  padding: 8px 0 24px;
}

.messages{
  width: min(920px, 100%);
  min-height: 100%;
  margin: 0 auto;
  display: grid;
  align-content: start;
  gap: 22px;
}

.messages-empty{
  width: min(760px, 100%);
  min-height: 100%;
  margin: 0 auto;
  display: grid;
  place-items: center;
  padding: 16px 0 24px;
}

.composer-shell{
  position: relative;
  z-index: 2;
  padding: 14px 24px 20px;
  background: linear-gradient(180deg, rgba(11, 16, 32, 0), rgba(11, 16, 32, 0.74) 22%, rgba(11, 16, 32, 0.96) 100%);
}

.composer-wrap{
  width: min(920px, 100%);
  margin: 0 auto;
}

.composer-form{
  display: grid;
  gap: 12px;
}

.composer{
  display: grid;
  gap: 12px;
  padding: 12px 14px 14px;
  backdrop-filter: blur(14px);
}

.composer-main{
  min-width: 0;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto auto;
  align-items: end;
  gap: 10px;
}

.composer-input-wrap{
  min-width: 0;
  display: grid;
  align-items: end;
}

.composer-input{
  display: block;
}

.composer-footer{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.composer-meta{
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text-dim);
  font-size: 0.8rem;
}

.composer-hint{
  color: var(--text-dim);
  font-size: 0.78rem;
}

.pending-attachments{
  min-width: 0;
}

.pending-attachments-list{
  min-width: 0;
}

.empty-state-shell{
  width: min(920px, 100%);
  min-height: 100%;
  margin: 0 auto;
}

.app-loading,
.app-error{
  width: min(760px, 100%);
  margin: 48px auto 0;
  padding: 18px 20px;
  border: 1px solid var(--border);
  border-radius: 18px;
  background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.025));
  box-shadow: var(--shadow-md);
}

.app-error{
  border-color: rgba(239, 68, 68, 0.22);
  background: linear-gradient(180deg, rgba(239, 68, 68, 0.08), rgba(239, 68, 68, 0.04));
  color: #fecaca;
}

@media (max-width: 1199px){
  :root{
    --sidebar-w: 280px;
  }

  .topbar,
  .chat-stage,
  .composer-shell{
    padding-left: 20px;
    padding-right: 20px;
  }

  .messages,
  .composer-wrap,
  .empty-state-shell{
    width: min(860px, 100%);
  }
}

@media (max-width: 959px){
  .app-shell{
    grid-template-columns: minmax(0, 1fr);
  }

  .sidebar{
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(86vw, 320px);
    max-width: 320px;
    transform: translateX(-100%);
    transition: transform 180ms ease;
    z-index: 40;
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.42);
  }

  body.sidebar-open .sidebar{
    transform: translateX(0);
  }

  body.sidebar-open .mobile-overlay{
    opacity: 1;
    pointer-events: auto;
  }

  .main{
    height: 100dvh;
  }

  .topbar{
    height: auto;
    min-height: var(--topbar-h);
    padding: 12px 16px 8px;
  }

  .topbar-title{
    font-size: 0.96rem;
  }

  .topbar-subtitle{
    display: none;
  }

  .topbar-actions{
    gap: 8px;
  }

  .topbar-action{
    height: 38px;
    padding: 0 12px;
  }

  .chat-stage{
    padding: 0 16px;
  }

  .messages-scroll{
    padding: 6px 0 18px;
  }

  .messages{
    gap: 18px;
  }

  .composer-shell{
    padding: 12px 16px max(16px, env(safe-area-inset-bottom));
  }

  .composer{
    padding: 10px 12px 12px;
    border-radius: 18px;
  }

  .composer-main{
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 8px;
  }

  .composer-stop{
    grid-column: 1 / -1;
  }

  .composer-footer{
    flex-direction: column;
    align-items: flex-start;
  }

  .composer-hint{
    display: none;
  }
}

@media (max-width: 639px){
  :root{
    --topbar-h: 60px;
  }

  .sidebar{
    width: min(90vw, 320px);
    padding: 16px 14px 14px;
  }

  .topbar{
    padding: 10px 12px 6px;
  }

  .chat-stage{
    padding: 0 12px;
  }

  .messages{
    gap: 16px;
  }

  .composer-shell{
    padding: 10px 12px max(12px, env(safe-area-inset-bottom));
  }

  .composer-main{
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  .composer-attach,
  .composer-send,
  .composer-stop{
    width: 100%;
    justify-content: center;
  }

  .composer-input{
    min-height: 52px;
    padding-top: 14px;
    padding-bottom: 14px;
  }

  .chat-list-actions{
    flex-wrap: wrap;
  }

  .empty-state-card{
    padding: 24px 18px;
    border-radius: 18px;
  }
}