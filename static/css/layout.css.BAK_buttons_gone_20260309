/* C:\Users\Owner\nova\static\css\layout.css */

html,
body{
  margin:0;
  padding:0;
  width:100%;
  min-height:100%;
}

body{
  background:var(--bg);
  color:var(--text);
}

/* ================================
   APP GRID
================================ */

#appShell.app-shell{
  min-height:100vh !important;
  width:100% !important;
  display:grid !important;
  grid-template-columns:320px minmax(0,1fr) !important;
  align-items:stretch !important;
  background:var(--bg) !important;
  transition:grid-template-columns 180ms ease !important;
}

/* ================================
   SIDEBAR
================================ */

#sidebar.sidebar{
  position:relative !important;
  z-index:30 !important;
  display:flex !important;
  flex-direction:column !important;
  min-width:0 !important;
  min-height:100vh !important;
  background:var(--panel) !important;
  border-right:1px solid var(--border) !important;
  overflow:hidden !important;
}

.sidebar-header{
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:12px !important;
  padding:16px !important;
  border-bottom:1px solid var(--border) !important;
}

.sidebar-title{
  font-size:.95rem !important;
  font-weight:700 !important;
}

.sidebar-actions{
  display:flex !important;
  flex-direction:column !important;
  gap:10px !important;
  padding:14px 16px !important;
  border-bottom:1px solid var(--border) !important;
}

#chatList.chat-list{
  flex:1 !important;
  overflow:auto !important;
  padding:12px !important;
}

.chat-list-empty{
  padding:18px 14px !important;
  border:1px dashed var(--border) !important;
  border-radius:14px !important;
  text-align:center !important;
  color:var(--text-soft) !important;
}

.chat-list-row{
  display:grid !important;
  grid-template-columns:minmax(0,1fr) 36px !important;
  gap:8px !important;
  align-items:center !important;
  margin-bottom:8px !important;
}

.chat-list-item{
  min-width:0 !important;
  width:100% !important;
}

.chat-list-item-title{
  display:block !important;
  min-width:0 !important;
  overflow:hidden !important;
  text-overflow:ellipsis !important;
  white-space:nowrap !important;
}

.chat-item-delete{
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  width:36px !important;
  height:36px !important;
  border:1px solid rgba(239,68,68,.18) !important;
  border-radius:10px !important;
  background:rgba(255,255,255,.04) !important;
  color:#fca5a5 !important;
  cursor:pointer !important;
  font-size:20px !important;
  line-height:1 !important;
  padding:0 !important;
  opacity:1 !important;
  visibility:visible !important;
  transition:background 140ms ease, border-color 140ms ease, transform 140ms ease !important;
}

.chat-item-delete:hover{
  background:rgba(239,68,68,.14) !important;
  border-color:rgba(239,68,68,.32) !important;
}

.chat-item-delete:active{
  transform:scale(.96) !important;
}

.chat-rename-input{
  width:100% !important;
  min-width:0 !important;
  height:40px !important;
  padding:0 12px !important;
  border:1px solid rgba(139,92,246,.34) !important;
  border-radius:12px !important;
  background:rgba(255,255,255,.05) !important;
  color:var(--text) !important;
  outline:none !important;
  box-shadow:0 0 0 3px rgba(124,58,237,.10) !important;
}

.chat-rename-input::placeholder{
  color:var(--text-soft) !important;
}

/* ================================
   MAIN PANEL
================================ */

.main-panel{
  min-width:0 !important;
  width:100% !important;
  display:flex !important;
  flex-direction:column !important;
  min-height:100vh !important;
}

/* ================================
   TOP BAR
================================ */

.topbar{
  position:sticky !important;
  top:0 !important;
  z-index:20 !important;
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:12px !important;
  min-height:64px !important;
  padding:14px 18px !important;
  border-bottom:1px solid var(--border) !important;
  background:rgba(11,16,32,.88) !important;
  backdrop-filter:blur(10px) !important;
  box-shadow:0 8px 30px rgba(0,0,0,.16) !important;
}

.topbar-left,
.topbar-right{
  display:flex !important;
  align-items:center !important;
  gap:10px !important;
  min-width:0 !important;
}

.topbar-title{
  font-size:.98rem !important;
  font-weight:700 !important;
  white-space:nowrap !important;
  overflow:hidden !important;
  text-overflow:ellipsis !important;
}

/* ================================
   SIDEBAR TOGGLE
================================ */

#btnSidebarToggle{
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  width:40px !important;
  height:40px !important;
  min-width:40px !important;
  border:1px solid var(--border) !important;
  border-radius:12px !important;
  background:var(--panel-2) !important;
  color:var(--text) !important;
  cursor:pointer !important;
}

/* ================================
   MESSAGES AREA
================================ */

.messages-scroll{
  position:relative !important;
  flex:1 !important;
  min-height:0 !important;
  height:100% !important;
  overflow-y:auto !important;
  overflow-x:hidden !important;
  scroll-behavior:smooth !important;
  padding-bottom:220px !important;
  -webkit-overflow-scrolling:touch;
}

#messages.messages{
  width:min(900px,100%) !important;
  max-width:900px !important;
  margin:0 auto !important;
  padding:20px 20px 220px !important;
}

.message{
  display:grid !important;
  grid-template-columns:44px minmax(0,1fr) !important;
  gap:14px !important;
  margin-bottom:18px !important;
}

.message-avatar{
  width:44px !important;
  height:44px !important;
  border:1px solid var(--border) !important;
  border-radius:14px !important;
  display:grid !important;
  place-items:center !important;
  font-weight:700 !important;
}

.message-main{
  min-width:0 !important;
}

.message-bubble{
  border:1px solid rgba(148,163,184,.14) !important;
  border-radius:18px !important;
  padding:14px 16px !important;
  background:rgba(255,255,255,.035) !important;
  box-shadow:0 10px 30px rgba(0,0,0,.18) !important;
  backdrop-filter:blur(10px) !important;
}

.message-content{
  white-space:normal !important;
  word-break:break-word !important;
  overflow-wrap:anywhere !important;
}

.message-attachments{
  display:flex !important;
  flex-wrap:wrap !important;
  gap:8px !important;
  margin-top:12px !important;
}

.message-attachment-chip{
  display:inline-flex !important;
  align-items:center !important;
  gap:8px !important;
  min-height:34px !important;
  padding:0 12px !important;
  border:1px solid var(--border) !important;
  border-radius:999px !important;
  background:rgba(255,255,255,.04) !important;
  color:var(--text) !important;
  text-decoration:none !important;
}

.message-attachment-name{
  min-width:0 !important;
  max-width:240px !important;
  overflow:hidden !important;
  text-overflow:ellipsis !important;
  white-space:nowrap !important;
}

.message-attachment-size{
  color:var(--text-soft) !important;
  font-size:.82rem !important;
}

.message-actions{
  display:flex !important;
  flex-wrap:wrap !important;
  gap:8px !important;
  margin-top:10px !important;
  padding-left:2px !important;
}

.message-action-btn{
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  min-height:32px !important;
  padding:0 12px !important;
  border:1px solid var(--border) !important;
  border-radius:999px !important;
  background:rgba(255,255,255,.035) !important;
  color:var(--text-soft) !important;
  font-size:.82rem !important;
  font-weight:600 !important;
  cursor:pointer !important;
  transition:background 140ms ease, border-color 140ms ease, color 140ms ease, transform 140ms ease !important;
}

.message-action-btn:hover{
  background:rgba(255,255,255,.06) !important;
  border-color:var(--border-strong) !important;
  color:var(--text) !important;
}

.message-action-btn:active{
  transform:scale(.98) !important;
}

.message-action-btn.is-danger{
  color:#fca5a5 !important;
  border-color:rgba(239,68,68,.18) !important;
}

.message-action-btn.is-danger:hover{
  background:rgba(239,68,68,.14) !important;
  border-color:rgba(239,68,68,.32) !important;
  color:#fecaca !important;
}

/* ================================
   JUMP TO LATEST
================================ */

.jump-to-latest-btn{
  position:sticky !important;
  left:50% !important;
  bottom:22px !important;
  transform:translateX(-50%) !important;
  z-index:12 !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  min-height:42px !important;
  padding:0 16px !important;
  border:1px solid rgba(139,92,246,.32) !important;
  border-radius:999px !important;
  background:rgba(15,23,42,.92) !important;
  color:var(--text) !important;
  box-shadow:0 10px 26px rgba(0,0,0,.28) !important;
  backdrop-filter:blur(12px) !important;
  cursor:pointer !important;
}

.jump-to-latest-btn:hover{
  border-color:rgba(139,92,246,.5) !important;
  background:rgba(23,32,54,.96) !important;
}

/* ================================
   COMPOSER
================================ */

.composer-wrap{
  position:sticky !important;
  bottom:0 !important;
  z-index:15 !important;
  padding:14px 18px 18px !important;
  background:linear-gradient(180deg,rgba(11,16,32,0),rgba(11,16,32,.92) 28%,rgba(11,16,32,.98)) !important;
}

.composer-shell{
  width:min(900px,100%) !important;
  max-width:900px !important;
  margin:0 auto !important;
}

.composer-form{
  display:flex !important;
  flex-direction:column !important;
  gap:10px !important;
  padding:12px !important;
  border:1px solid var(--border) !important;
  border-radius:22px !important;
  background:rgba(15,23,42,.92) !important;
  box-shadow:0 12px 40px rgba(0,0,0,.22) !important;
  backdrop-filter:blur(14px) !important;
}

#input{
  width:100% !important;
  min-height:52px !important;
  max-height:280px !important;
  resize:none !important;
  border:1px solid var(--border) !important;
  border-radius:14px !important;
  padding:12px 14px !important;
  background:rgba(255,255,255,.03) !important;
}

#input:focus{
  outline:none !important;
  border-color:rgba(139,92,246,.45) !important;
  box-shadow:0 0 0 4px rgba(124,58,237,.12) !important;
}

/* ================================
   COMPOSER ACTIONS / BUTTON FIX
================================ */

.composer-actions{
  display:flex !important;
  align-items:center !important;
  justify-content:space-between !important;
  gap:10px !important;
  width:100% !important;
  flex-wrap:nowrap !important;
}

.composer-actions-left,
.composer-actions-right{
  display:flex !important;
  align-items:center !important;
  gap:10px !important;
}

#sendBtn,
#stopBtn,
#attachBtn{
  position:relative !important;
  inset:auto !important;
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  min-width:44px !important;
  height:44px !important;
  padding:0 14px !important;
  border-radius:12px !important;
  flex:0 0 auto !important;
}

#sendBtn,
#stopBtn{
  min-width:96px !important;
}

#stopBtn{
  margin-left:0 !important;
}

/* ================================
   EMPTY STATE POLISH
================================ */

.empty-state-shell{
  min-height:100%;
  display:flex !important;
  align-items:center !important;
  justify-content:center !important;
  padding:32px 18px 180px !important;
}

.empty-state{
  width:min(760px,100%) !important;
  margin:0 auto !important;
  text-align:center !important;
}

.empty-state-badge{
  display:inline-flex !important;
  align-items:center !important;
  justify-content:center !important;
  min-height:32px !important;
  padding:0 12px !important;
  border:1px solid var(--border) !important;
  border-radius:999px !important;
  background:rgba(255,255,255,.04) !important;
  color:var(--text-soft) !important;
  font-size:.86rem !important;
  font-weight:700 !important;
  letter-spacing:.02em !important;
  margin-bottom:16px !important;
}

.empty-state h1{
  margin:0 0 12px !important;
  font-size:clamp(2rem,4vw,3rem) !important;
  line-height:1.05 !important;
  letter-spacing:-.03em !important;
  color:var(--text) !important;
}

.empty-state p{
  margin:0 auto 24px !important;
  max-width:620px !important;
  color:var(--text-soft) !important;
  font-size:1rem !important;
  line-height:1.6 !important;
}

.empty-state-suggestions{
  display:grid !important;
  grid-template-columns:repeat(2,minmax(0,1fr)) !important;
  gap:12px !important;
  width:100% !important;
  margin-top:10px !important;
}

.suggestion-chip{
  display:flex !important;
  align-items:center !important;
  justify-content:flex-start !important;
  text-align:left !important;
  min-height:64px !important;
  width:100% !important;
  padding:14px 16px !important;
  border:1px solid var(--border) !important;
  border-radius:18px !important;
  background:rgba(255,255,255,.03) !important;
  color:var(--text) !important;
  cursor:pointer !important;
  transition:transform 140ms ease, border-color 140ms ease, background 140ms ease !important;
}

.suggestion-chip:hover{
  transform:translateY(-1px) !important;
  border-color:var(--border-strong) !important;
  background:rgba(255,255,255,.05) !important;
}

.suggestion-chip:active{
  transform:translateY(0) !important;
}

/* ================================
   LAYOUT / SCROLL FIXES
================================ */

.content-shell{
  min-height:0 !important;
  height:100vh !important;
  overflow:hidden !important;
}

.messages-shell{
  min-height:0 !important;
  overflow:hidden !important;
}

/* ================================
   DESKTOP SIDEBAR COLLAPSE
================================ */

@media (min-width:621px){
  body:not(.sidebar-open) #appShell.app-shell{
    grid-template-columns:0 minmax(0,1fr) !important;
  }

  body:not(.sidebar-open) #sidebar.sidebar{
    width:0 !important;
    border-right:0 !important;
    padding:0 !important;
  }

  body:not(.sidebar-open) #sidebar.sidebar > *{
    opacity:0 !important;
    pointer-events:none !important;
  }
}

/* ================================
   MOBILE SIDEBAR
================================ */

@media (max-width:760px){
  .empty-state-suggestions{
    grid-template-columns:minmax(0,1fr) !important;
  }
}

@media (max-width:620px){
  #appShell.app-shell{
    grid-template-columns:minmax(0,1fr) !important;
  }

  #sidebar.sidebar{
    position:fixed !important;
    top:0 !important;
    left:0 !important;
    bottom:0 !important;
    z-index:40 !important;
    width:min(86vw,320px) !important;
    transform:translateX(-100%) !important;
    transition:transform 180ms ease !important;
  }

  #sidebar.sidebar.is-open,
  #sidebar.sidebar[data-open="true"]{
    transform:translateX(0) !important;
  }

  .jump-to-latest-btn{
    bottom:16px !important;
  }

  .chat-list-row{
    grid-template-columns:minmax(0,1fr) 40px !important;
  }

  .chat-item-delete{
    width:40px !important;
    height:40px !important;
  }

  .message-actions{
    gap:6px !important;
  }

  .message-action-btn{
    min-height:30px !important;
    padding:0 10px !important;
    font-size:.78rem !important;
  }
}


