  function parseAttachmentMarkers(text){
    const re = /\[\[att:([A-Za-z0-9_\-\.~]+)\]\]/g;
    const ids = [];
    let m;
    while ((m = re.exec(text)) !== null) ids.push(m[1]);
    const clean = (text || "").replace(re, "").trim();
    return { clean, ids };
  }

