(() => {
"use strict"

function createRenderService(options = {}){
  const {
    state,
    elements = {},
    utils = {},
  } = options

  if(!state){
    throw new Error("NovaChatRender: state is required")
  }

  const el = {
    chatList: elements.chatList || null,
    emptyState: elements.emptyState || null,
    jumpToLatestBtn: elements.jumpToLatestBtn || null,
    messages: elements.messages || null,
    messagesScroll: elements.messagesScroll || null,
    pendingAttachments: elements.pendingAttachments || null,
    topbarTitle: elements.topbarTitle || null,
    sendBtn: elements.sendBtn || null,
    stopBtn: elements.stopBtn || null,
    attachBtn: elements.attachBtn || null,
    input: elements.input || null,
  }

  const escapeHtml =
    utils.escapeHtml ||
    ((value) => String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;"))

  const getChatTitle =
    utils.getChatTitle ||
    ((chat) => String(chat?.title || chat?.name || "New chat").trim() || "New chat")

  const getChatId =
    utils.getChatId ||
    ((chat) => String(chat?.chat_id || chat?.id || ""))

  const ensureChatsArray =
    utils.ensureChatsArray ||
    (() => Array.isArray(state.chats) ? state.chats : [])

  const ensureMessagesArray =
    utils.ensureMessagesArray ||
    (() => Array.isArray(state.messages) ? state.messages : [])

  const getActiveChat =
    utils.getActiveChat ||
    (() => null)

  function updateTopbarTitle(){
    if(!el.topbarTitle){
      return
    }

    el.topbarTitle.textContent = getChatTitle(getActiveChat())
  }

  function updateComposerState(){
    const text = String(el.input?.value || "").trim()
    const hasPendingFiles = Array.isArray(state.pendingFiles) && state.pendingFiles.length > 0
    const canSend = !state.isStreaming && (!!text || hasPendingFiles)

    if(el.sendBtn){
      el.sendBtn.disabled = !canSend
    }

    if(el.stopBtn){
      el.stopBtn.hidden = !state.isStreaming
      el.stopBtn.style.display = state.isStreaming ? "inline-flex" : "none"
    }

    if(el.attachBtn){
      el.attachBtn.disabled = state.isStreaming
    }

    if(el.input){
      el.input.disabled = false
    }
  }

  function renderEmptyState(){
    const hasMessages = ensureMessagesArray().length > 0

    if(el.emptyState){
      el.emptyState.hidden = hasMessages
      el.emptyState.style.display = hasMessages ? "none" : "flex"
    }

    if(el.messages){
      el.messages.style.display = hasMessages ? "" : "none"
    }
  }

  function updateJumpButton(){
    if(!el.jumpToLatestBtn || !el.messagesScroll){
      return
    }

    const hasMessages = ensureMessagesArray().length > 0
    const shouldShow = hasMessages && !!state.hasUserScrolledUp

    el.jumpToLatestBtn.hidden = !shouldShow
    el.jumpToLatestBtn.style.display = shouldShow ? "inline-flex" : "none"
  }

  function renderChatList(){
    if(!el.chatList){
      return
    }

    const chats = ensureChatsArray()

    if(!chats.length){
      el.chatList.innerHTML = `<div class="chat-list-empty">No chats yet</div>`
      return
    }

    const html = chats.map((chat) => {
      const chatId = getChatId(chat)
      const isActive = String(state.activeChatId || "") === chatId
      const isRenaming = String(state.renamingChatId || "") === chatId
      const safeTitle = escapeHtml(getChatTitle(chat))

      if(isRenaming){
        return `
          <div class="chat-list-row" data-chat-row-id="${escapeHtml(chatId)}">
            <input
              class="chat-rename-input"
              data-rename-chat-id="${escapeHtml(chatId)}"
              type="text"
              value="${safeTitle}"
              maxlength="120"
              autocomplete="off"
              spellcheck="false"
              placeholder="Rename chat"
            />
            <button
              type="button"
              class="chat-item-delete"
              data-delete-chat-id="${escapeHtml(chatId)}"
              aria-label="Delete chat"
              title="Delete chat"
            >×</button>
          </div>
        `
      }

      return `
        <div class="chat-list-row" data-chat-row-id="${escapeHtml(chatId)}">
          <button
            type="button"
            class="chat-list-item${isActive ? " is-active" : ""}"
            data-chat-id="${escapeHtml(chatId)}"
            title="${safeTitle}"
          >
            <span
              class="chat-list-item-title"
              data-rename-trigger="true"
              data-chat-id="${escapeHtml(chatId)}"
            >${safeTitle}</span>
          </button>
          <button
            type="button"
            class="chat-item-delete"
            data-delete-chat-id="${escapeHtml(chatId)}"
            aria-label="Delete chat"
            title="Delete chat"
          >×</button>
        </div>
      `
    }).join("")

    el.chatList.innerHTML = html
  }

  function renderAttachments(attachments){
    if(!Array.isArray(attachments) || !attachments.length){
      return ""
    }

    const html = attachments.map((attachment) => {
      const name = escapeHtml(attachment?.filename || attachment?.name || "Attachment")
      const size = attachment?.size_label
        ? ` <span class="message-attachment-size">${escapeHtml(attachment.size_label)}</span>`
        : ""
      const href = String(attachment?.url || attachment?.href || "#")

      return `
        <a class="message-attachment-chip" href="${escapeHtml(href)}" target="_blank" rel="noopener noreferrer">
          <span class="message-attachment-name">${name}</span>${size}
        </a>
      `
    }).join("")

    return `<div class="message-attachments">${html}</div>`
  }

  function renderMessageActions(message){
    const role = String(message?.role || "")
    if(role !== "assistant"){
      return ""
    }

    const messageId = escapeHtml(String(message?.id || ""))

    return `
      <div class="message-actions">
        <button type="button" class="message-action-btn" data-copy-message-id="${messageId}">Copy</button>
        <button type="button" class="message-action-btn" data-retry-message-id="${messageId}">Retry</button>
        <button type="button" class="message-action-btn is-danger" data-delete-message-id="${messageId}">Delete</button>
      </div>
    `
  }

  function renderMessages(){
    if(!el.messages){
      return
    }

    const messages = ensureMessagesArray()

    if(!messages.length){
      el.messages.innerHTML = ""
      renderEmptyState()
      return
    }

    const html = messages.map((message) => {
      const role = String(message.role || "assistant")
      const isUser = role === "user"
      const avatar = isUser ? "You" : "N"
      const safeContent = escapeHtml(message.content || "").replaceAll("\n", "<br>")

      return `
        <article class="message role-${escapeHtml(role)}" data-message-id="${escapeHtml(message.id)}">
          <div class="message-avatar">${escapeHtml(avatar)}</div>
          <div class="message-main">
            <div class="message-bubble">
              <div class="message-content">${safeContent || "&nbsp;"}</div>
              ${renderAttachments(message.attachments)}
            </div>
            ${renderMessageActions(message)}
          </div>
        </article>
      `
    }).join("")

    el.messages.innerHTML = html
    renderEmptyState()
  }

  function renderPendingAttachments(){
    if(!el.pendingAttachments){
      return
    }

    const files = Array.isArray(state.pendingFiles) ? state.pendingFiles : []

    if(!files.length){
      el.pendingAttachments.innerHTML = ""
      el.pendingAttachments.style.display = "none"
      return
    }

    el.pendingAttachments.style.display = "flex"
    el.pendingAttachments.innerHTML = files.map((file, index) => {
      const name = escapeHtml(file?.name || `file-${index + 1}`)
      return `
        <button
          type="button"
          class="message-attachment-chip"
          data-remove-pending-file-index="${index}"
          title="Remove ${name}"
        >
          <span class="message-attachment-name">${name}</span>
        </button>
      `
    }).join("")
  }

  function renderAll(){
    updateTopbarTitle()
    renderChatList()
    renderMessages()
    renderPendingAttachments()
    updateComposerState()
    updateJumpButton()
  }

  return {
    updateTopbarTitle,
    updateComposerState,
    renderEmptyState,
    updateJumpButton,
    renderChatList,
    renderAttachments,
    renderMessageActions,
    renderMessages,
    renderPendingAttachments,
    renderAll,
  }
}

window.NovaChatRender = {
  create: createRenderService,
  createRenderService,
}

})()