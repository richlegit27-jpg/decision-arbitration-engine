(() => {
"use strict"

function ensureArray(value){
  return Array.isArray(value) ? value : []
}

function getAttachmentId(file){
  return String(
    file?.attachment_id ||
    file?.attachmentId ||
    file?.id ||
    file?.name ||
    crypto.randomUUID()
  )
}

function normalizeFile(file){
  if(!file){
    return null
  }

  return {
    id: getAttachmentId(file),
    attachment_id: getAttachmentId(file),
    name: file.name || file.filename || "file",
    type: file.type || file.content_type || "file",
    size: file.size || file.bytes || 0,
    file,
  }
}

function createAttachmentsService(options = {}){
  const state = options.state || {}
  const elements = options.elements || {}
  const renderService = options.renderService || null

  const el = {
    attachBtn: elements.attachBtn || null,
    fileInput: elements.fileInput || null,
    pendingAttachments: elements.pendingAttachments || null,
    pendingAttachmentsList: elements.pendingAttachmentsList || null,
  }

  if(!Array.isArray(state.pendingAttachments)){
    state.pendingAttachments = []
  }

  function syncUi(){
    const files = ensureArray(state.pendingAttachments)

    if(renderService?.renderPendingAttachments){
      renderService.renderPendingAttachments(files)
    }

    if(el.pendingAttachments){
      el.pendingAttachments.hidden = files.length === 0
    }
  }

  function getPendingAttachments(){
    return ensureArray(state.pendingAttachments)
  }

  function setPendingAttachments(files){
    const normalized = ensureArray(files)
      .map(normalizeFile)
      .filter(Boolean)

    state.pendingAttachments = normalized
    syncUi()
    return normalized
  }

  function addFiles(files){
    const incoming = ensureArray(files)
      .map(normalizeFile)
      .filter(Boolean)

    if(incoming.length === 0){
      return state.pendingAttachments
    }

    const existing = ensureArray(state.pendingAttachments)

    const next = [...existing]

    for(const file of incoming){
      const exists = next.some(
        (item) =>
          item.name === file.name &&
          item.size === file.size
      )

      if(!exists){
        next.push(file)
      }
    }

    state.pendingAttachments = next
    syncUi()

    return next
  }

  function removeAttachment(id){
    const target = String(id || "")
    if(!target){
      return state.pendingAttachments
    }

    state.pendingAttachments = ensureArray(state.pendingAttachments).filter((item) => {
      const itemId = String(
        item.attachment_id ||
        item.id ||
        item.name
      )

      return itemId !== target
    })

    syncUi()
    return state.pendingAttachments
  }

  function clearPendingAttachments(){
    state.pendingAttachments = []
    syncUi()

    if(el.fileInput){
      el.fileInput.value = ""
    }
  }

  function handleFileInputChange(event){
    const files = Array.from(event?.target?.files || [])
    if(files.length === 0){
      return
    }

    addFiles(files)

    if(el.fileInput){
      el.fileInput.value = ""
    }
  }

  function openFileDialog(){
    if(el.fileInput){
      el.fileInput.click()
    }
  }

  function bindEvents(){
    el.attachBtn?.addEventListener("click", openFileDialog)

    el.fileInput?.addEventListener("change", handleFileInputChange)

    el.pendingAttachmentsList?.addEventListener("click", (event) => {
      const removeBtn = event.target.closest("[data-attachment-action='remove']")
      if(!removeBtn){
        return
      }

      const id = removeBtn.dataset.attachmentId
      removeAttachment(id)
    })
  }

  bindEvents()
  syncUi()

  return {
    getPendingAttachments,
    setPendingAttachments,
    addFiles,
    removeAttachment,
    clearPendingAttachments,
  }
}

window.NovaAttachments = {
  createAttachmentsService,
}

})()