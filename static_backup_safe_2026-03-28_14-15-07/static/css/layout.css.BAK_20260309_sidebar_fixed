.app-shell{
  min-height: 100vh;
  display: grid;
  grid-template-columns: 320px minmax(0, 1fr);
  background: var(--bg);
}

.sidebar{
  position: relative;
  z-index: 40;
  display: flex;
  flex-direction: column;
  min-width: 0;
  background: var(--panel);
  border-right: 1px solid var(--border);
  transform: translateX(0);
  transition: transform 180ms ease;
}

.sidebar-header{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 16px;
  border-bottom: 1px solid var(--border);
}

.sidebar-title{
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 0.01em;
}

.sidebar-close{
  display: none;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: var(--panel-2);
  color: var(--text);
  cursor: pointer;
}

.sidebar-actions{
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 14px;
}

.chat-list{
  flex: 1;
  overflow-y: auto;
  padding: 8px;
}

.chat-list-empty{
  padding: 14px 12px;
  color: var(--text-soft);
  font-size: 0.92rem;
}

.chat-list-item{
  width: 100%;
  display: block;
  text-align: left;
  padding: 10px 12px;
  border: 1px solid transparent;
  border-radius: 12px;
  background: transparent;
  color: var(--text);
  cursor: pointer;
}

.chat-list-item:hover{
  background: var(--panel-2);
  border-color: var(--border);
}

.chat-list-item.is-active{
  background: var(--panel-2);
  border-color: var(--border-strong);
}

.chat-list-item-title{
  display: block;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-main{
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  min-width: 0;
}

.topbar{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  min-height: 64px;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  background: var(--panel);
}

.topbar-title{
  min-width: 0;
  font-size: 0.98rem;
  font-weight: 700;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.messages-panel{
  position: relative;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.messages-scroll{
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 18px 20px 132px;
  scroll-padding-bottom: 132px;
}

.messages{
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.message{
  display: grid;
  grid-template-columns: 44px minmax(0, 1fr);
  gap: 14px;
  align-items: start;
  animation: novaMessageIn 180ms ease;
}

@keyframes novaMessageIn{
  from{
    opacity: 0;
    transform: translateY(6px);
  }
  to{
    opacity: 1;
    transform: translateY(0);
  }
}

.message-avatar{
  width: 44px;
  height: 44px;
  border: 1px solid var(--border);
  border-radius: 14px;
  display: grid;
  place-items: center;
  font-weight: 700;
  color: #f8fafc;
  background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
  box-shadow: var(--shadow-md);
}

.role-user .message-avatar{
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.38), rgba(124, 58, 237, 0.18));
  border-color: rgba(124, 58, 237, 0.5);
}

.message-body{
  min-width: 0;
}

.message-content{
  background: var(--panel-2);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 14px 16px;
  line-height: 1.55;
  color: var(--text);
  overflow-wrap: anywhere;
}

.composer-wrap{
  position: sticky;
  bottom: 0;
  z-index: 30;
  background: linear-gradient(180deg, rgba(11,16,32,0), rgba(11,16,32,0.9) 16px, var(--bg) 40px);
  border-top: 1px solid var(--border);
  padding: 14px 18px 18px;
}

.composer-form{
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.composer-row{
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: end;
  gap: 12px;
}

.composer-input,
#input{
  width: 100%;
  resize: none;
  border-radius: 18px;
  border: 1px solid var(--border);
  background: var(--panel);
  color: var(--text);
  padding: 14px 16px;
  min-height: 56px;
  max-height: 220px;
  line-height: 1.5;
  font-size: 15px;
  box-shadow: var(--shadow-sm);
}

.composer-input:focus,
#input:focus{
  outline: none;
  border-color: var(--border-strong);
}

.composer-actions{
  display: flex;
  align-items: center;
  gap: 10px;
}

.composer-actions button,
#attachBtn,
#stopBtn,
#sendBtn{
  min-width: 46px;
  min-height: 46px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 10px 12px;
  background: var(--panel-2);
  color: var(--text);
  cursor: pointer;
  box-shadow: var(--shadow-sm);
}

.composer-actions button:hover,
#attachBtn:hover,
#stopBtn:hover,
#sendBtn:hover{
  background: var(--accent-soft);
}

.composer-actions button:disabled,
#attachBtn:disabled,
#stopBtn:disabled,
#sendBtn:disabled{
  opacity: 0.6;
  cursor: default;
}

.pending-attachments{
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.pending-attachment{
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.76rem;
  background: var(--panel-2);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 6px 10px;
  color: var(--text);
}

.jump-to-latest{
  position: absolute;
  right: 20px;
  bottom: 138px;
  z-index: 20;
}

.mobile-overlay{
  display: none;
}

@media (max-width: 900px){
  .app-shell{
    grid-template-columns: minmax(0, 1fr);
  }

  .sidebar{
    position: fixed;
    top: 0;
    bottom: 0;
    left: 0;
    width: 280px;
    max-width: calc(100vw - 44px);
    transform: translateX(-100%);
    box-shadow: var(--shadow-lg);
  }

  body.sidebar-open .sidebar{
    transform: translateX(0);
  }

  .mobile-overlay{
    display: block;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.42);
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms ease;
  }

  body.sidebar-open .mobile-overlay{
    opacity: 1;
    pointer-events: auto;
  }

  .sidebar-close{
    display: inline-flex;
  }
}

@media (max-width: 620px){
  .topbar{
    min-height: 58px;
    padding: 12px 12px;
  }

  .messages-scroll{
    padding: 14px 12px 144px;
    scroll-padding-bottom: 144px;
  }

  .composer-wrap{
    padding: 12px 12px 16px;
  }

  .composer-row{
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
  }

  .composer-input,
  #input{
    min-height: 52px;
    padding: 12px 14px;
    border-radius: 16px;
  }

  .composer-actions{
    gap: 8px;
  }

  .composer-actions button,
  #attachBtn,
  #stopBtn,
  #sendBtn{
    min-width: 42px;
    min-height: 42px;
    border-radius: 12px;
    padding: 9px 10px;
  }

  .jump-to-latest{
    right: 12px;
    bottom: 146px;
  }
}

/* ===== NOVA BUTTON VISIBILITY FIX ===== */

#btnSidebarToggle,
#btnCloseSidebar,
.message-actions button,
.message-action,
.delete-message,
.copy-message,
.retry-message{
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

/* sidebar toggle button */

#btnSidebarToggle{
  width: 38px;
  height: 38px;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--panel-2);
  color: var(--text);
}

#btnSidebarToggle:hover{
  background: var(--accent-soft);
}

/* sidebar close */

#btnCloseSidebar{
  width: 36px;
  height: 36px;
}

/* message action buttons */

.message-actions{
  display: flex;
  gap: 6px;
  margin-top: 6px;
}

.message-actions button{
  border: 1px solid var(--border);
  background: var(--panel-2);
  color: var(--text);
  border-radius: 8px;
  padding: 4px 6px;
  font-size: 12px;
}

.message-actions button:hover{
  background: var(--accent-soft);
}