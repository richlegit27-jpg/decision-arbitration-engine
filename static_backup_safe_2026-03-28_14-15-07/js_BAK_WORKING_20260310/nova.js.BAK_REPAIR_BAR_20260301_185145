(function(){
  "use strict";

  console.log("[NOVA] nova.js V6 loaded: REAL_SESSIONS_MESSAGES");

  // --------------------------
  // Helpers
  // --------------------------
  const qs  = (s, r=document) => r.querySelector(s);
  const qsa = (s, r=document) => Array.from(r.querySelectorAll(s));

  function esc(s){
    return String(s ?? "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#39;");
  }

  function fmtTime(iso){
    if(!iso) return "";
    try{
      const d = new Date(iso);
      if(isNaN(d.getTime())) return iso;
      const hh = String(d.getHours()).padStart(2,"0");
      const mm = String(d.getMinutes()).padStart(2,"0");
      const mon = d.toLocaleString(undefined, { month:"short" });
      const day = String(d.getDate()).padStart(2,"0");
      return `${mon} ${day} ${hh}:${mm}`;
    }catch(e){
      return iso;
    }
  }

  // --------------------------
  // API Key / Headers
  // --------------------------
  function getApiKey(){
    // prefer localStorage (browser-side), fallback to empty
    return (localStorage.getItem("nova_api_key") || "").trim();
  }

  function apiHeaders(extra){
    const h = Object.assign({ "Content-Type":"application/json" }, extra || {});
    const k = getApiKey();
    if(k) h["x-api-key"] = k;
    return h;
  }

  async function apiJson(url, opts){
    const o = Object.assign({}, opts || {});
    o.headers = apiHeaders(o.headers);
    const r = await fetch(url, o);
    const txt = await r.text();
    let data = null;
    try{ data = txt ? JSON.parse(txt) : null; } catch(e){ data = { raw: txt }; }
    if(!r.ok){
      const err = new Error(`HTTP ${r.status}`);
      err.status = r.status;
      err.data = data;
      throw err;
    }
    return data;
  }

  // --------------------------
  // Session selection
  // --------------------------
  const SEL_KEY = "nova_selected_session_id";
  function getSelectedSessionId(){
    return (localStorage.getItem(SEL_KEY) || "").trim();
  }
  function setSelectedSessionId(id){
    if(!id) return;
    localStorage.setItem(SEL_KEY, id);
  }

  // --------------------------
  // Sidebar UI
  // --------------------------
  function ensureSidebar(){
    if(qs("#novaSessionsSidebarRoot")) return;

    const root = document.createElement("div");
    root.id = "novaSessionsSidebarRoot";
    root.innerHTML = `
      <div id="novaSessionsSidebar" class="nova-ssb">
        <div class="nova-ssb-top">
          <div class="nova-ssb-title">Sessions</div>
          <div class="nova-ssb-actions">
            <button id="novaSessNewBtn" class="nova-ssb-btn" title="New session">＋</button>
            <button id="novaSessRefreshBtn" class="nova-ssb-btn" title="Refresh">↻</button>
          </div>
        </div>
        <div id="novaSessStatus" class="nova-ssb-status"></div>
        <div id="novaSessList" class="nova-ssb-list"></div>
      </div>
    `;
    document.body.appendChild(root);

    // minimal CSS (won't fight your theme)
    const st = document.createElement("style");
    st.textContent = `
      #novaSessionsSidebarRoot{ position:fixed; top:0; left:0; height:100vh; width:320px; z-index:2147483647 !important; display:block !important; visibility:visible !important; opacity:1 !important; pointer-events:auto !important; }
      #novaSessionsSidebar{ position:relative; height:100%; background:rgba(10,14,24,.96); border-right:1px solid rgba(255,255,255,.10); color:rgba(255,255,255,.92); font-family:system-ui,Segoe UI,Roboto,Arial; display:flex; flex-direction:column; z-index:2147483647 !important; visibility:visible !important; opacity:1 !important; }
      .nova-ssb-top{ display:flex; align-items:center; justify-content:space-between; padding:12px 12px 8px; }
      .nova-ssb-title{ font-weight:700; letter-spacing:.2px; }
      .nova-ssb-actions{ display:flex; gap:8px; }
      .nova-ssb-btn{ width:30px; height:30px; border-radius:10px; border:1px solid rgba(255,255,255,.12); background:rgba(255,255,255,.06); color:rgba(255,255,255,.90); cursor:pointer; }
      .nova-ssb-btn:hover{ background:rgba(255,255,255,.10); }
      .nova-ssb-status{ padding:0 12px 8px; font-size:12px; opacity:.75; min-height:16px; }
      .nova-ssb-list{ padding:8px; overflow:auto; display:flex; flex-direction:column; gap:8px; }
      .nova-ssb-item{ padding:10px 10px; border-radius:14px; border:1px solid rgba(255,255,255,.10); background:rgba(255,255,255,.05); cursor:pointer; }
      .nova-ssb-item:hover{ background:rgba(255,255,255,.08); }
      .nova-ssb-item.sel{ outline:2px solid rgba(120,170,255,.55); background:rgba(120,170,255,.10); }
      .nova-ssb-item .t{ font-weight:650; font-size:13px; margin-bottom:4px; }
      .nova-ssb-item .m{ font-size:12px; opacity:.82; margin-bottom:6px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
      .nova-ssb-item .b{ display:flex; justify-content:space-between; font-size:11px; opacity:.70; }
    `;
    document.head.appendChild(st);
  }

  function setStatus(msg){
    const el = qs("#novaSessStatus");
    if(el) el.textContent = msg || "";
  }

  function normalizeSession(s){
    if(!s) return null;
    const id = s.id || s.session_id || s.uuid || "";
    if(!id) return null;
    return {
      id,
      title: s.title || s.name || "",
      created: s.created_at || s.created || "",
      updated: s.updated_at || s.updated || "",
      preview: s.last_message_preview || s.preview || ""
    };
  }

  function sortSessions(arr){
    return arr.slice().sort((a,b)=>{
      const ta = (a.updated || a.created || "");
      const tb = (b.updated || b.created || "");
      return (tb > ta) ? 1 : (tb < ta ? -1 : 0);
    });
  }

  function highlightSelected(){
    const selected = getSelectedSessionId();
    qsa(".nova-ssb-item").forEach(el => el.classList.remove("sel"));
    if(!selected) return;
    qsa(".nova-ssb-item").forEach(el => {
      const sid = el.getAttribute("data-sid") || "";
      if(sid === selected) el.classList.add("sel");
    });
  }

  function renderSessions(sessions){
    const listEl = qs("#novaSessList");
    if(!listEl) return;

    const selected = getSelectedSessionId();
    listEl.innerHTML = "";

    for(const s of sessions){
      const t = s.title ? s.title : (s.id ? `Session ${s.id.slice(0,8)}` : "Session");
      const pv = s.preview ? s.preview : "";
      const ts = fmtTime(s.updated || s.created);

      const div = document.createElement("div");
      div.className = "nova-ssb-item" + ((selected && s.id === selected) ? " sel" : "");
      div.setAttribute("data-sid", s.id);

      div.innerHTML = `
        <div class="t">${esc(t)}</div>
        ${pv ? `<div class="m">${esc(pv)}</div>` : `<div class="m" style="opacity:.55">—</div>`}
        <div class="b">
          <span>${esc(s.id.slice(0,8))}</span>
          <span>${esc(ts)}</span>
        </div>
      `;

      div.addEventListener("click", async () => {
        setSelectedSessionId(s.id);
        highlightSelected();
        await loadSessionMessages(s.id);
      });

      listEl.appendChild(div);
    }

    if(!selected && sessions.length){
      setSelectedSessionId(sessions[0].id);
      highlightSelected();
      loadSessionMessages(sessions[0].id);
    }
  }

  async function fetchSessions(){
    const data = await apiJson("/api/sessions", { method:"GET" });
    const arr = Array.isArray(data) ? data : (data.sessions || data.items || []);
    const norm = arr.map(normalizeSession).filter(Boolean);
    return sortSessions(norm);
  }

  async function createSession(){
    const data = await apiJson("/api/sessions", { method:"POST", body: JSON.stringify({}) });
    const s = normalizeSession(data.session || data);
    return s?.id || "";
  }

  async function renameSessionIfPossible(sessionId, firstUserText){
    if(!sessionId || !firstUserText) return;
    const title = firstUserText.trim().split(/\s+/).slice(0,8).join(" ");
    if(!title) return;
    const tries = [
      { url: `/api/sessions/${encodeURIComponent(sessionId)}`, method:"PATCH", body: JSON.stringify({ title }) },
      { url: `/api/sessions/${encodeURIComponent(sessionId)}`, method:"PUT",   body: JSON.stringify({ title }) }
    ];
    for(const t of tries){
      try{ await apiJson(t.url, { method:t.method, body:t.body }); return; }catch(e){}
    }
  }

  let lastFingerprint = "";
  async function refreshSessions(reason=""){
    try{
      if(reason) setStatus(reason);
      const sessions = await fetchSessions();
      const fp = JSON.stringify(sessions.map(s => [s.id, s.title, s.updated, s.created, s.preview].join("|")));
      if(fp !== lastFingerprint){
        lastFingerprint = fp;
        renderSessions(sessions);
      } else {
        highlightSelected();
      }
      setStatus("");
    }catch(e){
      setStatus(`sessions: ${e.status || "err"}`);
    }
  }

  // --------------------------
  // Messages UI (render + load)
  // --------------------------
  function findChatLog(){
    return qs("#chatLog") || qs("#messages") || qs("#output") || qs(".messages") || qs("main") || document.body;
  }

  function clearChatUI(){
    const log = findChatLog();
    if(!log) return;
    // If your app has a dedicated log container, clear it.
    if(log.id === "chatLog" || log.id === "messages" || log.id === "output" || log.classList.contains("messages")){
      log.innerHTML = "";
    }
  }

  function addMessageToUI(role, content){
    const log = findChatLog();
    if(!log) return;

    const wrap = document.createElement("div");
    wrap.className = "nova-msg " + role;

    wrap.innerHTML = `
      <div style="padding:10px 12px; margin:8px 0; border:1px solid rgba(255,255,255,.10); border-radius:14px; background:rgba(255,255,255,.04);">
        <div style="font-size:11px; opacity:.7; margin-bottom:6px;">${esc(role)}</div>
        <div style="white-space:pre-wrap;">${esc(content)}</div>
      </div>
    `;
    log.appendChild(wrap);
    // scroll if possible
    try{ log.scrollTop = log.scrollHeight; }catch(e){}
  }

  async function loadSessionMessages(sessionId){
    if(!sessionId) return;
    try{
      const msgs = await apiJson(`/api/sessions/${encodeURIComponent(sessionId)}/messages`, { method:"GET" });
      clearChatUI();
      (Array.isArray(msgs) ? msgs : []).forEach(m => addMessageToUI(m.role || "user", m.content || ""));
    }catch(e){
      // If endpoint not found yet, show nothing
      console.warn("loadSessionMessages failed:", e);
    }
  }

  // expose for sidebar click (used by earlier block versions)
  window.__novaLoadSessionMessages = loadSessionMessages;

  // --------------------------
  // Send integration (persist messages)
  // --------------------------
  function findInput(){
    return qs("#chatInput") || qs("#input") || qs("textarea") || qs("input[type='text']");
  }

  async function ensureSessionBeforeSend(userText){
    let sid = getSelectedSessionId();
    if(sid) return sid;
    sid = await createSession();
    if(sid){
      setSelectedSessionId(sid);
      await renameSessionIfPossible(sid, userText);
      await refreshSessions("");
    }
    return sid;
  }

  async function persistUserMessage(sessionId, text){
    if(!sessionId) return;
    await apiJson(`/api/sessions/${encodeURIComponent(sessionId)}/messages`, {
      method:"POST",
      body: JSON.stringify({ role:"user", content: text })
    });
  }

  // Wrap any existing global send() if present
  function installSendHook(){
    const input = findInput();
    if(!input) return;

    // If there is an existing send() function, wrap it.
    if(typeof window.send === "function" && !window.__novaSendWrappedV6){
      const orig = window.send.bind(window);
      window.send = async function(){
        const t = (input.value || "").trim();
        if(t){
          try{
            const sid = await ensureSessionBeforeSend(t);
            await persistUserMessage(sid, t);
            // render immediately too (so UI never feels laggy)
            addMessageToUI("user", t);
            // update sidebar soon
            setTimeout(()=>refreshSessions(""), 250);
          }catch(e){
            console.warn("persistUserMessage failed:", e);
          }
        }
        return orig();
      };
      window.__novaSendWrappedV6 = true;
      return;
    }

    // Otherwise bind Enter + any submit button to persist + render (basic mode)
    const sendBtn = qs("#sendBtn") || qs("button[type='submit']") || qs("button");
    const doSend = async () => {
      const t = (input.value || "").trim();
      if(!t) return;
      input.value = "";
      const sid = await ensureSessionBeforeSend(t);
      await persistUserMessage(sid, t);
      addMessageToUI("user", t);
      setTimeout(()=>refreshSessions(""), 250);
    };

    if(sendBtn && !sendBtn.__novaBoundV6){
      sendBtn.addEventListener("click", (e)=>{ e.preventDefault(); doSend(); });
      sendBtn.__novaBoundV6 = true;
    }

    if(!input.__novaBoundV6){
      input.addEventListener("keydown", (e)=>{
        if(e.key === "Enter" && !e.shiftKey){
          e.preventDefault();
          doSend();
        }
      });
      input.__novaBoundV6 = true;
    }
  }

  // --------------------------
  // Boot
  // --------------------------
  function boot(){
    ensureSidebar();
    
    ensureSidebarToggle();
    novaForceSidebarVisible();
installSendHook();

    const newBtn = qs("#novaSessNewBtn");
    const refBtn = qs("#novaSessRefreshBtn");

    if(newBtn && !newBtn.__novaBound){
      newBtn.addEventListener("click", async () => {
        try{
          setStatus("creating…");
          const id = await createSession();
          if(id){
            setSelectedSessionId(id);
            await refreshSessions("");
            await loadSessionMessages(id);
          }
          setStatus("");
        }catch(e){
          setStatus("create failed");
        }
      });
      newBtn.__novaBound = true;
    }

    if(refBtn && !refBtn.__novaBound){
      refBtn.addEventListener("click", async () => refreshSessions("refreshing…"));
      refBtn.__novaBound = true;
    }

    refreshSessions("loading…");
    setInterval(() => refreshSessions(""), 2000);
  }

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
})();

  // === NOVA_SIDEBAR_TOGGLE_V1 ===
  function novaForceSidebarVisible(){
    try{
      const root = document.getElementById("novaSessionsSidebarRoot");
      const bar  = document.getElementById("novaSessionsSidebar");
      if(root){
        root.style.display="block";
        root.style.visibility="visible";
        root.style.opacity="1";
        root.style.zIndex="2147483647";
        root.style.pointerEvents="auto";
      }
      if(bar){
        bar.style.display="flex";
        bar.style.visibility="visible";
        bar.style.opacity="1";
      }
    }catch(e){}
  }

  function ensureSidebarToggle(){
    if(document.getElementById("novaSidebarToggleBtn")) return;
    const b = document.createElement("button");
    b.id = "novaSidebarToggleBtn";
    b.textContent = "≡";
    b.title = "Toggle Sessions Sidebar";
    b.style.position = "fixed";
    b.style.top = "10px";
    b.style.left = "10px";
    b.style.zIndex = "2147483647";
    b.style.width = "36px";
    b.style.height = "36px";
    b.style.borderRadius = "12px";
    b.style.border = "1px solid rgba(255,255,255,.16)";
    b.style.background = "rgba(10,14,24,.70)";
    b.style.color = "rgba(255,255,255,.92)";
    b.style.cursor = "pointer";
    b.addEventListener("click", () => {
      const root = document.getElementById("novaSessionsSidebarRoot");
      if(!root) return;
      const cur = getComputedStyle(root).display;
      root.style.display = (cur === "none") ? "block" : "none";
    });
    document.body.appendChild(b);
  }
  // === /NOVA_SIDEBAR_TOGGLE_V1 ===

