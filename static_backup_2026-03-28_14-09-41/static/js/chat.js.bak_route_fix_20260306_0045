(() => {
  "use strict";

  const $ = (sel, root = document) => root.querySelector(sel);
  const $$ = (sel, root = document) => Array.from(root.querySelectorAll(sel));

  const state = {
    chatId: null,
    messages: [],
    sending: false,
    editingMessageId: null,
    abortController: null,
  };

  function safeJsonParse(s) {
    try {
      return JSON.parse(s);
    } catch {
      return null;
    }
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function el(tag, attrs = {}, children = []) {
    const node = document.createElement(tag);

    for (const [key, value] of Object.entries(attrs || {})) {
      if (value == null) continue;

      if (key === "class") node.className = value;
      else if (key === "text") node.textContent = value;
      else if (key === "html") node.innerHTML = value;
      else if (key === "dataset" && typeof value === "object") {
        for (const [dk, dv] of Object.entries(value)) {
          node.dataset[dk] = dv;
        }
      } else if (key.startsWith("on") && typeof value === "function") {
        node.addEventListener(key.slice(2), value);
      } else {
        node.setAttribute(key, value);
      }
    }

    for (const child of Array.isArray(children) ? children : [children]) {
      if (child == null) continue;
      node.appendChild(typeof child === "string" ? document.createTextNode(child) : child);
    }

    return node;
  }

  function uid() {
    return `m_${Date.now()}_${Math.random().toString(16).slice(2, 10)}`;
  }

  function getUrlChatId() {
    const url = new URL(window.location.href);
    return url.searchParams.get("chat_id");
  }

  function setUrlChatId(chatId) {
    const url = new URL(window.location.href);
    url.searchParams.set("chat_id", chatId);
    window.history.replaceState({}, "", url.toString());
  }

  function fmtTime(input) {
    if (!input) return "";
    const d = new Date(input);
    if (Number.isNaN(d.getTime())) return "";

    return d.toLocaleTimeString([], {
      hour: "numeric",
      minute: "2-digit",
    });
  }

  function ensureMarked() {
    if (!window.marked) return;

    marked.setOptions({
      breaks: true,
      gfm: true,
    });
  }

  function renderMarkdown(text) {
    const raw = String(text ?? "");

    if (!window.marked) {
      return `<p>${escapeHtml(raw).replace(/\n/g, "<br>")}</p>`;
    }

    const html = marked.parse(raw);

    return typeof window.DOMPurify !== "undefined"
      ? window.DOMPurify.sanitize(html)
      : html;
  }

  function enhanceRenderedContent(container) {
    if (!container) return;

    $$("pre code", container).forEach((code) => {
      if (window.hljs) {
        try {
          window.hljs.highlightElement(code);
        } catch {}
      }

      const pre = code.closest("pre");
      if (!pre || pre.dataset.enhanced === "1") return;
      pre.dataset.enhanced = "1";

      const languageClass = Array.from(code.classList).find((c) => c.startsWith("language-"));
      const lang = languageClass ? languageClass.replace("language-", "") : "code";

      const toolbar = el("div", { class: "code-toolbar" }, [
        el("span", { class: "code-lang", text: lang }),
        el("button", {
          class: "code-copy-btn",
          type: "button",
          text: "Copy",
          onclick: async () => {
            try {
              await navigator.clipboard.writeText(code.innerText);
              flashButton(toolbar.querySelector(".code-copy-btn"), "Copied");
            } catch {
              flashButton(toolbar.querySelector(".code-copy-btn"), "Failed");
            }
          },
        }),
      ]);

      pre.parentNode.insertBefore(toolbar, pre);
    });

    $$("table", container).forEach((table) => {
      if (table.parentElement && table.parentElement.classList.contains("table-wrap")) return;
      const wrap = el("div", { class: "table-wrap" });
      table.parentNode.insertBefore(wrap, table);
      wrap.appendChild(table);
    });

    $$("a", container).forEach((a) => {
      a.setAttribute("target", "_blank");
      a.setAttribute("rel", "noopener noreferrer");
    });
  }

  function flashButton(button, text) {
    if (!button) return;
    const prev = button.textContent;
    button.textContent = text;
    button.disabled = true;
    setTimeout(() => {
      button.textContent = prev;
      button.disabled = false;
    }, 900);
  }

  function getEls() {
    return {
      app: $("#app"),
      sidebar: $("#sidebar"),
      chatList: $("#chatList"),
      thread: $("#thread"),
      composerForm: $("#composerForm"),
      input: $("#messageInput"),
      btnSend: $("#btnSend"),
      btnRegenerate: $("#btnRegenerate"),
      btnNewChat: $("#btnNewChat"),
      btnClear: $("#btnClear"),
      titleText: $("#titleText"),
      statusText: $("#statusText"),
    };
  }

  function updateStatus(text) {
    const { statusText } = getEls();
    if (statusText) statusText.textContent = text || "Ready";
  }

  function setSending(isSending) {
    state.sending = !!isSending;
    const { btnSend, input, btnRegenerate } = getEls();

    if (btnSend) {
      btnSend.disabled = state.sending;
      btnSend.textContent = state.sending ? "Sending..." : "Send";
    }

    if (btnRegenerate) btnRegenerate.disabled = state.sending;
    if (input) input.disabled = false;

    updateStatus(state.sending ? "Responding..." : "Ready");
  }

  function scrollThreadToBottom(force = false) {
    const { thread } = getEls();
    if (!thread) return;

    const nearBottom =
      thread.scrollHeight - thread.scrollTop - thread.clientHeight < 120;

    if (force || nearBottom) {
      thread.scrollTop = thread.scrollHeight;
    }
  }

  function buildMessageActions(message) {
    const isUser = message.role === "user";
    const isAssistant = message.role === "assistant";

    const actions = el("div", { class: "msg-actions" });

    if (isAssistant) {
      actions.appendChild(
        el("button", {
          class: "msg-action-btn",
          type: "button",
          title: "Copy message",
          "aria-label": "Copy message",
          text: "Copy",
          onclick: async () => {
            try {
              await navigator.clipboard.writeText(message.content || "");
              flashButton(actions.lastElementChild, "Copied");
            } catch {
              flashButton(actions.lastElementChild, "Failed");
            }
          },
        })
      );
    }

    if (isUser) {
      actions.appendChild(
        el("button", {
          class: "msg-action-btn",
          type: "button",
          title: "Edit message",
          "aria-label": "Edit message",
          text: "Edit",
          onclick: () => startEditMessage(message.id),
        })
      );
    }

    return actions;
  }

  function renderMessage(message) {
    const isUser = message.role === "user";
    const isAssistant = message.role === "assistant";

    const row = el("article", {
      class: `message ${isUser ? "user" : "assistant"}`,
      dataset: { messageId: message.id, role: message.role },
      tabindex: "0",
    });

    const bubble = el("div", { class: "bubble" });

    const content = el("div", {
      class: "msg-content markdown-body",
      html: renderMarkdown(message.content || ""),
    });

    const meta = el("div", { class: "msg-meta" }, [
      el("div", { class: "msg-time", text: fmtTime(message.created_at) }),
      buildMessageActions(message),
    ]);

    bubble.appendChild(content);
    bubble.appendChild(meta);
    row.appendChild(bubble);

    enhanceRenderedContent(content);

    return row;
  }

  function rerenderMessages() {
    const { thread } = getEls();
    if (!thread) return;

    thread.innerHTML = "";
    for (const message of state.messages) {
      thread.appendChild(renderMessage(message));
    }

    scrollThreadToBottom(true);
  }

  function upsertMessage(message) {
    const idx = state.messages.findIndex((m) => m.id === message.id);
    if (idx >= 0) state.messages[idx] = { ...state.messages[idx], ...message };
    else state.messages.push(message);

    const { thread } = getEls();
    if (!thread) return;

    const existing = thread.querySelector(`[data-message-id="${CSS.escape(message.id)}"]`);
    const rendered = renderMessage(message);

    if (existing) {
      existing.replaceWith(rendered);
    } else {
      thread.appendChild(rendered);
    }

    scrollThreadToBottom();
  }

  function removeMessage(messageId) {
    state.messages = state.messages.filter((m) => m.id !== messageId);
    const { thread } = getEls();
    const node = thread?.querySelector(`[data-message-id="${CSS.escape(messageId)}"]`);
    if (node) node.remove();
  }

  function getLastUserMessage() {
    for (let i = state.messages.length - 1; i >= 0; i--) {
      if (state.messages[i].role === "user") return state.messages[i];
    }
    return null;
  }

  function getLastAssistantMessage() {
    for (let i = state.messages.length - 1; i >= 0; i--) {
      if (state.messages[i].role === "assistant") return state.messages[i];
    }
    return null;
  }

  function buildTypingMessage() {
    return {
      id: uid(),
      role: "assistant",
      content: "▍",
      created_at: new Date().toISOString(),
      pending: true,
    };
  }

  async function fetchJson(url, options = {}) {
    const res = await fetch(url, {
      credentials: "same-origin",
      headers: {
        "Content-Type": "application/json",
        ...(options.headers || {}),
      },
      ...options,
    });

    const text = await res.text();
    const data = text ? safeJsonParse(text) : null;

    if (!res.ok) {
      const msg = data?.error || text || `HTTP ${res.status}`;
      throw new Error(msg);
    }

    return data;
  }

  function extractDataJsonObjects(buffer) {
    const out = [];
    const blocks = buffer.split("\n\n");
    const consumed = blocks.slice(0, -1);

    for (const block of consumed) {
      const lines = block.split("\n");
      const eventLine = lines.find((l) => l.startsWith("event:"));
      const dataLines = lines.filter((l) => l.startsWith("data:"));

      const event = eventLine ? eventLine.slice(6).trim() : "";
      const dataText = dataLines.map((l) => l.slice(5).trim()).join("\n");
      const parsed = safeJsonParse(dataText);

      out.push({
        event,
        raw: dataText,
        data: parsed,
      });
    }

    return {
      events: out,
      remainder: blocks[blocks.length - 1] || "",
    };
  }

  async function ensureChat() {
    if (state.chatId) return state.chatId;

    const existing = getUrlChatId();
    if (existing) {
      state.chatId = existing;
      return state.chatId;
    }

    const created = await fetchJson("/api/chats", {
      method: "POST",
      body: JSON.stringify({}),
    });

    state.chatId = created?.chat_id || created?.id || uid();
    setUrlChatId(state.chatId);
    return state.chatId;
  }

  async function loadChat() {
    const chatId = await ensureChat();

    try {
      const data = await fetchJson(`/api/chats/${encodeURIComponent(chatId)}`);
      state.messages = Array.isArray(data?.messages) ? data.messages : [];
      rerenderMessages();

      const title = data?.title || "Nova";
      const { titleText } = getEls();
      if (titleText) titleText.textContent = title;
    } catch {
      rerenderMessages();
    }

    try {
      const list = await fetchJson("/api/chats");
      renderChatList(Array.isArray(list?.items) ? list.items : Array.isArray(list) ? list : []);
    } catch {}
  }

  function renderChatList(items) {
    const { chatList } = getEls();
    if (!chatList) return;

    chatList.innerHTML = "";

    if (!items.length) {
      chatList.appendChild(
        el("div", { class: "chat-list-empty", text: "No chats yet" })
      );
      return;
    }

    for (const item of items) {
      const active = item.id === state.chatId;
      const button = el("button", {
        class: `chat-row ${active ? "active" : ""}`,
        type: "button",
        onclick: () => {
          state.chatId = item.id;
          setUrlChatId(item.id);
          state.messages = [];
          rerenderMessages();
          loadChat();
        },
      });

      button.appendChild(el("div", { class: "chat-row-title", text: item.title || "New chat" }));
      button.appendChild(
        el("div", {
          class: "chat-row-meta",
          text: item.updated_at ? new Date(item.updated_at).toLocaleDateString() : "",
        })
      );

      chatList.appendChild(button);
    }
  }

  function autosizeInput() {
    const { input } = getEls();
    if (!input) return;

    input.style.height = "0px";
    const next = Math.min(Math.max(input.scrollHeight, 44), 220);
    input.style.height = `${next}px`;
  }

  function startEditMessage(messageId) {
    const msg = state.messages.find((m) => m.id === messageId);
    if (!msg) return;

    const { input } = getEls();
    if (!input) return;

    state.editingMessageId = messageId;
    input.value = msg.content || "";
    autosizeInput();
    input.focus();
    input.setSelectionRange(input.value.length, input.value.length);
    updateStatus("Editing message...");
  }

  function clearEditState() {
    state.editingMessageId = null;
    updateStatus("Ready");
  }

  async function submitMessage() {
    if (state.sending) return;

    const { input } = getEls();
    if (!input) return;

    const raw = input.value;
    const text = String(raw || "").trim();
    if (!text) return;

    const chatId = await ensureChat();
    setSending(true);

    const isEditing = !!state.editingMessageId;
    const editingId = state.editingMessageId;

    if (isEditing) {
      const oldIndex = state.messages.findIndex((m) => m.id === editingId);
      if (oldIndex >= 0) {
        state.messages = state.messages.slice(0, oldIndex);
        rerenderMessages();
      }
      clearEditState();
    }

    input.value = "";
    autosizeInput();

    const userMessage = {
      id: editingId || uid(),
      role: "user",
      content: text,
      created_at: new Date().toISOString(),
    };

    upsertMessage(userMessage);

    const assistantMessage = buildTypingMessage();
    upsertMessage(assistantMessage);

    state.abortController = new AbortController();

    try {
      const response = await fetch(
        `/api/sessions/${encodeURIComponent(chatId)}/messages/stream`,
        {
          method: "POST",
          credentials: "same-origin",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ message: text }),
          signal: state.abortController.signal,
        }
      );

      if (!response.ok || !response.body) {
        throw new Error(`HTTP ${response.status}`);
      }

      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let sseBuffer = "";
      let fullText = "";
      let gotAnyToken = false;

      while (true) {
        const { value, done } = await reader.read();
        if (done) break;

        sseBuffer += decoder.decode(value, { stream: true });

        const parsed = extractDataJsonObjects(sseBuffer);
        sseBuffer = parsed.remainder;

        for (const evt of parsed.events) {
          const payload = evt.data || {};

          if (evt.event === "token") {
            const token =
              payload.t ??
              payload.token ??
              payload.delta ??
              payload.text ??
              "";

            if (token) {
              gotAnyToken = true;
              fullText += token;
              upsertMessage({
                ...assistantMessage,
                content: `${fullText}▍`,
                created_at: assistantMessage.created_at,
              });
            }
          } else if (evt.event === "final") {
            const finalText =
              payload.text ??
              payload.content ??
              payload.message ??
              fullText;

            fullText = finalText || fullText;
            upsertMessage({
              ...assistantMessage,
              content: fullText || "(No response)",
              created_at: assistantMessage.created_at,
              pending: false,
            });
          } else if (evt.event === "error") {
            throw new Error(payload.error || payload.message || "Stream error");
          }
        }
      }

      if (!gotAnyToken && !fullText) {
        upsertMessage({
          ...assistantMessage,
          content: "⚠️ No response received.",
          created_at: assistantMessage.created_at,
          pending: false,
        });
      } else {
        upsertMessage({
          ...assistantMessage,
          content: fullText.replace(/▍$/, ""),
          created_at: assistantMessage.created_at,
          pending: false,
        });
      }

      try {
        const list = await fetchJson("/api/chats");
        renderChatList(Array.isArray(list?.items) ? list.items : Array.isArray(list) ? list : []);
      } catch {}
    } catch (err) {
      upsertMessage({
        ...assistantMessage,
        content: `⚠️ Network/stream error: ${err.message}`,
        created_at: assistantMessage.created_at,
        pending: false,
      });
    } finally {
      state.abortController = null;
      setSending(false);
      scrollThreadToBottom(true);
    }
  }

  async function regenerateLastAssistant() {
    if (state.sending) return;

    const lastUser = getLastUserMessage();
    const lastAssistant = getLastAssistantMessage();

    if (!lastUser) return;
    if (lastAssistant) removeMessage(lastAssistant.id);

    const { input } = getEls();
    if (input) input.value = lastUser.content || "";

    await submitMessage();
  }

  async function createNewChat() {
    state.chatId = null;
    state.messages = [];
    clearEditState();
    rerenderMessages();

    const chatId = await ensureChat();
    setUrlChatId(chatId);

    try {
      const list = await fetchJson("/api/chats");
      renderChatList(Array.isArray(list?.items) ? list.items : Array.isArray(list) ? list : []);
    } catch {}
  }

  async function clearCurrentChat() {
    state.messages = [];
    rerenderMessages();
    clearEditState();
  }

  function bindEvents() {
    const { composerForm, input, btnRegenerate, btnNewChat, btnClear } = getEls();

    if (composerForm) {
      composerForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        await submitMessage();
      });
    }

    if (input) {
      input.addEventListener("input", autosizeInput);

      input.addEventListener("keydown", async (e) => {
        if (e.key === "Enter" && !e.shiftKey) {
          e.preventDefault();
          await submitMessage();
        }

        if (e.key === "Escape" && state.editingMessageId) {
          clearEditState();
          input.value = "";
          autosizeInput();
        }
      });
    }

    if (btnRegenerate) {
      btnRegenerate.addEventListener("click", async () => {
        await regenerateLastAssistant();
      });
    }

    if (btnNewChat) {
      btnNewChat.addEventListener("click", async () => {
        await createNewChat();
      });
    }

    if (btnClear) {
      btnClear.addEventListener("click", async () => {
        await clearCurrentChat();
      });
    }
  }

  function init() {
    ensureMarked();
    bindEvents();
    autosizeInput();
    loadChat();
  }

  document.addEventListener("DOMContentLoaded", init);
})();