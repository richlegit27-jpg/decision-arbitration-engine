:root{
  --bg: #0b1020;
  --bg-elev: #11182d;
  --bg-elev-2: #161f38;
  --panel: #0f172a;
  --panel-2: #172036;
  --border: rgba(148, 163, 184, 0.16);
  --border-strong: rgba(148, 163, 184, 0.28);
  --text: #e5e7eb;
  --text-soft: #94a3b8;
  --text-dim: #64748b;
  --accent: #7c3aed;
  --accent-2: #8b5cf6;
  --accent-soft: rgba(124, 58, 237, 0.18);
  --green: #22c55e;
  --red: #ef4444;
  --red-soft: rgba(239, 68, 68, 0.14);
  --shadow-lg: 0 20px 60px rgba(0, 0, 0, 0.35);
  --shadow-md: 0 10px 30px rgba(0, 0, 0, 0.22);
  --radius-sm: 10px;
  --radius-md: 14px;
  --radius-lg: 18px;
  --radius-xl: 24px;
  --sidebar-w: 300px;
  --topbar-h: 64px;
  --composer-h: 88px;
  --font: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

*{
  box-sizing: border-box;
}

html{
  height: 100%;
  color-scheme: dark;
}

body{
  min-height: 100%;
  margin: 0;
  background:
    radial-gradient(circle at top, rgba(124, 58, 237, 0.14), transparent 26%),
    linear-gradient(180deg, #0a1020 0%, #0b1120 100%);
  color: var(--text);
  font-family: var(--font);
  font-size: 15px;
  line-height: 1.5;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  overflow: hidden;
}

body.sidebar-open{
  overflow: hidden;
}

button,
input,
textarea,
select{
  font: inherit;
}

button{
  border: 0;
  outline: none;
  cursor: pointer;
  color: inherit;
  background: none;
}

button:disabled{
  cursor: not-allowed;
  opacity: 0.55;
}

textarea{
  resize: none;
  outline: none;
}

a{
  color: inherit;
  text-decoration: none;
}

[hidden]{
  display: none !important;
}

::selection{
  background: rgba(139, 92, 246, 0.32);
  color: #fff;
}

::-webkit-scrollbar{
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track{
  background: transparent;
}

::-webkit-scrollbar-thumb{
  background: rgba(148, 163, 184, 0.22);
  border: 2px solid transparent;
  background-clip: padding-box;
  border-radius: 999px;
}

::-webkit-scrollbar-thumb:hover{
  background: rgba(148, 163, 184, 0.34);
  border: 2px solid transparent;
  background-clip: padding-box;
}

.sidebar-logo{
  font-size: 1.15rem;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.sidebar-toggle,
.mobile-sidebar-btn{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 42px;
  height: 42px;
  padding: 0 12px;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  color: var(--text);
  transition: background 140ms ease, border-color 140ms ease, transform 140ms ease;
}

.sidebar-toggle:hover,
.mobile-sidebar-btn:hover{
  background: rgba(255, 255, 255, 0.06);
  border-color: var(--border-strong);
}

.sidebar-toggle:active,
.mobile-sidebar-btn:active{
  transform: translateY(1px);
}

.new-chat-btn{
  width: 100%;
  height: 46px;
  padding: 0 16px;
  border: 1px solid rgba(139, 92, 246, 0.34);
  border-radius: 14px;
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.24), rgba(124, 58, 237, 0.16));
  color: #f5f3ff;
  font-weight: 600;
  transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
}

.new-chat-btn:hover{
  border-color: rgba(139, 92, 246, 0.48);
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.3), rgba(124, 58, 237, 0.2));
}

.new-chat-btn:active{
  transform: translateY(1px);
}

.chat-title{
  min-width: 0;
  font-size: 1rem;
  font-weight: 650;
  letter-spacing: 0.01em;
  color: #f8fafc;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ---------- Message Markdown Structure ---------- */

.message-text h1,
.message-text h2,
.message-text h3{
  margin: 0 0 12px;
  line-height: 1.2;
  font-weight: 700;
}

.message-text h1{
  font-size: 1.5rem;
}

.message-text h2{
  font-size: 1.25rem;
}

.message-text h3{
  font-size: 1.1rem;
}

.message-text p{
  margin: 0 0 12px;
  line-height: 1.6;
}

.message-text p:last-child{
  margin-bottom: 0;
}

.message-text ul{
  margin: 0 0 12px 20px;
  padding: 0;
}

.message-text li{
  margin: 0 0 6px;
  line-height: 1.5;
}

.message-text code{
  font-family: Consolas, "Courier New", monospace;
  font-size: 0.95em;
}

.message-text p code,
.message-text li code,
.message-text h1 code,
.message-text h2 code,
.message-text h3 code{
  padding: 2px 6px;
  border-radius: 6px;
  background: rgba(255,255,255,0.08);
}

.message-text pre{
  margin: 12px 0;
  padding: 14px 16px;
  overflow-x: auto;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(0,0,0,0.28);
}

.message-text pre code{
  display: block;
  white-space: pre;
  line-height: 1.55;
  background: transparent;
  padding: 0;
}

@media (max-width: 959px){
  body{
    overflow: auto;
  }

  .message-row{
    grid-template-columns: 38px minmax(0, 1fr);
    gap: 12px;
  }

  .message-avatar{
    width: 38px;
    height: 38px;
    border-radius: 12px;
  }

  .message-bubble{
    padding: 14px 15px;
  }
}

/* ---------- Streaming Cursor ---------- */

.streaming-cursor{
  display: inline-block;
  width: 8px;
  margin-left: 3px;
  background: #a78bfa;
  border-radius: 2px;
  animation: novaBlink 1s infinite;
}

@keyframes novaBlink{
  0%{opacity:1;}
  50%{opacity:0;}
  100%{opacity:1;}
}

/* ===== Nova markdown safe patch ===== */

.message-text{
  font-size: 15px;
  line-height: 1.7;
  color: inherit;
}

.message-text > :first-child{
  margin-top: 0;
}

.message-text > :last-child{
  margin-bottom: 0;
}

.message-text p{
  margin: 0 0 12px;
}

.message-text h1,
.message-text h2,
.message-text h3{
  margin: 18px 0 10px;
  line-height: 1.25;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.message-text h1{
  font-size: 1.35rem;
}

.message-text h2{
  font-size: 1.15rem;
}

.message-text h3{
  font-size: 1rem;
}

.message-text ul{
  margin: 0 0 12px 0;
  padding-left: 1.2rem;
}

.message-text li{
  margin: 0 0 8px;
}

.message-text li:last-child{
  margin-bottom: 0;
}

.message-text strong{
  font-weight: 800;
}

.message-text em{
  font-style: italic;
}

.message-text code{
  display: inline-block;
  vertical-align: baseline;
  padding: 0.12rem 0.45rem;
  margin: 0 0.08rem;
  border-radius: 8px;
  background: rgba(148, 163, 184, 0.14);
  border: 1px solid rgba(148, 163, 184, 0.16);
  color: inherit;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
  font-size: 0.92em;
  line-height: 1.35;
}

.message-text pre{
  margin: 14px 0 16px;
  padding: 14px 16px;
  border-radius: 16px;
  overflow: auto;
  background: rgba(2, 6, 23, 0.55);
  border: 1px solid rgba(148, 163, 184, 0.14);
}

.message-text pre code{
  display: block;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  color: inherit;
  font-size: 0.9rem;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.streaming-cursor{
  display: inline-block;
  width: 10px;
  height: 1.15em;
  margin-left: 2px;
  vertical-align: -0.16em;
  border-radius: 999px;
  background: currentColor;
  opacity: 0.92;
  animation: nova-caret-blink 1s steps(1, end) infinite;
}

@keyframes nova-caret-blink{
  0%, 49%{
    opacity: 0.95;
  }

  50%, 100%{
    opacity: 0.12;
  }
}