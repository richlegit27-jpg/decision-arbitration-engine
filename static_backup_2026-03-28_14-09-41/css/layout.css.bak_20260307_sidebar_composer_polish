.app-shell{
  height: 100vh;
  display: grid;
  grid-template-columns: var(--sidebar-w) minmax(0, 1fr);
  background: transparent;
  transition: grid-template-columns 220ms ease;
}

body.sidebar-collapsed .app-shell{
  grid-template-columns: 84px minmax(0, 1fr);
}

.sidebar{
  position: relative;
  min-width: 0;
  height: 100vh;
  display: grid;
  grid-template-rows: auto auto minmax(0, 1fr);
  gap: 14px;
  padding: 18px 16px 16px;
  border-right: 1px solid var(--border);
  background:
    linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.94));
  backdrop-filter: blur(14px);
  overflow: hidden;
  transition: padding 220ms ease, width 220ms ease, transform 180ms ease;
}

.sidebar::after{
  content: "";
  position: absolute;
  inset: 0 0 auto 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.3), transparent);
  pointer-events: none;
}

body.sidebar-collapsed .sidebar{
  padding-left: 10px;
  padding-right: 10px;
}

.sidebar-top{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  min-width: 0;
}

.sidebar-brand{
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12px;
}

.sidebar-brand-mark{
  width: 42px;
  height: 42px;
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  border: 1px solid rgba(139, 92, 246, 0.28);
  border-radius: 14px;
  background: linear-gradient(180deg, rgba(124, 58, 237, 0.28), rgba(124, 58, 237, 0.12));
  color: #f5f3ff;
  box-shadow: var(--shadow-md);
  font-weight: 800;
  letter-spacing: 0.02em;
  transition: transform 160ms ease, box-shadow 180ms ease;
}

.sidebar-brand-copy{
  min-width: 0;
  display: grid;
  gap: 2px;
  transition: opacity 160ms ease, transform 160ms ease;
}

body.sidebar-collapsed .sidebar-brand-copy,
body.sidebar-collapsed .chat-list-header,
body.sidebar-collapsed .chat-list-item-title,
body.sidebar-collapsed .chat-list-item-meta,
body.sidebar-collapsed .new-chat-btn{
  opacity: 0;
  pointer-events: none;
  transform: translateX(-6px);
}

.sidebar-subtitle{
  color: var(--text-dim);
  font-size: 0.78rem;
  letter-spacing: 0.02em;
}

.sidebar-actions{
  display: grid;
  gap: 12px;
  transition: min-height 160ms ease;
}

body.sidebar-collapsed .sidebar-actions{
  min-height: 48px;
}

.chat-list-wrap{
  min-height: 0;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr);
  gap: 12px;
}

.chat-list-header{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 0 6px;
  transition: opacity 160ms ease, transform 160ms ease;
}

.chat-list-heading{
  color: #f8fafc;
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.01em;
}

.chat-list-count{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 28px;
  height: 24px;
  padding: 0 8px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-dim);
  font-size: 0.74rem;
  font-weight: 700;
}

body.sidebar-collapsed .chat-list-count{
  opacity: 0;
}

.chat-list{
  min-height: 0;
  overflow-y: auto;
  padding-right: 4px;
  display: grid;
  align-content: start;
  gap: 10px;
}

body.sidebar-collapsed .chat-list{
  padding-right: 0;
}

.mobile-overlay{
  position: fixed;
  inset: 0;
  background: rgba(2, 6, 23, 0.56);
  backdrop-filter: blur(4px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 180ms ease;
  z-index: 30;
}

.main{
  min-width: 0;
  height: 100vh;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  position: relative;
  overflow: hidden;
}

.main::before{
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top right, rgba(139, 92, 246, 0.08), transparent 28%),
    radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.05), transparent 24%);
  pointer-events: none;
}

.topbar{
  position: relative;
  z-index: 2;
  min-width: 0;
  height: var(--topbar-h);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 14px 24px 10px;
}

.topbar-left,
.topbar-right{
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12px;
}

.topbar-title-wrap{
  min-width: 0;
  display: grid;
  gap: 2px;
}

.topbar-title{
  min-width: 0;
  color: #f8fafc;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.topbar-subtitle{
  color: var(--text-dim);
  font-size: 0.8rem;
}

.topbar-actions{
  display: flex;
  align-items: center;
  gap: 10px;
}

.topbar-action,
.sidebar-toggle,
.mobile-sidebar-btn,
.new-chat-btn,
.composer-attach,
.composer-send,
.composer-stop{
  transition:
    transform 160ms ease,
    box-shadow 180ms ease,
    border-color 180ms ease,
    background 180ms ease,
    color 180ms ease,
    opacity 180ms ease;
}

.topbar-action:hover,
.sidebar-toggle:hover,
.mobile-sidebar-btn:hover,
.new-chat-btn:hover,
.composer-attach:hover,
.composer-send:hover,
.composer-stop:hover{
  transform: translateY(-1px);
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.22);
}

.topbar-action:active,
.sidebar-toggle:active,
.mobile-sidebar-btn:active,
.new-chat-btn:active,
.composer-attach:active,
.composer-send:active,
.composer-stop:active{
  transform: translateY(1px) scale(0.99);
}

.topbar-action{
  height: 40px;
  padding: 0 14px;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-soft);
}

.topbar-action:hover{
  background: rgba(255, 255, 255, 0.06);
  border-color: var(--border-strong);
  color: var(--text);
}

.chat-stage{
  position: relative;
  z-index: 1;
  min-height: 0;
  display: grid;
  grid-template-rows: minmax(0, 1fr);
  padding: 0 24px;
}

.messages-panel{
  min-width: 0;
  min-height: 0;
  height: 100%;
  display: grid;
  grid-template-rows: minmax(0, 1fr);
}

.messages-scroll{
  position: relative;
  min-height: 0;
  overflow-y: auto;
  overscroll-behavior: contain;
  scroll-behavior: smooth;
  padding: 8px 0 24px;
}

.messages{
  width: min(920px, 100%);
  min-height: 100%;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 22px;
  padding: 0 0 4px;
  position: relative;
  z-index: 5;
}

.messages-empty{
  width: min(760px, 100%);
  min-height: 100%;
  margin: 0 auto;
  display: grid;
  place-items: center;
  padding: 16px 0 24px;
}

.composer-shell{
  position: relative;
  z-index: 2;
  padding: 14px 24px 20px;
  background: linear-gradient(180deg, rgba(11, 16, 32, 0), rgba(11, 16, 32, 0.74) 22%, rgba(11, 16, 32, 0.96) 100%);
}

.composer-wrap{
  width: min(920px, 100%);
  margin: 0 auto;
}

.composer-form{
  display: grid;
  gap: 12px;
}

.composer{
  display: grid;
  gap: 12px;
  padding: 12px 14px 14px;
  border: 1px solid rgba(148, 163, 184, 0.14);
  border-radius: 22px;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.94), rgba(17, 24, 39, 0.90));
  box-shadow:
    0 20px 50px rgba(0, 0, 0, 0.32),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(18px);
}

.composer-main{
  min-width: 0;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto auto;
  align-items: end;
  gap: 10px;
}

.composer-input-wrap{
  min-width: 0;
  display: grid;
  align-items: end;
}

.composer-input{
  display: block;
}

.composer-footer{
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.composer-meta{
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text-dim);
  font-size: 0.8rem;
}

.composer-hint{
  color: var(--text-dim);
  font-size: 0.78rem;
}

.pending-attachments{
  min-width: 0;
}

.pending-attachments-list{
  min-width: 0;
}

.empty-state-shell{
  width: min(920px, 100%);
  min-height: 100%;
  margin: 0 auto;
  position: absolute;
  inset: 8px 0 24px 0;
  z-index: 1;
  pointer-events: none;
}

.empty-state-shell[hidden],
.empty-state[hidden],
.messages-empty[hidden],
.settings-modal[hidden]{
  display: none !important;
}

.messages[hidden]{
  display: none !important;
}

.message-row{
  display: flex;
  width: 100%;
  visibility: visible;
  opacity: 1;
  animation: novaMessageIn 180ms ease;
}

.message-card{
  display: block;
  visibility: visible;
  opacity: 1;
}

.settings-modal{
  position: fixed;
  inset: 0;
  z-index: 90;
}

.settings-backdrop{
  position: absolute;
  inset: 0;
  background: rgba(2, 6, 23, 0.62);
  backdrop-filter: blur(8px);
}

.settings-dialog{
  position: absolute;
  top: 50%;
  left: 50%;
  width: min(440px, calc(100vw - 24px));
  transform: translate(-50%, -50%);
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 18px;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(17, 24, 39, 0.96));
  box-shadow: 0 30px 80px rgba(0, 0, 0, 0.42);
}

.settings-dialog-head{
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 16px;
}

.settings-dialog-title{
  color: #f8fafc;
  font-size: 1rem;
  font-weight: 700;
}

.settings-dialog-subtitle{
  color: var(--text-dim);
  font-size: 0.82rem;
  margin-top: 4px;
}

.settings-close,
.settings-option{
  border: 1px solid var(--border);
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.04);
  color: var(--text);
  transition:
    transform 160ms ease,
    background 180ms ease,
    border-color 180ms ease;
}

.settings-close{
  width: 40px;
  height: 40px;
}

.settings-option{
  width: 100%;
  min-height: 48px;
  padding: 0 14px;
  text-align: left;
}

.settings-close:hover,
.settings-option:hover{
  transform: translateY(-1px);
  background: rgba(255, 255, 255, 0.07);
  border-color: var(--border-strong);
}

.settings-dialog-body{
  display: grid;
  gap: 10px;
}

@keyframes novaMessageIn{
  from{
    opacity: 0;
    transform: translateY(8px);
  }
  to{
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 1199px){
  :root{
    --sidebar-w: 280px;
  }

  .topbar,
  .chat-stage,
  .composer-shell{
    padding-left: 20px;
    padding-right: 20px;
  }

  .messages,
  .composer-wrap,
  .empty-state-shell{
    width: min(860px, 100%);
  }
}

@media (max-width: 959px){
  .app-shell{
    grid-template-columns: minmax(0, 1fr);
  }

  body.sidebar-collapsed .app-shell{
    grid-template-columns: minmax(0, 1fr);
  }

  .sidebar{
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(86vw, 320px);
    max-width: 320px;
    transform: translateX(-100%);
    transition: transform 180ms ease;
    z-index: 40;
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.42);
  }

  body.sidebar-open .sidebar{
    transform: translateX(0);
  }

  body.sidebar-open .mobile-overlay{
    opacity: 1;
    pointer-events: auto;
  }

  .main{
    height: 100dvh;
  }

  .topbar{
    height: auto;
    min-height: var(--topbar-h);
    padding: 12px 16px 8px;
  }

  .topbar-title{
    font-size: 0.96rem;
  }

  .topbar-subtitle{
    display: none;
  }

  .topbar-actions{
    gap: 8px;
  }

  .topbar-action{
    height: 38px;
    padding: 0 12px;
  }

  .chat-stage{
    padding: 0 16px;
  }

  .messages-scroll{
    padding: 6px 0 18px;
  }

  .messages{
    gap: 18px;
  }

  .composer-shell{
    padding: 12px 16px max(16px, env(safe-area-inset-bottom));
  }

  .composer{
    padding: 10px 12px 12px;
    border-radius: 18px;
  }

  .composer-main{
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 8px;
  }

  .composer-stop{
    grid-column: 1 / -1;
  }

  .composer-footer{
    flex-direction: column;
    align-items: flex-start;
  }

  .composer-hint{
    display: none;
  }
}

@media (max-width: 639px){
  :root{
    --topbar-h: 60px;
  }

  .sidebar{
    width: min(90vw, 320px);
    padding: 16px 14px 14px;
  }

  .topbar{
    padding: 10px 12px 6px;
  }

  .chat-stage{
    padding: 0 12px;
  }

  .messages{
    gap: 16px;
  }

  .composer-shell{
    padding: 10px 12px max(12px, env(safe-area-inset-bottom));
  }

  .composer-main{
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  .composer-attach,
  .composer-send,
  .composer-stop{
    width: 100%;
    justify-content: center;
  }

  .composer-input{
    min-height: 52px;
    padding-top: 14px;
    padding-bottom: 14px;
  }

  .empty-state-card{
    padding: 24px 18px;
    border-radius: 18px;
  }
}