document.addEventListener("DOMContentLoaded", () => {
  const chatMessages = document.getElementById("chatMessages")
  const chatInput = document.getElementById("chatInput")
  const sendBtn = document.getElementById("sendBtn")
  const sendBtnText = document.getElementById("sendBtnText")
  const stopBtn = document.getElementById("stopBtn")
  const newChatBtn = document.getElementById("newChatBtn")
  const chatList = document.getElementById("chatList")
  const attachBtn = document.getElementById("btnAttach")
  const fileInput = document.getElementById("fileUpload")
  const emptyState = document.getElementById("emptyState")
  const sidebar = document.getElementById("sidebar")
  const sidebarToggle = document.getElementById("sidebarToggle")
  const mobileOverlay = document.getElementById("mobileOverlay")
  const clearComposerBtn = document.getElementById("clearComposerBtn")
  const regenBtn = document.getElementById("regenBtn")
  const renameChatBtn = document.getElementById("renameChatBtn")
  const deleteChatBtn = document.getElementById("deleteChatBtn")
  const chatTitleTop = document.getElementById("chatTitleTop")
  const attachmentPreview = document.getElementById("attachmentPreview")

  let currentChatId = null
  let isSending = false
  let lastUserMessage = ""
  let pendingFiles = []
  let activeAbortController = null

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;")
  }

  function setTopTitle(text) {
    if (chatTitleTop) {
      chatTitleTop.textContent = text || "Ready"
    }
  }

  function setEmptyState() {
    if (!emptyState || !chatMessages) return
    const hasMessages = chatMessages.querySelector(".message")
    emptyState.style.display = hasMessages ? "none" : ""
  }

  function scrollToBottom() {
    if (!chatMessages) return
    chatMessages.scrollTop = chatMessages.scrollHeight
  }

  function setSendingState(sending) {
    isSending = sending

    if (sendBtn) sendBtn.disabled = sending
    if (attachBtn) attachBtn.disabled = sending
    if (chatInput) chatInput.disabled = sending

    if (sendBtnText) {
      sendBtnText.textContent = sending ? "Sending..." : "Send"
    } else if (sendBtn) {
      sendBtn.textContent = sending ? "Sending..." : "Send"
    }

    if (stopBtn) {
      stopBtn.hidden = !sending
      stopBtn.disabled = !sending
    }
  }

  function getChatIdFromUrl() {
    const url = new URL(window.location.href)
    return url.searchParams.get("chat_id") || null
  }

  function setChatIdInUrl(chatId) {
    const url = new URL(window.location.href)

    if (chatId) {
      url.searchParams.set("chat_id", chatId)
    } else {
      url.searchParams.delete("chat_id")
    }

    window.history.replaceState({}, "", url.toString())
  }

  function closeSidebar() {
    if (sidebar) sidebar.classList.remove("open")
    if (mobileOverlay) mobileOverlay.classList.remove("show")
  }

  function openSidebar() {
    if (sidebar) sidebar.classList.add("open")
    if (mobileOverlay) mobileOverlay.classList.add("show")
  }

  function createMessageShell(role) {
    if (!chatMessages) return null

    const el = document.createElement("div")
    el.className = `message ${role}`

    el.innerHTML = `
      <div class="message-inner">
        <div class="message-text"></div>
        <div class="message-attachments"></div>
      </div>
    `

    chatMessages.appendChild(el)
    setEmptyState()
    scrollToBottom()
    return el
  }

  function renderUserMessage(text, attachments = []) {
    const el = createMessageShell("user")
    if (!el) return null

    const textEl = el.querySelector(".message-text")
    if (textEl) {
      textEl.innerHTML = escapeHtml(text || "").replace(/\n/g, "<br>")
    }

    renderMessageAttachments(el, attachments)
    scrollToBottom()
    return el
  }

  function renderAssistantMessage(text, attachments = []) {
    const el = createMessageShell("assistant")
    if (!el) return null

    renderAssistantText(el, text || "")
    renderMessageAttachments(el, attachments)
    scrollToBottom()
    return el
  }

  function renderAssistantText(messageEl, text) {
    if (!messageEl) return

    const textEl = messageEl.querySelector(".message-text")
    if (!textEl) return

    if (window.marked) {
      try {
        textEl.innerHTML = marked.parse(text || "")
      } catch (_) {
        textEl.innerHTML = escapeHtml(text || "").replace(/\n/g, "<br>")
      }
    } else {
      textEl.innerHTML = escapeHtml(text || "").replace(/\n/g, "<br>")
    }

    if (window.hljs) {
      textEl.querySelectorAll("pre code").forEach((block) => {
        try {
          window.hljs.highlightElement(block)
        } catch (_) {}
      })
    }

    scrollToBottom()
  }

  function renderError(text) {
    if (!chatMessages) return

    const el = document.createElement("div")
    el.className = "message error"
    el.innerHTML = `
      <div class="message-inner">
        <div class="message-text">${escapeHtml(text)}</div>
      </div>
    `
    chatMessages.appendChild(el)
    setEmptyState()
    scrollToBottom()
  }

  function formatBytes(bytes) {
    const n = Number(bytes || 0)
    if (!n) return "0 B"
    const units = ["B", "KB", "MB", "GB"]
    let value = n
    let unitIndex = 0
    while (value >= 1024 && unitIndex < units.length - 1) {
      value /= 1024
      unitIndex += 1
    }
    return `${value.toFixed(value >= 10 || unitIndex === 0 ? 0 : 1)} ${units[unitIndex]}`
  }

  function clearPendingFiles() {
    pendingFiles = []
    if (fileInput) fileInput.value = ""
    renderPendingAttachments()
  }

  function renderPendingAttachments() {
    if (!attachmentPreview) return

    if (!pendingFiles.length) {
      attachmentPreview.innerHTML = ""
      attachmentPreview.style.display = "none"
      return
    }

    attachmentPreview.style.display = ""
    attachmentPreview.innerHTML = pendingFiles
      .map((file, index) => {
        return `
          <div class="attachment-chip" data-index="${index}">
            <div class="attachment-chip-main">
              <div class="attachment-chip-name">${escapeHtml(file.name)}</div>
              <div class="attachment-chip-meta">${escapeHtml(formatBytes(file.size))}</div>
            </div>
            <button class="attachment-chip-remove" type="button" data-index="${index}" aria-label="Remove attachment">×</button>
          </div>
        `
      })
      .join("")

    attachmentPreview.querySelectorAll(".attachment-chip-remove").forEach((btn) => {
      btn.addEventListener("click", () => {
        const index = Number(btn.getAttribute("data-index"))
        pendingFiles.splice(index, 1)
        renderPendingAttachments()
      })
    })
  }

  function renderMessageAttachments(messageEl, attachments = []) {
    if (!messageEl) return

    const wrap = messageEl.querySelector(".message-attachments")
    if (!wrap) return

    const valid = Array.isArray(attachments) ? attachments.filter(Boolean) : []
    if (!valid.length) {
      wrap.innerHTML = ""
      return
    }

    wrap.innerHTML = valid
      .map((file) => {
        if (file.error) {
          return `
            <div class="message-attachment error">
              <div class="message-attachment-name">${escapeHtml(file.original_name || "Attachment")}</div>
              <div class="message-attachment-meta">${escapeHtml(file.error)}</div>
            </div>
          `
        }

        const name = escapeHtml(file.original_name || "Attachment")
        const meta = escapeHtml(`${file.mime_type || "file"} · ${formatBytes(file.size_bytes)}`)
        const url = escapeHtml(file.url || "#")

        if (file.is_image && file.url) {
          return `
            <a class="message-attachment image" href="${url}" target="_blank" rel="noreferrer">
              <img src="${url}" alt="${name}" loading="lazy" />
              <div class="message-attachment-name">${name}</div>
              <div class="message-attachment-meta">${meta}</div>
            </a>
          `
        }

        return `
          <a class="message-attachment" href="${url}" target="_blank" rel="noreferrer">
            <div class="message-attachment-name">${name}</div>
            <div class="message-attachment-meta">${meta}</div>
          </a>
        `
      })
      .join("")
  }

  async function loadChats() {
    if (!chatList) return

    try {
      const res = await fetch("/api/chats", { cache: "no-store" })
      if (!res.ok) throw new Error(`HTTP ${res.status}`)

      const data = await res.json()
      const chats = Array.isArray(data.chats) ? data.chats : []

      chatList.innerHTML = ""

      if (!chats.length) {
        chatList.innerHTML = `<div class="chat-list-empty">No chats yet</div>`
        return
      }

      chats.forEach((chat) => {
        const btn = document.createElement("button")
        btn.type = "button"
        btn.className = "chat-item"
        btn.innerHTML = `
          <div class="chat-item-title">${escapeHtml(chat.title || "New chat")}</div>
          <div class="chat-item-meta">${escapeHtml(chat.updated || "")}</div>
        `

        if (chat.chat_id === currentChatId) {
          btn.classList.add("active")
        }

        btn.addEventListener("click", async () => {
          currentChatId = chat.chat_id
          setChatIdInUrl(currentChatId)
          await loadChats()
          await loadMessages(currentChatId)
          closeSidebar()
        })

        chatList.appendChild(btn)
      })
    } catch (_) {
      chatList.innerHTML = `<div class="chat-list-empty">Failed to load chats</div>`
    }
  }

  async function loadMessages(chatId) {
    if (!chatMessages) return

    chatMessages.innerHTML = ""

    if (!chatId) {
      setTopTitle("Ready")
      setEmptyState()
      return
    }

    try {
      const res = await fetch(`/api/chats/${encodeURIComponent(chatId)}`, {
        cache: "no-store"
      })

      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`)
      }

      const data = await res.json()
      const title = data.title || data.chat_title || "Chat"

      setTopTitle(title)

      const messages = Array.isArray(data.messages) ? data.messages : []

      messages.forEach((msg) => {
        const role = msg.role === "assistant" ? "assistant" : "user"
        const text = msg.content || msg.message || ""
        const attachments = Array.isArray(msg.attachments) ? msg.attachments : []

        if (role === "assistant") {
          renderAssistantMessage(text, attachments)
        } else {
          renderUserMessage(text, attachments)
        }
      })

      setEmptyState()
      scrollToBottom()
    } catch (err) {
      renderError(`Failed to load messages: ${err.message}`)
    }
  }

  async function createNewChat() {
    currentChatId = null
    setChatIdInUrl(null)

    if (chatMessages) {
      chatMessages.innerHTML = ""
    }

    clearPendingFiles()
    setTopTitle("Ready")
    setEmptyState()
    await loadChats()

    if (chatInput) {
      chatInput.value = ""
      chatInput.focus()
    }
  }

  async function readSseResponse(res, onEvent) {
    if (!res.body) {
      throw new Error("Streaming response body missing")
    }

    const reader = res.body.getReader()
    const decoder = new TextDecoder()
    let buffer = ""

    while (true) {
      const { value, done } = await reader.read()
      if (done) break

      buffer += decoder.decode(value, { stream: true })

      let boundaryIndex
      while ((boundaryIndex = buffer.indexOf("\n\n")) !== -1) {
        const rawEvent = buffer.slice(0, boundaryIndex)
        buffer = buffer.slice(boundaryIndex + 2)

        const lines = rawEvent.split(/\r?\n/)
        let eventName = "message"
        const dataLines = []

        for (const line of lines) {
          if (line.startsWith("event:")) {
            eventName = line.slice(6).trim()
          } else if (line.startsWith("data:")) {
            dataLines.push(line.slice(5).trim())
          }
        }

        const dataText = dataLines.join("\n")
        let payload = dataText

        try {
          payload = JSON.parse(dataText)
        } catch (_) {}

        onEvent(eventName, payload)
      }
    }
  }

  async function sendMessage() {
    if (isSending) return
    if (!chatInput) return

    const message = chatInput.value.trim()
    const hasFiles = pendingFiles.length > 0

    if (!message && !hasFiles) return

    renderUserMessage(message, pendingFiles.map((file) => ({
      original_name: file.name,
      mime_type: file.type || "application/octet-stream",
      size_bytes: file.size || 0,
      is_image: (file.type || "").startsWith("image/"),
      url: hasFiles && (file.type || "").startsWith("image/") ? URL.createObjectURL(file) : ""
    })))

    lastUserMessage = message
    chatInput.value = ""

    const filesToSend = [...pendingFiles]
    clearPendingFiles()

    setSendingState(true)

    const assistantEl = renderAssistantMessage("")
    let assistantBuffer = ""

    try {
      activeAbortController = new AbortController()

      const formData = new FormData()
      formData.append("chat_id", currentChatId || "")
      formData.append("message", message)

      filesToSend.forEach((file) => {
        formData.append("files", file)
      })

      const res = await fetch("/api/chat/stream", {
        method: "POST",
        body: formData,
        signal: activeAbortController.signal
      })

      if (!res.ok) {
        let errText = `HTTP ${res.status}`
        try {
          const errJson = await res.json()
          errText = errJson.error || errText
        } catch (_) {}
        throw new Error(errText)
      }

      await readSseResponse(res, async (eventName, payload) => {
        if (eventName === "meta") {
          if (payload && payload.chat_id) {
            currentChatId = payload.chat_id
            setChatIdInUrl(currentChatId)
          }

          if (assistantEl && payload && Array.isArray(payload.attachments)) {
            const userEls = chatMessages ? chatMessages.querySelectorAll(".message.user") : []
            const lastUserEl = userEls.length ? userEls[userEls.length - 1] : null
            if (lastUserEl) {
              renderMessageAttachments(lastUserEl, payload.attachments)
            }
          }

          await loadChats()
          return
        }

        if (eventName === "token") {
          const token = payload && typeof payload.t === "string" ? payload.t : ""
          assistantBuffer += token
          if (assistantEl) {
            renderAssistantText(assistantEl, assistantBuffer)
          }
          return
        }

        if (eventName === "done") {
          const finalText =
            (payload && typeof payload.full_text === "string" && payload.full_text) ||
            assistantBuffer

          if (assistantEl) {
            renderAssistantText(assistantEl, finalText)
            renderMessageAttachments(assistantEl, Array.isArray(payload?.attachments) ? payload.attachments : [])
          }

          await loadChats()
        }
      })
    } catch (err) {
      if (assistantEl) {
        assistantEl.remove()
      }

      if (err.name === "AbortError") {
        renderError("Stopped.")
      } else {
        renderError(`Network error: ${err.message}`)
      }
    } finally {
      activeAbortController = null
      setSendingState(false)
      setEmptyState()
      scrollToBottom()
    }
  }

  async function regenerateLast() {
    if (isSending) return
    if (!lastUserMessage) return

    if (chatInput) {
      chatInput.value = lastUserMessage
    }

    await sendMessage()
  }

  async function renameCurrentChat() {
    if (!currentChatId) return

    const nextTitle = window.prompt("Rename chat")
    if (!nextTitle || !nextTitle.trim()) return

    try {
      const res = await fetch(`/api/chats/${encodeURIComponent(currentChatId)}/rename`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          title: nextTitle.trim()
        })
      })

      if (!res.ok) {
        let errText = `HTTP ${res.status}`
        try {
          const errJson = await res.json()
          errText = errJson.error || errText
        } catch (_) {}
        throw new Error(errText)
      }

      setTopTitle(nextTitle.trim())
      await loadChats()
    } catch (err) {
      renderError(`Rename failed: ${err.message}`)
    }
  }

  async function deleteCurrentChat() {
    if (!currentChatId) return

    const ok = window.confirm("Delete this chat?")
    if (!ok) return

    try {
      const res = await fetch(`/api/chats/${encodeURIComponent(currentChatId)}`, {
        method: "DELETE"
      })

      if (!res.ok) {
        let errText = `HTTP ${res.status}`
        try {
          const errJson = await res.json()
          errText = errJson.error || errText
        } catch (_) {}
        throw new Error(errText)
      }

      await createNewChat()
    } catch (err) {
      renderError(`Delete failed: ${err.message}`)
    }
  }

  if (sendBtn) {
    sendBtn.addEventListener("click", sendMessage)
  }

  if (chatInput) {
    chatInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault()
        sendMessage()
      }
    })
  }

  if (newChatBtn) {
    newChatBtn.addEventListener("click", async () => {
      await createNewChat()
      closeSidebar()
    })
  }

  if (attachBtn) {
    attachBtn.addEventListener("click", () => {
      if (fileInput) fileInput.click()
    })
  }

  if (fileInput) {
    fileInput.addEventListener("change", () => {
      const incoming = Array.from(fileInput.files || [])
      if (!incoming.length) return

      pendingFiles = [...pendingFiles, ...incoming]
      renderPendingAttachments()

      if (chatInput) {
        chatInput.focus()
      }
    })
  }

  if (sidebarToggle) {
    sidebarToggle.addEventListener("click", () => {
      const isOpen = sidebar && sidebar.classList.contains("open")
      if (isOpen) closeSidebar()
      else openSidebar()
    })
  }

  if (mobileOverlay) {
    mobileOverlay.addEventListener("click", closeSidebar)
  }

  if (clearComposerBtn) {
    clearComposerBtn.addEventListener("click", () => {
      if (chatInput) chatInput.value = ""
      clearPendingFiles()
    })
  }

  if (regenBtn) {
    regenBtn.addEventListener("click", regenerateLast)
  }

  if (renameChatBtn) {
    renameChatBtn.addEventListener("click", renameCurrentChat)
  }

  if (deleteChatBtn) {
    deleteChatBtn.addEventListener("click", deleteCurrentChat)
  }

  if (stopBtn) {
    stopBtn.hidden = true
    stopBtn.disabled = true
    stopBtn.addEventListener("click", () => {
      if (activeAbortController) {
        activeAbortController.abort()
      }
    })
  }

  currentChatId = getChatIdFromUrl()

  loadChats().then(async () => {
    if (currentChatId) {
      await loadMessages(currentChatId)
    } else {
      setTopTitle("Ready")
      setEmptyState()
    }
  })
})