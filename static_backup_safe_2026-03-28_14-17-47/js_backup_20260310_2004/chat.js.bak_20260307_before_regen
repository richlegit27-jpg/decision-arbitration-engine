(() => {
"use strict"

const el = {
  sidebar: document.getElementById("sidebar"),
  mobileOverlay: document.getElementById("mobileOverlay"),
  btnSidebarToggle: document.getElementById("btnSidebarToggle"),
  btnNewChat: document.getElementById("btnNewChat"),
  chatList: document.getElementById("chatList"),
  messages: document.getElementById("messages"),
  composerForm: document.getElementById("composerForm"),
  input: document.getElementById("promptInput"),
  sendBtn: document.getElementById("btnSend"),
  stopBtn: document.getElementById("btnStop"),
  attachBtn: document.getElementById("btnAttach"),
  fileInput: document.getElementById("fileUpload"),
  pendingAttachments: document.getElementById("pendingAttachments"),
}

const utils = window.NovaUtils || {}
const stateApi = window.NovaState || {}
const attachmentsApi = window.NovaAttachmentsService || {}
const renderApi = window.NovaRenderService || {}
const streamApi = window.NovaStreamService || {}
const chatApi = window.NovaChatService || {}
const composerApi = window.NovaComposerService || {}

function requireFactory(apiObj, factoryName){
  if(!apiObj || typeof apiObj[factoryName] !== "function"){
    throw new Error(`Missing required factory: ${factoryName}`)
  }

  return apiObj[factoryName]
}

const createState = requireFactory(stateApi, "createState")
const createAttachmentsService = requireFactory(attachmentsApi, "createAttachmentsService")
const createRenderService = requireFactory(renderApi, "createRenderService")
const createStreamService = requireFactory(streamApi, "createStreamService")
const createChatService = requireFactory(chatApi, "createChatService")
const createComposerService = requireFactory(composerApi, "createComposerService")

const state = createState()

const renderService = createRenderService({
  state,
  elements: {
    messages: el.messages,
    chatList: el.chatList,
    pendingAttachments: el.pendingAttachments,
  },
  utils,
})

const attachmentsService = createAttachmentsService({
  state,
  elements: {
    fileInput: el.fileInput,
    pendingAttachments: el.pendingAttachments,
  },
  utils,
  renderService,
})

const chatService = createChatService({
  state,
  elements: {
    chatList: el.chatList,
    messages: el.messages,
  },
  utils,
  renderService,
})

const streamService = createStreamService({
  state,
  elements: {
    messages: el.messages,
  },
  utils,
  renderService,
  chatService,
  attachmentsService,
})

const composerService = createComposerService({
  state,
  elements: {
    input: el.input,
    sendBtn: el.sendBtn,
    attachBtn: el.attachBtn,
    fileInput: el.fileInput,
    stopBtn: el.stopBtn,
    composerForm: el.composerForm,
  },
  attachmentsService,
  streamService,
  renderService,
  chatService,
})

function closeMobileSidebar(){
  el.sidebar?.classList.remove("open")
  el.mobileOverlay?.classList.remove("show")
  document.body.classList.remove("sidebar-open")
}

function openMobileSidebar(){
  el.sidebar?.classList.add("open")
  el.mobileOverlay?.classList.add("show")
  document.body.classList.add("sidebar-open")
}

function toggleMobileSidebar(){
  const isOpen = el.sidebar?.classList.contains("open")

  if(isOpen){
    closeMobileSidebar()
    return
  }

  openMobileSidebar()
}

async function requestJson(url, options = {}){
  const response = await fetch(url, options)

  if(!response.ok){
    throw new Error(`HTTP ${response.status}`)
  }

  const text = await response.text()
  return text ? JSON.parse(text) : {}
}

function getMessageById(messageId){
  return (state.messages || []).find((msg) => String(msg.id) === String(messageId)) || null
}

function getLastUserMessage(){
  const messages = Array.isArray(state.messages) ? state.messages : []

  for(let i = messages.length - 1; i >= 0; i -= 1){
    if(messages[i]?.role === "user"){
      return messages[i]
    }
  }

  return null
}

function fallbackCopyText(text){
  const textarea = document.createElement("textarea")
  textarea.value = String(text || "")
  textarea.setAttribute("readonly", "")
  textarea.style.position = "fixed"
  textarea.style.top = "-9999px"
  textarea.style.left = "-9999px"
  textarea.style.opacity = "0"

  document.body.appendChild(textarea)
  textarea.focus()
  textarea.select()
  textarea.setSelectionRange(0, textarea.value.length)

  let ok = false

  try {
    ok = document.execCommand("copy")
  } catch(error){
    console.error("Nova fallbackCopyText error:", error)
    ok = false
  } finally {
    document.body.removeChild(textarea)
  }

  return ok
}

async function loadChats(){
  try {
    if(typeof chatService.loadChats === "function"){
      await chatService.loadChats()
    }

    renderService.renderChats?.()
  } catch(error){
    console.error("Nova loadChats error:", error)
  }
}

async function loadMessages(chatId){
  try {
    if(typeof chatService.loadMessages === "function"){
      await chatService.loadMessages(chatId)
    }

    renderService.renderMessages?.()
  } catch(error){
    console.error("Nova loadMessages error:", error)
  }
}

async function startNewChat(){
  try {
    attachmentsService.clearPendingFiles?.()
    composerService.clearInput?.()

    if(typeof chatService.createChat !== "function"){
      throw new Error("NovaChatService.createChat is missing")
    }

    const created = await chatService.createChat("New Chat")
    const chatId = String(
      created?.chat_id ||
      created?.chat?.chat_id ||
      state.activeChatId ||
      ""
    ).trim()

    if(chatId && typeof chatService.loadMessages === "function"){
      await chatService.loadMessages(chatId)
    }

    renderService.renderAll?.()
    composerService.updateComposerState?.()
    composerService.focusInput?.()
    closeMobileSidebar()
  } catch(error){
    console.error("Nova startNewChat error:", error)
  }
}

async function renameChat(chatId){
  const resolvedChatId = String(chatId || "").trim()

  if(!resolvedChatId){
    return
  }

  const current = (state.chats || []).find((chat) => String(chat.chat_id) === resolvedChatId)
  const currentTitle = current?.title || "New Chat"
  const nextTitle = window.prompt("Rename chat", currentTitle)

  if(nextTitle === null){
    return
  }

  const cleanTitle = String(nextTitle).trim()

  if(!cleanTitle){
    return
  }

  try {
    await requestJson(`/api/chats/${encodeURIComponent(resolvedChatId)}/rename`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ title: cleanTitle }),
    })

    const target = (state.chats || []).find((chat) => String(chat.chat_id) === resolvedChatId)

    if(target){
      target.title = cleanTitle
    }

    renderService.renderChats?.()
  } catch(error){
    console.error("Nova renameChat error:", error)
    alert(`Rename failed: ${error.message || error}`)
  }
}

async function deleteChat(chatId){
  const resolvedChatId = String(chatId || "").trim()

  if(!resolvedChatId){
    return
  }

  const ok = window.confirm("Delete this chat?")
  if(!ok){
    return
  }

  try {
    await requestJson(`/api/chats/${encodeURIComponent(resolvedChatId)}`, {
      method: "DELETE",
    })

    state.chats = (state.chats || []).filter((chat) => String(chat.chat_id) !== resolvedChatId)

    if(String(state.activeChatId || "") === resolvedChatId){
      state.activeChatId = ""
      state.chatId = ""
      state.messages = []

      if(state.chats.length > 0){
        state.activeChatId = state.chats[0].chat_id
        state.chatId = state.chats[0].chat_id
        await loadMessages(state.chats[0].chat_id)
      } else {
        renderService.renderMessages?.()
      }
    }

    renderService.renderChats?.()
    composerService.updateComposerState?.()
  } catch(error){
    console.error("Nova deleteChat error:", error)
    alert(`Delete failed: ${error.message || error}`)
  }
}

async function copyMessage(messageId){
  const msg = getMessageById(messageId)
  const text = String(msg?.content || "")

  if(!text){
    return
  }

  try {
    if(navigator.clipboard && window.isSecureContext){
      await navigator.clipboard.writeText(text)
      return
    }

    const ok = fallbackCopyText(text)

    if(!ok){
      throw new Error("Fallback copy failed")
    }
  } catch(error){
    console.error("Nova copyMessage error:", error)

    const ok = fallbackCopyText(text)

    if(!ok){
      alert("Copy failed.")
    }
  }
}

function editMessage(messageId){
  const msg = getMessageById(messageId)

  if(!msg || msg.role !== "user"){
    return
  }

  composerService.setInputValue?.(msg.content || "")
  composerService.focusInput?.()
}

async function regenerateFromMessage(messageId){
  const msg = getMessageById(messageId)

  let seedUserMessage = null

  if(msg?.role === "assistant"){
    const messages = Array.isArray(state.messages) ? state.messages : []
    const assistantIndex = messages.findIndex((item) => String(item.id) === String(messageId))

    for(let i = assistantIndex - 1; i >= 0; i -= 1){
      if(messages[i]?.role === "user"){
        seedUserMessage = messages[i]
        break
      }
    }
  }

  if(!seedUserMessage){
    seedUserMessage = getLastUserMessage()
  }

  const text = String(seedUserMessage?.content || "").trim()

  if(!text){
    return
  }

  try {
    composerService.setInputValue?.(text)
    await composerService.sendCurrentMessage?.()
  } catch(error){
    console.error("Nova regenerateFromMessage error:", error)
  }
}

function bindSidebarEvents(){
  el.btnSidebarToggle?.addEventListener("click", (event) => {
    event.preventDefault()
    toggleMobileSidebar()
  })

  el.mobileOverlay?.addEventListener("click", () => {
    closeMobileSidebar()
  })

  el.btnNewChat?.addEventListener("click", (event) => {
    event.preventDefault()
    void startNewChat()
  })

  el.chatList?.addEventListener("click", async (event) => {
    const actionBtn = event.target.closest("[data-chat-action]")

    if(actionBtn){
      event.preventDefault()
      event.stopPropagation()

      const action = String(actionBtn.dataset.chatAction || "").trim()
      const chatId = String(actionBtn.dataset.chatId || "").trim()

      if(action === "rename"){
        await renameChat(chatId)
        return
      }

      if(action === "delete"){
        await deleteChat(chatId)
        return
      }
    }

    const item = event.target.closest("[data-chat-id]")

    if(!item){
      return
    }

    const chatId = String(item.dataset.chatId || "").trim()

    if(!chatId){
      return
    }

    if(state.activeChatId === chatId){
      closeMobileSidebar()
      return
    }

    try {
      state.activeChatId = chatId
      state.chatId = chatId

      attachmentsService.clearPendingFiles?.()
      composerService.clearInput?.()

      await loadMessages(chatId)
      renderService.renderChats?.()
      composerService.updateComposerState?.()
      composerService.focusInput?.()
      closeMobileSidebar()
    } catch(error){
      console.error("Nova chat switch error:", error)
    }
  })
}

function bindMessageEvents(){
  el.messages?.addEventListener("click", async (event) => {
    const actionBtn = event.target.closest("[data-message-action]")

    if(!actionBtn){
      return
    }

    event.preventDefault()
    event.stopPropagation()

    const action = String(actionBtn.dataset.messageAction || "").trim()
    const messageId = String(actionBtn.dataset.messageId || "").trim()

    if(action === "copy"){
      await copyMessage(messageId)
      return
    }

    if(action === "edit"){
      editMessage(messageId)
      return
    }

    if(action === "regenerate"){
      await regenerateFromMessage(messageId)
    }
  })
}

function bindWindowEvents(){
  window.addEventListener("resize", () => {
    if(window.innerWidth > 900){
      closeMobileSidebar()
    }
  })
}

async function init(){
  bindSidebarEvents()
  bindMessageEvents()
  bindWindowEvents()

  attachmentsService.init?.()
  composerService.init?.()

  await loadChats()

  const firstChatId = String(state.activeChatId || state.chatId || "").trim()

  if(firstChatId){
    await loadMessages(firstChatId)
  }

  renderService.renderAll?.()
  composerService.updateComposerState?.()
  composerService.focusInput?.()
}

void init()

window.NovaApp = {
  state,
  el,
  loadChats,
  loadMessages,
  startNewChat,
  renameChat,
  deleteChat,
  copyMessage,
  editMessage,
  regenerateFromMessage,
  closeMobileSidebar,
  openMobileSidebar,
  toggleMobileSidebar,
  services: {
    attachmentsService,
    renderService,
    streamService,
    chatService,
    composerService,
  },
}

})()