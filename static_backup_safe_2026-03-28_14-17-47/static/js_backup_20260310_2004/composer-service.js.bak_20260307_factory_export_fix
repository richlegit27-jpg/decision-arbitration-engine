(() => {
"use strict"

function createComposerService(options = {}){

  const {
    state,
    elements = {},
    attachmentsService,
    streamService,
    renderService,
    chatService
  } = options

  if(!state){
    throw new Error("NovaComposerService: state is required")
  }

  if(!streamService){
    throw new Error("NovaComposerService: streamService is required")
  }

  const el = {
    input: elements.input || null,
    sendBtn: elements.sendBtn || null,
    attachBtn: elements.attachBtn || null,
    fileInput: elements.fileInput || null,
    stopBtn: elements.stopBtn || null,
    composerForm: elements.composerForm || null
  }

  function uid(prefix = "msg"){
    if(window.crypto?.randomUUID){
      return `${prefix}-${window.crypto.randomUUID()}`
    }
    return `${prefix}-${Date.now()}-${Math.random().toString(16).slice(2)}`
  }

  function updateControls(){

    const text = String(el.input?.value || "").trim()
    const hasFiles = Array.isArray(state.pendingAttachments) && state.pendingAttachments.length > 0

    const sendable = (!!text || hasFiles) && !state.isStreaming

    if(el.sendBtn){
      el.sendBtn.disabled = !sendable
    }

    if(el.stopBtn){
      el.stopBtn.hidden = !state.isStreaming
      el.stopBtn.disabled = !state.isStreaming
    }
  }

  function autoResize(){

    if(!el.input){
      return
    }

    el.input.style.height = "auto"
    el.input.style.height = `${Math.min(el.input.scrollHeight, 220)}px`
  }

  function clearInput(){

    if(!el.input){
      return
    }

    el.input.value = ""
    el.input.style.height = ""
  }

  function addUserMessage(text, attachments = []){

    const message = {
      message_id: uid(),
      role: "user",
      content: text,
      created_at: new Date().toISOString(),
      attachments
    }

    state.messages.push(message)

    renderService?.appendMessage?.(message)
    renderService?.scrollToBottom?.()

    return message
  }

  function addThinkingMessage(){

    const message = {
      message_id: uid(),
      role: "assistant",
      content: "",
      created_at: new Date().toISOString(),
      streaming: false,
      thinking: true,
      error: "",
      attachments: []
    }

    state.messages.push(message)

    renderService?.appendMessage?.(message)
    renderService?.scrollToBottom?.()

    return message
  }

  async function handleSubmit(event){

    event?.preventDefault?.()

    if(state.isStreaming){
      return
    }

    const text = String(el.input?.value || "").trim()
    const attachments = Array.isArray(state.pendingAttachments)
      ? [...state.pendingAttachments]
      : []

    if(!text && attachments.length === 0){
      return
    }

    const userMsg = addUserMessage(text, attachments)

    clearInput()

    if(attachmentsService?.clearPending){
      attachmentsService.clearPending()
    }else{
      state.pendingAttachments = []
    }

    updateControls()

    const thinking = addThinkingMessage()

    try{

      await streamService.send({
        chatId: state.activeChatId,
        message: text,
        files: attachments,
        extra: {
          messageId: thinking.message_id
        }
      })

    }catch(error){

      const err = error?.message || String(error)

      renderService?.updateMessage?.(thinking.message_id, {
        error: err,
        thinking: false,
        streaming: false,
        content: "Something went wrong."
      })

    }
  }

  function handleStopClick(){

    try{
      streamService?.stop?.()
    }catch(error){
      console.error("Stop failed:", error)
    }

    state.isStreaming = false
    updateControls()
  }

  function handleKeyDown(event){

    if(event.key !== "Enter"){
      return
    }

    if(event.shiftKey){
      return
    }

    event.preventDefault()
    handleSubmit(event)
  }

  function wire(){

    el.input?.addEventListener("input", () => {
      autoResize()
      updateControls()
    })

    el.input?.addEventListener("keydown", handleKeyDown)

    el.stopBtn?.addEventListener("click", handleStopClick)

    el.composerForm?.addEventListener("submit", handleSubmit)

    el.sendBtn?.addEventListener("click", handleSubmit)
  }

  wire()
  updateControls()

  return {
    submit: handleSubmit,
    stop: handleStopClick,
    updateControls
  }

}

/* ------------------------------------------------ */
/* EXPORT FIX (this was the bug)                    */
/* chat.js expects createComposerService factory    */
/* ------------------------------------------------ */

window.NovaComposerService = {
  create: createComposerService,
  createComposerService
}

})()