:root{
  color-scheme: dark;
  --bg:#0b0f14;
  --panel:#0f1720;
  --panel2:#101b26;
  --text:#e6edf3;
  --muted:#9fb1c1;
  --border:#223041;
  --accent:#2f81f7;
  --shadow: 0 10px 30px rgba(0,0,0,.45);
  --radius:16px;
  --radius2:12px;
  --pad:14px;
  --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  --sans: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
}

html,body{height:100%}
body{
  margin:0;
  font-family:var(--sans);
  background: radial-gradient(1200px 700px at 10% 0%, #0f1d2b 0%, var(--bg) 55%) fixed;
  color:var(--text);
}

a{color:var(--accent); text-decoration:none}
a:hover{text-decoration:underline}

.wrap{
  max-width: 980px;
  margin: 0 auto;
  padding: 18px;
}

.card{
  background: linear-gradient(180deg, var(--panel) 0%, var(--panel2) 100%);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  padding: 14px 16px;
  border-bottom:1px solid var(--border);
}

.header .title{
  font-weight:650;
  letter-spacing:.2px;
}

.header .sub{
  font-size:12px;
  color:var(--muted);
}

.main{
  display:flex;
  flex-direction:column;
  height: calc(100vh - 48px);
  min-height: 560px;
}

.chat{
  flex:1;
  overflow:auto;
  padding: 14px 14px 0 14px;
}

.msg{
  padding: 12px 12px;
  border:1px solid var(--border);
  border-radius: var(--radius2);
  margin: 10px 0;
  background: rgba(255,255,255,.02);
}

.msg.me{
  background: rgba(47,129,247,.12);
  border-color: rgba(47,129,247,.35);
}

.msg .meta{
  font-size:12px;
  color:var(--muted);
  margin-bottom:6px;
}

.msg pre, .msg code{
  font-family: var(--mono);
  font-size: 12.5px;
  white-space: pre-wrap;
  word-break: break-word;
}

.composer{
  padding: 12px 14px 14px 14px;
  border-top:1px solid var(--border);
  display:flex;
  gap:10px;
  align-items:flex-end;
}

textarea, input[type="text"]{
  flex:1;
  width:100%;
  min-height: 44px;
  max-height: 180px;
  resize: vertical;
  padding: 10px 12px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: rgba(0,0,0,.25);
  color: var(--text);
  outline:none;
}

textarea:focus, input[type="text"]:focus{
  border-color: rgba(47,129,247,.7);
  box-shadow: 0 0 0 3px rgba(47,129,247,.15);
}

button{
  border: 1px solid rgba(47,129,247,.55);
  background: rgba(47,129,247,.15);
  color: var(--text);
  border-radius: 12px;
  padding: 10px 12px;
  cursor:pointer;
  user-select:none;
}

button:hover{ background: rgba(47,129,247,.22); }
button:active{ transform: translateY(1px); }

hr{
  border:0;
  border-top:1px solid var(--border);
  margin: 12px 0;
}

/* Hide obvious dev junk if it exists */
.dev, .debug, #debug, #log, #logs, .logs, .console, .trace{ display:none !important; }

/* ===== NOVA_UI_COMPAT_V1 (matches /app HTML classes) ===== */
.row{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}

.grow{ flex:1; }

h1{
  margin: 10px 0 12px 0;
  font-size: 22px;
  letter-spacing: .2px;
}

.small{
  font-size: 12px;
  color: var(--muted);
}

.btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  padding: 9px 12px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.03);
  color: var(--text);
  cursor:pointer;
  user-select:none;
}

.btn:hover{
  background: rgba(255,255,255,.06);
}

.btn:active{
  transform: translateY(1px);
}

#output{
  background: rgba(0,0,0,.25);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px;
  margin-top: 8px;
  overflow:auto;
  white-space: pre-wrap;
  word-break: break-word;
  font-family: var(--mono);
  font-size: 12.5px;
  line-height: 1.35;
}
/* ===== /NOVA_UI_COMPAT_V1 ===== */
